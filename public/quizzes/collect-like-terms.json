  "questions": [
    {
      "id": "q1",
      "q": "Simplify $9k - 4k$.",
      "structure": "combine-single-variable",
      "mastery": false,
      "options": [
        { "text": "$5k$", "correct": true },
        { "text": "$13k$", "why": "Added the coefficients $9 + 4$ instead of subtracting them." },
        { "text": "$5k^2$", "why": "Multiplied the variables together, turning $k$ into $k^2$ when only the coefficients should change." },
        { "text": "$5$", "why": "Subtracted the coefficients but dropped the variable $k$ from the answer." }
      ],
      "solution": [
        { "math": "$9k - 4k$" },
        { "math": "$= 5k$", "note": "Combine" }
      ]
    },
    {
      "id": "q2",
      "q": "Simplify $4 + 2n - n$.",
      "structure": "variable-and-constant",
      "mastery": false,
      "options": [
        { "text": "$n + 4$", "correct": true },
        { "text": "$3n + 4$", "why": "Added $2n$ and $n$ instead of subtracting, giving $3n$." },
        { "text": "$5n$", "why": "Treated the constant $4$ as a like term with the $n$ terms and combined all three." },
        { "text": "$n$", "why": "Combined the $n$ terms correctly but dropped the constant $4$." }
      ],
      "solution": [
        { "math": "$4 + 2n - n$" },
        { "math": "$= (2n - n) + 4$", "note": "Group terms" },
        { "math": "$= n + 4$", "note": "Combine" }
      ]
    },
    {
      "id": "q3",
      "q": "Simplify $6a + 5b - 4a - 3b$.",
      "structure": "two-variable-groups",
      "mastery": false,
      "options": [
        { "text": "$2a + 2b$", "correct": true },
        { "text": "$2a - 8b$", "why": "Made both $b$ terms negative, working out $-5b - 3b$ instead of $5b - 3b$." },
        { "text": "$10a + 8b$", "why": "Ignored the subtraction signs and added every coefficient." },
        { "text": "$4ab$", "why": "Treated all four terms as alike, adding $6 - 4 + 5 - 3$ and merging the variables into $ab$." }
      ],
      "solution": [
        { "math": "$6a + 5b - 4a - 3b$" },
        { "math": "$= (6a - 4a) + (5b - 3b)$", "note": "Group terms" },
        { "math": "$= 2a + 2b$", "note": "Combine" }
      ]
    },
    {
      "id": "q4",
      "q": "Simplify $2pq + 3qp$.",
      "structure": "rearranged-like-terms",
      "mastery": false,
      "options": [
        { "text": "$5pq$", "correct": true },
        { "text": "$2pq + 3qp$", "why": "Treated $pq$ and $qp$ as unlike terms, so they were left uncombined." },
        { "text": "$6pq$", "why": "Multiplied the coefficients $2 \\times 3$ instead of adding them." },
        { "text": "$5$", "why": "Added the coefficients but dropped the variable part $pq$." }
      ],
      "solution": [
        { "math": "$2pq + 3qp$" },
        { "math": "$= 2pq + 3pq$", "note": "Same term" },
        { "math": "$= 5pq$", "note": "Combine" }
      ]
    },
    {
      "id": "q5",
      "q": "Simplify $5x^2 + 3x + 2x^2$.",
      "structure": "powers-stay-separate",
      "mastery": false,
      "options": [
        { "text": "$7x^2 + 3x$", "correct": true },
        { "text": "$10x^2$", "why": "Combined all three terms, treating $3x$ as a like term with the $x^2$ terms." },
        { "text": "$7x^4 + 3x$", "why": "Added the exponents when combining $x^2 + x^2$, giving $x^4$ instead of $x^2$." },
        { "text": "$10x^3$", "why": "Added every coefficient and also added the exponents of the variables." }
      ],
      "solution": [
        { "math": "$5x^2 + 3x + 2x^2$" },
        { "math": "$= (5x^2 + 2x^2) + 3x$", "note": "Group terms" },
        { "math": "$= 7x^2 + 3x$", "note": "Combine" }
      ]
    },
    {
      "id": "q6",
      "q": "Simplify $4x - 5x$.",
      "structure": "negative-result",
      "mastery": false,
      "options": [
        { "text": "$-x$", "correct": true },
        { "text": "$x$", "why": "Subtracted the smaller coefficient from the larger and kept the result positive." },
        { "text": "$9x$", "why": "Added the coefficients $4 + 5$ instead of subtracting." },
        { "text": "$-1$", "why": "Combined the coefficients but dropped the variable $x$." }
      ],
      "solution": [
        { "math": "$4x - 5x$" },
        { "math": "$= -x$", "note": "Combine" }
      ]
    },
    {
      "id": "q7",
      "q": "Simplify $6y + y^2 - 2y^2 - 4y + 3$.",
      "structure": "mixed-powers-groups",
      "mastery": true,
      "options": [
        { "text": "$-y^2 + 2y + 3$", "correct": true },
        { "text": "$y^2 + 2y + 3$", "why": "Worked out $y^2 - 2y^2$ by subtracting magnitudes and kept the result positive instead of $-y^2$." },
        { "text": "$-y^4 + 2y + 3$", "why": "Added the exponents when combining the $y^2$ terms, giving $y^4$." },
        { "text": "$-y^2 + 2y$", "why": "Combined the variable terms correctly but dropped the constant $3$." }
      ],
      "solution": [
        { "math": "$6y + y^2 - 2y^2 - 4y + 3$" },
        { "math": "$= (y^2 - 2y^2) + (6y - 4y) + 3$", "note": "Group terms" },
        { "math": "$= -y^2 + 2y + 3$", "note": "Combine" }
      ]
    }
  ]
}
