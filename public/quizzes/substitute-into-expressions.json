      "structure": "powers",
      "mastery": true,
      "options": [
        {
          "text": "$18$",
          "correct": true
        },
        {
          "text": "$36$",
          "why": "Squared $2x$ together as $(2\\times 3)^2$ — the power applies only to $x$, giving $2\\times x^2$."
        },
        {
          "text": "$12$",
          "why": "Doubled $x$ instead of squaring it, computing $2\\times 3\\times 2$ — $x^2$ means $x\\times x$."
        },
        {
          "text": "$9$",
          "why": "Evaluated $x^2=9$ but dropped the coefficient 2."
        }
      ],
      "solution_text": "$2x^2$\n$= 2(3)^2$\n$= 2(9)$\n$= 18$"
