      "mastery": false,
      "options": [
        {
          "text": "$5$",
          "correct": true
        },
        {
          "text": "$10$",
          "why": "Computed the numerator $x+4=10$ but forgot to divide by 2."
        },
        {
          "text": "$7$",
          "why": "Divided only $x$ by 2 then added 4 ($\\frac{6}{2}+4$) — the whole numerator must be divided."
        },
        {
          "text": "$3$",
          "why": "Halved $x$ to get 3 but dropped the $+4$ in the numerator."
        }
      ],
      "solution_text": "$\\frac{x + 4}{2}$\n$= \\frac{6 + 4}{2}$\n$= \\frac{10}{2}$\n$= 5$"
    },
