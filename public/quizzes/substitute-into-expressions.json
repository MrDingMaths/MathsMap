{
  "skillId": "substitute-into-expressions",
  "questions": [
    {
      "id": "q1",
      "q": "Evaluate $2x + 5$ when $x = 6$.",
      "structure": "single-variable-linear",
      "mastery": false,
      "options": [
        { "text": "$17$", "correct": true },
        { "text": "$22$", "why": "Added the 5 before multiplying, evaluating $2(6+5)$ — the coefficient multiplies only $x$." },
        { "text": "$13$", "why": "Read $2x$ as $2+x$, computing $2+6+5$ instead of $2\\times 6$." },
        { "text": "$12$", "why": "Evaluated $2x=12$ but left off the constant $+5$." }
      ],
      "solution": [
        { "math": "$2x + 5$" },
        { "math": "$= 2(6) + 5$", "note": "Substitute" },
        { "math": "$= 12 + 5$", "note": "Multiply" },
        { "math": "$= 17$", "note": "Add" }
      ]
    },
    {
      "id": "q2",
      "q": "Evaluate $20 - 3x$ when $x = 4$.",
      "structure": "order-of-operations",
      "mastery": false,
      "options": [
        { "text": "$8$", "correct": true },
        { "text": "$68$", "why": "Subtracted before multiplying, doing $20-3=17$ then $\\times 4$ — multiplication comes first." },
        { "text": "$17$", "why": "Did not multiply the 3 by $x$, evaluating $20-3$ and ignoring the pronumeral." },
        { "text": "$12$", "why": "Reported $3x=12$ only and dropped the $20-$ part of the expression." }
      ],
      "solution": [
        { "math": "$20 - 3x$" },
        { "math": "$= 20 - 3(4)$", "note": "Substitute" },
        { "math": "$= 20 - 12$", "note": "Multiply" },
        { "math": "$= 8$", "note": "Subtract" }
      ]
    },
    {
      "id": "q3",
      "q": "Evaluate $\\frac{x + 4}{2}$ when $x = 6$.",
      "structure": "fraction-form",
      "mastery": false,
      "options": [
        { "text": "$5$", "correct": true },
        { "text": "$10$", "why": "Computed the numerator $x+4=10$ but forgot to divide by 2." },
        { "text": "$7$", "why": "Divided only $x$ by 2 then added 4 ($\\frac{6}{2}+4$) — the whole numerator must be divided." },
        { "text": "$3$", "why": "Halved $x$ to get 3 but dropped the $+4$ in the numerator." }
      ],
      "solution": [
        { "math": "$\\frac{x + 4}{2}$" },
        { "math": "$= \\frac{6 + 4}{2}$", "note": "Substitute" },
        { "math": "$= \\frac{10}{2}$", "note": "Add" },
        { "math": "$= 5$", "note": "Divide" }
      ]
    },
    {
      "id": "q4",
      "q": "Evaluate $3a + 2b$ when $a = 4$ and $b = 5$.",
      "structure": "multiple-variables",
      "mastery": false,
      "options": [
        { "text": "$22$", "correct": true },
        { "text": "$23$", "why": "Swapped the values, substituting $a=5$ and $b=4$ to get $15+8$." },
        { "text": "$17$", "why": "Treated $2b$ as just $b$, adding 5 instead of $2\\times 5$." },
        { "text": "$14$", "why": "Dropped the pronumeral $b$, evaluating $2b$ as $2$ to get $12+2$." }
      ],
      "solution": [
        { "math": "$3a + 2b$" },
        { "math": "$= 3(4) + 2(5)$", "note": "Substitute" },
        { "math": "$= 12 + 10$", "note": "Multiply" },
        { "math": "$= 22$", "note": "Add" }
      ]
    },
    {
      "id": "q5",
      "q": "Evaluate $2x^2$ when $x = 3$.",
      "structure": "powers",
      "mastery": true,
      "options": [
        { "text": "$18$", "correct": true },
        { "text": "$36$", "why": "Squared $2x$ together as $(2\\times 3)^2$ — the power applies only to $x$, giving $2\\times x^2$." },
        { "text": "$12$", "why": "Doubled $x$ instead of squaring it, computing $2\\times 3\\times 2$ — $x^2$ means $x\\times x$." },
        { "text": "$9$", "why": "Evaluated $x^2=9$ but dropped the coefficient 2." }
      ],
      "solution": [
        { "math": "$2x^2$" },
        { "math": "$= 2(3)^2$", "note": "Substitute" },
        { "math": "$= 2(9)$", "note": "Powers" },
        { "math": "$= 18$", "note": "Multiply" }
      ]
    },
    {
      "id": "q6",
      "q": "Evaluate $2d - 3e - 4f$ when $d = 2$, $e = 3$ and $f = \\frac{1}{2}$.",
      "structure": "multiple-variables",
      "mastery": true,
      "options": [
        { "text": "$-7$", "correct": true },
        { "text": "$-9$", "why": "Used $4f=4$ instead of $4\\times\\frac{1}{2}=2$, treating $f$ as if it were 1." },
        { "text": "$-3$", "why": "Grouped the last two terms as $2d-(3e-4f)=4-(9-2)$, flipping the sign on $4f$." },
        { "text": "$-5$", "why": "Evaluated $2d-3e=-5$ but dropped the final $-4f$ term." }
      ],
      "solution": [
        { "math": "$2d - 3e - 4f$" },
        { "math": "$= 2(2) - 3(3) - 4(\\frac{1}{2})$", "note": "Substitute" },
        { "math": "$= 4 - 9 - 2$", "note": "Multiply" },
        { "math": "$= -7$", "note": "Subtract" }
      ]
    }
  ]
}
