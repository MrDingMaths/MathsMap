    {
      "id": "q1",
      "question_text": "Evaluate $2x + 5$ when $x = 6$.",
      "structure": "single-variable-linear",
      "mastery": false,
      "options": [
        {
          "text": "$17$",
          "correct": true
        },
        {
          "text": "$22$",
          "why": "Added the 5 before multiplying, evaluating $2(6+5)$ — the coefficient multiplies only $x$."
        },
        {
          "text": "$13$",
          "why": "Read $2x$ as $2+x$, computing $2+6+5$ instead of $2\\times 6$."
        },
        {
          "text": "$12$",
          "why": "Evaluated $2x=12$ but left off the constant $+5$."
        }
      ],
      "solution_text": "$2x + 5$\n$= 2(6) + 5$\n$= 12 + 5$\n$= 17$"
    },
    {
      "id": "q2",
      "question_text": "Evaluate $20 - 3x$ when $x = 4$.",
      "structure": "order-of-operations",
      "mastery": false,
      "options": [
        {
          "text": "$8$",
          "correct": true
        },
        {
          "text": "$68$",
          "why": "Subtracted before multiplying, doing $20-3=17$ then $\\times 4$ — multiplication comes first."
        },
        {
          "text": "$17$",
          "why": "Did not multiply the 3 by $x$, evaluating $20-3$ and ignoring the pronumeral."
        },
        {
          "text": "$12$",
          "why": "Reported $3x=12$ only and dropped the $20-$ part of the expression."
        }
      ],
      "solution_text": "$20 - 3x$\n$= 20 - 3(4)$\n$= 20 - 12$\n$= 8$"
    },
    {
