    {
      "id": "q6",
      "question_text": "Evaluate $2d - 3e - 4f$ when $d = 2$, $e = 3$ and $f = \\frac{1}{2}$.",
      "structure": "multiple-variables",
      "mastery": true,
      "options": [
        {
          "text": "$-7$",
          "correct": true
        },
        {
          "text": "$-9$",
          "why": "Used $4f=4$ instead of $4\\times\\frac{1}{2}=2$, treating $f$ as if it were 1."
        },
        {
          "text": "$-3$",
          "why": "Grouped the last two terms as $2d-(3e-4f)=4-(9-2)$, flipping the sign on $4f$."
        },
        {
          "text": "$-5$",
          "why": "Evaluated $2d-3e=-5$ but dropped the final $-4f$ term."
        }
      ],
      "solution_text": "$2d - 3e - 4f$\n$= 2(2) - 3(3) - 4(\\frac{1}{2})$\n$= 4 - 9 - 2$\n$= -7$"
    }
  ]
