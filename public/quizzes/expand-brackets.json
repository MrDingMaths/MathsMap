{
  "skillId": "expand-brackets",
  "questions": [
    {
      "id": "q1",
      "q": "Expand $6(y+8)$.",
      "structure": "numeric-multiplier-add",
      "mastery": false,
      "options": [
        { "text": "$6y+48$", "correct": true },
        { "text": "$6y+8$", "why": "Distributed the $6$ to the first term only, leaving the $8$ un-multiplied." },
        { "text": "$6y+14$", "why": "Added $6+8$ instead of multiplying $6 \\times 8$ for the second term." },
        { "text": "$48y$", "why": "Treated $y+8$ as a single term and multiplied everything together." }
      ],
      "solution": [
        { "math": "$6(y+8)$" },
        { "math": "$= 6(y) + 6(8)$", "note": "Multiply each" },
        { "math": "$= 6y+48$", "note": "Simplify" }
      ]
    },
    {
      "id": "q2",
      "q": "Expand $5(x-3)$.",
      "structure": "numeric-multiplier-subtract",
      "mastery": false,
      "options": [
        { "text": "$5x-15$", "correct": true },
        { "text": "$5x-3$", "why": "Distributed to the $x$ only and copied the $-3$ unchanged." },
        { "text": "$5x+15$", "why": "Lost the subtraction sign, turning $-3$ into $+15$." },
        { "text": "$x-15$", "why": "Forgot to multiply the $x$ term by $5$." }
      ],
      "solution": [
        { "math": "$5(x-3)$" },
        { "math": "$= 5(x) - 5(3)$", "note": "Keep each sign" },
        { "math": "$= 5x-15$", "note": "Simplify" }
      ]
    },
    {
      "id": "q3",
      "q": "Expand $2x(3x+4)$.",
      "structure": "variable-multiplier",
      "mastery": false,
      "options": [
        { "text": "$6x^2+8x$", "correct": true },
        { "text": "$6x+8x$", "why": "Treated $x \\times x$ as $x$ instead of $x^2$ for the first product." },
        { "text": "$6x^2+8$", "why": "Multiplied $2x \\times 4$ as $8$, dropping the $x$ from the second product." },
        { "text": "$5x^2+8x$", "why": "Added $2+3$ instead of multiplying $2 \\times 3$ for the first product." }
      ],
      "solution": [
        { "math": "$2x(3x+4)$" },
        { "math": "$= 2x(3x) + 2x(4)$", "note": "Multiply each" },
        { "math": "$= 6x^2+8x$", "note": "$x \\times x = x^2$" }
      ]
    },
    {
      "id": "q4",
      "q": "Expand $2(a+3b+4)$.",
      "structure": "three-terms",
      "mastery": false,
      "options": [
        { "text": "$2a+6b+8$", "correct": true },
        { "text": "$2a+3b+4$", "why": "Distributed the $2$ to the first term only, copying $3b$ and $4$ unchanged." },
        { "text": "$2a+6b+4$", "why": "Stopped early and forgot to multiply the last term $4$." },
        { "text": "$2a+6b+6$", "why": "Added $2$ to the last term ($4+2$) instead of multiplying it." }
      ],
      "solution": [
        { "math": "$2(a+3b+4)$" },
        { "math": "$= 2(a) + 2(3b) + 2(4)$", "note": "Multiply each" },
        { "math": "$= 2a+6b+8$", "note": "Simplify" }
      ]
    },
    {
      "id": "q5",
      "q": "Expand and simplify $4(2x+3)+3(x-2)$.",
      "structure": "expand-collect",
      "mastery": true,
      "options": [
        { "text": "$11x+6$", "correct": true },
        { "text": "$11x+18$", "why": "Expanded $3(x-2)$ as $3x+6$, dropping the minus sign on the $2$." },
        { "text": "$5x+6$", "why": "Collected the $x$-terms by subtracting ($8x-3x$) instead of adding." },
        { "text": "$11x-3$", "why": "Distributed the $4$ to the $2x$ only, leaving the $+3$ un-multiplied." }
      ],
      "solution": [
        { "math": "$4(2x+3)+3(x-2)$" },
        { "math": "$= 8x+12 + 3x-6$", "note": "Keep each sign" },
        { "math": "$= 11x+6$", "note": "Collect like terms" }
      ]
    },
    {
      "id": "q6",
      "q": "Expand $2xy(3x-2y)$.",
      "structure": "variable-multiplier",
      "mastery": true,
      "options": [
        { "text": "$6x^2y-4xy^2$", "correct": true },
        { "text": "$6x^2y+4xy^2$", "why": "Sign slip — made the second product positive despite the $-2y$." },
        { "text": "$6x^2y-4y^2$", "why": "Dropped the $x$ from $2xy \\times 2y$, losing a factor in the second product." },
        { "text": "$5x^2y-4xy^2$", "why": "Added $2+3$ instead of multiplying $2 \\times 3$ for the first product." }
      ],
      "solution": [
        { "math": "$2xy(3x-2y)$" },
        { "math": "$= 2xy(3x) - 2xy(2y)$", "note": "Keep each sign" },
        { "math": "$= 6x^2y-4xy^2$", "note": "$x \\times x = x^2$" }
      ]
    }
  ]
}
