{
  "skillId": "substitute-negative-numbers",
  "questions": [
    {
      "id": "q1",
      "q": "Evaluate $10 + 4b$ for $b = -2$.",
      "structure": "add-negative",
      "mastery": false,
      "options": [
        { "text": "$2$", "correct": true },
        { "text": "$18$", "why": "Ignored the negative sign, using $b = 2$: $10 + 4(2) = 18$." },
        { "text": "$12$", "why": "Read $4b$ as $4 - 2$ instead of multiplying: $10 + 4 - 2 = 12$." },
        { "text": "$-8$", "why": "Evaluated only $4(-2)$ and left out the $+10$." }
      ],
      "solution": [
        { "math": "$10 + 4b$" },
        { "math": "$= 10 + 4(-2)$" },
        { "math": "$= 10 + (-8)$", "note": "Multiply" },
        { "math": "$= 2$", "note": "Add" }
      ]
    },
    {
      "id": "q2",
      "q": "Evaluate $12 - 3b$ for $b = -5$.",
      "structure": "subtract-negative",
      "mastery": false,
      "options": [
        { "text": "$27$", "correct": true },
        { "text": "$-3$", "why": "Did not flip the double negative: kept $12 - 15$ instead of $12 + 15$." },
        { "text": "$-45$", "why": "Subtracted before multiplying: $(12 - 3)(-5) = -45$." },
        { "text": "$14$", "why": "Added instead of multiplying: $3b = 3 + (-5) = -2$, then $12 - (-2) = 14$." }
      ],
      "solution": [
        { "math": "$12 - 3b$" },
        { "math": "$= 12 - 3(-5)$" },
        { "math": "$= 12 + 15$", "note": "Subtract negative" },
        { "math": "$= 27$", "note": "Add" }
      ]
    },
    {
      "id": "q3",
      "q": "Evaluate $-2z$ for $z = -5$.",
      "structure": "multiply-negative",
      "mastery": false,
      "options": [
        { "text": "$10$", "correct": true },
        { "text": "$-10$", "why": "Made the product of two negatives negative: treated $-2 \\times -5$ as $-10$." },
        { "text": "$-7$", "why": "Added instead of multiplying: $-2 + (-5) = -7$." },
        { "text": "$3$", "why": "Read $-2z$ as $-2 - z = -2 - (-5) = 3$." }
      ],
      "solution": [
        { "math": "$-2z$" },
        { "math": "$= -2(-5)$" },
        { "math": "$= 10$", "note": "Multiply" }
      ]
    },
    {
      "id": "q4",
      "q": "Evaluate $2b^2$ for $b = -3$.",
      "structure": "square-of-negative",
      "mastery": false,
      "options": [
        { "text": "$18$", "correct": true },
        { "text": "$-18$", "why": "Made the square negative: took $(-3)^2 = -9$, then $2(-9) = -18$." },
        { "text": "$36$", "why": "Squared $2b$ together: $(2 \\times -3)^2 = 36$." },
        { "text": "$-6$", "why": "Multiplied by $2$ without squaring: $2 \\times (-3) = -6$." }
      ],
      "solution": [
        { "math": "$2b^2$" },
        { "math": "$= 2(-3)^2$" },
        { "math": "$= 2(9)$", "note": "Evaluate power" },
        { "math": "$= 18$", "note": "Multiply" }
      ]
    },
    {
      "id": "q5",
      "q": "Evaluate $6b - 7a$ for $a = 6$ and $b = -2$.",
      "structure": "multiple-negatives",
      "mastery": false,
      "options": [
        { "text": "$-54$", "correct": true },
        { "text": "$30$", "why": "Treated $-7a$ as $+7a$: $-12 + 42 = 30$." },
        { "text": "$-30$", "why": "Used $b = 2$ instead of $-2$: $12 - 42 = -30$." },
        { "text": "$54$", "why": "Made both products positive and added: $12 + 42 = 54$." }
      ],
      "solution": [
        { "math": "$6b - 7a$" },
        { "math": "$= 6(-2) - 7(6)$" },
        { "math": "$= -12 - 42$", "note": "Multiply" },
        { "math": "$= -54$", "note": "Subtract" }
      ]
    },
    {
      "id": "q6",
      "q": "Evaluate $a^2 - b^2$ for $a = -2$ and $b = -3$.",
      "structure": "square-of-negative",
      "mastery": true,
      "options": [
        { "text": "$-5$", "correct": true },
        { "text": "$5$", "why": "Subtracted in the wrong order: $9 - 4 = 5$." },
        { "text": "$-13$", "why": "Made $(-2)^2 = -4$, then $-4 - 9 = -13$." },
        { "text": "$13$", "why": "Took $b^2 = -9$, then $4 - (-9) = 13$." }
      ],
      "solution": [
        { "math": "$a^2 - b^2$" },
        { "math": "$= (-2)^2 - (-3)^2$" },
        { "math": "$= 4 - 9$", "note": "Evaluate powers" },
        { "math": "$= -5$", "note": "Subtract" }
      ]
    },
    {
      "id": "q7",
      "q": "Evaluate $3ab + ac$ for $a = -2$, $b = 6$ and $c = -3$.",
      "structure": "multiple-negatives",
      "mastery": true,
      "options": [
        { "text": "$-30$", "correct": true },
        { "text": "$-42$", "why": "Made $ac = -6$: $-36 + (-6) = -42$." },
        { "text": "$42$", "why": "Made $3ab = +36$: $36 + 6 = 42$." },
        { "text": "$-36$", "why": "Left out the $ac$ term and evaluated only $3ab = -36$." }
      ],
      "solution": [
        { "math": "$3ab + ac$" },
        { "math": "$= 3(-2)(6) + (-2)(-3)$" },
        { "math": "$= -36 + 6$", "note": "Multiply" },
        { "math": "$= -30$", "note": "Add" }
      ]
    }
  ]
}
