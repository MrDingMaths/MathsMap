      "question_text": "Evaluate $10 + 4b$ for $b = -2$.",
      "structure": "add-negative",
      "mastery": false,
      "options": [
        {
          "text": "$2$",
          "correct": true
        },
        {
          "text": "$18$",
          "why": "Ignored the negative sign, using $b = 2$: $10 + 4(2) = 18$."
        },
        {
          "text": "$12$",
          "why": "Read $4b$ as $4 - 2$ instead of multiplying: $10 + 4 - 2 = 12$."
        },
        {
          "text": "$-8$",
          "why": "Evaluated only $4(-2)$ and left out the $+10$."
        }
      ],
      "solution_text": "$10 + 4b$¥n$= 10 + 4(-2)$¥n$= 10 + (-8)$¥n$= 2$"
