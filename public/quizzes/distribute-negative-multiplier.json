  "skillId": "distribute-negative-multiplier",
  "questions": [
    {
      "id": "q1",
      "q": "Expand $-4(2x+5)$.",
      "structure": "neg-times-sum",
      "mastery": false,
      "options": [
        { "text": "$-8x-20$", "correct": true },
        { "text": "$-8x+20$", "why": "Made the second product positive; $-4 \\times (+5)$ is $-20$, not $+20$." },
        { "text": "$8x+20$", "why": "Dropped the negative on the multiplier and expanded as $4(2x+5)$." },
        { "text": "$-8x+5$", "why": "Multiplied only the first term by $-4$ and copied the $+5$ across unchanged." }
      ],
      "solution": [
        { "math": "$-4(2x+5)$" },
        { "math": "$= -4(2x) - 4(5)$", "note": "Multiply each" },
        { "math": "$= -8x-20$", "note": "Apply signs" }
      ]
    },
    {
      "id": "q2",
      "q": "Expand $-3(2x-5)$.",
      "structure": "neg-times-difference",
      "mastery": false,
      "options": [
        { "text": "$-6x+15$", "correct": true },
        { "text": "$-6x-15$", "why": "Treated $-3 \\times (-5)$ as $-15$; a negative times a negative is positive." },
        { "text": "$-6x-5$", "why": "Left the $5$ unmultiplied and kept it as $-5$ instead of $-3 \\times (-5)$." },
        { "text": "$-6x+5$", "why": "Flipped the sign of the $5$ but forgot to multiply it by $3$." }
      ],
      "solution": [
        { "math": "$-3(2x-5)$" },
        { "math": "$= -3(2x) - 3(-5)$", "note": "Multiply each" },
        { "math": "$= -6x+15$", "note": "Apply signs" }
      ]
    },
    {
      "id": "q3",
      "q": "Expand $-(3x-7)$.",
      "structure": "bare-negative-bracket",
      "mastery": false,
      "options": [
        { "text": "$-3x+7$", "correct": true },
        { "text": "$-3x-7$", "why": "Flipped the sign of $3x$ but left the $-7$ unchanged." },
        { "text": "$3x-7$", "why": "Removed the brackets without multiplying by $-1$, so no signs changed." },
        { "text": "$3x+7$", "why": "Flipped the $-7$ to $+7$ but left the $3x$ positive." }
      ],
      "solution": [
        { "math": "$-(3x-7)$" },
        { "math": "$= -1(3x) - 1(-7)$", "note": "Multiply by $-1$" },
        { "math": "$= -3x+7$", "note": "Apply signs" }
      ]
    },
    {
      "id": "q4",
      "q": "Expand $-5(2-3x)$.",
      "structure": "reversed-order-difference",
      "mastery": false,
      "options": [
        { "text": "$-10+15x$", "correct": true },
        { "text": "$-10-15x$", "why": "Treated $-5 \\times (-3x)$ as $-15x$; a negative times a negative is positive." },
        { "text": "$10+15x$", "why": "Made $-5 \\times 2$ positive; a negative times a positive is negative." },
        { "text": "$-10+15$", "why": "Multiplied $-5$ by the $3$ but dropped the variable $x$ from $-3x$." }
      ],
      "solution": [
        { "math": "$-5(2-3x)$" },
        { "math": "$= -5(2) - 5(-3x)$", "note": "Multiply each" },
        { "math": "$= -10+15x$", "note": "Apply signs" }
      ]
    },
    {
      "id": "q5",
      "q": "Expand $-2a(3a-4)$.",
      "structure": "neg-algebraic-multiplier",
      "mastery": true,
      "options": [
        { "text": "$-6a^2+8a$", "correct": true },
        { "text": "$-6a^2-8a$", "why": "Treated $-2a \\times (-4)$ as $-8a$; a negative times a negative is positive." },
        { "text": "$-6a+8a$", "why": "Multiplied the numbers but left $a \\times a$ as $a$ instead of $a^2$." },
        { "text": "$6a^2-8a$", "why": "Ignored the negative on the multiplier and expanded $2a(3a-4)$." }
      ],
      "solution": [
        { "math": "$-2a(3a-4)$" },
        { "math": "$= -2a(3a) - 2a(-4)$", "note": "Multiply each" },
        { "math": "$= -6a^2+8a$", "note": "Apply signs" }
      ]
    },
    {
      "id": "q6",
      "q": "Expand $-(-2x-5)$.",
      "structure": "bare-negative-bracket",
      "mastery": true,
      "options": [
        { "text": "$2x+5$", "correct": true },
        { "text": "$-2x-5$", "why": "Removed the brackets without multiplying by $-1$, so no signs flipped." },
        { "text": "$2x-5$", "why": "Flipped the sign of the $-2x$ but left the $-5$ unchanged." },
        { "text": "$-2x+5$", "why": "Flipped only the second term; $-1 \\times (-2x)$ should also become $+2x$." }
      ],
      "solution": [
        { "math": "$-(-2x-5)$" },
        { "math": "$= -1(-2x) - 1(-5)$", "note": "Multiply by $-1$" },
        { "math": "$= 2x+5$", "note": "Apply signs" }
      ]
    }
  ]
}
