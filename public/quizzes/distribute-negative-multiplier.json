    {
      "id": "q1",
      "question_text": "Expand $-4(2x+5)$.",
      "structure": "neg-times-sum",
      "mastery": false,
      "options": [
        {
          "text": "$-8x-20$",
          "correct": true
        },
        {
          "text": "$-8x+20$",
          "why": "Made the second product positive; $-4 \\times (+5)$ is $-20$, not $+20$."
        },
        {
          "text": "$8x+20$",
          "why": "Dropped the negative on the multiplier and expanded as $4(2x+5)$."
        },
        {
          "text": "$-8x+5$",
          "why": "Multiplied only the first term by $-4$ and copied the $+5$ across unchanged."
        }
      ],
      "solution_text": "$-4(2x+5)$\n$= -4(2x) - 4(5)$\n$= -8x-20$"
    },
    {
      "id": "q2",
      "question_text": "Expand $-3(2x-5)$.",
      "structure": "neg-times-difference",
      "mastery": false,
      "options": [
        {
          "text": "$-6x+15$",
          "correct": true
        },
        {
          "text": "$-6x-15$",
          "why": "Treated $-3 \\times (-5)$ as $-15$; a negative times a negative is positive."
        },
        {
          "text": "$-6x-5$",
          "why": "Left the $5$ unmultiplied and kept it as $-5$ instead of $-3 \\times (-5)$."
        },
        {
          "text": "$-6x+5$",
          "why": "Flipped the sign of the $5$ but forgot to multiply it by $3$."
        }
      ],
      "solution_text": "$-3(2x-5)$\n$= -3(2x) - 3(-5)$\n$= -6x+15$"
    },
    {
      "id": "q3",
      "question_text": "Expand $-(3x-7)$.",
      "structure": "bare-negative-bracket",
      "mastery": false,
      "options": [
        {
          "text": "$-3x+7$",
          "correct": true
        },
        {
          "text": "$-3x-7$",
          "why": "Flipped the sign of $3x$ but left the $-7$ unchanged."
        },
        {
          "text": "$3x-7$",
          "why": "Removed the brackets without multiplying by $-1$, so no signs changed."
        },
        {
          "text": "$3x+7$",
          "why": "Flipped the $-7$ to $+7$ but left the $3x$ positive."
        }
      ],
      "solution_text": "$-(3x-7)$\n$= -1(3x) - 1(-7)$\n$= -3x+7$"
    },
