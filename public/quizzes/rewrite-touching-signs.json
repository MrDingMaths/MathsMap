{
  "skillId": "rewrite-touching-signs",
  "questions": [
    {
      "id": "q1",
      "question_text": "Rewrite $8 + (-5)$ with a single sign.",
      "structure": "rewrite-plus-negative",
      "mastery": false,
      "options": [
        { "text": "$8 - 5$", "correct": true },
        { "text": "$8 + 5$", "why": "Combined the different signs $+$ and $-$ as a single $+$." },
        { "text": "$-8 - 5$", "why": "Attached the negative to the leading $8$ instead of only combining the touching pair." }
      ],
      "solution_text": "$8 + (-5)$\n$= 8 - 5$"
    },
    {
      "id": "q2",
      "question_text": "Rewrite $6 - (-2)$ with a single sign.",
      "structure": "rewrite-minus-negative",
      "mastery": false,
      "options": [
        { "text": "$6 + 2$", "correct": true },
        { "text": "$6 - 2$", "why": "Left it as subtraction, not recognising two $-$ signs combine to $+$." },
        { "text": "$-6 + 2$", "why": "Changed the sign of the first term instead of the touching pair." }
      ],
      "solution_text": "$6 - (-2)$\n$= 6 + 2$"
    },
    {
      "id": "q3",
      "question_text": "Rewrite $5 + (+3)$ with a single sign.",
      "structure": "rewrite-plus-positive",
      "mastery": false,
      "options": [
        { "text": "$5 + 3$", "correct": true },
        { "text": "$5 - 3$", "why": "Read the same-sign pair $+,+$ as a subtraction." },
        { "text": "$-5 + 3$", "why": "Flipped the sign of the first term instead of combining the touching pair." }
      ],
      "solution_text": "$5 + (+3)$\n$= 5 + 3$"
    },
    {
      "id": "q4",
      "question_text": "Rewrite $9 - (+4)$ with a single sign.",
      "structure": "rewrite-minus-positive",
      "mastery": false,
      "options": [
        { "text": "$9 - 4$", "correct": true },
        { "text": "$9 + 4$", "why": "Read the different signs $-,+$ as a single $+$." },
        { "text": "$-9 - 4$", "why": "Changed the sign of the $9$ as well as combining the touching pair." }
      ],
      "solution_text": "$9 - (+4)$\n$= 9 - 4$"
    },
    {
      "id": "q5",
      "question_text": "Rewrite $-6 + (-3)$ with a single sign.",
      "structure": "rewrite-first-term-negative",
      "mastery": false,
      "options": [
        { "text": "$-6 - 3$", "correct": true },
        { "text": "$-6 + 3$", "why": "Kept the $+$, not turning the different signs $+(-)$ into a $-$." },
        { "text": "$6 - 3$", "why": "Dropped the negative on the first term." }
      ],
      "solution_text": "$-6 + (-3)$\n$= -6 - 3$"
    },
    {
      "id": "q6",
      "question_text": "Rewrite $-8 - (+5)$ with a single sign.",
      "structure": "rewrite-minus-positive",
      "mastery": false,
      "options": [
        { "text": "$-8 - 5$", "correct": true },
        { "text": "$-8 + 5$", "why": "Read the different signs $-,+$ as a single $+$." },
        { "text": "$8 - 5$", "why": "Dropped the leading negative on the first term." }
      ],
      "solution_text": "$-8 - (+5)$\n$= -8 - 5$"
    },
    {
      "id": "q7",
      "question_text": "Rewrite $-4 + (-6) - (-3) + (+2)$ with single signs.",
      "structure": "rewrite-multi-pair",
      "mastery": true,
      "options": [
        { "text": "$-4 - 6 + 3 + 2$", "correct": true },
        { "text": "$-4 - 6 - 3 + 2$", "why": "Rewrote the $-(-3)$ pair as $-$ instead of $+$." },
        { "text": "$-4 + 6 + 3 + 2$", "why": "Rewrote the $+(-6)$ pair as $+$ rather than $-$." }
      ],
      "solution_text": "$-4 + (-6) - (-3) + (+2)$\n$= -4 - 6 + 3 + 2$"
    }
  ]
}
