  "skillId": "factorise-negative-common-factor",
  "questions": [
    {
      "id": "q1",
      "question_text": "Factorise $-4x - 10$.",
      "structure": "both-terms-negative",
      "mastery": false,
      "options": [
        {
          "text": "$-2(2x + 5)$",
          "correct": true
        },
        {
          "text": "$2(2x + 5)$",
          "why": "Took out $+2$; expanding $2(2x + 5) = 4x + 10$, the opposite sign of the original."
        },
        {
          "text": "$-2(2x - 5)$",
          "why": "Did not flip the second sign; $-10 \\div -2 = +5$, so it is $+5$ inside."
        },
        {
          "text": "$-2(2x + 10)$",
          "why": "Flipped the constant's sign but forgot to divide it by $2$, leaving $10$ instead of $5$."
        }
      ],
      "solution_text": "$-4x - 10$\n$= -2(2x + 5)$"
    },
    {
      "id": "q2",
      "question_text": "Factorise $-x - 9$.",
      "structure": "factor-out-negative-one",
      "mastery": false,
      "options": [
        {
          "text": "$-(x + 9)$",
          "correct": true
        },
        {
          "text": "$-(x - 9)$",
          "why": "Left the constant negative; $-9 \\div -1 = +9$, so it should be $+9$ inside."
        },
        {
          "text": "$(x + 9)$",
          "why": "Dropped the negative factor; $x + 9$ expands to $x + 9$, not $-x - 9$."
        },
        {
          "text": "$-9(x + 1)$",
          "why": "Treated $9$ as the common factor; $-9(x + 1) = -9x - 9$ changes the $x$ coefficient."
        }
      ],
      "solution_text": "$-x - 9$\n$= -(x + 9)$"
    },
    {
      "id": "q3",
      "question_text": "Factorise $-6x + 9$.",
      "structure": "mixed-sign-terms",
      "mastery": false,
      "options": [
        {
          "text": "$-3(2x - 3)$",
          "correct": true
        },
        {
          "text": "$-3(2x + 3)$",
          "why": "Did not flip the $+9$; dividing $9$ by $-3$ gives $-3$, not $+3$."
        },
        {
          "text": "$3(2x - 3)$",
          "why": "Took out $+3$ instead of $-3$; $3(2x - 3) = 6x - 9$ has both signs reversed."
        },
        {
          "text": "$-3(6x - 3)$",
          "why": "Left the $-6x$ undivided; $-6x \\div -3 = 2x$, not $6x$."
        }
      ],
      "solution_text": "$-6x + 9$\n$= -3(2x - 3)$"
    },
    {
      "id": "q4",
      "question_text": "Factorise $-8y^2 - 12y$.",
      "structure": "negative-algebraic-factor",
      "mastery": false,
      "options": [
        {
          "text": "$-4y(2y + 3)$",
          "correct": true
        },
        {
          "text": "$-4y(2y - 3)$",
          "why": "Kept the $-12y$ term negative; $-12y \\div -4y = +3$, so it is $+3$ inside."
        },
        {
          "text": "$4y(2y + 3)$",
          "why": "Took out $+4y$; $4y(2y + 3) = 8y^2 + 12y$, the opposite sign of the original."
        },
        {
          "text": "$-4y(2y^2 + 3)$",
          "why": "Left $y^2$ after dividing; $-8y^2 \\div -4y = 2y$, dropping one power of $y$."
        }
      ],
      "solution_text": "$-8y^2 - 12y$\n$= -4y(2y + 3)$"
    },
    {
      "id": "q5",
      "question_text": "Factorise $-12xy - 8yz - 20xyz$.",
      "structure": "three-terms-negative",
      "mastery": true,
      "options": [
        {
          "text": "$-4y(3x + 2z + 5xz)$",
          "correct": true
        },
        {
          "text": "$4y(3x + 2z + 5xz)$",
          "why": "Took out $+4y$; every term then expands with the wrong sign."
        },
        {
          "text": "$-4(3xy + 2yz + 5xyz)$",
          "why": "Took out $-4$ only, leaving the common $y$ inside — not fully factorised."
        },
        {
          "text": "$-4y(3x + 2z + 5x)$",
          "why": "Dropped the $z$ when dividing $-20xyz$ by $-4y$; the quotient is $5xz$."
        }
      ],
      "solution_text": "$-12xy - 8yz - 20xyz$\n$= -4y(3x + 2z + 5xz)$"
    },
    {
      "id": "q6",
      "question_text": "Factorise $-6 + 10p^2$ by taking out a negative common factor.",
      "structure": "leading-negative-power",
      "mastery": true,
      "options": [
        {
          "text": "$-2(3 - 5p^2)$",
          "correct": true
        },
        {
          "text": "$-2(3 + 5p^2)$",
          "why": "Did not flip the $p^2$ term; $10p^2 \\div -2 = -5p^2$, so it is $-5p^2$ inside."
        },
        {
          "text": "$2(3 - 5p^2)$",
          "why": "Took out $+2$; $2(3 - 5p^2) = 6 - 10p^2$, the opposite sign of every term."
        },
        {
          "text": "$-2(3 - 5p)$",
          "why": "Dropped the square; $10p^2 \\div -2 = -5p^2$, which keeps the power."
        }
      ],
      "solution_text": "$-6 + 10p^2$\n$= -2(3 - 5p^2)$"
    }
  ]
}
