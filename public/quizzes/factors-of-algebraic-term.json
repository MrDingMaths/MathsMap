{
  "skillId": "factors-of-algebraic-term",
  "questions": [
    {
      "id": "q1",
      "q": "Which of these is a factor of $10y$?",
      "structure": "numeric-and-variable",
      "mastery": false,
      "options": [
        { "text": "$5y$", "correct": true },
        { "text": "$4y$", "why": "$4$ does not divide $10$, so $4y$ cannot divide $10y$." },
        { "text": "$3y$", "why": "$3$ does not divide $10$, so $3y$ is not a factor." },
        { "text": "$10y^2$", "why": "$10y^2$ is a multiple of $10y$, not a factor ‚Äî the term has only one $y$." }
      ],
      "solution": [
        { "math": "$10y = 10 \\times y$" },
        { "math": "$5$ divides $10$, so $5y$ is a factor", "note": "Check" }
      ]
    },
    {
      "id": "q2",
      "q": "Which is the complete list of factors of $ab$?",
      "structure": "product-of-pronumerals",
      "mastery": false,
      "options": [
        { "text": "$1, a, b, ab$", "correct": true },
        { "text": "$a, b, ab$", "why": "Forgot that $1$ is always a factor." },
        { "text": "$1, a, b$", "why": "Forgot the term itself, $ab$, is always a factor." },
        { "text": "$1, ab$", "why": "Only listed $1$ and the term; missed the factors $a$ and $b$." }
      ],
      "solution": [
        { "math": "$ab = a \\times b$" },
        { "math": "$1, a, b, ab$", "note": "All factors" }
      ]
    },
    {
      "id": "q3",
      "q": "Which is the complete list of factors of $x^2$?",
      "structure": "pronumeral-power",
      "mastery": false,
      "options": [
        { "text": "$1, x, x^2$", "correct": true },
        { "text": "$1, x^2$", "why": "Missed $x$ ‚Äî since $x^2 = x \\times x$, $x$ divides it exactly." },
        { "text": "$x, x^2$", "why": "Forgot that $1$ is always a factor." },
        { "text": "$1, x, x^2, x^3$", "why": "$x^3$ is a multiple of $x^2$, not a factor ‚Äî it has more $x$'s than the term." }
      ],
      "solution": [
        { "math": "$x^2 = x \\times x$" },
        { "math": "$1, x, x^2$", "note": "All factors" }
      ]
    },
    {
      "id": "q4",
      "q": "Which of these is **not** a factor of $6x$?",
      "structure": "is-it-a-factor",
      "mastery": false,
      "options": [
        { "text": "$4$", "correct": true },
        { "text": "$3x$", "why": "$3x$ is a factor: $6x \\div 3x = 2$." },
        { "text": "$6$", "why": "$6$ is a factor: $6x \\div 6 = x$." },
        { "text": "$2x$", "why": "$2x$ is a factor: $6x \\div 2x = 3$." }
      ],
      "solution": [
        { "math": "Factors of $6$: $1, 2, 3, 6$", "note": "Number part" },
        { "math": "$4$ is not among them", "note": "Not a factor" }
      ]
    },
    {
      "id": "q5",
      "q": "Which of these is a factor of $6ab$?",
      "structure": "coefficient-two-pronumerals",
      "mastery": true,
      "options": [
        { "text": "$3ab$", "correct": true },
        { "text": "$4a$", "why": "$4$ does not divide $6$, so $4a$ is not a factor." },
        { "text": "$6a^2$", "why": "$6ab$ has only one $a$; $a^2$ needs two, so $6a^2$ is not a factor." },
        { "text": "$ab^2$", "why": "$6ab$ has only one $b$; $b^2$ needs two, so $ab^2$ is not a factor." }
      ],
      "solution": [
        { "math": "$6ab = 6 \\times a \\times b$" },
        { "math": "$3$ divides $6$, and $ab$ divides $ab$", "note": "Check" },
        { "math": "$3ab$ is a factor", "note": "Answer" }
      ]
    },
    {
      "id": "q6",
      "q": "Which of these is **not** a factor of $4x^2$?",
      "structure": "pronumeral-power",
      "mastery": true,
      "options": [
        { "text": "$8x$", "correct": true },
        { "text": "$4x$", "why": "$4x$ is a factor: $4x^2 \\div 4x = x$." },
        { "text": "$x^2$", "why": "$x^2$ is a factor: $4x^2 \\div x^2 = 4$." },
        { "text": "$2x$", "why": "$2x$ is a factor: $4x^2 \\div 2x = 2x$." }
      ],
      "solution": [
        { "math": "$4x^2 = 4 \\times x \\times x$" },
        { "math": "$8$ does not divide $4$, so $8x$ is not a factor", "note": "Check" }
      ]
    }
  ]
}
