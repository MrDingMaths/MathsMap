    {
      "id": "q6",
      "q": "Identify the constant term in $3a - 8 + 13c$.",
      "structure": "identify-constant",
      "mastery": true,
      "options": [
        {
          "text": "$-8$",
          "correct": true
        },
        {
          "text": "$8$",
          "why": "Dropped the minus sign — the subtraction travels with the term, so the constant is $-8$."
        },
        {
          "text": "$13$",
          "why": "Chose the coefficient of $c$; a constant term has no pronumeral."
        },
        {
          "text": "$3$",
          "why": "Chose the coefficient of $a$; a constant term has no pronumeral."
        }
      ],
      "solution": [
        {
          "math": "$3a - 8 + 13c$"
        },
        {
          "math": "$= 3a + (-8) + 13c$",
          "note": "Sign travels"
        },
        {
          "math": "$-8$",
          "note": "No pronumeral"
        }
      ]
    },
    {
      "id": "q7",
      "q": "State the coefficient of $x$ in $9 - x$.",
      "structure": "signed-coefficient",
      "mastery": true,
      "options": [
        {
          "text": "$-1$",
          "correct": true
        },
        {
          "text": "$1$",
          "why": "Missed the subtraction; $-x$ means the coefficient is $-1$."
        },
        {
          "text": "$9$",
          "why": "Gave the constant term instead of the number multiplying $x$."
        },
        {
          "text": "$-9$",
          "why": "Attached the sign to $9$; the constant is $9$ and the coefficient is $-1$."
        }
      ],
      "solution": [
        {
          "math": "$9 - x$"
        },
        {
          "math": "$= 9 + (-x)$",
          "note": "Rewrite subtractions"
        },
        {
          "math": "$= 9 + (-1)x$",
          "note": "Hidden $-1$"
        },
        {
          "math": "$-1$",
          "note": "Read coefficient"
        }
      ]
    }
  ]
}
