{
  "skillId": "identify-parts-of-expression",
  "questions": [
    {
      "id": "q1",
      "q": "List all the terms in $5a + 3b - 7c + 12$.",
      "structure": "list-terms",
      "mastery": false,
      "options": [
        {
          "text": "$5a,\\ 3b,\\ -7c,\\ 12$",
          "correct": true
        },
        {
          "text": "$5a,\\ 3b,\\ 7c,\\ 12$",
          "why": "Dropped the minus sign — the term is $-7c$, and the sign travels with the term."
        },
        {
          "text": "$5a,\\ 3b,\\ -7c$",
          "why": "Left out $12$ — a number on its own is still a term."
        },
        {
          "text": "$5,\\ a,\\ 3,\\ b,\\ 7,\\ c,\\ 12$",
          "why": "Split every symbol apart instead of keeping each term ($5a$, $3b$) whole."
        }
      ],
      "solution": [
        {
          "math": "$5a + 3b - 7c + 12$"
        },
        {
          "math": "$= 5a + 3b + (-7c) + 12$",
          "note": "Rewrite subtractions"
        },
        {
          "math": "$5a,\\ 3b,\\ -7c,\\ 12$",
          "note": "Split into terms"
        }
      ]
    },
    {
      "id": "q2",
      "q": "State the coefficient of $n$ in $15w + 21n + 1$.",
      "structure": "state-coefficient",
      "mastery": false,
      "options": [
        {
          "text": "$21$",
          "correct": true
        },
        {
          "text": "$15$",
          "why": "Read the coefficient of the wrong pronumeral ($w$) instead of $n$."
        },
        {
          "text": "$1$",
          "why": "Gave the constant term instead of the number multiplying $n$."
        },
        {
          "text": "$21n$",
          "why": "Included the pronumeral — a coefficient is just the number $21$."
        }
      ],
      "solution": [
        {
          "math": "$15w + 21n + 1$"
        },
        {
          "math": "$21$",
          "note": "Read coefficient"
        }
      ]
    },
    {
      "id": "q3",
      "q": "State the coefficient of $x$ in $18 - 9x$.",
      "structure": "signed-coefficient",
      "mastery": false,
      "options": [
        {
          "text": "$-9$",
          "correct": true
        },
        {
          "text": "$9$",
          "why": "Ignored the subtraction; the term is $-9x$, so the coefficient is $-9$."
        },
        {
          "text": "$18$",
          "why": "Gave the constant term instead of the number multiplying $x$."
        },
        {
          "text": "$-18$",
          "why": "Attached the sign to $18$ — that is the constant, not the coefficient."
        }
      ],
      "solution": [
        {
          "math": "$18 - 9x$"
        },
        {
          "math": "$= 18 + (-9x)$",
          "note": "Rewrite subtractions"
        },
        {
          "math": "$-9$",
          "note": "Read coefficient"
        }
      ]
    },
    {
      "id": "q4",
      "q": "State the coefficient of $x$ in $\\frac{x}{3}$.",
      "structure": "fractional-coefficient",
      "mastery": false,
      "options": [
        {
          "text": "$\\frac{1}{3}$",
          "correct": true
        },
        {
          "text": "$3$",
          "why": "Read the denominator as the coefficient; $\\frac{x}{3} = \\frac{1}{3}x$, so it is $\\frac{1}{3}$."
        },
        {
          "text": "$1$",
          "why": "Treated $x$ as coefficient $1$, ignoring the division by $3$."
        },
        {
          "text": "$\\frac{1}{x}$",
          "why": "Inverted the term instead of reading the number multiplying $x$."
        }
      ],
      "solution": [
        {
          "math": "$\\frac{x}{3}$"
        },
        {
          "math": "$= \\frac{1}{3}x$",
          "note": "Rewrite"
        },
        {
          "math": "$\\frac{1}{3}$",
          "note": "Read coefficient"
        }
      ]
    },
