  "questions": [
    {
      "id": "q1",
      "q": "Find the HCF of $6x$ and $9x$.",
      "structure": "numeric-hcf-shared-variable",
      "mastery": false,
      "options": [
        { "text": "$3x$", "correct": true },
        { "text": "$3$", "why": "Found the numeric HCF but dropped $x$, which is common to both terms." },
        { "text": "$x$", "why": "Kept the variable but used $1$ instead of the HCF of $6$ and $9$, which is $3$." },
        { "text": "$18x$", "why": "Used the lowest common multiple of $6$ and $9$ instead of their highest common factor." }
      ],
      "solution": [
        { "math": "$\\text{HCF of } 6, 9 = 3$", "note": "Numbers' HCF" },
        { "math": "$= 3x$", "note": "Multiply" }
      ]
    },
    {
      "id": "q2",
      "q": "Find the HCF of $10x$ and $15$.",
      "structure": "numeric-hcf-only",
      "mastery": false,
      "options": [
        { "text": "$5$", "correct": true },
        { "text": "$5x$", "why": "Included $x$, but $x$ is not a factor of $15$, so it is not common to both terms." },
        { "text": "$1$", "why": "Missed that $5$ divides both $10$ and $15$; treated the terms as sharing no factor." },
        { "text": "$10$", "why": "Took the first coefficient as the HCF, but $10$ does not divide $15$." }
      ],
      "solution": [
        { "math": "$\\text{HCF of } 10, 15 = 5$", "note": "Numbers' HCF" },
        { "math": "$x \\text{ is not in } 15$", "note": "Common variable" },
        { "math": "$= 5$", "note": "Multiply" }
      ]
    },
    {
      "id": "q3",
      "q": "Find the HCF of $8x^2y$ and $12x^5y$.",
      "structure": "common-variable-powers",
      "mastery": false,
      "options": [
        { "text": "$4x^2y$", "correct": true },
        { "text": "$4x^5y$", "why": "Took the higher power $x^5$; the HCF uses the lower power $x^2$." },
        { "text": "$4x^7y$", "why": "Added the exponents $2+5$; shared powers are compared, not added." },
        { "text": "$2x^2y$", "why": "Used $2$, a common factor of $8$ and $12$, instead of their highest common factor $4$." }
      ],
      "solution": [
        { "math": "$\\text{HCF of } 8, 12 = 4$", "note": "Numbers' HCF" },
        { "math": "$x^2 \\text{ is the lower power}$", "note": "Take lowest power" },
        { "math": "$= 4x^2y$", "note": "Multiply" }
      ]
    },
    {
      "id": "q4",
      "q": "Find the HCF of $6xy$ and $12x$.",
      "structure": "multiple-common-variables",
      "mastery": false,
      "options": [
        { "text": "$6x$", "correct": true },
        { "text": "$6xy$", "why": "Kept $y$, but $y$ appears only in the first term, so it is not common." },
        { "text": "$6$", "why": "Found the numeric HCF but dropped $x$, which is common to both terms." },
        { "text": "$2x$", "why": "Used $2$, a common factor of $6$ and $12$, rather than their highest common factor $6$." }
      ],
      "solution": [
        { "math": "$\\text{HCF of } 6, 12 = 6$", "note": "Numbers' HCF" },
        { "math": "$x \\text{ in both, } y \\text{ is not}$", "note": "Common variable" },
        { "math": "$= 6x$", "note": "Multiply" }
      ]
    },
    {
      "id": "q5",
      "q": "Find the HCF of $7a$ and $13a$.",
      "structure": "coprime-coefficients",
      "mastery": false,
      "options": [
        { "text": "$a$", "correct": true },
        { "text": "$1$", "why": "The HCF of $7$ and $13$ is $1$, but the shared variable $a$ must still be included." },
        { "text": "$91a$", "why": "Multiplied $7$ and $13$; that gives a common multiple, not the highest common factor." },
        { "text": "$7a$", "why": "Assumed the smaller coefficient is the HCF, but $7$ does not divide $13$." }
      ],
      "solution": [
        { "math": "$\\text{HCF of } 7, 13 = 1$", "note": "Numbers' HCF" },
        { "math": "$a \\text{ in both}$", "note": "Common variable" },
        { "math": "$= a$", "note": "Multiply" }
      ]
    },
    {
      "id": "q6",
      "q": "Find the HCF of $18a^3b^2c$ and $24a^2b^4$.",
      "structure": "multiple-common-variables",
      "mastery": true,
      "options": [
        { "text": "$6a^2b^2$", "correct": true },
        { "text": "$6a^3b^4c$", "why": "Took the higher power of each variable and kept $c$; the HCF uses the lower power and only shared variables." },
        { "text": "$6a^2b^2c$", "why": "Included $c$, but $c$ appears only in the first term, so it is not common." },
        { "text": "$2a^2b^2$", "why": "Used $2$, a common factor of $18$ and $24$, instead of their highest common factor $6$." }
      ],
      "solution": [
        { "math": "$\\text{HCF of } 18, 24 = 6$", "note": "Numbers' HCF" },
        { "math": "$a^2 \\text{ and } b^2 \\text{ are lower powers}$", "note": "Take lowest power" },
        { "math": "$c \\text{ is not in both}$", "note": "Common variable" },
        { "math": "$= 6a^2b^2$", "note": "Multiply" }
      ]
    }
  ]
