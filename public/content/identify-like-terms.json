{
  "skillId": "identify-like-terms",
  "atomType": "Cat",
  "theory": {
    "intro": "Like terms have exactly the same variable part — the same letters raised to the same powers. Only the number in front (the coefficient) may differ.",
    "facts": [
      "**Like terms** have the **same variables** raised to the **same powers**.",
      "The **coefficient** (the number in front) does not matter: $3a$ and $-7a$ are like terms.",
      "Variable **order** does not matter: $xy$ and $yx$ are like terms.",
      "A different **power** makes terms unlike: $x$ and $x^2$ are **not** like terms.",
      "All plain **numbers** (constants) are like terms with each other: $5$ and $12$ are like."
    ],
    "steps": [
      "Ignore the coefficients.",
      "Compare the variables.",
      "Compare the powers.",
      "Same part means like."
    ]
  },
  "practice": {
    "foundation": [
      {
        "q": "Are $3a$ and $2a$ like terms?",
        "a": "Yes — like terms",
        "solution": [
          { "math": "$3a$, $2a$" },
          { "math": "Variable parts: $a$, $a$", "note": "Ignore coefficients" },
          { "math": "Same variables and powers", "note": "Like" }
        ]
      },
      {
        "q": "Are $5a$ and $5b$ like terms?",
        "a": "No — unlike terms",
        "solution": [
          { "math": "$5a$, $5b$" },
          { "math": "Variable parts: $a$, $b$", "note": "Ignore coefficients" },
          { "math": "Different variables", "note": "Unlike" }
        ]
      },
      {
        "q": "Are $x$ and $x^2$ like terms?",
        "a": "No — unlike terms",
        "solution": [
          { "math": "$x$, $x^2$" },
          { "math": "Same variable $x$, powers $1$ and $2$", "note": "Compare powers" },
          { "math": "Different powers", "note": "Unlike" }
        ]
      },
      {
        "q": "Are $xy$ and $yx$ like terms?",
        "a": "Yes — like terms",
        "solution": [
          { "math": "$xy$, $yx$" },
          { "math": "Both have variables $x$ and $y$", "note": "Compare variables" },
          { "math": "Order does not matter", "note": "Like" }
        ]
      },
      {
        "q": "Are $7$ and $12$ like terms?",
        "a": "Yes — like terms",
        "solution": [
          { "math": "$7$, $12$" },
          { "math": "Both are plain numbers, no variables", "note": "Compare variables" },
          { "math": "All constants are like", "note": "Like" }
        ]
      }
    ],
    "development": [
      {
        "q": "Are $-3a^2$ and $7a^2$ like terms?",
        "a": "Yes — like terms",
        "solution": [
          { "math": "$-3a^2$, $7a^2$" },
          { "math": "Variable parts: $a^2$, $a^2$", "note": "Ignore coefficients" },
          { "math": "Same variable and power", "note": "Like" }
        ]
      },
      {
        "q": "Are $4a^2y$ and $5ya^2$ like terms?",
        "a": "Yes — like terms",
        "solution": [
          { "math": "$4a^2y$, $5ya^2$" },
          { "math": "Variable parts: $a^2y$, $a^2y$", "note": "Ignore coefficients" },
          { "math": "Same variables, same powers", "note": "Like" }
        ]
      },
      {
        "q": "Are $4a^2y$ and $5ay^2$ like terms?",
        "a": "No — unlike terms",
        "solution": [
          { "math": "$4a^2y$, $5ay^2$" },
          { "math": "$a^2y$ has $a^2$; $ay^2$ has $y^2$", "note": "Compare powers" },
          { "math": "Powers on $a$ and $y$ differ", "note": "Unlike" }
        ]
      },
      {
        "q": "Are $3a$ and $3$ like terms?",
        "a": "No — unlike terms",
        "solution": [
          { "math": "$3a$, $3$" },
          { "math": "$3a$ has variable $a$; $3$ has none", "note": "Compare variables" },
          { "math": "One has a variable, one does not", "note": "Unlike" }
        ]
      },
      {
        "q": "Identify the like terms in $3a - 5b + 4a$.",
        "a": "$3a$ and $4a$",
        "solution": [
          { "math": "$3a$, $-5b$, $4a$" },
          { "math": "Variable parts: $a$, $b$, $a$", "note": "Ignore coefficients" },
          { "math": "$3a$ and $4a$ share $a$", "note": "Like" }
        ]
      }
    ],
    "mastery": [
      {
        "q": "Which term is **unlike** the other two: $xy^2$, $x^2y$, $y^2x$?",
        "a": "$x^2y$",
        "solution": [
          { "math": "$xy^2$ is $x^1y^2$" },
          { "math": "$x^2y$ is $x^2y^1$", "note": "Compare powers" },
          { "math": "$y^2x$ is $x^1y^2$", "note": "Order ignored" },
          { "math": "$x^2y$ has different powers", "note": "Unlike" }
        ]
      },
      {
        "q": "Identify the like terms in $2pq + 3qp + 9p + 9q$.",
        "a": "$2pq$ and $3qp$",
        "solution": [
          { "math": "$2pq$, $3qp$, $9p$, $9q$" },
          { "math": "Variable parts: $pq$, $pq$, $p$, $q$", "note": "Order ignored" },
          { "math": "Only $2pq$ and $3qp$ share $pq$", "note": "Like" }
        ]
      },
      {
        "q": "List all sets of like terms in $5yx + 3xy - 4 + 3 - 2$.",
        "a": "$5yx$ and $3xy$; and the constants $-4$, $3$, $-2$",
        "solution": [
          { "math": "$5yx$, $3xy$, $-4$, $3$, $-2$" },
          { "math": "$5yx$ and $3xy$ both have $xy$", "note": "Order ignored" },
          { "math": "$-4$, $3$, $-2$ are all constants", "note": "Compare variables" },
          { "math": "Two sets of like terms", "note": "Like" }
        ]
      }
    ]
  }
}
