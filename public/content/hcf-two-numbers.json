{
  "skillId": "hcf-two-numbers",
  "atomType": "R",
  "theory": {
    "intro": "The **highest common factor (HCF)** of two numbers is the largest whole number that divides into both of them exactly.",
    "facts": [
      "A **common factor** divides both numbers with no remainder.",
      "$1$ is a common factor of every pair, so the HCF is at least $1$.",
      "Factors of $12$: $1, 2, 3, 4, 6, 12$; factors of $18$: $1, 2, 3, 6, 9, 18$; the largest shared factor is $6$."
    ],
    "steps": [
      "List the factors of each number.",
      "Identify the factors common to both.",
      "The HCF is the largest of the common factors."
    ]
  },
  "practice": {
