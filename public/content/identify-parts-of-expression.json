          },
          {
            "math": "$-11$",
            "note": "Find constant"
          }
        ]
      }
    ],
    "mastery": [
      {
        "q": "Identify the constant term in $7p - 12 + 4q$.",
        "a": "$-12$",
        "solution": [
          {
            "math": "$7p - 12 + 4q$"
          },
          {
            "math": "$= 7p + (-12) + 4q$",
            "note": "Sign travels"
          },
          {
            "math": "$-12$",
            "note": "No pronumeral"
          }
        ]
      },
      {
        "q": "State the coefficient of $a$ in $3b - \\frac{3a}{7} - 14$.",
        "a": "$-\\frac{3}{7}$",
        "solution": [
          {
            "math": "$3b - \\frac{3a}{7} - 14$"
          },
          {
            "math": "$= 3b + \\left(-\\frac{3a}{7}\\right) + (-14)$",
            "note": "Rewrite subtractions"
          },
          {
            "math": "$= 3b + \\left(-\\frac{3}{7}\\right)a + (-14)$",
            "note": "Rewrite"
          },
          {
            "math": "$-\\frac{3}{7}$",
            "note": "Read coefficient"
          }
        ]
      },
      {
        "q": "State the coefficient of $x$ in $9 - x$.",
        "a": "$-1$",
        "solution": [
          {
            "math": "$9 - x$"
          },
          {
            "math": "$= 9 + (-x)$",
            "note": "Rewrite subtractions"
          },
          {
            "math": "$= 9 + (-1)x$",
            "note": "Hidden $-1$"
          },
          {
            "math": "$-1$",
            "note": "Read coefficient"
          }
        ]
      }
    ]
  }
}
