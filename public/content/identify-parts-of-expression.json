            "math": "$\\frac{3x}{7}$"
          },
          {
            "math": "$= \\frac{3}{7}x$",
            "note": "Rewrite"
          },
          {
            "math": "$\\frac{3}{7}$",
            "note": "Read coefficient"
          }
        ]
      },
      {
        "q": "Identify the constant term in $3x - 11$.",
        "a": "$-11$",
        "solution": [
          {
            "math": "$3x - 11$"
          },
          {
            "math": "$= 3x + (-11)$",
