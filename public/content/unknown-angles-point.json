{
 "skillId":"unknown-angles-point","atomType":"R",
 "theory":{"intro":"Unknown angles at one point are found by matching the diagram to a known angle total or equality and stating the reason.","facts":["Angles on a **straight line** add to $180^{\\circ}$.","Angles in a **right angle** add to $90^{\\circ}$.","Angles **at a point** add to $360^{\\circ}$.","**Vertically opposite** angles are equal."],"steps":["Choose the relationship.","Write the angle equation.","Solve for the unknown.","State the reason."]},
 "practice":{"foundation":[
  {"q":"Find $x$ and give a reason.","a":"$x=112^{\\circ}$, angles on a straight line","tikz":"\\begin{tikzpicture}[scale=0.7]\\draw (-2,0)--(2,0);\\draw (0,0)--(68:1.8);\\node at (-0.75,0.38) {$x$};\\node at (0.65,0.35) {$68^{\\circ}$};\\end{tikzpicture}","solution":[{"math":"$x+68^{\\circ}=180^{\\circ}$"},{"math":"$=180^{\\circ}-68^{\\circ}$","note":"Solve unknown"},{"math":"$=112^{\\circ}$","note":"Straight line"}]},
  {"q":"Find $x$ and give a reason.","a":"$x=53^{\\circ}$, angles in a right angle","tikz":"\\begin{tikzpicture}[scale=0.7]\\draw (0,0)--(2,0);\\draw (0,0)--(0,2);\\draw (0,0)--(37:1.8);\\node at (0.75,0.25) {$37^{\\circ}$};\\node at (0.3,0.9) {$x$};\\end{tikzpicture}","solution":[{"math":"$x+37^{\\circ}=90^{\\circ}$"},{"math":"$=90^{\\circ}-37^{\\circ}$","note":"Solve unknown"},{"math":"$=53^{\\circ}$","note":"Right angle"}]},
  {"q":"Find $x$ and give a reason.","a":"$x=145^{\\circ}$, vertically opposite angles","tikz":"\\begin{tikzpicture}[scale=0.7]\\draw (-2,-0.7)--(2,0.7);\\draw (-2,0.7)--(2,-0.7);\\node at (0,0.55) {$145^{\\circ}$};\\node at (0,-0.55) {$x$};\\end{tikzpicture}","solution":[{"math":"$x=145^{\\circ}$","note":"Vertically opposite"}]},
  {"q":"Find $x$ and give a reason.","a":"$x=215^{\\circ}$, angles at a point","tikz":"\\begin{tikzpicture}[scale=0.7]\\draw (0,0)--(2,0);\\draw (0,0)--(145:2);\\draw (145:0.65) arc[start angle=145,end angle=360,radius=0.65];\\node at (0.25,0.75) {$145^{\\circ}$};\\node at (0,-0.85) {$x$};\\end{tikzpicture}","solution":[{"math":"$x+145^{\\circ}=360^{\\circ}$"},{"math":"$=360^{\\circ}-145^{\\circ}$","note":"Solve unknown"},{"math":"$=215^{\\circ}$","note":"Angles at point"}]}
 ],"development":[
  {"q":"Find $x$ and give a reason.","a":"$x=75^{\\circ}$, angles on a straight line","tikz":"\\begin{tikzpicture}[scale=0.7]\\draw (-2,0)--(2,0);\\draw (0,0)--(75:1.8);\\draw (0,0)--(138:1.8);\\node at (-0.88,0.34) {$42^{\\circ}$};\\node at (-0.27,0.9) {$63^{\\circ}$};\\node at (0.72,0.55) {$x$};\\end{tikzpicture}","solution":[{"math":"$42^{\\circ}+63^{\\circ}+x=180^{\\circ}$"},{"math":"$x=180^{\\circ}-105^{\\circ}$","note":"Solve unknown"},{"math":"$=75^{\\circ}$","note":"Straight line"}]},
  {"q":"Find $x$ and give a reason.","a":"$x=29^{\\circ}$, angles in a right angle","tikz":"\\begin{tikzpicture}[scale=0.7]\\draw (0,0)--(2,0);\\draw (0,0)--(0,2);\\draw (0,0)--(28:1.8);\\draw (0,0)--(61:1.8);\\node at (0.95,0.22) {$28^{\\circ}$};\\node at (0.78,0.72) {$33^{\\circ}$};\\node at (0.18,1.12) {$x$};\\end{tikzpicture}","solution":[{"math":"$28^{\\circ}+33^{\\circ}+x=90^{\\circ}$"},{"math":"$x=90^{\\circ}-61^{\\circ}$","note":"Solve unknown"},{"math":"$=29^{\\circ}$","note":"Right angle"}]},
  {"q":"Find $x$ and give a reason.","a":"$x=132^{\\circ}$, angles at a point","tikz":"\\begin{tikzpicture}[scale=0.7]\\foreach \\a in {0,80,205}{\\draw (0,0)--(\\a:2);}\\node at (0.75,0.45) {$80^{\\circ}$};\\node at (-0.4,0.7) {$148^{\\circ}$};\\node at (0,-0.75) {$x$};\\end{tikzpicture}","solution":[{"math":"$80^{\\circ}+148^{\\circ}+x=360^{\\circ}$"},{"math":"$x=360^{\\circ}-228^{\\circ}$","note":"Solve unknown"},{"math":"$=132^{\\circ}$","note":"Angles at point"}]},
  {"q":"Two lines intersect. One angle is $3x+8$ degrees and its vertically opposite angle is $86^{\\circ}$. Find $x$.","a":"$x=26$","solution":[{"math":"$3x+8=86$"},{"math":"$3x=78$","note":"Vertically opposite"},{"math":"$x=26$","note":"Solve unknown"}]},
  {"q":"On a straight line, two adjacent angles are equal. Find each angle.","a":"Each angle is $90^{\\circ}$","solution":[{"math":"$x+x=180^{\\circ}$"},{"math":"$2x=180^{\\circ}$","note":"Straight line"},{"math":"$x=90^{\\circ}$","note":"Solve unknown"}]}
 ],"mastery":[
  {"q":"Two lines intersect. A third ray splits one angle into $38^{\\circ}$ and $47^{\\circ}$. Find the angle vertically opposite the whole split angle.","a":"$85^{\\circ}$","tikz":"\\begin{tikzpicture}[scale=0.7]\\draw (-2,-1)--(2,1);\\draw (-2,1)--(2,-1);\\draw (0,0)--(90:1.8);\\node at (-0.3,0.65) {$38^{\\circ}$};\\node at (0.45,0.55) {$47^{\\circ}$};\\node at (0,-0.65) {$x$};\\end{tikzpicture}","solution":[{"math":"$38^{\\circ}+47^{\\circ}=85^{\\circ}$"},{"math":"$x=85^{\\circ}$","note":"Vertically opposite"}]},
  {"q":"Four angles meet at a point. Two vertically opposite angles are each $124^{\\circ}$; the other two are equal. Find either remaining angle.","a":"$56^{\\circ}$","solution":[{"math":"$124^{\\circ}+124^{\\circ}+2x=360^{\\circ}$"},{"math":"$2x=112^{\\circ}$","note":"Angles at point"},{"math":"$x=56^{\\circ}$","note":"Solve unknown"}]}
 ]}}
