{
  "skillId": "pattern-from-expression",
  "atomType": "R",
  "theory": {
    "intro": "Substituting the consecutive values $x = 1, 2, 3, \\dots$ into an expression produces a **number pattern** — the list of results written in order.",
    "facts": [
      "The expression is a **rule**: it says what to do to each input value.",
      "Use the **same expression** every time; only the value of $x$ changes.",
      "Substitute the values **in order** ($x = 1, 2, 3, 4, 5$) and write each result down.",
      "Keep the input in **brackets** when you substitute, e.g. $2x - 1$ at $x = 3$ is $2(3) - 1$."
    ],
    "steps": [
      "Write the input values in order.",
      "Substitute each value into the expression.",
      "Evaluate each result.",
      "List the results to form the pattern."
    ]
  },
  "practice": {
    "foundation": [
      {
        "q": "Generate the number pattern from $3x$ for $x = 1, 2, 3, 4, 5$.",
        "a": "$3, 6, 9, 12, 15$",
        "solution": [
          { "math": "$3(1) = 3$" },
          { "math": "$3(2) = 6$", "note": "Substitute" },
          { "math": "$3(3) = 9$", "note": "Substitute" },
          { "math": "$3, 6, 9, 12, 15$", "note": "List pattern" }
        ]
      },
      {
        "q": "Generate the number pattern from $5x$ for $x = 1, 2, 3, 4, 5$.",
        "a": "$5, 10, 15, 20, 25$",
        "solution": [
          { "math": "$5(1) = 5$" },
          { "math": "$5(2) = 10$", "note": "Substitute" },
          { "math": "$5(3) = 15$", "note": "Substitute" },
          { "math": "$5, 10, 15, 20, 25$", "note": "List pattern" }
        ]
      },
      {
        "q": "Generate the number pattern from $2x + 1$ for $x = 1, 2, 3, 4, 5$.",
        "a": "$3, 5, 7, 9, 11$",
        "solution": [
          { "math": "$2(1) + 1 = 3$" },
          { "math": "$2(2) + 1 = 5$", "note": "Substitute" },
          { "math": "$2(3) + 1 = 7$", "note": "Substitute" },
          { "math": "$3, 5, 7, 9, 11$", "note": "List pattern" }
        ]
      },
      {
        "q": "Generate the number pattern from $x + 4$ for $x = 1, 2, 3, 4, 5$.",
        "a": "$5, 6, 7, 8, 9$",
        "solution": [
          { "math": "$(1) + 4 = 5$" },
          { "math": "$(2) + 4 = 6$", "note": "Substitute" },
          { "math": "$(3) + 4 = 7$", "note": "Substitute" },
          { "math": "$5, 6, 7, 8, 9$", "note": "List pattern" }
        ]
      },
      {
        "q": "Generate the number pattern from $2x - 1$ for $x = 1, 2, 3, 4, 5$.",
        "a": "$1, 3, 5, 7, 9$",
        "solution": [
          { "math": "$2(1) - 1 = 1$" },
          { "math": "$2(2) - 1 = 3$", "note": "Substitute" },
          { "math": "$2(3) - 1 = 5$", "note": "Substitute" },
          { "math": "$1, 3, 5, 7, 9$", "note": "List pattern" }
        ]
      }
    ],
    "development": [
      {
        "q": "Generate the number pattern from $3x + 2$ for $x = 1, 2, 3, 4, 5$.",
        "a": "$5, 8, 11, 14, 17$",
        "solution": [
          { "math": "$3(1) + 2 = 5$" },
          { "math": "$3(2) + 2 = 8$", "note": "Substitute" },
          { "math": "$3(3) + 2 = 11$", "note": "Substitute" },
          { "math": "$5, 8, 11, 14, 17$", "note": "List pattern" }
        ]
      },
      {
        "q": "Generate the number pattern from $3x - 7$ for $x = 1, 2, 3, 4, 5$.",
        "a": "$-4, -1, 2, 5, 8$",
        "solution": [
          { "math": "$3(1) - 7 = -4$" },
          { "math": "$3(2) - 7 = -1$", "note": "Substitute" },
          { "math": "$3(3) - 7 = 2$", "note": "Substitute" },
          { "math": "$-4, -1, 2, 5, 8$", "note": "List pattern" }
        ]
      },
      {
        "q": "Generate the number pattern from $10 - 2x$ for $x = 1, 2, 3, 4, 5$.",
        "a": "$8, 6, 4, 2, 0$",
        "solution": [
          { "math": "$10 - 2(1) = 8$" },
          { "math": "$10 - 2(2) = 6$", "note": "Substitute" },
          { "math": "$10 - 2(3) = 4$", "note": "Substitute" },
          { "math": "$8, 6, 4, 2, 0$", "note": "List pattern" }
        ]
      },
      {
        "q": "Generate the number pattern from $2 - 3x$ for $x = 1, 2, 3, 4, 5$.",
        "a": "$-1, -4, -7, -10, -13$",
        "solution": [
          { "math": "$2 - 3(1) = -1$" },
          { "math": "$2 - 3(2) = -4$", "note": "Substitute" },
          { "math": "$2 - 3(3) = -7$", "note": "Substitute" },
          { "math": "$-1, -4, -7, -10, -13$", "note": "List pattern" }
        ]
      },
      {
        "q": "Generate the number pattern from $4x - 3$ for $x = 1, 2, 3, 4, 5$.",
        "a": "$1, 5, 9, 13, 17$",
        "solution": [
          { "math": "$4(1) - 3 = 1$" },
          { "math": "$4(2) - 3 = 5$", "note": "Substitute" },
          { "math": "$4(3) - 3 = 9$", "note": "Substitute" },
          { "math": "$1, 5, 9, 13, 17$", "note": "List pattern" }
        ]
      }
    ],
    "mastery": [
      {
        "q": "The number pattern comes from $2x + 3$. Find its value when $x = 20$, without listing every earlier term.",
        "a": "$43$",
        "solution": [
          { "math": "$2(20) + 3$" },
          { "math": "$= 40 + 3$", "note": "Evaluate" },
          { "math": "$= 43$", "note": "Evaluate" }
        ]
      },
      {
        "q": "The number pattern comes from $5 - 4x$. Find its value when $x = 12$, without listing every earlier term.",
        "a": "$-43$",
        "solution": [
          { "math": "$5 - 4(12)$" },
          { "math": "$= 5 - 48$", "note": "Evaluate" },
          { "math": "$= -43$", "note": "Evaluate" }
        ]
      },
      {
        "q": "The number pattern comes from $4x - 9$. Find its value when $x = 25$, without listing every earlier term.",
        "a": "$91$",
        "solution": [
          { "math": "$4(25) - 9$" },
          { "math": "$= 100 - 9$", "note": "Evaluate" },
          { "math": "$= 91$", "note": "Evaluate" }
        ]
      }
    ]
  }
}
