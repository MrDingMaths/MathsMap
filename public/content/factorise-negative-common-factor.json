{
  "skillId": "factorise-negative-common-factor",
  "atomType": "R",
  "theory": {
    "intro": "Factorising is the inverse of expanding. When the first term of an expression is negative, we take out a **negative** common factor — and every term inside the brackets then has its sign flipped.",
    "facts": [
      "Take out a **negative** factor whenever the first term is negative, so the leading term inside the brackets comes out positive.",
      "Dividing by a negative flips the sign of **every** term inside the brackets: $-2x - 6 = -2(x + 3)$.",
      "The factor is the **negative of the HCF** of the terms: for $-6x - 9$ the HCF is $3$, so take out $-3$ to get $-3(2x + 3)$.",
      "If the HCF is $1$, take out $-1$ and write it as a single minus sign: $-x - 7 = -(x + 7)$.",
      "Check by expanding: $-3(2x - 3) = -6x + 9$ returns the original expression."
    ],
    "steps": [
      "Find the HCF.",
      "Take out the negative.",
      "Divide each term.",
      "Flip every sign.",
      "Check by expanding."
    ]
  },
