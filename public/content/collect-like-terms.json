{
  "skillId": "collect-like-terms",
  "atomType": "R",
  "theory": {
    "intro": "Collecting like terms simplifies an expression by adding and subtracting the terms that are alike â€” the ones with the same variables raised to the same powers.",
    "facts": [
      "Only **like terms** can be combined: they must have the **same variables** with the **same powers**.",
      "To combine like terms, add or subtract their **coefficients**; the variable part stays the same, e.g. $5a - 3a = 2a$.",
      "Keep the **sign in front** of each term when you move it â€” treat a subtraction as a negative term.",
      "Plain numbers (**constant terms**) are like terms with each other.",
      "Variable order does not matter, so $xy$ and $yx$ are like terms.",
      "Terms that are **not alike** cannot be combined â€” leave them as they are. An expression with no remaining like terms is fully simplified."
    ],
    "steps": [
      "Identify the like terms.",
      "Group like terms.",
      "Combine coefficients.",
      "Leave unlike terms."
    ]
  },
  "practice": {
    "foundation": [
      {
        "q": "Simplify $5a - 3a$.",
        "a": "$2a$",
        "solution": [
          { "math": "$5a - 3a$" },
          { "math": "$= 2a$", "note": "Combine" }
        ]
      },
      {
        "q": "Simplify $3a + 6 + 5a$.",
        "a": "$8a + 6$",
        "solution": [
          { "math": "$3a + 6 + 5a$" },
          { "math": "$= (3a + 5a) + 6$", "note": "Group terms" },
          { "math": "$= 8a + 6$", "note": "Combine" }
        ]
      },
      {
        "q": "Simplify $6a + 5b - a - b$.",
        "a": "$5a + 4b$",
        "solution": [
          { "math": "$6a + 5b - a - b$" },
          { "math": "$= (6a - a) + (5b - b)$", "note": "Group terms" },
          { "math": "$= 5a + 4b$", "note": "Combine" }
        ]
      },
      {
        "q": "Simplify $2xy + yx$.",
        "a": "$3xy$",
        "solution": [
          { "math": "$2xy + yx$" },
          { "math": "$= 2xy + xy$", "note": "Same term" },
          { "math": "$= 3xy$", "note": "Combine" }
        ]
      },
      {
        "q": "Simplify $4x - 5x$.",
        "a": "$-x$",
        "solution": [
          { "math": "$4x - 5x$" },
          { "math": "$= -x$", "note": "Combine" }
        ]
      }
    ],
    "development": [
      {
        "q": "Simplify $7 + 10 - 5m$.",
        "a": "$17 - 5m$",
        "solution": [
          { "math": "$7 + 10 - 5m$" },
          { "math": "$= (7 + 10) - 5m$", "note": "Group terms" },
          { "math": "$= 17 - 5m$", "note": "Leave unlike" }
        ]
      },
      {
        "q": "Simplify $6a - 5b - 4a - 3b$.",
        "a": "$2a - 8b$",
        "solution": [
          { "math": "$6a - 5b - 4a - 3b$" },
          { "math": "$= (6a - 4a) + (-5b - 3b)$", "note": "Group terms" },
          { "math": "$= 2a - 8b$", "note": "Combine" }
        ]
      },
      {
        "q": "Simplify $d^2 + 5d - 3d^2$.",
        "a": "$-2d^2 + 5d$",
        "solution": [
          { "math": "$d^2 + 5d - 3d^2$" },
          { "math": "$= (d^2 - 3d^2) + 5d$", "note": "Group terms" },
          { "math": "$= -2d^2 + 5d$", "note": "Combine" }
        ]
      },
      {
        "q": "Simplify $8xy - 10 + yx + 3$.",
        "a": "$9xy - 7$",
        "solution": [
          { "math": "$8xy - 10 + yx + 3$" },
          { "math": "$= (8xy + xy) + (-10 + 3)$", "note": "Group terms" },
          { "math": "$= 9xy - 7$", "note": "Combine" }
        ]
      },
      {
        "q": "Simplify $-6a - 5b + 4a + 3b$.",
        "a": "$-2a - 2b$",
        "solution": [
          { "math": "$-6a - 5b + 4a + 3b$" },
          { "math": "$= (-6a + 4a) + (-5b + 3b)$", "note": "Group terms" },
          { "math": "$= -2a - 2b$", "note": "Combine" }
        ]
      }
    ],
    "mastery": [
      {
        "q": "Simplify $15l + 2 - 3l + 7c - 12c + 6$.",
        "a": "$12l - 5c + 8$",
        "solution": [
          { "math": "$15l + 2 - 3l + 7c - 12c + 6$" },
          { "math": "$= (15l - 3l) + (7c - 12c) + (2 + 6)$", "note": "Group terms" },
          { "math": "$= 12l - 5c + 8$", "note": "Combine" }
        ]
      },
      {
        "q": "Simplify $7e + e^2 + 3 - e^2 - 5e + 6 + 6a$.",
        "a": "$2e + 6a + 9$",
        "solution": [
          { "math": "$7e + e^2 + 3 - e^2 - 5e + 6 + 6a$" },
          { "math": "$= (7e - 5e) + (e^2 - e^2) + 6a + (3 + 6)$", "note": "Group terms" },
          { "math": "$= 2e + 0 + 6a + 9$", "note": "Combine" },
          { "math": "$= 2e + 6a + 9$", "note": "Leave unlike" }
        ]
      },
      {
        "q": "Simplify $ac + 2pa - 6a + 7 - 5ap + 9ac + 12$.",
        "a": "$10ac - 3ap - 6a + 19$",
        "solution": [
          { "math": "$ac + 2pa - 6a + 7 - 5ap + 9ac + 12$" },
          { "math": "$= (ac + 9ac) + (2ap - 5ap) - 6a + (7 + 12)$", "note": "Group terms" },
          { "math": "$= 10ac - 3ap - 6a + 19$", "note": "Combine" }
        ]
      }
    ]
  }
}
