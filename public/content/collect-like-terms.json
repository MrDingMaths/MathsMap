{
  "skillId": "collect-like-terms",
  "atomType": "R",
  "theory": {
    "intro": "Collecting like terms simplifies an expression by adding and subtracting the terms that are alike — the ones with the same variables raised to the same powers.",
    "facts": [
      "Only **like terms** can be combined: they must have the **same variables** with the **same powers**.",
      "To combine like terms, add or subtract their **coefficients**; the variable part stays the same, e.g. $5a - 3a = 2a$.",
      "Keep the **sign in front** of each term when you move it — treat a subtraction as a negative term.",
      "Plain numbers (**constant terms**) are like terms with each other.",
      "Variable order does not matter, so $xy$ and $yx$ are like terms.",
      "Terms that are **not alike** cannot be combined — leave them as they are. An expression with no remaining like terms is fully simplified."
    ],
    "steps": [
      "Identify the like terms.",
      "Group like terms.",
      "Combine coefficients.",
      "Leave unlike terms."
    ]
  },
  "practice": {
    "foundation": [
      {
        "question_text": "Simplify $5a - 3a$.",
        "solution_text": "$5a - 3a$\n$= 2a$"
      },
      {
        "question_text": "Simplify $3a + 6 + 5a$.",
        "solution_text": "$3a + 6 + 5a$\n$= (3a + 5a) + 6$\n$= 8a + 6$"
      },
      {
        "question_text": "Simplify $6a + 5b - a - b$.",
        "solution_text": "$6a + 5b - a - b$\n$= (6a - a) + (5b - b)$\n$= 5a + 4b$"
      },
      {
        "question_text": "Simplify $2xy + yx$.",
        "solution_text": "$2xy + yx$\n$= 2xy + xy$\n$= 3xy$"
      },
      {
        "question_text": "Simplify $4x - 5x$.",
        "solution_text": "$4x - 5x$\n$= -x$"
      }
    ],
    "development": [
      {
        "question_text": "Simplify $7 + 10 - 5m$.",
        "solution_text": "$7 + 10 - 5m$\n$= (7 + 10) - 5m$\n$= 17 - 5m$"
      },
      {
        "question_text": "Simplify $6a - 5b - 4a - 3b$.",
        "solution_text": "$6a - 5b - 4a - 3b$\n$= (6a - 4a) + (-5b - 3b)$\n$= 2a - 8b$"
      },
      {
        "question_text": "Simplify $d^2 + 5d - 3d^2$.",
        "solution_text": "$d^2 + 5d - 3d^2$\n$= (d^2 - 3d^2) + 5d$\n$= -2d^2 + 5d$"
      },
      {
        "question_text": "Simplify $8xy - 10 + yx + 3$.",
        "solution_text": "$8xy - 10 + yx + 3$\n$= (8xy + xy) + (-10 + 3)$\n$= 9xy - 7$"
      },
      {
        "question_text": "Simplify $-6a - 5b + 4a + 3b$.",
        "solution_text": "$-6a - 5b + 4a + 3b$\n$= (-6a + 4a) + (-5b + 3b)$\n$= -2a - 2b$"
      }
    ],
    "mastery": [
      {
        "question_text": "Simplify $15l + 2 - 3l + 7c - 12c + 6$.",
        "solution_text": "$15l + 2 - 3l + 7c - 12c + 6$\n$= (15l - 3l) + (7c - 12c) + (2 + 6)$\n$= 12l - 5c + 8$"
      },
      {
        "question_text": "Simplify $7e + e^2 + 3 - e^2 - 5e + 6 + 6a$.",
        "solution_text": "$7e + e^2 + 3 - e^2 - 5e + 6 + 6a$\n$= (7e - 5e) + (e^2 - e^2) + 6a + (3 + 6)$\n$= 2e + 0 + 6a + 9$\n$= 2e + 6a + 9$"
      },
      {
        "question_text": "Simplify $ac + 2pa - 6a + 7 - 5ap + 9ac + 12$.",
        "solution_text": "$ac + 2pa - 6a + 7 - 5ap + 9ac + 12$\n$= (ac + 9ac) + (2ap - 5ap) - 6a + (7 + 12)$\n$= 10ac - 3ap - 6a + 19$"
      }
    ]
  }
}
