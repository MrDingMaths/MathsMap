{
  "skillId": "compare-order-fractions",
  "atomType": "R",
  "theory": {
    "intro": "To compare or order fractions with unrelated denominators, rewrite them with a **common denominator** — the lowest common multiple of the denominators — then compare the numerators.",
    "facts": [
      "Fractions can only be compared directly when they share the same denominator.",
      "The **lowest common denominator (LCD)** is the LCM of the denominators.",
      "With equal denominators, the fraction with the larger numerator is larger: $\\frac{9}{12} < \\frac{10}{12}$."
    ],
    "steps": [
      "Find the lowest common denominator (the LCM of the denominators).",
      "Rewrite each fraction with that denominator using equivalence.",
      "Compare the numerators."
    ]
  },
  "practice": {
