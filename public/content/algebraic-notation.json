{
  "skillId": "algebraic-notation",
  "atomType": "T",
  "theory": {
    "intro": "Algebra uses a set of agreed conventions to write expressions concisely — dropping the $\\times$ sign, showing division as a fraction, and writing repeated multiplication as a power.",
    "facts": [
      "**Drop the $\\times$ sign** when multiplying: $3 \\times x = 3x$ and $a \\times b = ab$.",
      "**Write the number first**, then the pronumerals: $x \\times 6 = 6x$.",
      "**Hide a coefficient of $1$ or $-1$**: $1 \\times x = x$ and $-1 \\times x = -x$.",
      "**Repeated multiplication** of the same pronumeral becomes a power: $x \\times x = x^2$ and $x \\times x \\times x = x^3$.",
      "**Show division as a fraction**: $x \\div 3 = \\frac{x}{3}$ and $7 \\div a = \\frac{7}{a}$."
    ],
    "steps": [
      "Drop the $\\times$ sign.",
      "Number first.",
      "Hide the 1.",
      "Repeats to powers.",
      "Division to fraction."
    ]
  },
  "practice": {
    "foundation": [
      {
        "q": "Write $4 \\times m$ using algebraic conventions.",
        "a": "$4m$",
        "solution": [
          { "math": "$4 \\times m$" },
          { "math": "$= 4m$", "note": "Drop ×" }
        ]
      },
      {
        "q": "Write $h \\times z$ using algebraic conventions.",
        "a": "$hz$",
        "solution": [
          { "math": "$h \\times z$" },
          { "math": "$= hz$", "note": "Drop ×" }
        ]
      },
      {
        "q": "Write $t \\times 3$ using algebraic conventions.",
        "a": "$3t$",
        "solution": [
          { "math": "$t \\times 3$" },
          { "math": "$= 3t$", "note": "Number first" }
        ]
      },
      {
        "q": "Write $-1 \\times y$ using algebraic conventions.",
        "a": "$-y$",
        "solution": [
          { "math": "$-1 \\times y$" },
          { "math": "$= -y$", "note": "Hide the 1" }
        ]
      },
      {
        "q": "Write $w \\times w$ using algebraic conventions.",
        "a": "$w^2$",
        "solution": [
          { "math": "$w \\times w$" },
          { "math": "$= w^2$", "note": "To power" }
        ]
      },
      {
        "q": "Write $x \\div 3$ using algebraic conventions.",
        "a": "$\\frac{x}{3}$",
        "solution": [
          { "math": "$x \\div 3$" },
          { "math": "$= \\frac{x}{3}$", "note": "To fraction" }
        ]
      }
    ],
    "development": [
      {
        "q": "Write $x \\times 5 \\times y$ using algebraic conventions.",
        "a": "$5xy$",
        "solution": [
          { "math": "$x \\times 5 \\times y$" },
          { "math": "$= 5xy$", "note": "Number first" }
        ]
      },
      {
        "q": "Write $y \\times 6 \\times y$ using algebraic conventions.",
        "a": "$6y^2$",
        "solution": [
          { "math": "$y \\times 6 \\times y$" },
          { "math": "$= 6y \\times y$", "note": "Number first" },
          { "math": "$= 6y^2$", "note": "To power" }
        ]
      },
      {
        "q": "Write $2x \\div 13$ using algebraic conventions.",
        "a": "$\\frac{2x}{13}$",
        "solution": [
          { "math": "$2x \\div 13$" },
          { "math": "$= \\frac{2x}{13}$", "note": "To fraction" }
        ]
      },
      {
        "q": "Write $3abc$ in full, showing every multiplication sign.",
        "a": "$3 \\times a \\times b \\times c$",
        "solution": [
          { "math": "$3abc$" },
          { "math": "$= 3 \\times a \\times b \\times c$", "note": "Insert ×" }
        ]
      },
      {
        "q": "Write $v^2$ in full, showing the multiplication sign.",
        "a": "$v \\times v$",
        "solution": [
