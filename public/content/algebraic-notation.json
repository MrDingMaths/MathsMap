          { "math": "$= 7 \\times x \\times x \\times y$", "note": "Number first" },
          { "math": "$= 7x^2y$", "note": "To power" }
        ]
      },
      {
        "q": "Write $a \\times b \\times a \\times a$ using algebraic conventions.",
        "a": "$a^3b$",
        "solution": [
          { "math": "$a \\times b \\times a \\times a$" },
          { "math": "$= a \\times a \\times a \\times b$", "note": "Group repeats" },
          { "math": "$= a^3b$", "note": "To power" }
        ]
      },
      {
        "q": "Write $c \\times c \\div 4$ using algebraic conventions.",
        "a": "$\\frac{c^2}{4}$",
        "solution": [
