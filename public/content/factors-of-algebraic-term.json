{
  "skillId": "factors-of-algebraic-term",
  "atomType": "R",
  "theory": {
    "intro": "A **factor** of an algebraic term is any number or expression that divides into it exactly. A term's factors combine the factors of its **number part** with the factors of its **pronumeral part**.",
    "facts": [
      "$1$ and the term itself are always factors.",
      "List the factors of the **coefficient** (e.g. factors of $6$ are $1, 2, 3, 6$).",
      "List the pronumeral parts that divide the term (for $ab$: $1, a, b, ab$; for $x^2$: $1, x, x^2$).",
      "Every factor is a **numerical factor** multiplied by a **pronumeral factor**."
    ],
    "steps": [
      "Factor the number part.",
      "Factor the pronumeral part.",
      "Combine each pair.",
      "List all factors."
    ]
  },
  "practice": {
    "foundation": [
      {
        "q": "List all the factors of $ab$.",
        "a": "$1, a, b, ab$",
        "solution": [
          { "math": "$ab = a \\times b$" },
          { "math": "$1, a, b, ab$", "note": "All factors" }
        ]
      },
      {
        "q": "List all the factors of $3y$.",
        "a": "$1, 3, y, 3y$",
        "solution": [
          { "math": "$3y = 3 \\times y$" },
          { "math": "Numbers: $1, 3$", "note": "Factor 3" },
          { "math": "$1, 3, y, 3y$", "note": "Times $y$" }
        ]
      },
      {
        "q": "List all the factors of $x^2$.",
        "a": "$1, x, x^2$",
        "solution": [
          { "math": "$x^2 = x \\times x$" },
          { "math": "$1, x, x^2$", "note": "All factors" }
        ]
      },
      {
        "q": "List all the factors of $5x$.",
        "a": "$1, 5, x, 5x$",
        "solution": [
          { "math": "$5x = 5 \\times x$" },
          { "math": "Numbers: $1, 5$", "note": "Factor 5" },
          { "math": "$1, 5, x, 5x$", "note": "Times $x$" }
        ]
      },
      {
        "q": "Is $x$ a factor of $5x$?",
        "a": "Yes",
        "solution": [
          { "math": "$5x = 5 \\times x$" },
          { "math": "$5x \\div x = 5$", "note": "Divides exactly" },
          { "math": "Yes", "note": "It is a factor" }
        ]
      }
    ],
    "development": [
      {
        "q": "List all the factors of $6x$.",
        "a": "$1, 2, 3, 6, x, 2x, 3x, 6x$",
        "solution": [
          { "math": "$6x = 6 \\times x$" },
          { "math": "Numbers: $1, 2, 3, 6$", "note": "Factor 6" },
          { "math": "$1, 2, 3, 6, x, 2x, 3x, 6x$", "note": "Times $x$" }
        ]
      },
      {
        "q": "List all the factors of $4y$.",
        "a": "$1, 2, 4, y, 2y, 4y$",
        "solution": [
          { "math": "$4y = 4 \\times y$" },
          { "math": "Numbers: $1, 2, 4$", "note": "Factor 4" },
          { "math": "$1, 2, 4, y, 2y, 4y$", "note": "Times $y$" }
        ]
      },
      {
        "q": "List all the factors of $3x^2$.",
        "a": "$1, 3, x, 3x, x^2, 3x^2$",
        "solution": [
          { "math": "$3x^2 = 3 \\times x \\times x$" },
          { "math": "Numbers: $1, 3$", "note": "Factor 3" },
          { "math": "Powers of $x$: $1, x, x^2$", "note": "Factor $x^2$" },
          { "math": "$1, 3, x, 3x, x^2, 3x^2$", "note": "Combine" }
        ]
      },
      {
        "q": "List all the factors of $2xy$.",
        "a": "$1, 2, x, 2x, y, 2y, xy, 2xy$",
        "solution": [
          { "math": "$2xy = 2 \\times x \\times y$" },
          { "math": "Numbers: $1, 2$", "note": "Factor 2" },
          { "math": "Letters: $1, x, y, xy$", "note": "Factor $xy$" },
          { "math": "$1, 2, x, 2x, y, 2y, xy, 2xy$", "note": "Combine" }
        ]
      },
      {
        "q": "Is $4$ a factor of $6x$?",
        "a": "No",
        "solution": [
          { "math": "$6x = 6 \\times x$" },
          { "math": "Factors of $6$: $1, 2, 3, 6$", "note": "Factor 6" },
          { "math": "$4$ is not in the list", "note": "Not a factor" },
          { "math": "No", "note": "Answer" }
        ]
      }
    ],
    "mastery": [
      {
        "q": "List all the factors of $6ab$.",
        "a": "$1, 2, 3, 6, a, 2a, 3a, 6a, b, 2b, 3b, 6b, ab, 2ab, 3ab, 6ab$",
        "solution": [
          { "math": "$6ab = 6 \\times a \\times b$" },
          { "math": "Numbers: $1, 2, 3, 6$", "note": "Factor 6" },
          { "math": "Letters: $1, a, b, ab$", "note": "Factor $ab$" },
          { "math": "$1, 2, 3, 6, a, 2a, 3a, 6a, b, 2b, 3b, 6b, ab, 2ab, 3ab, 6ab$", "note": "Combine all" }
        ]
      },
      {
        "q": "List all the factors of $4x^2$.",
        "a": "$1, 2, 4, x, 2x, 4x, x^2, 2x^2, 4x^2$",
        "solution": [
          { "math": "$4x^2 = 4 \\times x \\times x$" },
          { "math": "Numbers: $1, 2, 4$", "note": "Factor 4" },
          { "math": "Powers of $x$: $1, x, x^2$", "note": "Factor $x^2$" },
          { "math": "$1, 2, 4, x, 2x, 4x, x^2, 2x^2, 4x^2$", "note": "Combine" }
        ]
      },
      {
        "q": "Is $2x^2$ a factor of $6x$?",
        "a": "No",
        "solution": [
          { "math": "$6x = 2 \\times 3 \\times x$" },
          { "math": "$6x$ has only one $x$", "note": "Check powers" },
          { "math": "$2x^2$ needs $x \\times x$", "note": "Too many $x$" },
          { "math": "No", "note": "Answer" }
        ]
      }
    ]
  }
}
