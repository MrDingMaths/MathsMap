  "theory": {
    "intro": "To multiply or divide integers, work out the sign and the size separately, then put them together.",
    "facts": [
      "Same signs $\\rightarrow$ positive; different signs $\\rightarrow$ negative.",
      "The size is the usual multiplication or division of the numbers, ignoring their signs.",
      "A run of multiplications and divisions has equal priority, so work it from left to right."
    ],
    "steps": [
      "Determine the sign of the answer (same signs give positive, different signs give negative).",
      "Multiply or divide the magnitudes, ignoring the signs.",
      "Write the answer with its sign."
    ]
  },
