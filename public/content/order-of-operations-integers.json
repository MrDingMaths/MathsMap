        "solution_text": "$2+3\\times(-3)$\n$=2+(-9)$\n$=-7$"
      },
      {
        "question_text": "Evaluate $10-2\\times(-3)$.",
        "solution_text": "$10-2\\times(-3)$\n$=10-(-6)$\n$=16$"
      },
      {
        "question_text": "Evaluate $11+10\\div(-2)$.",
        "solution_text": "$11+10\\div(-2)$\n$=11+(-5)$\n$=6$"
      },
      {
        "question_text": "Evaluate $-7\\times(3-5)$.",
        "solution_text": "$-7\\times(3-5)$\n$=-7\\times(-2)$\n$=14$"
      },
      {
        "question_text": "Evaluate $(-3)^2\\times 4$.",
        "solution_text": "$(-3)^2\\times 4$\n$=9\\times 4$\n$=36$"
      },
      {
        "question_text": "Evaluate $-4\\times 3\\div(-6)$.",
        "solution_text": "$-4\\times 3\\div(-6)$\n$=-12\\div(-6)$\n$=2$"
      },
      {
        "question_text": "Evaluate $4\\times(-2)+3\\times 5$.",
        "solution_text": "$4\\times(-2)+3\\times 5$\n$=-8+15$\n$=7$"
      },
      {
        "question_text": "Evaluate $-6-3\\times 5$.",
        "solution_text": "$-6-3\\times 5$\n$=-6-15$\n$=-21$"
      }
