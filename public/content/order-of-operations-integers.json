{
  "skillId": "order-of-operations-integers",
  "atomType": "R",
  "theory": {
    "intro": "Follow the usual order of operations, but keep careful track of every sign as you work through the steps.",
    "facts": [
      "Work **brackets** first, then any **powers**, then **multiplication and division** (left to right), then **addition and subtraction** (left to right).",
      "Decide each sign as you go: same signs multiply or divide to a **positive**, different signs to a **negative**.",
      "A minus sign can mean *negative* or *subtract* — read each one carefully before applying the order."
    ],
    "steps": [
      "Evaluate anything inside brackets (and any powers) first.",
      "Do all $\\times$ and $\\div$ from left to right.",
      "Do all $+$ and $-$ from left to right."
    ]
  },
  "practice": {
    "foundation": [
      {
