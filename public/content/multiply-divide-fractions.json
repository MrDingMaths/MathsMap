  "atomType": "R",
  "theory": {
    "intro": "To multiply fractions, multiply the numerators and multiply the denominators. To divide by a fraction, multiply by its reciprocal. Convert whole and mixed numbers to improper fractions before you start.",
    "facts": [
      "Multiplying: $\\frac{a}{b}\\times\\frac{c}{d}=\\frac{a\\times c}{b\\times d}$.",
      "Dividing: $\\frac{a}{b}\\div\\frac{c}{d}=\\frac{a}{b}\\times\\frac{d}{c}$ — multiply by the reciprocal of the divisor.",
      "The word 'of' means multiply.",
      "A whole number $c$ can be written as $\\frac{c}{1}$; a mixed number is converted with $a\\frac{b}{n}=\\frac{a\\times n+b}{n}$."
    ],
    "steps": [
      "Convert whole and mixed numbers to improper fractions.",
      "To divide, replace $\\div$ with $\\times$ and use the reciprocal of the divisor.",
      "Multiply the numerators and multiply the denominators.",
      "Simplify, writing the answer as a mixed number if appropriate."
    ]
  },
