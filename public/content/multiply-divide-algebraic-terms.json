{
  "skillId": "multiply-divide-algebraic-terms",
  "atomType": "R",
  "theory": {
    "intro": "To multiply or divide algebraic terms, deal with the numbers and the pronumerals separately: multiply (or cancel) the numbers, then multiply (or cancel) the letters.",
    "facts": [
      "A simplified answer has no $\\times$ or $\\div$ sign: write $3 \\times a$ as $3a$ and $a \\div 4$ as $\\frac{a}{4}$.",
      "To **multiply** terms, multiply the numbers together, then multiply the letters together: $3a \\times 4b = 12ab$.",
      "A letter multiplied by itself becomes a power: $x \\times x = x^2$.",
      "To **divide** terms, write the division as a fraction, then cancel any common factors from the top and bottom: $12ab \\div 4a = \\frac{12ab}{4a} = 3b$.",
      "Signs multiply and divide like numbers: a negative times a positive is negative."
    ],
    "steps": [
      "Multiply the numbers.",
      "Multiply the letters.",
      "Write division as a fraction.",
      "Cancel common factors."
    ]
  },
  "practice": {
    "foundation": [
      {
        "q": "Simplify $4a \\times 3b$.",
        "a": "$12ab$",
        "solution": [
          { "math": "$4a \\times 3b$" },
          { "math": "$= (4 \\times 3)(a \\times b)$", "note": "Group parts" },
          { "math": "$= 12ab$", "note": "Multiply" }
        ]
      },
      {
        "q": "Simplify $3a \\times 12$.",
        "a": "$36a$",
        "solution": [
          { "math": "$3a \\times 12$" },
          { "math": "$= (3 \\times 12)a$", "note": "Multiply numbers" },
          { "math": "$= 36a$", "note": "Keep letter" }
        ]
      },
      {
        "q": "Simplify $x \\times x$.",
        "a": "$x^2$",
        "solution": [
          { "math": "$x \\times x$" },
          { "math": "$= x^2$", "note": "Letter squared" }
        ]
      },
      {
        "q": "Simplify $15x \\div 5$.",
        "a": "$3x$",
        "solution": [
          { "math": "$15x \\div 5$" },
          { "math": "$= \\frac{15x}{5}$", "note": "As a fraction" },
          { "math": "$= 3x$", "note": "Cancel" }
        ]
      },
      {
        "q": "Simplify $\\frac{4ab}{2a}$.",
        "a": "$2b$",
        "solution": [
          { "math": "$\\frac{4ab}{2a}$" },
          { "math": "$= 2b$", "note": "Cancel $2$, $a$" }
        ]
      }
    ],
    "development": [
      {
        "q": "Simplify $4x \\times (-3y)$.",
        "a": "$-12xy$",
        "solution": [
          { "math": "$4x \\times (-3y)$" },
          { "math": "$= (4 \\times -3)(x \\times y)$", "note": "Multiply numbers" },
          { "math": "$= -12xy$", "note": "Signs" }
        ]
      },
      {
        "q": "Simplify $2x \\times 5x$.",
        "a": "$10x^2$",
        "solution": [
          { "math": "$2x \\times 5x$" },
          { "math": "$= (2 \\times 5)(x \\times x)$", "note": "Group parts" },
          { "math": "$= 10x^2$", "note": "Letter squared" }
        ]
      },
      {
        "q": "Simplify $20p \\div 15$.",
        "a": "$\\frac{4p}{3}$",
        "solution": [
          { "math": "$20p \\div 15$" },
          { "math": "$= \\frac{20p}{15}$", "note": "As a fraction" },
          { "math": "$= \\frac{4p}{3}$", "note": "Cancel $5$" }
        ]
      },
      {
        "q": "Simplify $\\frac{9ab}{4b}$.",
        "a": "$\\frac{9a}{4}$",
        "solution": [
          { "math": "$\\frac{9ab}{4b}$" },
          { "math": "$= \\frac{9a}{4}$", "note": "Cancel $b$" }
        ]
      },
      {
        "q": "Simplify $6x \\div 8xy$.",
        "a": "$\\frac{3}{4y}$",
        "solution": [
          { "math": "$6x \\div 8xy$" },
          { "math": "$= \\frac{6x}{8xy}$", "note": "As a fraction" },
          { "math": "$= \\frac{3}{4y}$", "note": "Cancel $2$, $x$" }
        ]
      }
    ],
    "mastery": [
      {
        "q": "Simplify $3ab \\times 8bc$.",
        "a": "$24ab^2c$",
        "solution": [
          { "math": "$3ab \\times 8bc$" },
          { "math": "$= (3 \\times 8)(a)(b \\times b)(c)$", "note": "Group parts" },
          { "math": "$= 24ab^2c$", "note": "$b \\times b = b^2$" }
        ]
      },
      {
        "q": "Simplify $-3x \\times 9x \\times 2xy$.",
        "a": "$-54x^3y$",
        "solution": [
          { "math": "$-3x \\times 9x \\times 2xy$" },
          { "math": "$= (-3 \\times 9 \\times 2)(x \\times x \\times x)(y)$", "note": "Group parts" },
          { "math": "$= -54x^3y$", "note": "Three $x$s" }
        ]
      },
      {
        "q": "Simplify $\\frac{2x^2}{6x}$.",
        "a": "$\\frac{x}{3}$",
        "solution": [
          { "math": "$\\frac{2x^2}{6x}$" },
          { "math": "$= \\frac{x^2}{3x}$", "note": "Cancel $2$" },
          { "math": "$= \\frac{x}{3}$", "note": "Cancel $x$" }
        ]
      }
    ]
  }
}
