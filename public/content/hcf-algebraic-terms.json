{
  "skillId": "hcf-algebraic-terms",
  "atomType": "R",
  "theory": {
    "intro": "The highest common factor (HCF) of two algebraic terms is the largest term that divides into both exactly. Find it by combining the HCF of the numbers with the variables common to both terms.",
    "facts": [
      "Find the **HCF of the coefficients** (the numbers in front) first.",
      "A variable belongs in the HCF only if it appears in **both** terms.",
      "For a shared variable raised to powers, take the **lower power** (e.g. $x^2$ and $x^5$ share $x^2$).",
      "Multiply the numerical HCF by every common variable part to get the HCF.",
      "If the coefficients share no factor, their HCF is $1$, but common variables are still kept."
    ],
    "steps": [
      "Numbers' HCF.",
      "Find common variables.",
      "Take lowest power.",
      "Multiply together."
    ]
  },
  "practice": {
    "foundation": [
      {
        "q": "Find the HCF of $6x$ and $9x$.",
        "a": "$3x$",
        "solution": [
          { "math": "$6x \\text{ and } 9x$" },
          { "math": "$\\text{HCF of } 6, 9 = 3$", "note": "Numbers' HCF" },
          { "math": "$x \\text{ in both}$", "note": "Common variable" },
          { "math": "$= 3x$", "note": "Multiply" }
        ]
      },
      {
        "q": "Find the HCF of $10x$ and $15$.",
        "a": "$5$",
        "solution": [
          { "math": "$10x \\text{ and } 15$" },
          { "math": "$\\text{HCF of } 10, 15 = 5$", "note": "Numbers' HCF" },
          { "math": "$x \\text{ is not in } 15$", "note": "Common variable" },
          { "math": "$= 5$", "note": "Multiply" }
        ]
      },
      {
        "q": "Find the HCF of $x^2$ and $x^5$.",
        "a": "$x^2$",
        "solution": [
          { "math": "$x^2 \\text{ and } x^5$" },
          { "math": "$\\text{take the lower power}$", "note": "Take lowest power" },
          { "math": "$= x^2$" }
        ]
      },
      {
        "q": "Find the HCF of $2xy$ and $8xy$.",
        "a": "$2xy$",
        "solution": [
          { "math": "$2xy \\text{ and } 8xy$" },
          { "math": "$\\text{HCF of } 2, 8 = 2$", "note": "Numbers' HCF" },
          { "math": "$x \\text{ and } y \\text{ in both}$", "note": "Common variables" },
          { "math": "$= 2xy$", "note": "Multiply" }
        ]
      },
      {
        "q": "Find the HCF of $7a$ and $13a$.",
        "a": "$a$",
        "solution": [
          { "math": "$7a \\text{ and } 13a$" },
          { "math": "$\\text{HCF of } 7, 13 = 1$", "note": "Numbers' HCF" },
          { "math": "$a \\text{ in both}$", "note": "Common variable" },
          { "math": "$= a$", "note": "Multiply" }
        ]
      }
    ],
    "development": [
      {
        "q": "Find the HCF of $25a$ and $15a$.",
        "a": "$5a$",
        "solution": [
          { "math": "$25a \\text{ and } 15a$" },
          { "math": "$\\text{HCF of } 25, 15 = 5$", "note": "Numbers' HCF" },
          { "math": "$a \\text{ in both}$", "note": "Common variable" },
          { "math": "$= 5a$", "note": "Multiply" }
        ]
      },
      {
        "q": "Find the HCF of $8x^2y$ and $12x^5y$.",
        "a": "$4x^2y$",
        "solution": [
          { "math": "$8x^2y \\text{ and } 12x^5y$" },
          { "math": "$\\text{HCF of } 8, 12 = 4$", "note": "Numbers' HCF" },
          { "math": "$x^2 \\text{ is the lower power}$", "note": "Take lowest power" },
          { "math": "$y \\text{ in both}$", "note": "Common variable" },
          { "math": "$= 4x^2y$", "note": "Multiply" }
        ]
      },
      {
        "q": "Find the HCF of $12qr$ and $8r^2$.",
        "a": "$4r$",
        "solution": [
          { "math": "$12qr \\text{ and } 8r^2$" },
          { "math": "$\\text{HCF of } 12, 8 = 4$", "note": "Numbers' HCF" },
          { "math": "$q \\text{ is not in both}$", "note": "Common variable" },
          { "math": "$r \\text{ has lower power } r^1$", "note": "Take lowest power" },
          { "math": "$= 4r$", "note": "Multiply" }
        ]
      },
      {
        "q": "Find the HCF of $6xy$ and $12x$.",
        "a": "$6x$",
        "solution": [
          { "math": "$6xy \\text{ and } 12x$" },
          { "math": "$\\text{HCF of } 6, 12 = 6$", "note": "Numbers' HCF" },
          { "math": "$x \\text{ in both, } y \\text{ is not}$", "note": "Common variable" },
          { "math": "$= 6x$", "note": "Multiply" }
        ]
      },
      {
        "q": "Find the HCF of $16a$ and $12b$.",
        "a": "$4$",
        "solution": [
          { "math": "$16a \\text{ and } 12b$" },
          { "math": "$\\text{HCF of } 16, 12 = 4$", "note": "Numbers' HCF" },
          { "math": "$\\text{no shared variable}$", "note": "Common variable" },
          { "math": "$= 4$", "note": "Multiply" }
        ]
      }
    ],
    "mastery": [
      {
        "q": "Find the HCF of $18a^3b^2c$ and $24a^2b^4$.",
        "a": "$6a^2b^2$",
        "solution": [
          { "math": "$18a^3b^2c \\text{ and } 24a^2b^4$" },
          { "math": "$\\text{HCF of } 18, 24 = 6$", "note": "Numbers' HCF" },
          { "math": "$a^2 \\text{ and } b^2 \\text{ are lower powers}$", "note": "Take lowest power" },
          { "math": "$c \\text{ is not in both}$", "note": "Common variable" },
          { "math": "$= 6a^2b^2$", "note": "Multiply" }
        ]
      },
      {
        "q": "Find the HCF of $15x^2y$ and $8x^3$.",
        "a": "$x^2$",
        "solution": [
          { "math": "$15x^2y \\text{ and } 8x^3$" },
          { "math": "$\\text{HCF of } 15, 8 = 1$", "note": "Numbers' HCF" },
          { "math": "$x^2 \\text{ is the lower power}$", "note": "Take lowest power" },
          { "math": "$y \\text{ is not in both}$", "note": "Common variable" },
          { "math": "$= x^2$", "note": "Multiply" }
        ]
      },
      {
        "q": "Find the HCF of $20p^2q^3$ and $30p^4q$.",
        "a": "$10p^2q$",
        "solution": [
          { "math": "$20p^2q^3 \\text{ and } 30p^4q$" },
          { "math": "$\\text{HCF of } 20, 30 = 10$", "note": "Numbers' HCF" },
          { "math": "$p^2 \\text{ and } q \\text{ are lower powers}$", "note": "Take lowest power" },
          { "math": "$= 10p^2q$", "note": "Multiply" }
        ]
      }
    ]
  }
}
