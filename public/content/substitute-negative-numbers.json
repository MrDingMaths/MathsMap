{
  "skillId": "substitute-negative-numbers",
  "atomType": "R",
  "theory": {
    "intro": "Substituting a negative value works just like any substitution, but you must wrap the value in brackets so its sign is handled correctly. The brackets keep the negative attached when you multiply, subtract or raise to a power.",
    "facts": [
      "**Always write a negative value in brackets** when you replace a pronumeral: $b = -2$ becomes $(-2)$.",
      "Brackets stop a negative sign being misread as subtraction, and keep the sign attached through the order of operations.",
      "**Subtracting a negative becomes adding:** $12 - 3(-5) = 12 + 15$.",
      "**Multiplying signs:** like signs give a positive, unlike signs give a negative.",
      "A negative to an **even** power is positive: $(-3)^2 = 9$. A negative to an **odd** power stays negative: $(-2)^3 = -8$."
    ],
    "steps": [
      "Bracket the value.",
      "Substitute in.",
      "Evaluate powers.",
      "Multiply and divide.",
      "Add and subtract."
    ]
  },
  "practice": {
    "foundation": [
      {
        "question_text": "Evaluate $x + 3$ for $x = -5$.",
        "solution_text": "$x + 3$\n$= (-5) + 3$\n$= -2$"
      },
      {
        "question_text": "Evaluate $2x$ for $x = -5$.",
        "solution_text": "$2x$\n$= 2(-5)$\n$= -10$"
      },
      {
        "question_text": "Evaluate $14 - x$ for $x = -5$.",
        "solution_text": "$14 - x$\n$= 14 - (-5)$\n$= 14 + 5$\n$= 19$"
      },
      {
        "question_text": "Evaluate $2b^2$ for $b = -3$.",
        "solution_text": "$2b^2$\n$= 2(-3)^2$\n$= 2(9)$\n$= 18$"
      },
      {
        "question_text": "Evaluate $a + b$ for $a = 6$ and $b = -2$.",
        "solution_text": "$a + b$\n$= 6 + (-2)$\n$= 4$"
      }
    ],
    "development": [
      {
        "question_text": "Evaluate $10 + 4b$ for $b = -2$.",
        "solution_text": "$10 + 4b$\n$= 10 + 4(-2)$\n$= 10 + (-8)$\n$= 2$"
      },
      {
        "question_text": "Evaluate $12 - 3b$ for $b = -5$.",
        "solution_text": "$12 - 3b$\n$= 12 - 3(-5)$\n$= 12 - (-15)$\n$= 12 + 15$\n$= 27$"
      },
      {
        "question_text": "Evaluate $a^2 - b$ for $a = -2$ and $b = 6$.",
        "solution_text": "$a^2 - b$\n$= (-2)^2 - 6$\n$= 4 - 6$\n$= -2$"
      },
      {
        "question_text": "Evaluate $6b - 7a$ for $a = 6$ and $b = -2$.",
        "solution_text": "$6b - 7a$\n$= 6(-2) - 7(6)$\n$= -12 - 42$\n$= -54$"
      },
      {
        "question_text": "Evaluate $2c + a$ for $a = -2$ and $c = -3$.",
        "solution_text": "$2c + a$\n$= 2(-3) + (-2)$\n$= -6 + (-2)$\n$= -8$"
      }
    ],
    "mastery": [
      {
        "question_text": "Evaluate $a^3 + c^2$ for $a = -2$ and $c = -3$.",
        "solution_text": "$a^3 + c^2$\n$= (-2)^3 + (-3)^2$\n$= -8 + 9$\n$= 1$"
      },
      {
        "question_text": "Evaluate $a^2 - b^2$ for $a = -2$ and $b = -3$.",
        "solution_text": "$a^2 - b^2$\n$= (-2)^2 - (-3)^2$\n$= 4 - 9$\n$= -5$"
      },
      {
        "question_text": "Evaluate $\\frac{2x + 7}{3}$ for $x = -4$.",
        "solution_text": "$\\frac{2x + 7}{3}$\n$= \\frac{2(-4) + 7}{3}$\n$= \\frac{-8 + 7}{3}$\n$= \\frac{-1}{3}$\n$= -\\frac{1}{3}$\n$-\\frac{1}{3}$"
      }
    ]
  }
}
