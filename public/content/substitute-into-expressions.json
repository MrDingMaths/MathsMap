{
  "skillId": "substitute-into-expressions",
  "atomType": "R",
  "theory": {
    "intro": "To **substitute** means to replace each pronumeral with a given number; to **evaluate** means to work out the result using the order of operations.",
    "facts": [
      "**Substitute** by replacing every pronumeral with its value, written in **brackets**: when $x = 3$, the expression $4x$ becomes $4(3)$.",
      "**Evaluate** using the order of operations — **powers**, then **× and ÷**, then **+ and −**.",
      "A power binds to the **pronumeral only**: $2x^2$ means $2 \\times x \\times x$, not $(2x)^2$.",
      "The same pronumeral takes the **same value** everywhere it appears."
    ],
    "steps": [
      "Substitute each value in brackets.",
      "Work out powers.",
      "Multiply and divide.",
      "Add and subtract."
    ]
  },
  "practice": {
    "foundation": [
      {
        "q": "Evaluate $3x$ when $x = 4$.",
        "a": "$12$",
        "solution": [
          { "math": "$3x$" },
          { "math": "$= 3(4)$", "note": "Substitute" },
          { "math": "$= 12$", "note": "Multiply" }
        ]
      },
      {
        "q": "Evaluate $x + 8$ when $x = 5$.",
        "a": "$13$",
        "solution": [
          { "math": "$x + 8$" },
          { "math": "$= (5) + 8$", "note": "Substitute" },
          { "math": "$= 13$", "note": "Add" }
        ]
      },
      {
        "q": "Evaluate $2x + 5$ when $x = 3$.",
        "a": "$11$",
        "solution": [
          { "math": "$2x + 5$" },
          { "math": "$= 2(3) + 5$", "note": "Substitute" },
          { "math": "$= 6 + 5$", "note": "Multiply" },
          { "math": "$= 11$", "note": "Add" }
        ]
      },
      {
        "q": "Evaluate $12 - 2x$ when $x = 4$.",
        "a": "$4$",
        "solution": [
          { "math": "$12 - 2x$" },
          { "math": "$= 12 - 2(4)$", "note": "Substitute" },
          { "math": "$= 12 - 8$", "note": "Multiply" },
          { "math": "$= 4$", "note": "Subtract" }
        ]
      },
      {
        "q": "Evaluate $\\frac{x}{3}$ when $x = 15$.",
        "a": "$5$",
        "solution": [
          { "math": "$\\frac{x}{3}$" },
          { "math": "$= \\frac{15}{3}$", "note": "Substitute" },
          { "math": "$= 5$", "note": "Divide" }
        ]
      }
    ],
    "development": [
      {
        "q": "Evaluate $3a + 2b$ when $a = 6$ and $b = 4$.",
        "a": "$26$",
        "solution": [
          { "math": "$3a + 2b$" },
          { "math": "$= 3(6) + 2(4)$", "note": "Substitute" },
          { "math": "$= 18 + 8$", "note": "Multiply" },
          { "math": "$= 26$", "note": "Add" }
        ]
      },
      {
        "q": "Evaluate $pq$ when $p = 6$ and $q = 4$.",
        "a": "$24$",
        "solution": [
          { "math": "$pq$" },
          { "math": "$= (6)(4)$", "note": "Substitute" },
          { "math": "$= 24$", "note": "Multiply" }
        ]
      },
      {
        "q": "Evaluate $x^2 + 3x$ when $x = 3$.",
        "a": "$18$",
        "solution": [
          { "math": "$x^2 + 3x$" },
          { "math": "$= (3)^2 + 3(3)$", "note": "Substitute" },
          { "math": "$= 9 + 9$", "note": "Powers" },
          { "math": "$= 18$", "note": "Add" }
        ]
      },
      {
        "q": "Evaluate $\\frac{5c - 7}{2}$ when $c = 3$.",
        "a": "$4$",
        "solution": [
          { "math": "$\\frac{5c - 7}{2}$" },
          { "math": "$= \\frac{5(3) - 7}{2}$", "note": "Substitute" },
          { "math": "$= \\frac{15 - 7}{2}$", "note": "Multiply" },
          { "math": "$= \\frac{8}{2}$", "note": "Subtract" },
          { "math": "$= 4$", "note": "Divide" }
        ]
      },
      {
        "q": "Evaluate $40 - 4x$ when $x = 8$.",
        "a": "$8$",
        "solution": [
          { "math": "$40 - 4x$" },
          { "math": "$= 40 - 4(8)$", "note": "Substitute" },
          { "math": "$= 40 - 32$", "note": "Multiply" },
          { "math": "$= 8$", "note": "Subtract" }
        ]
      }
    ],
    "mastery": [
      {
        "q": "Evaluate $2x^2$ when $x = 4$.",
        "a": "$32$",
        "solution": [
          { "math": "$2x^2$" },
          { "math": "$= 2(4)^2$", "note": "Substitute" },
          { "math": "$= 2(16)$", "note": "Powers" },
          { "math": "$= 32$", "note": "Multiply" }
        ]
      },
      {
        "q": "Evaluate $x^2 + 3x - 4$ when $x = 3$.",
        "a": "$14$",
        "solution": [
          { "math": "$x^2 + 3x - 4$" },
          { "math": "$= (3)^2 + 3(3) - 4$", "note": "Substitute" },
          { "math": "$= 9 + 9 - 4$", "note": "Powers" },
          { "math": "$= 14$", "note": "Evaluate" }
        ]
      },
      {
        "q": "Evaluate $2d - 3e - 4f$ when $d = 2$, $e = 3$ and $f = \\frac{1}{2}$.",
        "a": "$-7$",
        "solution": [
          { "math": "$2d - 3e - 4f$" },
          { "math": "$= 2(2) - 3(3) - 4(\\frac{1}{2})$", "note": "Substitute" },
          { "math": "$= 4 - 9 - 2$", "note": "Multiply" },
          { "math": "$= -7$", "note": "Subtract" }
        ]
      }
    ]
  }
}
