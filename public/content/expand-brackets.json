{
  "skillId": "expand-brackets",
  "atomType": "R",
  "theory": {
    "intro": "Expanding brackets means rewriting a product such as $a(b+c)$ without grouping symbols, by multiplying each term inside the bracket by the term outside. This is the distributive law.",
    "facts": [
      "The **distributive law**: $a(b+c) = ab + ac$ — the outside term multiplies **every** term inside.",
      "Keep the sign in front of each inside term: $a(b-c) = ab - ac$.",
      "A letter multiplied by itself becomes a power: $x \\times x = x^2$.",
      "Once the bracket is expanded, **collect any like terms** to write the answer in simplest form."
    ],
    "steps": [
      "Multiply each term.",
      "Keep each sign.",
      "Collect like terms."
    ]
  },
  "practice": {
    "foundation": [
      {
        "q": "Expand $6(y+8)$.",
        "a": "$6y+48$",
        "solution": [
          { "math": "$6(y+8)$" },
          { "math": "$= 6(y) + 6(8)$", "note": "Multiply each" },
          { "math": "$= 6y+48$", "note": "Simplify" }
        ]
      },
      {
        "q": "Expand $5(x-3)$.",
        "a": "$5x-15$",
        "solution": [
          { "math": "$5(x-3)$" },
          { "math": "$= 5(x) - 5(3)$", "note": "Keep each sign" },
          { "math": "$= 5x-15$", "note": "Simplify" }
        ]
      },
      {
        "q": "Expand $4(3a+2)$.",
        "a": "$12a+8$",
        "solution": [
          { "math": "$4(3a+2)$" },
          { "math": "$= 4(3a) + 4(2)$", "note": "Multiply each" },
          { "math": "$= 12a+8$", "note": "Simplify" }
        ]
      },
      {
        "q": "Expand $7(q-7)$.",
        "a": "$7q-49$",
        "solution": [
          { "math": "$7(q-7)$" },
          { "math": "$= 7(q) - 7(7)$", "note": "Keep each sign" },
          { "math": "$= 7q-49$", "note": "Simplify" }
        ]
      },
      {
        "q": "Expand $x(y+3)$.",
        "a": "$xy+3x$",
        "solution": [
          { "math": "$x(y+3)$" },
          { "math": "$= x(y) + x(3)$", "note": "Multiply each" },
          { "math": "$= xy+3x$", "note": "Simplify" }
        ]
      }
    ],
    "development": [
      {
        "q": "Expand $2x(3x+4)$.",
        "a": "$6x^2+8x$",
        "solution": [
          { "math": "$2x(3x+4)$" },
          { "math": "$= 2x(3x) + 2x(4)$", "note": "Multiply each" },
          { "math": "$= 6x^2+8x$", "note": "$x \\times x = x^2$" }
        ]
      },
      {
        "q": "Expand $x(x-5)$.",
        "a": "$x^2-5x$",
        "solution": [
          { "math": "$x(x-5)$" },
          { "math": "$= x(x) - x(5)$", "note": "Keep each sign" },
          { "math": "$= x^2-5x$", "note": "$x \\times x = x^2$" }
        ]
      },
      {
        "q": "Expand $2(a+3b+4)$.",
        "a": "$2a+6b+8$",
        "solution": [
          { "math": "$2(a+3b+4)$" },
          { "math": "$= 2(a) + 2(3b) + 2(4)$", "note": "Multiply each" },
          { "math": "$= 2a+6b+8$", "note": "Simplify" }
        ]
      },
      {
        "q": "Expand $5a(2x+3)$.",
        "a": "$10ax+15a$",
        "solution": [
          { "math": "$5a(2x+3)$" },
          { "math": "$= 5a(2x) + 5a(3)$", "note": "Multiply each" },
          { "math": "$= 10ax+15a$", "note": "Simplify" }
        ]
      },
      {
        "q": "Expand and simplify $2(x+1)+3(x+4)$.",
        "a": "$5x+14$",
        "solution": [
          { "math": "$2(x+1)+3(x+4)$" },
          { "math": "$= 2x+2 + 3x+12$", "note": "Multiply each" },
          { "math": "$= 5x+14$", "note": "Collect like terms" }
        ]
      }
    ],
    "mastery": [
      {
        "q": "Expand and simplify $4(2x+3)+3(x-2)$.",
        "a": "$11x+6$",
        "solution": [
          { "math": "$4(2x+3)+3(x-2)$" },
          { "math": "$= 8x+12 + 3x-6$", "note": "Keep each sign" },
          { "math": "$= 11x+6$", "note": "Collect like terms" }
        ]
      },
      {
        "q": "Expand $2xy(3x-2y)$.",
        "a": "$6x^2y-4xy^2$",
        "solution": [
          { "math": "$2xy(3x-2y)$" },
          { "math": "$= 2xy(3x) - 2xy(2y)$", "note": "Keep each sign" },
          { "math": "$= 6x^2y-4xy^2$", "note": "$x \\times x = x^2$" }
        ]
      },
      {
        "q": "Expand $3a(2a+5b+1)$.",
        "a": "$6a^2+15ab+3a$",
        "solution": [
          { "math": "$3a(2a+5b+1)$" },
          { "math": "$= 3a(2a) + 3a(5b) + 3a(1)$", "note": "Multiply each" },
          { "math": "$= 6a^2+15ab+3a$", "note": "$a \\times a = a^2$" }
        ]
      }
    ]
  }
}
