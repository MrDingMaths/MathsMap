{
  "skillId": "expand-brackets",
  "atomType": "R",
  "theory": {
    "intro": "Expanding brackets means rewriting a product such as $a(b+c)$ without grouping symbols, by multiplying each term inside the bracket by the term outside. This is the distributive law.",
    "facts": [
      "The **distributive law**: $a(b+c) = ab + ac$ — the outside term multiplies **every** term inside.",
      "Keep the sign in front of each inside term: $a(b-c) = ab - ac$.",
      "A letter multiplied by itself becomes a power: $x \\times x = x^2$.",
      "Once the bracket is expanded, **collect any like terms** to write the answer in simplest form."
    ],
    "steps": [
      "Multiply each term.",
      "Keep each sign.",
      "Collect like terms."
    ]
  },
  "practice": {
    "foundation": [
      {
        "question_text": "Expand $6(y+8)$.",
        "solution_text": "$6(y+8)$\n$= 6(y) + 6(8)$\n$= 6y+48$"
      },
      {
        "question_text": "Expand $5(x-3)$.",
        "solution_text": "$5(x-3)$\n$= 5(x) - 5(3)$\n$= 5x-15$"
      },
      {
        "question_text": "Expand $4(3a+2)$.",
        "solution_text": "$4(3a+2)$\n$= 4(3a) + 4(2)$\n$= 12a+8$"
      },
      {
        "question_text": "Expand $7(q-7)$.",
        "solution_text": "$7(q-7)$\n$= 7(q) - 7(7)$\n$= 7q-49$"
      },
      {
        "question_text": "Expand $x(y+3)$.",
        "solution_text": "$x(y+3)$\n$= x(y) + x(3)$\n$= xy+3x$"
      }
    ],
    "development": [
      {
        "question_text": "Expand $2x(3x+4)$.",
        "solution_text": "$2x(3x+4)$\n$= 2x(3x) + 2x(4)$\n$= 6x^2+8x$"
      },
      {
        "question_text": "Expand $x(x-5)$.",
        "solution_text": "$x(x-5)$\n$= x(x) - x(5)$\n$= x^2-5x$"
      },
      {
        "question_text": "Expand $2(a+3b+4)$.",
        "solution_text": "$2(a+3b+4)$\n$= 2(a) + 2(3b) + 2(4)$\n$= 2a+6b+8$"
      },
      {
        "question_text": "Expand $5a(2x+3)$.",
        "solution_text": "$5a(2x+3)$\n$= 5a(2x) + 5a(3)$\n$= 10ax+15a$"
      },
      {
        "question_text": "Expand and simplify $2(x+1)+3(x+4)$.",
        "solution_text": "$2(x+1)+3(x+4)$\n$= 2x+2 + 3x+12$\n$= 5x+14$"
      }
    ],
    "mastery": [
      {
        "question_text": "Expand and simplify $4(2x+3)+3(x-2)$.",
        "solution_text": "$4(2x+3)+3(x-2)$\n$= 8x+12 + 3x-6$\n$= 11x+6$"
      },
      {
        "question_text": "Expand $2xy(3x-2y)$.",
        "solution_text": "$2xy(3x-2y)$\n$= 2xy(3x) - 2xy(2y)$\n$= 6x^2y-4xy^2$"
      },
      {
        "question_text": "Expand $3a(2a+5b+1)$.",
        "solution_text": "$3a(2a+5b+1)$\n$= 3a(2a) + 3a(5b) + 3a(1)$\n$= 6a^2+15ab+3a$"
      }
    ]
  }
}
