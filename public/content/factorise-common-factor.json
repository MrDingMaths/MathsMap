{
  "skillId": "factorise-common-factor",
  "atomType": "R",
  "theory": {
    "intro": "Factorising is the reverse of expanding: it rewrites a sum of terms as the highest common factor (HCF) multiplied by a bracket.",
    "facts": [
      "Factorising is the **inverse** of expanding: $3(2x+5)=6x+15$ expands, and $6x+15=3(2x+5)$ factorises.",
      "The **highest common factor (HCF)** of all the terms is written **outside** the brackets.",
      "Divide each term by the HCF; the results go **inside** the brackets.",
      "When a term equals the HCF, dividing leaves a $1$ inside the brackets: $3p^2+3p=3p(p+1)$.",
      "**Fully factorised** means the terms left inside the brackets share **no** further common factor.",
      "**Check by expanding**: multiply back out and confirm you get the original expression."
    ],
    "steps": [
      "Find the HCF.",
      "Write it outside.",
      "Divide each term.",
      "Write results inside.",
      "Check by expanding."
    ]
  },
  "practice": {
    "foundation": [
      {
        "q": "Factorise $4x+6$.",
        "a": "$2(2x+3)$",
        "solution": [
          { "math": "$4x+6$" },
          { "math": "$= 2\\left(\\frac{4x}{2}+\\frac{6}{2}\\right)$", "note": "Divide by HCF" },
          { "math": "$= 2(2x+3)$", "note": "Simplify" }
        ]
      },
      {
        "q": "Factorise $9y+12$.",
        "a": "$3(3y+4)$",
        "solution": [
          { "math": "$9y+12$" },
          { "math": "$= 3\\left(\\frac{9y}{3}+\\frac{12}{3}\\right)$", "note": "Divide by HCF" },
          { "math": "$= 3(3y+4)$", "note": "Simplify" }
        ]
      },
      {
        "q": "Factorise $15a-10$.",
        "a": "$5(3a-2)$",
        "solution": [
          { "math": "$15a-10$" },
          { "math": "$= 5\\left(\\frac{15a}{5}-\\frac{10}{5}\\right)$", "note": "Divide by HCF" },
          { "math": "$= 5(3a-2)$", "note": "Simplify" }
        ]
      },
      {
        "q": "Factorise $6x+xy$.",
        "a": "$x(6+y)$",
        "solution": [
          { "math": "$6x+xy$" },
          { "math": "$= x\\left(\\frac{6x}{x}+\\frac{xy}{x}\\right)$", "note": "Divide by HCF" },
          { "math": "$= x(6+y)$", "note": "Simplify" }
        ]
      },
      {
        "q": "Factorise $y^2-12y$.",
        "a": "$y(y-12)$",
        "solution": [
          { "math": "$y^2-12y$" },
          { "math": "$= y\\left(\\frac{y^2}{y}-\\frac{12y}{y}\\right)$", "note": "Divide by HCF" },
          { "math": "$= y(y-12)$", "note": "Simplify" }
        ]
      }
    ],
    "development": [
      {
        "q": "Factorise $8xy+12y$.",
        "a": "$4y(2x+3)$",
        "solution": [
          { "math": "$8xy+12y$" },
          { "math": "$= 4y\\left(\\frac{8xy}{4y}+\\frac{12y}{4y}\\right)$", "note": "Divide by HCF" },
          { "math": "$= 4y(2x+3)$", "note": "Simplify" }
        ]
      },
      {
        "q": "Factorise $10a^2-15a$.",
        "a": "$5a(2a-3)$",
        "solution": [
          { "math": "$10a^2-15a$" },
          { "math": "$= 5a\\left(\\frac{10a^2}{5a}-\\frac{15a}{5a}\\right)$", "note": "Divide by HCF" },
          { "math": "$= 5a(2a-3)$", "note": "Simplify" }
        ]
      },
      {
        "q": "Factorise $6x+9y+12$.",
        "a": "$3(2x+3y+4)$",
        "solution": [
          { "math": "$6x+9y+12$" },
          { "math": "$= 3\\left(\\frac{6x}{3}+\\frac{9y}{3}+\\frac{12}{3}\\right)$", "note": "Divide by HCF" },
          { "math": "$= 3(2x+3y+4)$", "note": "Simplify" }
        ]
      },
      {
        "q": "Factorise $14x-21y+7$.",
        "a": "$7(2x-3y+1)$",
        "solution": [
          { "math": "$14x-21y+7$" },
          { "math": "$= 7\\left(\\frac{14x}{7}-\\frac{21y}{7}+\\frac{7}{7}\\right)$", "note": "Divide by HCF" },
          { "math": "$= 7(2x-3y+1)$", "note": "Keep the $1$" }
        ]
      },
      {
        "q": "Ravi factorised $6x+9$ as $3(2x+3)$. Expand to check his answer is correct.",
        "a": "Yes — $3(2x+3)$ expands to $6x+9$.",
        "solution": [
          { "math": "$3(2x+3)$" },
          { "math": "$= 3 \\times 2x + 3 \\times 3$", "note": "Expand" },
          { "math": "$= 6x+9$", "note": "Matches original" }
        ]
      }
    ],
    "mastery": [
      {
        "q": "Factorise $3p^2+3p$.",
        "a": "$3p(p+1)$",
        "solution": [
          { "math": "$3p^2+3p$" },
          { "math": "$= 3p\\left(\\frac{3p^2}{3p}+\\frac{3p}{3p}\\right)$", "note": "Divide by HCF" },
          { "math": "$= 3p(p+1)$", "note": "Keep the $1$" }
        ]
      },
      {
        "q": "Amina wrote $4a-12b=2(2a-6b)$, but it is not fully factorised. Write the fully factorised form.",
        "a": "$4(a-3b)$",
        "solution": [
          { "math": "$4a-12b$" },
          { "math": "$= 4\\left(\\frac{4a}{4}-\\frac{12b}{4}\\right)$", "note": "Divide by HCF" },
          { "math": "$= 4(a-3b)$", "note": "No factor left" }
        ]
      },
      {
        "q": "Factorise $15x^3+9x^2$.",
        "a": "$3x^2(5x+3)$",
        "solution": [
          { "math": "$15x^3+9x^2$" },
          { "math": "$= 3x^2\\left(\\frac{15x^3}{3x^2}+\\frac{9x^2}{3x^2}\\right)$", "note": "Divide by HCF" },
          { "math": "$= 3x^2(5x+3)$", "note": "Simplify" }
        ]
      }
    ]
  }
}
