{
  "skillId": "factorise-common-factor",
  "atomType": "R",
  "theory": {
    "intro": "Factorising is the reverse of expanding: it rewrites a sum of terms as the highest common factor (HCF) multiplied by a bracket.",
    "facts": [
      "Factorising is the **inverse** of expanding: $3(2x+5)=6x+15$ expands, and $6x+15=3(2x+5)$ factorises.",
      "The **highest common factor (HCF)** of all the terms is written **outside** the brackets.",
      "Divide each term by the HCF; the results go **inside** the brackets.",
      "When a term equals the HCF, dividing leaves a $1$ inside the brackets: $3p^2+3p=3p(p+1)$.",
      "**Fully factorised** means the terms left inside the brackets share **no** further common factor.",
      "**Check by expanding**: multiply back out and confirm you get the original expression."
    ],
    "steps": [
      "Find the HCF.",
      "Write it outside.",
      "Divide each term.",
      "Write results inside.",
      "Check by expanding."
    ]
  },
  "practice": {
    "foundation": [
      {
        "question_text": "Factorise $4x+6$.",
        "solution_text": "$4x+6$\n$= 2\\left(\\frac{4x}{2}+\\frac{6}{2}\\right)$\n$= 2(2x+3)$"
      },
      {
        "question_text": "Factorise $9y+12$.",
        "solution_text": "$9y+12$\n$= 3\\left(\\frac{9y}{3}+\\frac{12}{3}\\right)$\n$= 3(3y+4)$"
      },
      {
        "question_text": "Factorise $15a-10$.",
        "solution_text": "$15a-10$\n$= 5\\left(\\frac{15a}{5}-\\frac{10}{5}\\right)$\n$= 5(3a-2)$"
      },
      {
        "question_text": "Factorise $6x+xy$.",
        "solution_text": "$6x+xy$\n$= x\\left(\\frac{6x}{x}+\\frac{xy}{x}\\right)$\n$= x(6+y)$"
      },
      {
        "question_text": "Factorise $y^2-12y$.",
        "solution_text": "$y^2-12y$\n$= y\\left(\\frac{y^2}{y}-\\frac{12y}{y}\\right)$\n$= y(y-12)$"
      }
    ],
    "development": [
      {
        "question_text": "Factorise $8xy+12y$.",
        "solution_text": "$8xy+12y$\n$= 4y\\left(\\frac{8xy}{4y}+\\frac{12y}{4y}\\right)$\n$= 4y(2x+3)$"
      },
      {
        "question_text": "Factorise $10a^2-15a$.",
        "solution_text": "$10a^2-15a$\n$= 5a\\left(\\frac{10a^2}{5a}-\\frac{15a}{5a}\\right)$\n$= 5a(2a-3)$"
      },
      {
        "question_text": "Factorise $6x+9y+12$.",
        "solution_text": "$6x+9y+12$\n$= 3\\left(\\frac{6x}{3}+\\frac{9y}{3}+\\frac{12}{3}\\right)$\n$= 3(2x+3y+4)$"
      },
      {
        "question_text": "Factorise $14x-21y+7$.",
        "solution_text": "$14x-21y+7$\n$= 7\\left(\\frac{14x}{7}-\\frac{21y}{7}+\\frac{7}{7}\\right)$\n$= 7(2x-3y+1)$"
      },
      {
        "question_text": "Ravi factorised $6x+9$ as $3(2x+3)$. Expand to check his answer is correct.",
        "solution_text": "$3(2x+3)$\n$= 3 \\times 2x + 3 \\times 3$\n$= 6x+9$\nYes — $3(2x+3)$ expands to $6x+9$."
      }
    ],
    "mastery": [
      {
        "question_text": "Factorise $3p^2+3p$.",
        "solution_text": "$3p^2+3p$\n$= 3p\\left(\\frac{3p^2}{3p}+\\frac{3p}{3p}\\right)$\n$= 3p(p+1)$"
      },
      {
        "question_text": "Amina wrote $4a-12b=2(2a-6b)$, but it is not fully factorised. Write the fully factorised form.",
        "solution_text": "$4a-12b$\n$= 4\\left(\\frac{4a}{4}-\\frac{12b}{4}\\right)$\n$= 4(a-3b)$"
      },
      {
        "question_text": "Factorise $15x^3+9x^2$.",
        "solution_text": "$15x^3+9x^2$\n$= 3x^2\\left(\\frac{15x^3}{3x^2}+\\frac{9x^2}{3x^2}\\right)$\n$= 3x^2(5x+3)$"
      }
    ]
  }
}
