{
  "skillId": "lcm-two-numbers",
  "atomType": "R",
  "theory": {
    "intro": "The **lowest common multiple (LCM)** of two numbers is the smallest number that both divide into — the smallest multiple they share.",
    "facts": [
      "The multiples of a number are what you get by multiplying it by $1, 2, 3, \\dots$",
      "Multiples of $6$: $6, 12, 18, 24, \\dots$; multiples of $8$: $8, 16, 24, \\dots$; the lowest shared multiple is $24$.",
      "Shortcut: $\\text{LCM} = \\dfrac{\\text{product}}{\\text{HCF}}$, useful when listing would take too long."
    ],
    "steps": [
      "List the first few multiples of each number.",
      "Find the smallest multiple that appears in both lists.",
      "Or divide the product of the two numbers by their HCF."
    ]
  },
  "practice": {
    "foundation": [
      {
        "question_text": "Find the LCM of $4$ and $6$.",
        "solution_text": "$\\text{Multiples of } 4: 4, 8, 12$\n$\\text{Multiples of } 6: 6, 12$\n$= 12$"
      },
      {
        "question_text": "Find the LCM of $6$ and $9$.",
        "solution_text": "$\\text{Multiples of } 6: 6, 12, 18$\n$\\text{Multiples of } 9: 9, 18$\n$= 18$"
      },
      {
        "question_text": "Find the LCM of $3$ and $5$.",
        "solution_text": "$\\text{Multiples of } 3: 3, 6, 9, 12, 15$\n$\\text{Multiples of } 5: 5, 10, 15$\n$= 15$"
      },
      {
        "question_text": "Find the LCM of $8$ and $12$.",
        "solution_text": "$\\text{Multiples of } 8: 8, 16, 24$\n$\\text{Multiples of } 12: 12, 24$\n$= 24$"
      }
    ],
    "development": [
      {
        "question_text": "Find the LCM of $6$ and $12$.",
        "solution_text": "$\\text{Multiples of } 6: 6, 12$\n$\\text{Multiples of } 12: 12$\n$= 12$"
      },
      {
        "question_text": "Find the LCM of $4$ and $5$.",
        "solution_text": "$\\text{Multiples of } 4: 4, 8, 12, 16, 20$\n$\\text{Multiples of } 5: 5, 10, 15, 20$\n$= 20$"
      },
      {
        "question_text": "Find the LCM of $10$ and $15$.",
        "solution_text": "$\\text{Multiples of } 10: 10, 20, 30$\n$\\text{Multiples of } 15: 15, 30$\n$= 30$"
      },
      {
        "question_text": "Find the LCM of $12$ and $18$ by dividing the product by the HCF.",
        "solution_text": "$\\text{HCF of } 12, 18 = 6$\n$\\text{LCM} = \\frac{12 \\times 18}{6}$\n$= 36$"
      }
    ],
    "mastery": [
      {
        "question_text": "Find the LCM of $18$ and $24$.",
        "solution_text": "$\\text{HCF of } 18, 24 = 6$\n$\\text{LCM} = \\frac{18 \\times 24}{6}$\n$= 72$"
      },
      {
        "question_text": "Find the LCM of $24$ and $36$.",
        "solution_text": "$\\text{HCF of } 24, 36 = 12$\n$\\text{LCM} = \\frac{24 \\times 36}{12}$\n$= 72$"
      },
      {
        "question_text": "Find the LCM of $15$ and $20$.",
        "solution_text": "$\\text{HCF of } 15, 20 = 5$\n$\\text{LCM} = \\frac{15 \\times 20}{5}$\n$= 60$"
      }
    ]
  }
}
