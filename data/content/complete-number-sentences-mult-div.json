{
  "skillId": "complete-number-sentences-mult-div",
  "atomType": "R",
  "theory": {
    "intro": "A number sentence with a missing number can be completed by working out what value makes both sides equal.",
    "facts": [
      "The $=$ sign means both sides have the **same value**.",
      "To find a missing factor, **divide**; to find a missing dividend or product, multiply.",
      "Always check by substituting your answer back into the sentence."
    ],
    "steps": [
      "Identify which number is missing and which operation links the numbers.",
      "Use the inverse operation to find the missing value.",
      "Check the sentence balances."
    ]
  },
  "practice": {
    "foundation": [
      { "q": "Find the missing number: $\\square \\times 4 = 28$.", "a": "$7$",
        "solution": [ { "math": "$\\square = 28 \\div 4$", "note": "Divide to undo $\\times 4$" }, { "math": "$= 7$", "note": "Check $7 \\times 4 = 28$" } ] },
      { "q": "Find the missing number: $6 \\times \\square = 42$.", "a": "$7$",
        "solution": [ { "math": "$\\square = 42 \\div 6$", "note": "Divide" }, { "math": "$= 7$", "note": "Check $6 \\times 7 = 42$" } ] },
      { "q": "Find the missing number: $\\square \\div 3 = 9$.", "a": "$27$",
        "solution": [ { "math": "$\\square = 9 \\times 3$", "note": "Multiply to undo $\\div 3$" }, { "math": "$= 27$", "note": "Check $27 \\div 3 = 9$" } ] },
      { "q": "Find the missing number: $40 \\div \\square = 8$.", "a": "$5$",
        "solution": [ { "math": "$\\square = 40 \\div 8$", "note": "Rearrange" }, { "math": "$= 5$", "note": "Check $40 \\div 5 = 8$" } ] },
      { "q": "Find the missing number: $5 \\times \\square = 45$.", "a": "$9$",
        "solution": [ { "math": "$\\square = 45 \\div 5$", "note": "Divide" }, { "math": "$= 9$", "note": "Check $5 \\times 9 = 45$" } ] },
      { "q": "Find the missing number: $\\square \\times 8 = 56$.", "a": "$7$",
        "solution": [ { "math": "$\\square = 56 \\div 8$", "note": "Divide" }, { "math": "$= 7$", "note": "Check $7 \\times 8 = 56$" } ] },
      { "q": "Find the missing number: $\\square \\div 6 = 4$.", "a": "$24$",
        "solution": [ { "math": "$\\square = 4 \\times 6$", "note": "Multiply" }, { "math": "$= 24$", "note": "Check $24 \\div 6 = 4$" } ] },
      { "q": "Find the missing number: $9 \\times \\square = 36$.", "a": "$4$",
        "solution": [ { "math": "$\\square = 36 \\div 9$", "note": "Divide" }, { "math": "$= 4$", "note": "Check $9 \\times 4 = 36$" } ] },
      { "q": "Find the missing number: $54 \\div \\square = 6$.", "a": "$9$",
        "solution": [ { "math": "$\\square = 54 \\div 6$", "note": "Rearrange" }, { "math": "$= 9$", "note": "Check $54 \\div 9 = 6$" } ] },
      { "q": "Find the missing number: $\\square \\times 7 = 63$.", "a": "$9$",
        "solution": [ { "math": "$\\square = 63 \\div 7$", "note": "Divide" }, { "math": "$= 9$", "note": "Check $9 \\times 7 = 63$" } ] }
    ],
    "development": [
      { "q": "Find the missing number: $\\square \\times 6 = 132$.", "a": "$22$",
        "solution": [ { "math": "$\\square = 132 \\div 6$", "note": "Divide" }, { "math": "$= 22$", "note": "Check $22 \\times 6 = 132$" } ] },
      { "q": "Find the missing number: $\\square \\times 3 + 5 = 20$.", "a": "$5$",
        "solution": [ { "math": "$\\square \\times 3 = 15$", "note": "Subtract $5$ first" }, { "math": "$\\square = 15 \\div 3 = 5$", "note": "Then divide" } ] },
      { "q": "Find the missing number: $2 \\times \\square - 4 = 10$.", "a": "$7$",
        "solution": [ { "math": "$2 \\times \\square = 14$", "note": "Add $4$" }, { "math": "$\\square = 14 \\div 2 = 7$", "note": "Then divide" } ] },
      { "q": "Find the missing number: $\\square \\div 4 + 3 = 9$.", "a": "$24$",
        "solution": [ { "math": "$\\square \\div 4 = 6$", "note": "Subtract $3$" }, { "math": "$\\square = 6 \\times 4 = 24$", "note": "Then multiply" } ] },
      { "q": "Find the missing number: $100 \\div \\square = 25$.", "a": "$4$",
        "solution": [ { "math": "$\\square = 100 \\div 25$", "note": "Rearrange" }, { "math": "$= 4$", "note": "Check $100 \\div 4 = 25$" } ] },
      { "q": "Find the missing number: $3 \\times \\square = 4 \\times 9$.", "a": "$12$",
        "solution": [ { "math": "$3 \\times \\square = 36$", "note": "Work out the right side" }, { "math": "$\\square = 36 \\div 3 = 12$", "note": "Divide" } ] },
      { "q": "Find the missing number: $\\square \\times 12 = 96$.", "a": "$8$",
        "solution": [ { "math": "$\\square = 96 \\div 12$", "note": "Divide" }, { "math": "$= 8$", "note": "Check $8 \\times 12 = 96$" } ] },
      { "q": "Find the missing number: $5 \\times \\square + 7 = 47$.", "a": "$8$",
        "solution": [ { "math": "$5 \\times \\square = 40$", "note": "Subtract $7$" }, { "math": "$\\square = 40 \\div 5 = 8$", "note": "Then divide" } ] },
      { "q": "Find the missing number: $\\square \\div 5 - 2 = 6$.", "a": "$40$",
        "solution": [ { "math": "$\\square \\div 5 = 8$", "note": "Add $2$" }, { "math": "$\\square = 8 \\times 5 = 40$", "note": "Then multiply" } ] },
      { "q": "Find the missing number: $144 \\div \\square = 12$.", "a": "$12$",
        "solution": [ { "math": "$\\square = 144 \\div 12$", "note": "Rearrange" }, { "math": "$= 12$", "note": "Check $144 \\div 12 = 12$" } ] }
    ],
    "mastery": [
      { "q": "A number is multiplied by $6$ and then $4$ is added, giving $34$. Find the number.", "a": "$5$",
        "solution": [ { "math": "$\\square \\times 6 = 30$", "note": "Subtract $4$" }, { "math": "$\\square = 30 \\div 6 = 5$", "note": "Then divide" } ] },
      { "q": "Find both missing numbers: $\\square \\times 4 = 32$ and $32 \\div \\triangle = 8$.", "a": "$\\square = 8,\\ \\triangle = 4$",
        "solution": [ { "math": "$\\square = 32 \\div 4 = 8$", "note": "First sentence" }, { "math": "$\\triangle = 32 \\div 8 = 4$", "note": "Second sentence" } ] },
      { "q": "Equal groups: $\\square$ groups of $7$ make $84$. How many groups?", "a": "$12$",
        "solution": [ { "math": "$\\square \\times 7 = 84$", "note": "Set up sentence" }, { "math": "$\\square = 84 \\div 7 = 12$", "note": "Divide" } ] },
      { "q": "A number divided by $8$, then doubled, gives $14$. Find the number.", "a": "$56$",
        "solution": [ { "math": "$\\square \\div 8 = 7$", "note": "Halve $14$" }, { "math": "$\\square = 7 \\times 8 = 56$", "note": "Then multiply" } ] },
      { "q": "Find the missing number: $\\square \\times 9 - 11 = 70$.", "a": "$9$",
        "solution": [ { "math": "$\\square \\times 9 = 81$", "note": "Add $11$" }, { "math": "$\\square = 81 \\div 9 = 9$", "note": "Then divide" } ] },
      { "q": "Tickets cost $\\$8$ each. After spending $\\$8 \\times \\square$ you have paid $\\$72$. How many tickets?", "a": "$9$",
        "solution": [ { "math": "$8 \\times \\square = 72$", "note": "Set up sentence" }, { "math": "$\\square = 72 \\div 8 = 9$", "note": "Divide" } ] },
      { "q": "Find the missing number: $\\square \\div 7 + 10 = 16$.", "a": "$42$",
        "solution": [ { "math": "$\\square \\div 7 = 6$", "note": "Subtract $10$" }, { "math": "$\\square = 6 \\times 7 = 42$", "note": "Then multiply" } ] },
      { "q": "Three times a number equals five times $6$. Find the number.", "a": "$10$",
        "solution": [ { "math": "$3 \\times \\square = 30$", "note": "$5 \\times 6 = 30$" }, { "math": "$\\square = 30 \\div 3 = 10$", "note": "Divide" } ] },
      { "q": "Find the missing number: $48 \\div \\square + 1 = 7$.", "a": "$8$",
        "solution": [ { "math": "$48 \\div \\square = 6$", "note": "Subtract $1$" }, { "math": "$\\square = 48 \\div 6 = 8$", "note": "Rearrange" } ] },
      { "q": "A baker packs $\\square$ trays of $6$ buns to make $90$ buns. Find $\\square$, then how many buns are in $5$ trays.", "a": "$\\square = 15$; $30$ buns",
        "solution": [ { "math": "$\\square \\times 6 = 90 \\Rightarrow \\square = 15$", "note": "Divide $90$ by $6$" }, { "math": "$5 \\times 6 = 30$", "note": "Buns in $5$ trays" } ] }
    ]
  }
}
