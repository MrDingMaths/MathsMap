{
  "skillId": "multiply-by-powers-of-10",
  "atomType": "R",
  "theory": {
    "intro": "Multiplying by $10$, $100$ or $1000$ shifts every digit to a larger place value. Multiplying by their multiples (like $30$ or $400$) combines this with a basic fact.",
    "facts": [
      "$\\times 10$ adds one zero, $\\times 100$ adds two, $\\times 1000$ adds three.",
      "$7 \\times 30 = 7 \\times 3 \\times 10 = 21 \\times 10 = 210$.",
      "Multiply the non-zero digits first, then attach the zeros."
    ],
    "steps": [
      "Multiply the leading (non-zero) digits using a basic fact.",
      "Count the total number of zeros in the factors.",
      "Attach that many zeros to the product."
    ]
  },
  "practice": {
    "foundation": [
      { "q": "Calculate $6 \\times 10$.", "a": "$60$",
        "solution": [ { "math": "$6 \\times 10$", "note": "One zero" }, { "math": "$= 60$", "note": "" } ] },
      { "q": "Calculate $4 \\times 100$.", "a": "$400$",
        "solution": [ { "math": "$4 \\times 100$", "note": "Two zeros" }, { "math": "$= 400$", "note": "" } ] },
      { "q": "Calculate $9 \\times 1000$.", "a": "$9000$",
        "solution": [ { "math": "$9 \\times 1000$", "note": "Three zeros" }, { "math": "$= 9\\,000$", "note": "" } ] },
      { "q": "Calculate $7 \\times 10$.", "a": "$70$",
        "solution": [ { "math": "$7 \\times 10$", "note": "One zero" }, { "math": "$= 70$", "note": "" } ] },
      { "q": "Calculate $3 \\times 100$.", "a": "$300$",
        "solution": [ { "math": "$3 \\times 100$", "note": "Two zeros" }, { "math": "$= 300$", "note": "" } ] },
      { "q": "Calculate $5 \\times 1000$.", "a": "$5000$",
        "solution": [ { "math": "$5 \\times 1000$", "note": "Three zeros" }, { "math": "$= 5\\,000$", "note": "" } ] },
      { "q": "Calculate $8 \\times 10$.", "a": "$80$",
        "solution": [ { "math": "$8 \\times 10$", "note": "One zero" }, { "math": "$= 80$", "note": "" } ] },
      { "q": "Calculate $2 \\times 100$.", "a": "$200$",
        "solution": [ { "math": "$2 \\times 100$", "note": "Two zeros" }, { "math": "$= 200$", "note": "" } ] },
      { "q": "Calculate $6 \\times 1000$.", "a": "$6000$",
        "solution": [ { "math": "$6 \\times 1000$", "note": "Three zeros" }, { "math": "$= 6\\,000$", "note": "" } ] },
      { "q": "Calculate $1 \\times 100$.", "a": "$100$",
        "solution": [ { "math": "$1 \\times 100$", "note": "" }, { "math": "$= 100$", "note": "" } ] }
    ],
    "development": [
      { "q": "Calculate $7 \\times 30$.", "a": "$210$",
        "solution": [ { "math": "$7 \\times 3 = 21$", "note": "Basic fact" }, { "math": "$21 \\times 10 = 210$", "note": "Attach zero" } ] },
      { "q": "Calculate $6 \\times 40$.", "a": "$240$",
        "solution": [ { "math": "$6 \\times 4 = 24$", "note": "Basic fact" }, { "math": "$24 \\times 10 = 240$", "note": "" } ] },
      { "q": "Calculate $8 \\times 50$.", "a": "$400$",
        "solution": [ { "math": "$8 \\times 5 = 40$", "note": "Basic fact" }, { "math": "$40 \\times 10 = 400$", "note": "" } ] },
      { "q": "Calculate $5 \\times 300$.", "a": "$1500$",
        "solution": [ { "math": "$5 \\times 3 = 15$", "note": "Basic fact" }, { "math": "$15 \\times 100 = 1\\,500$", "note": "Two zeros" } ] },
      { "q": "Calculate $4 \\times 600$.", "a": "$2400$",
        "solution": [ { "math": "$4 \\times 6 = 24$", "note": "Basic fact" }, { "math": "$24 \\times 100 = 2\\,400$", "note": "" } ] },
      { "q": "Calculate $9 \\times 20$.", "a": "$180$",
        "solution": [ { "math": "$9 \\times 2 = 18$", "note": "Basic fact" }, { "math": "$18 \\times 10 = 180$", "note": "" } ] },
      { "q": "Calculate $3 \\times 7000$.", "a": "$21\\,000$",
        "solution": [ { "math": "$3 \\times 7 = 21$", "note": "Basic fact" }, { "math": "$21 \\times 1000 = 21\\,000$", "note": "Three zeros" } ] },
      { "q": "Calculate $7 \\times 80$.", "a": "$560$",
        "solution": [ { "math": "$7 \\times 8 = 56$", "note": "Basic fact" }, { "math": "$56 \\times 10 = 560$", "note": "" } ] },
      { "q": "Calculate $6 \\times 500$.", "a": "$3000$",
        "solution": [ { "math": "$6 \\times 5 = 30$", "note": "Basic fact" }, { "math": "$30 \\times 100 = 3\\,000$", "note": "" } ] },
      { "q": "Calculate $8 \\times 90$.", "a": "$720$",
        "solution": [ { "math": "$8 \\times 9 = 72$", "note": "Basic fact" }, { "math": "$72 \\times 10 = 720$", "note": "" } ] }
    ],
    "mastery": [
      { "q": "Calculate $40 \\times 60$.", "a": "$2400$",
        "solution": [ { "math": "$4 \\times 6 = 24$", "note": "Leading digits" }, { "math": "$24 \\times 100 = 2\\,400$", "note": "Two zeros total" } ] },
      { "q": "Calculate $300 \\times 20$.", "a": "$6000$",
        "solution": [ { "math": "$3 \\times 2 = 6$", "note": "Leading digits" }, { "math": "$6 \\times 1000 = 6\\,000$", "note": "Three zeros total" } ] },
      { "q": "A pallet holds $200$ tins. How many tins on $8$ pallets?", "a": "$1600$",
        "solution": [ { "math": "$8 \\times 2 = 16$", "note": "Leading digits" }, { "math": "$16 \\times 100 = 1\\,600$", "note": "" } ] },
      { "q": "Calculate $50 \\times 50$.", "a": "$2500$",
        "solution": [ { "math": "$5 \\times 5 = 25$", "note": "Leading digits" }, { "math": "$25 \\times 100 = 2\\,500$", "note": "" } ] },
      { "q": "A theatre has $700$ seats. Across $6$ nights, how many seat-bookings are possible?", "a": "$4200$",
        "solution": [ { "math": "$6 \\times 7 = 42$", "note": "Leading digits" }, { "math": "$42 \\times 100 = 4\\,200$", "note": "" } ] },
      { "q": "Calculate $90 \\times 400$.", "a": "$36\\,000$",
        "solution": [ { "math": "$9 \\times 4 = 36$", "note": "Leading digits" }, { "math": "$36 \\times 1000 = 36\\,000$", "note": "Three zeros total" } ] },
      { "q": "$\\square \\times 100 = 4\\,500$. Find $\\square$.", "a": "$45$",
        "solution": [ { "math": "$4\\,500 \\div 100$", "note": "Reverse" }, { "math": "$= 45$", "note": "" } ] },
      { "q": "Each crate holds $30$ bottles. How many bottles in $40$ crates?", "a": "$1200$",
        "solution": [ { "math": "$3 \\times 4 = 12$", "note": "Leading digits" }, { "math": "$12 \\times 100 = 1\\,200$", "note": "" } ] },
      { "q": "Calculate $20 \\times 20 \\times 5$.", "a": "$2000$",
        "solution": [ { "math": "$20 \\times 20 = 400$", "note": "First pair" }, { "math": "$400 \\times 5 = 2\\,000$", "note": "" } ] },
      { "q": "$6 \\times \\square = 4\\,200$. Find $\\square$.", "a": "$700$",
        "solution": [ { "math": "$4\\,200 \\div 6$", "note": "Reverse" }, { "math": "$= 700$", "note": "" } ] }
    ]
  }
}
