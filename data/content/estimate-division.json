  "theory": {
    "intro": "To estimate a division, round the number being divided to a nearby **compatible** number that the divisor goes into evenly.",
    "facts": [
      "A **compatible number** is close to the original and divides exactly by the divisor.",
      "e.g. $\\$298 \\div 5 \\approx 300 \\div 5 = 60$.",
      "Estimates are quick and tell you the rough size of the answer."
    ],
    "steps": [
      "Look at the divisor and recall its multiples.",
      "Round the dividend to the nearest convenient multiple.",
      "Divide to get the estimate."
    ]
  },
  "practice": {
