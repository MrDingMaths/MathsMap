{
  "skillId": "estimate-decimal-products",
  "atomType": "R",
  "theory": {
    "intro": "To judge the size of a decimal product, round the decimal to a convenient whole number (or simple value) and multiply mentally.",
    "facts": [
      "Rounding a factor gives an **estimate**, not the exact answer.",
      "A decimal a little less than a whole number gives a product a little **less** than the rounded estimate.",
      "Estimating first tells you the **magnitude** — roughly how big the answer should be."
    ],
    "steps": [
      "Round the decimal to the nearest whole number (or simple value).",
      "Multiply by the whole number.",
      "Use the estimate to judge whether an exact answer is reasonable."
    ]
  },
  "practice": {
    "foundation": [
      { "q": "Estimate $3.8 \\times 6$ by rounding $3.8$ to the nearest whole number.", "a": "$24$",
        "solution": [ { "math": "$3.8 \\approx 4$", "note": "Round to nearest whole" }, { "math": "$4 \\times 6 = 24$", "note": "Estimate" } ] },
      { "q": "Estimate $5.2 \\times 4$ by rounding $5.2$.", "a": "$20$",
        "solution": [ { "math": "$5.2 \\approx 5$", "note": "Round down" }, { "math": "$5 \\times 4 = 20$", "note": "Estimate" } ] },
      { "q": "Estimate $7.9 \\times 3$ by rounding $7.9$.", "a": "$24$",
        "solution": [ { "math": "$7.9 \\approx 8$", "note": "Round up" }, { "math": "$8 \\times 3 = 24$", "note": "Estimate" } ] },
      { "q": "Estimate $2.1 \\times 9$ by rounding $2.1$.", "a": "$18$",
        "solution": [ { "math": "$2.1 \\approx 2$", "note": "Round down" }, { "math": "$2 \\times 9 = 18$", "note": "Estimate" } ] },
      { "q": "Estimate $6.7 \\times 5$ by rounding $6.7$.", "a": "$35$",
        "solution": [ { "math": "$6.7 \\approx 7$", "note": "Round up" }, { "math": "$7 \\times 5 = 35$", "note": "Estimate" } ] },
      { "q": "Estimate $4.3 \\times 7$ by rounding $4.3$.", "a": "$28$",
        "solution": [ { "math": "$4.3 \\approx 4$", "note": "Round down" }, { "math": "$4 \\times 7 = 28$", "note": "Estimate" } ] },
      { "q": "Estimate $8.9 \\times 2$ by rounding $8.9$.", "a": "$18$",
        "solution": [ { "math": "$8.9 \\approx 9$", "note": "Round up" }, { "math": "$9 \\times 2 = 18$", "note": "Estimate" } ] },
      { "q": "Estimate $1.8 \\times 8$ by rounding $1.8$.", "a": "$16$",
        "solution": [ { "math": "$1.8 \\approx 2$", "note": "Round up" }, { "math": "$2 \\times 8 = 16$", "note": "Estimate" } ] },
      { "q": "Estimate $9.2 \\times 4$ by rounding $9.2$.", "a": "$36$",
        "solution": [ { "math": "$9.2 \\approx 9$", "note": "Round down" }, { "math": "$9 \\times 4 = 36$", "note": "Estimate" } ] },
      { "q": "Estimate $3.1 \\times 6$ by rounding $3.1$.", "a": "$18$",
        "solution": [ { "math": "$3.1 \\approx 3$", "note": "Round down" }, { "math": "$3 \\times 6 = 18$", "note": "Estimate" } ] }
    ],
    "development": [
      { "q": "Estimate $12.4 \\times 5$ by rounding to the nearest whole number.", "a": "$60$",
        "solution": [ { "math": "$12.4 \\approx 12$", "note": "Round down" }, { "math": "$12 \\times 5 = 60$", "note": "Estimate" } ] },
      { "q": "Estimate $18.7 \\times 3$.", "a": "$57$",
        "solution": [ { "math": "$18.7 \\approx 19$", "note": "Round up" }, { "math": "$19 \\times 3 = 57$", "note": "Estimate" } ] },
      { "q": "Estimate $24.6 \\times 4$.", "a": "$100$",
        "solution": [ { "math": "$24.6 \\approx 25$", "note": "Round up" }, { "math": "$25 \\times 4 = 100$", "note": "Estimate" } ] },
      { "q": "Estimate $9.8 \\times 12$.", "a": "$120$",
        "solution": [ { "math": "$9.8 \\approx 10$", "note": "Round up" }, { "math": "$10 \\times 12 = 120$", "note": "Estimate" } ] },
      { "q": "Estimate $0.49 \\times 8$ by rounding $0.49$ to a simple value.", "a": "$4$",
        "solution": [ { "math": "$0.49 \\approx 0.5$", "note": "Round to one half" }, { "math": "$0.5 \\times 8 = 4$", "note": "Estimate" } ] },
      { "q": "Estimate $1.97 \\times 15$.", "a": "$30$",
        "solution": [ { "math": "$1.97 \\approx 2$", "note": "Round up" }, { "math": "$2 \\times 15 = 30$", "note": "Estimate" } ] },
      { "q": "Estimate $4.95 \\times 6$.", "a": "$30$",
        "solution": [ { "math": "$4.95 \\approx 5$", "note": "Round up" }, { "math": "$5 \\times 6 = 30$", "note": "Estimate" } ] },
      { "q": "Estimate $11.3 \\times 7$.", "a": "$77$",
        "solution": [ { "math": "$11.3 \\approx 11$", "note": "Round down" }, { "math": "$11 \\times 7 = 77$", "note": "Estimate" } ] },
      { "q": "Estimate $0.21 \\times 20$ by rounding $0.21$.", "a": "$4$",
        "solution": [ { "math": "$0.21 \\approx 0.2$", "note": "Round to two tenths" }, { "math": "$0.2 \\times 20 = 4$", "note": "Estimate" } ] },
      { "q": "Estimate $29.8 \\times 3$.", "a": "$90$",
        "solution": [ { "math": "$29.8 \\approx 30$", "note": "Round up" }, { "math": "$30 \\times 3 = 90$", "note": "Estimate" } ] }
    ],
    "mastery": [
      { "q": "Petrol costs $\\$1.89$ per litre. Estimate the cost of $40$ litres.", "a": "about $\\$80$",
        "solution": [ { "math": "$1.89 \\approx 2$", "note": "Round up" }, { "math": "$2 \\times 40 = 80$", "note": "About $\\$80$" } ] },
      { "q": "A book is $2.7$ cm thick. Estimate the height of a stack of $9$ books.", "a": "about $27$ cm",
        "solution": [ { "math": "$2.7 \\approx 3$", "note": "Round up" }, { "math": "$3 \\times 9 = 27$", "note": "About $27$ cm" } ] },
      { "q": "Without calculating exactly, is $6.8 \\times 7$ more or less than $50$?", "a": "less than $50$",
        "solution": [ { "math": "$6.8 \\approx 7$", "note": "Round up" }, { "math": "$7 \\times 7 = 49 < 50$", "note": "Less than $50$" } ] },
      { "q": "A worker earns $\\$19.50$ per hour. Estimate the pay for $8$ hours.", "a": "about $\\$160$",
        "solution": [ { "math": "$19.50 \\approx 20$", "note": "Round up" }, { "math": "$20 \\times 8 = 160$", "note": "About $\\$160$" } ] },
      { "q": "A student says $4.2 \\times 11 = 462$. Use estimation to show this is wrong.", "a": "No — about $44$",
        "solution": [ { "math": "$4.2 \\approx 4$", "note": "Round down" }, { "math": "$4 \\times 11 = 44$", "note": "$462$ is far too big" } ] },
      { "q": "One ribbon is $3.1$ m long. Estimate the total length of $12$ ribbons.", "a": "about $36$ m",
        "solution": [ { "math": "$3.1 \\approx 3$", "note": "Round down" }, { "math": "$3 \\times 12 = 36$", "note": "About $36$ m" } ] },
      { "q": "Apples cost $\\$0.95$ each. Estimate the cost of $20$ apples.", "a": "about $\\$20$",
        "solution": [ { "math": "$0.95 \\approx 1$", "note": "Round up" }, { "math": "$1 \\times 20 = 20$", "note": "About $\\$20$" } ] },
      { "q": "A car uses $7.9$ litres per $100$ km. Estimate the fuel for $5$ such trips.", "a": "about $40$ litres",
        "solution": [ { "math": "$7.9 \\approx 8$", "note": "Round up" }, { "math": "$8 \\times 5 = 40$", "note": "About $40$ litres" } ] },
      { "q": "Is $14.6 \\times 6$ closer to $90$ or $150$?", "a": "closer to $90$",
        "solution": [ { "math": "$14.6 \\approx 15$", "note": "Round up" }, { "math": "$15 \\times 6 = 90$", "note": "Closer to $90$" } ] },
      { "q": "A phone plan is $\\$48.90$ per month. Estimate the yearly cost ($12$ months).", "a": "about $\\$600$",
        "solution": [ { "math": "$48.90 \\approx 50$", "note": "Round up" }, { "math": "$50 \\times 12 = 600$", "note": "About $\\$600$" } ] }
    ]
  }
}
