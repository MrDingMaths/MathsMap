{
  "skillId": "decimal-mass-equivalence",
  "atomType": "R",
  "theory": {
    "intro": "Because $1\\text{ kg} = 1000\\text{ g}$, a mass given in kilograms and grams can be written as a single decimal number of kilograms.",
    "facts": [
      "$1\\text{ kg} = 1000\\text{ g}$, so $1\\text{ g} = \\tfrac{1}{1000}\\text{ kg} = 0.001\\text{ kg}$.",
      "$500\\text{ g} = 0.5\\text{ kg}$, $250\\text{ g} = 0.25\\text{ kg}$, $750\\text{ g} = 0.75\\text{ kg}$.",
      "$3\\text{ kg } 250\\text{ g} = 3.25\\text{ kg}$ — the grams become the decimal part."
    ],
    "steps": [
      "Keep the whole kilograms before the decimal point.",
      "Divide the grams by $1000$ to get the decimal part.",
      "Combine: kilograms $+$ decimal."
    ]
  },
  "practice": {
    "foundation": [
      { "q": "Write $2\\text{ kg } 500\\text{ g}$ in kilograms.", "a": "$2.5\\text{ kg}$",
        "solution": [ { "math": "$500\\text{ g} = 0.5\\text{ kg}$", "note": "Halve of 1000" }, { "math": "$2 + 0.5 = 2.5\\text{ kg}$", "note": "Combine" } ] },
      { "q": "Write $4\\text{ kg } 250\\text{ g}$ in kilograms.", "a": "$4.25\\text{ kg}$",
        "solution": [ { "math": "$250\\text{ g} = 0.25\\text{ kg}$", "note": "Quarter of 1000" }, { "math": "$4 + 0.25 = 4.25\\text{ kg}$", "note": "Combine" } ] },
      { "q": "Write $1\\text{ kg } 750\\text{ g}$ in kilograms.", "a": "$1.75\\text{ kg}$",
        "solution": [ { "math": "$750\\text{ g} = 0.75\\text{ kg}$", "note": "Three quarters" }, { "math": "$1 + 0.75 = 1.75\\text{ kg}$", "note": "Combine" } ] },
      { "q": "Write $3\\text{ kg } 100\\text{ g}$ in kilograms.", "a": "$3.1\\text{ kg}$",
        "solution": [ { "math": "$100\\text{ g} = 0.1\\text{ kg}$", "note": "Tenth of 1000" }, { "math": "$3 + 0.1 = 3.1\\text{ kg}$", "note": "Combine" } ] },
      { "q": "Write $5\\text{ kg } 800\\text{ g}$ in kilograms.", "a": "$5.8\\text{ kg}$",
        "solution": [ { "math": "$800\\text{ g} = 0.8\\text{ kg}$", "note": "Eight tenths" }, { "math": "$5 + 0.8 = 5.8\\text{ kg}$", "note": "Combine" } ] },
      { "q": "Write $0.5\\text{ kg}$ in grams.", "a": "$500\\text{ g}$",
        "solution": [ { "math": "$0.5 \\times 1000$", "note": "kg → g" }, { "math": "$= 500\\text{ g}$", "note": "Half a kilogram" } ] },
      { "q": "Write $2.25\\text{ kg}$ as kilograms and grams.", "a": "$2\\text{ kg } 250\\text{ g}$",
        "solution": [ { "math": "$0.25 \\times 1000 = 250\\text{ g}$", "note": "Decimal part" }, { "math": "$2\\text{ kg } 250\\text{ g}$", "note": "Combine" } ] },
      { "q": "Write $6\\text{ kg } 200\\text{ g}$ in kilograms.", "a": "$6.2\\text{ kg}$",
        "solution": [ { "math": "$200\\text{ g} = 0.2\\text{ kg}$", "note": "Two tenths" }, { "math": "$6 + 0.2 = 6.2\\text{ kg}$", "note": "Combine" } ] },
      { "q": "Write $1.75\\text{ kg}$ as kilograms and grams.", "a": "$1\\text{ kg } 750\\text{ g}$",
        "solution": [ { "math": "$0.75 \\times 1000 = 750\\text{ g}$", "note": "Decimal part" }, { "math": "$1\\text{ kg } 750\\text{ g}$", "note": "Combine" } ] },
      { "q": "Write $7\\text{ kg } 500\\text{ g}$ in kilograms.", "a": "$7.5\\text{ kg}$",
        "solution": [ { "math": "$500\\text{ g} = 0.5\\text{ kg}$", "note": "Half" }, { "math": "$7 + 0.5 = 7.5\\text{ kg}$", "note": "Combine" } ] }
    ],
    "development": [
      { "q": "Write $2\\text{ kg } 60\\text{ g}$ in kilograms.", "a": "$2.06\\text{ kg}$",
        "solution": [ { "math": "$60\\text{ g} = 0.06\\text{ kg}$", "note": "$60 \\div 1000$" }, { "math": "$2 + 0.06 = 2.06\\text{ kg}$", "note": "Combine" } ] },
      { "q": "Write $3\\text{ kg } 5\\text{ g}$ in kilograms.", "a": "$3.005\\text{ kg}$",
