    ],
    "mastery": [
      { "q": "A parcel weighs $2\\text{ kg } 750\\text{ g}$. Write this in kilograms and explain the decimal part.", "a": "$2.75\\text{ kg}$",
        "solution": [ { "math": "$750\\text{ g} = 0.75\\text{ kg}$", "note": "Three quarters of a kg" }, { "math": "$2 + 0.75 = 2.75\\text{ kg}$", "note": "Combine" } ] },
      { "q": "Two bags weigh $1.5\\text{ kg}$ and $1\\text{ kg } 250\\text{ g}$. Which is heavier?", "a": "$1.5\\text{ kg}$",
