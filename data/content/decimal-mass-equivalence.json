      { "q": "A recipe needs $1.35\\text{ kg}$ of fruit. Express this as kilograms and grams.", "a": "$1\\text{ kg } 350\\text{ g}$",
        "solution": [ { "math": "$0.35 \\times 1000 = 350\\text{ g}$", "note": "Decimal part" }, { "math": "$1\\text{ kg } 350\\text{ g}$", "note": "Combine" } ] },
      { "q": "A scale shows $3\\text{ kg } 8\\text{ g}$. Write it as a decimal in kilograms.", "a": "$3.008\\text{ kg}$",
        "solution": [ { "math": "$8\\text{ g} = 0.008\\text{ kg}$", "note": "$8 \\div 1000$" }, { "math": "$3 + 0.008 = 3.008\\text{ kg}$", "note": "Two leading zeros" } ] },
      { "q": "Order these from lightest: $2.4\\text{ kg}$, $2\\text{ kg } 40\\text{ g}$, $2400\\text{ g}$.", "a": "$2\\text{ kg } 40\\text{ g}, \\text{ then } 2.4\\text{ kg} = 2400\\text{ g}$",
        "solution": [ { "math": "$2\\text{ kg } 40\\text{ g} = 2.04\\text{ kg}$", "note": "Convert all" }, { "math": "$2.04 < 2.4 = 2.4\\text{ kg}$", "note": "Last two equal" } ] },
      { "q": "A baby was $3\\text{ kg } 600\\text{ g}$ at birth and is now $7.2\\text{ kg}$. Express both in kilograms.", "a": "$3.6\\text{ kg}$ and $7.2\\text{ kg}$",
        "solution": [ { "math": "$600\\text{ g} = 0.6\\text{ kg}$", "note": "Convert birth mass" }, { "math": "$3.6\\text{ kg},\\ 7.2\\text{ kg}$", "note": "Both in kg" } ] },
      { "q": "A box plus contents is $5.05\\text{ kg}$. Write the mass as kilograms and grams.", "a": "$5\\text{ kg } 50\\text{ g}$",
        "solution": [ { "math": "$0.05 \\times 1000 = 50\\text{ g}$", "note": "Decimal part" }, { "math": "$5\\text{ kg } 50\\text{ g}$", "note": "Combine" } ] },
      { "q": "A digital scale reads $0.925\\text{ kg}$. How many kilograms and grams is this?", "a": "$0\\text{ kg } 925\\text{ g}$",
        "solution": [ { "math": "$0.925 \\times 1000 = 925\\text{ g}$", "note": "Less than 1 kg" }, { "math": "$925\\text{ g}$", "note": "No whole kilograms" } ] },
      { "q": "Three apples weigh $150\\text{ g}$, $0.18\\text{ kg}$ and $165\\text{ g}$. Write all three in grams.", "a": "$150\\text{ g}, 180\\text{ g}, 165\\text{ g}$",
        "solution": [ { "math": "$0.18\\text{ kg} = 180\\text{ g}$", "note": "$\\times 1000$" }, { "math": "$150, 165, 180\\text{ g}$", "note": "All in grams" } ] },
      { "q": "A truck carries $2\\text{ kg } 5\\text{ g}$ and a van $2.05\\text{ kg}$. Are these masses equal? Explain.", "a": "no — $2.005\\text{ kg}$ vs $2.05\\text{ kg}$",
        "solution": [ { "math": "$2\\text{ kg } 5\\text{ g} = 2.005\\text{ kg}$", "note": "$5 \\div 1000$" }, { "math": "$2.005 \\ne 2.05$", "note": "Van is heavier" } ] }
    ]
