      { "q": "Write $3045\\text{ g}$ in kilograms.", "a": "$3.045\\text{ kg}$",
        "solution": [ { "math": "$3045\\text{ g} = 3\\text{ kg } 45\\text{ g}$", "note": "Split 1000s" }, { "math": "$= 3.045\\text{ kg}$", "note": "$45 \\div 1000 = 0.045$" } ] },
      { "q": "Write $1200\\text{ g}$ in kilograms.", "a": "$1.2\\text{ kg}$",
