{
  "skillId": "whole-from-fractional-part",
  "atomType": "R",
  "theory": {
    "intro": "If you know the value of a fractional part of a whole, you can work back to find the whole. This reverses 'fraction of a quantity'.",
    "facts": [
      "If $\\tfrac{a}{b}$ of the whole equals a value, then **one part $\\tfrac{1}{b}$ = value $\\div a$**.",
      "The whole is made of $b$ equal parts, so **whole = one part $\\times b$**.",
      "A tape diagram split into $b$ segments, with $a$ shaded equalling the known value, makes the whole visible."
    ],
    "steps": [
      "Find the value of one part: divide the known amount by its numerator.",
      "Multiply one part by the denominator.",
      "That gives the whole."
    ]
  },
  "practice": {
    "foundation": [
      { "q": "$\\tfrac{1}{4}$ of a bar is $3$. What is the whole bar?", "a": "$12$",
        "tikz": "\\begin{tikzpicture}[x=0.8cm,y=0.7cm]\n\\draw (0,0) rectangle (4,1);\n\\foreach \\i in {1,2,3} \\draw (\\i,0) -- (\\i,1);\n\\fill[gray!40] (0,0) rectangle (1,1);\n\\node[above=4pt] at (0.5,1) {$3$};\n\\node[below=4pt] at (2,0) {$?$};\n\\end{tikzpicture}",
        "solution": [ { "math": "$\\tfrac{1}{4} = 3$", "note": "One part" }, { "math": "$4 \\times 3 = 12$", "note": "Four parts" } ] },
      { "q": "$\\tfrac{1}{5}$ of a group is $4$. How many in the whole group?", "a": "$20$",
        "tikz": "\\begin{tikzpicture}[x=0.6cm,y=0.7cm]\n\\draw (0,0) rectangle (5,1);\n\\foreach \\i in {1,2,3,4} \\draw (\\i,0) -- (\\i,1);\n\\fill[gray!40] (0,0) rectangle (1,1);\n\\node[above=4pt] at (0.5,1) {$4$};\n\\node[below=4pt] at (2.5,0) {$?$};\n\\end{tikzpicture}",
        "solution": [ { "math": "$\\tfrac{1}{5} = 4$", "note": "One part" }, { "math": "$5 \\times 4 = 20$", "note": "Five parts" } ] },
      { "q": "$\\tfrac{2}{3}$ of a bar is $10$. What is the whole bar?", "a": "$15$",
        "tikz": "\\begin{tikzpicture}[x=0.9cm,y=0.7cm]\n\\draw (0,0) rectangle (3,1);\n\\foreach \\i in {1,2} \\draw (\\i,0) -- (\\i,1);\n\\fill[gray!40] (0,0) rectangle (2,1);\n\\node[above=4pt] at (1,1) {$10$};\n\\node[below=4pt] at (1.5,0) {$?$};\n\\end{tikzpicture}",
        "solution": [ { "math": "$10 \\div 2 = 5$", "note": "One third" }, { "math": "$5 \\times 3 = 15$", "note": "Three thirds" } ] },
      { "q": "$\\tfrac{1}{2}$ of a number is $9$. What is the number?", "a": "$18$",
        "solution": [ { "math": "$\\tfrac{1}{2} = 9$", "note": "One part" }, { "math": "$2 \\times 9 = 18$", "note": "Two parts" } ] },
      { "q": "$\\tfrac{1}{10}$ of a number is $6$. What is the number?", "a": "$60$",
        "solution": [ { "math": "$\\tfrac{1}{10} = 6$", "note": "One part" }, { "math": "$10 \\times 6 = 60$", "note": "Ten parts" } ] },
      { "q": "$\\tfrac{3}{4}$ of a bar is $9$. What is the whole bar?", "a": "$12$",
        "tikz": "\\begin{tikzpicture}[x=0.8cm,y=0.7cm]\n\\draw (0,0) rectangle (4,1);\n\\foreach \\i in {1,2,3} \\draw (\\i,0) -- (\\i,1);\n\\fill[gray!40] (0,0) rectangle (3,1);\n\\node[above=4pt] at (1.5,1) {$9$};\n\\node[below=4pt] at (2,0) {$?$};\n\\end{tikzpicture}",
        "solution": [ { "math": "$9 \\div 3 = 3$", "note": "One quarter" }, { "math": "$3 \\times 4 = 12$", "note": "Four quarters" } ] },
      { "q": "$\\tfrac{1}{4}$ of a number is $7$. What is the number?", "a": "$28$",
        "solution": [ { "math": "$\\tfrac{1}{4} = 7$", "note": "One part" }, { "math": "$4 \\times 7 = 28$", "note": "Four parts" } ] },
      { "q": "$\\tfrac{2}{5}$ of a bar is $8$. What is the whole bar?", "a": "$20$",
        "solution": [ { "math": "$8 \\div 2 = 4$", "note": "One fifth" }, { "math": "$4 \\times 5 = 20$", "note": "Five fifths" } ] },
      { "q": "$\\tfrac{1}{3}$ of a number is $5$. What is the number?", "a": "$15$",
        "solution": [ { "math": "$\\tfrac{1}{3} = 5$", "note": "One part" }, { "math": "$3 \\times 5 = 15$", "note": "Three parts" } ] },
      { "q": "$\\tfrac{3}{5}$ of a bar is $12$. What is the whole bar?", "a": "$20$",
        "solution": [ { "math": "$12 \\div 3 = 4$", "note": "One fifth" }, { "math": "$4 \\times 5 = 20$", "note": "Five fifths" } ] }
    ],
    "development": [
      { "q": "$\\tfrac{2}{3}$ of a jar of lollies is $24$. How many lollies in the full jar?", "a": "$36$",
        "solution": [ { "math": "$24 \\div 2 = 12$", "note": "One third" }, { "math": "$12 \\times 3 = 36$", "note": "Whole jar" } ] },
      { "q": "$\\tfrac{3}{4}$ of a savings goal is $\\$90$. What is the full goal?", "a": "$\\$120$",
        "solution": [ { "math": "$90 \\div 3 = 30$", "note": "One quarter" }, { "math": "$30 \\times 4 = \\$120$", "note": "Whole goal" } ] },
      { "q": "$\\tfrac{4}{5}$ of a rope is $20$ m. How long is the whole rope?", "a": "$25$ m",
        "tikz": "\\begin{tikzpicture}[x=0.7cm,y=0.7cm]\n\\draw (0,0) rectangle (5,1);\n\\foreach \\i in {1,2,3,4} \\draw (\\i,0) -- (\\i,1);\n\\fill[gray!40] (0,0) rectangle (4,1);\n\\node[above=4pt] at (2,1) {$20$};\n\\node[below=4pt] at (2.5,0) {$?$};\n\\end{tikzpicture}",
        "solution": [ { "math": "$20 \\div 4 = 5$", "note": "One fifth" }, { "math": "$5 \\times 5 = 25 \\text{ m}$", "note": "Whole rope" } ] },
      { "q": "$\\tfrac{3}{10}$ of a crowd is $150$. How big is the whole crowd?", "a": "$500$",
        "solution": [ { "math": "$150 \\div 3 = 50$", "note": "One tenth" }, { "math": "$50 \\times 10 = 500$", "note": "Whole crowd" } ] },
      { "q": "$\\tfrac{5}{6}$ of a class is $25$. How many are in the class?", "a": "$30$",
        "solution": [ { "math": "$25 \\div 5 = 5$", "note": "One sixth" }, { "math": "$5 \\times 6 = 30$", "note": "Whole class" } ] },
      { "q": "$\\tfrac{2}{7}$ of a load of bricks is $18$. How many bricks in the load?", "a": "$63$",
        "solution": [ { "math": "$18 \\div 2 = 9$", "note": "One seventh" }, { "math": "$9 \\times 7 = 63$", "note": "Whole load" } ] },
      { "q": "$\\tfrac{3}{4}$ of a tank is $30$ L. What is the tank's full capacity?", "a": "$40$ L",
        "solution": [ { "math": "$30 \\div 3 = 10$", "note": "One quarter" }, { "math": "$10 \\times 4 = 40 \\text{ L}$", "note": "Full tank" } ] },
      { "q": "$\\tfrac{2}{5}$ of a journey is $48$ km. How long is the whole journey?", "a": "$120$ km",
        "solution": [ { "math": "$48 \\div 2 = 24$", "note": "One fifth" }, { "math": "$24 \\times 5 = 120 \\text{ km}$", "note": "Whole journey" } ] },
      { "q": "$\\tfrac{7}{10}$ of a sum of money is $\\$56$. What is the whole sum?", "a": "$\\$80$",
        "solution": [ { "math": "$56 \\div 7 = 8$", "note": "One tenth" }, { "math": "$8 \\times 10 = \\$80$", "note": "Whole sum" } ] },
      { "q": "$\\tfrac{4}{9}$ of a stack of cards is $20$. How many cards in the stack?", "a": "$45$",
        "solution": [ { "math": "$20 \\div 4 = 5$", "note": "One ninth" }, { "math": "$5 \\times 9 = 45$", "note": "Whole stack" } ] }
    ],
    "mastery": [
      { "q": "Mia spent $\\tfrac{3}{5}$ of her money, which was $\\$18$. How much did she start with?", "a": "$\\$30$",
        "solution": [ { "math": "$18 \\div 3 = 6$", "note": "One fifth" }, { "math": "$6 \\times 5 = \\$30$", "note": "Starting amount" } ] },
      { "q": "After eating $\\tfrac{2}{3}$ of the grapes, $12$ remain. How many were there to start?", "a": "$36$",
        "solution": [ { "math": "$\\tfrac{1}{3} \\text{ left} = 12$", "note": "Remaining third" }, { "math": "$12 \\times 3 = 36$", "note": "Starting amount" } ] },
      { "q": "$\\tfrac{3}{4}$ of the students passed. If $6$ failed, how many students were there?", "a": "$24$",
        "solution": [ { "math": "$\\tfrac{1}{4} \\text{ failed} = 6$", "note": "One quarter" }, { "math": "$6 \\times 4 = 24$", "note": "All students" } ] },
      { "q": "A tank is $\\tfrac{2}{5}$ full with $60$ L. How many litres does it hold when full?", "a": "$150$ L",
        "solution": [ { "math": "$60 \\div 2 = 30$", "note": "One fifth" }, { "math": "$30 \\times 5 = 150 \\text{ L}$", "note": "Full capacity" } ] },
      { "q": "After a $\\tfrac{1}{4}$ discount, a jacket cost $\\$60$. What was the original price?", "a": "$\\$80$",
        "solution": [ { "math": "$\\tfrac{3}{4} = 60$", "note": "Price paid" }, { "math": "$60 \\div 3 \\times 4 = \\$80$", "note": "Original price" } ] },
      { "q": "$\\tfrac{5}{8}$ of a book is $200$ pages. How many pages is the whole book?", "a": "$320$",
        "solution": [ { "math": "$200 \\div 5 = 40$", "note": "One eighth" }, { "math": "$40 \\times 8 = 320$", "note": "Whole book" } ] },
      { "q": "A walker has covered $\\tfrac{3}{7}$ of a trail, which is $9$ km. How long is the whole trail?", "a": "$21$ km",
        "solution": [ { "math": "$9 \\div 3 = 3$", "note": "One seventh" }, { "math": "$3 \\times 7 = 21 \\text{ km}$", "note": "Whole trail" } ] },
      { "q": "$\\tfrac{2}{3}$ of the seats are taken: $48$ people. How many seats are there altogether?", "a": "$72$",
        "solution": [ { "math": "$48 \\div 2 = 24$", "note": "One third" }, { "math": "$24 \\times 3 = 72$", "note": "All seats" } ] },
      { "q": "A bag lost $\\tfrac{1}{6}$ of its flour, leaving $2.5$ kg. How much was in it to start?", "a": "$3$ kg",
        "solution": [ { "math": "$\\tfrac{5}{6} = 2.5 \\text{ kg}$", "note": "Remaining" }, { "math": "$2.5 \\div 5 \\times 6 = 3 \\text{ kg}$", "note": "Original amount" } ] },
      { "q": "$\\tfrac{4}{5}$ of a class chose soccer, and $7$ chose another sport. How many in the class?", "a": "$35$",
        "solution": [ { "math": "$\\tfrac{1}{5} = 7$", "note": "The other fifth" }, { "math": "$7 \\times 5 = 35$", "note": "Whole class" } ] }
    ]
  }
}
