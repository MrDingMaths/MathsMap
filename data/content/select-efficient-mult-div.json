{
  "skillId": "select-efficient-mult-div",
  "atomType": "R",
  "theory": {
    "intro": "For multiplication and division you can choose a mental strategy or a written algorithm. Pick whichever is quicker and reliable for the numbers in front of you.",
    "facts": [
      "**Mental** methods suit friendly numbers: doubling/halving, multiplying by $10$ or $100$, or splitting a number into parts.",
      "**Written** methods (long/short multiplication or division) suit awkward numbers up to $4$ digits.",
      "Splitting works because $a \\times (b + c) = a \\times b + a \\times c$, e.g. $6 \\times 23 = 6 \\times 20 + 6 \\times 3$."
    ],
    "steps": [
      "Look at the numbers and decide: are they friendly enough for a mental method?",
      "If yes, use doubling, place value or splitting; if no, set out a written algorithm.",
      "Estimate first so you can check your answer is sensible."
    ]
  },
  "practice": {
    "foundation": [
      { "q": "Use a mental strategy: $7 \\times 30$.", "a": "$210$",
        "solution": [ { "math": "$7 \\times 3 = 21$", "note": "Multiply digits" }, { "math": "$= 210$", "note": "Then $\\times 10$" } ] },
      { "q": "Use halving and doubling: $5 \\times 16$.", "a": "$80$",
        "solution": [ { "math": "$5 \\times 16 = 10 \\times 8$", "note": "Double 5, halve 16" }, { "math": "$= 80$", "note": "" } ] },
      { "q": "Split to multiply: $6 \\times 23$.", "a": "$138$",
        "solution": [ { "math": "$6 \\times 20 + 6 \\times 3$", "note": "Split 23" }, { "math": "$= 120 + 18 = 138$", "note": "" } ] },
      { "q": "Use a mental strategy: $400 \\div 8$.", "a": "$50$",
        "solution": [ { "math": "$40 \\div 8 = 5$", "note": "Use the fact" }, { "math": "$400 \\div 8 = 50$", "note": "Ten times bigger" } ] },
      { "q": "Use doubling: $4 \\times 25$.", "a": "$100$",
        "solution": [ { "math": "$4 \\times 25 = 2 \\times 50$", "note": "Halve and double" }, { "math": "$= 100$", "note": "" } ] },
      { "q": "Split to multiply: $8 \\times 14$.", "a": "$112$",
        "solution": [ { "math": "$8 \\times 10 + 8 \\times 4$", "note": "Split 14" }, { "math": "$= 80 + 32 = 112$", "note": "" } ] },
      { "q": "Use a mental strategy: $90 \\div 3$.", "a": "$30$",
        "solution": [ { "math": "$9 \\div 3 = 3$", "note": "Use the fact" }, { "math": "$90 \\div 3 = 30$", "note": "" } ] },
      { "q": "Use a mental strategy: $3 \\times 200$.", "a": "$600$",
        "solution": [ { "math": "$3 \\times 2 = 6$", "note": "Multiply digits" }, { "math": "$= 600$", "note": "Then $\\times 100$" } ] },
      { "q": "Split to multiply: $5 \\times 32$.", "a": "$160$",
        "solution": [ { "math": "$5 \\times 30 + 5 \\times 2$", "note": "Split 32" }, { "math": "$= 150 + 10 = 160$", "note": "" } ] },
      { "q": "Use halving: $240 \\div 4$.", "a": "$60$",
        "solution": [ { "math": "$240 \\div 2 = 120$", "note": "Halve once" }, { "math": "$120 \\div 2 = 60$", "note": "Halve again" } ] }
    ],
    "development": [
      { "q": "Choose a method and find $24 \\times 15$.", "a": "$360$",
        "solution": [ { "math": "$24 \\times 10 + 24 \\times 5$", "note": "Split 15" }, { "math": "$= 240 + 120 = 360$", "note": "" } ] },
      { "q": "Choose a method and find $324 \\times 6$.", "a": "$1\\,944$",
        "solution": [ { "math": "$300 \\times 6 + 24 \\times 6$", "note": "Split 324" }, { "math": "$= 1\\,800 + 144 = 1\\,944$", "note": "" } ] },
      { "q": "Choose a method and find $1\\,250 \\times 8$.", "a": "$10\\,000$",
        "solution": [ { "math": "$1\\,250 \\times 8 = 1\\,250 \\times 2 \\times 4$", "note": "Double twice then $\\times 2$" }, { "math": "$= 2\\,500 \\times 4 = 10\\,000$", "note": "" } ] },
      { "q": "Choose a method and find $836 \\div 4$.", "a": "$209$",
        "solution": [ { "math": "$836 \\div 2 = 418$", "note": "Halve" }, { "math": "$418 \\div 2 = 209$", "note": "Halve again" } ] },
      { "q": "Choose a method and find $17 \\times 12$.", "a": "$204$",
        "solution": [ { "math": "$17 \\times 10 + 17 \\times 2$", "note": "Split 12" }, { "math": "$= 170 + 34 = 204$", "note": "" } ] },
      { "q": "Choose a method and find $2\\,406 \\times 3$.", "a": "$7\\,218$",
        "solution": [ { "math": "$2\\,000 \\times 3 + 400 \\times 3 + 6 \\times 3$", "note": "Split by place value" }, { "math": "$= 6\\,000 + 1\\,200 + 18 = 7\\,218$", "note": "" } ] },
      { "q": "Choose a method and find $945 \\div 5$.", "a": "$189$",
        "solution": [ { "math": "$945 \\times 2 = 1\\,890$", "note": "Dividing by 5: double then $\\div 10$" }, { "math": "$1\\,890 \\div 10 = 189$", "note": "" } ] },
      { "q": "Choose a method and find $48 \\times 25$.", "a": "$1\\,200$",
        "solution": [ { "math": "$48 \\times 25 = 12 \\times 100$", "note": "$\\times 25 = \\div 4 \\times 100$" }, { "math": "$= 1\\,200$", "note": "" } ] },
      { "q": "Choose a method and find $3\\,612 \\div 6$.", "a": "$602$",
        "solution": [ { "math": "$3\\,600 \\div 6 + 12 \\div 6$", "note": "Split 3612" }, { "math": "$= 600 + 2 = 602$", "note": "" } ] },
      { "q": "Choose a method and find $19 \\times 8$.", "a": "$152$",
        "solution": [ { "math": "$20 \\times 8 - 1 \\times 8$", "note": "Round 19 to 20" }, { "math": "$= 160 - 8 = 152$", "note": "" } ] }
    ],
    "mastery": [
      { "q": "A box holds $36$ pencils. A school orders $48$ boxes. How many pencils is that? Choose an efficient method.", "a": "$1\\,728$",
        "solution": [ { "math": "$36 \\times 48 = 36 \\times 50 - 36 \\times 2$", "note": "Round 48 to 50" }, { "math": "$= 1\\,800 - 72 = 1\\,728$", "note": "" } ] },
      { "q": "Stadium seating is arranged in $125$ rows of $32$ seats. How many seats? Choose an efficient method.", "a": "$4\\,000$",
        "solution": [ { "math": "$125 \\times 32 = 125 \\times 8 \\times 4$", "note": "$125 \\times 8 = 1\\,000$" }, { "math": "$= 1\\,000 \\times 4 = 4\\,000$", "note": "" } ] },
      { "q": "$2\\,484$ students are split equally into $4$ houses. How many per house? Choose an efficient method.", "a": "$621$",
        "solution": [ { "math": "$2\\,484 \\div 2 = 1\\,242$", "note": "Halve" }, { "math": "$1\\,242 \\div 2 = 621$", "note": "Halve again" } ] },
      { "q": "A worker earns $\\$45$ per hour and works $160$ hours. Total pay? Choose an efficient method.", "a": "$\\$7\\,200$",
        "solution": [ { "math": "$45 \\times 160 = 45 \\times 16 \\times 10$", "note": "Split off the 10" }, { "math": "$= 720 \\times 10 = 7\\,200$", "note": "" } ] },
      { "q": "A printer produces $1\\,500$ pages from each cartridge. How many pages from $6$ cartridges? Then how many cartridges for $12\\,000$ pages?", "a": "$9\\,000$ pages; $8$ cartridges",
        "solution": [ { "math": "$1\\,500 \\times 6 = 9\\,000$", "note": "Multiply" }, { "math": "$12\\,000 \\div 1\\,500 = 8$", "note": "Inverse" } ] },
      { "q": "Tickets cost $\\$18$ each. A group spends $\\$1\\,260$. How many tickets did they buy? Choose an efficient method.", "a": "$70$ tickets",
        "solution": [ { "math": "$1\\,260 \\div 18$", "note": "Both divisible by 9" }, { "math": "$= 140 \\div 2 = 70$", "note": "$\\div 9$ then $\\div 2$" } ] },
      { "q": "Explain why doubling-and-halving makes $25 \\times 28$ easy, then evaluate.", "a": "$700$",
        "solution": [ { "math": "$25 \\times 28 = 50 \\times 14 = 100 \\times 7$", "note": "Double / halve twice" }, { "math": "$= 700$", "note": "" } ] },
      { "q": "A van carries $2\\,016$ kg evenly across $3$ trips. Mass per trip? Choose an efficient method.", "a": "$672$ kg",
        "solution": [ { "math": "$2\\,016 \\div 3 = (2\\,100 - 84) \\div 3$", "note": "Split 2016" }, { "math": "$= 700 - 28 = 672$", "note": "" } ] },
      { "q": "A factory makes $24$ items per minute. How many in $8$ hours ($480$ minutes)? Choose an efficient method.", "a": "$11\\,520$ items",
        "solution": [ { "math": "$24 \\times 480 = 24 \\times 48 \\times 10$", "note": "Split off the 10" }, { "math": "$= 1\\,152 \\times 10 = 11\\,520$", "note": "" } ] },
      { "q": "Would you compute $3\\,608 \\times 7$ mentally or in writing? Justify, then evaluate.", "a": "$25\\,256$",
        "solution": [ { "math": "$3\\,000 \\times 7 + 600 \\times 7 + 8 \\times 7$", "note": "Splitting keeps it mental-ish" }, { "math": "$= 21\\,000 + 4\\,200 + 56 = 25\\,256$", "note": "" } ] }
    ]
  }
}
