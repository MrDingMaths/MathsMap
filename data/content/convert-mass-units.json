        "solution": [ { "math": "$1.5\\text{ t} = 1500\\text{ kg}$", "note": "t → kg" }, { "math": "$1500 \\times 1000 = 1\\,500\\,000\\text{ g}$", "note": "kg → g" } ] },
      { "q": "Convert $0.045\\text{ t}$ to kilograms, then to grams.", "a": "$45\\text{ kg}$, $45\\,000\\text{ g}$",
