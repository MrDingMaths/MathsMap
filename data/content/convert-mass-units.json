      { "q": "A scale shows $6\\text{ kg}$. A second shows $5800\\text{ g}$. What is the difference in grams?", "a": "$200\\text{ g}$",
        "solution": [ { "math": "$6\\text{ kg} = 6000\\text{ g}$", "note": "Same unit" }, { "math": "$6000 - 5800 = 200\\text{ g}$", "note": "Difference" } ] },
      { "q": "How many kilograms in half a tonne plus $250\\text{ kg}$?", "a": "$750\\text{ kg}$",
        "solution": [ { "math": "$0.5\\text{ t} = 500\\text{ kg}$", "note": "Convert half a tonne" }, { "math": "$500 + 250 = 750\\text{ kg}$", "note": "Add" } ] },
      { "q": "A recipe scaled up needs $0.3\\text{ kg}$ per batch for $5$ batches. Give the total in grams.", "a": "$1500\\text{ g}$",
        "solution": [ { "math": "$0.3 \\times 5 = 1.5\\text{ kg}$", "note": "Total in kg" }, { "math": "$1.5 \\times 1000 = 1500\\text{ g}$", "note": "kg → g" } ] }
    ]
