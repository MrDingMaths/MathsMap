{
  "skillId": "convert-mass-units",
  "atomType": "R",
  "theory": {
    "intro": "Mass units are linked by factors of $1000$. Convert by multiplying or dividing by $1000$.",
    "facts": [
      "$1\\text{ kg} = 1000\\text{ g}$ and $1\\text{ t} = 1000\\text{ kg}$.",
      "Going to a **smaller** unit (kg→g, t→kg): **multiply** by $1000$.",
      "Going to a **larger** unit (g→kg, kg→t): **divide** by $1000$."
    ],
    "steps": [
      "Decide if the new unit is smaller or larger.",
      "Smaller unit → multiply by $1000$; larger unit → divide by $1000$.",
      "Move the digits three places (or the decimal point)."
    ]
  },
  "practice": {
    "foundation": [
      { "q": "Convert $3\\text{ kg}$ to grams.", "a": "$3000\\text{ g}$",
        "solution": [ { "math": "$3 \\times 1000$", "note": "kg → g, multiply" }, { "math": "$= 3000\\text{ g}$", "note": "Done" } ] },
      { "q": "Convert $5000\\text{ g}$ to kilograms.", "a": "$5\\text{ kg}$",
        "solution": [ { "math": "$5000 \\div 1000$", "note": "g → kg, divide" }, { "math": "$= 5\\text{ kg}$", "note": "Done" } ] },
      { "q": "Convert $2\\text{ t}$ to kilograms.", "a": "$2000\\text{ kg}$",
