{
  "skillId": "calculate-elapsed-time",
  "atomType": "R",
  "theory": {
    "intro": "Elapsed time is how much time passes between a start time and a finish time. Count on from the start, jumping to easy 'landmark' times.",
    "facts": [
      "There are $60$ minutes in $1$ hour, so times 'roll over' at $60$, not $100$.",
      "**Count on** in steps: first up to the next o'clock, then whole hours, then the leftover minutes.",
      "In $24$-hour time, afternoon hours are $12$ to $23$; e.g. $2{:}30$ pm $= 14{:}30$."
    ],
    "steps": [
      "Write the start time and the finish time.",
      "Count on to the next full hour, then add whole hours, then the remaining minutes.",
      "Add the jumps together to get the elapsed time."
    ]
  },
  "practice": {
    "foundation": [
      { "q": "A movie starts at $3{:}00$ pm and finishes at $5{:}00$ pm. How long is it?", "a": "$2$ h",
        "solution": [ { "math": "$3{:}00 \\to 5{:}00$", "note": "Count whole hours" }, { "math": "$= 2 \\text{ h}$", "note": "" } ] },
      { "q": "A lesson runs from $9{:}00$ am to $9{:}45$ am. How long is it?", "a": "$45$ min",
        "solution": [ { "math": "$9{:}00 \\to 9{:}45$", "note": "Count minutes" }, { "math": "$= 45 \\text{ min}$", "note": "" } ] },
      { "q": "A train leaves at $10{:}15$ and arrives at $10{:}50$. How long is the trip?", "a": "$35$ min",
        "solution": [ { "math": "$50 - 15 = 35$", "note": "Same hour" }, { "math": "$= 35 \\text{ min}$", "note": "" } ] },
      { "q": "A swim starts at $4{:}00$ pm and ends at $4{:}30$ pm. How long is it?", "a": "$30$ min",
        "solution": [ { "math": "$4{:}00 \\to 4{:}30$", "note": "Count minutes" }, { "math": "$= 30 \\text{ min}$", "note": "" } ] },
      { "q": "School begins at $9{:}00$ am and recess is at $11{:}00$ am. How long until recess?", "a": "$2$ h",
        "solution": [ { "math": "$9{:}00 \\to 11{:}00$", "note": "Count whole hours" }, { "math": "$= 2 \\text{ h}$", "note": "" } ] },
      { "q": "A bus departs at $7{:}20$ and arrives at $7{:}55$. How long is the journey?", "a": "$35$ min",
        "solution": [ { "math": "$55 - 20 = 35$", "note": "Same hour" }, { "math": "$= 35 \\text{ min}$", "note": "" } ] },
      { "q": "A flight leaves at $1{:}00$ pm and lands at $4{:}00$ pm. How long is it?", "a": "$3$ h",
        "solution": [ { "math": "$1{:}00 \\to 4{:}00$", "note": "Count whole hours" }, { "math": "$= 3 \\text{ h}$", "note": "" } ] },
      { "q": "A cartoon runs from $6{:}10$ pm to $6{:}40$ pm. How long is it?", "a": "$30$ min",
        "solution": [ { "math": "$40 - 10 = 30$", "note": "Same hour" }, { "math": "$= 30 \\text{ min}$", "note": "" } ] },
      { "q": "A class starts at $2{:}00$ pm and ends at $3{:}15$ pm. How long is it?", "a": "$1$ h $15$ min",
        "solution": [ { "math": "$2{:}00 \\to 3{:}00$", "note": "$1$ h" }, { "math": "$3{:}00 \\to 3{:}15 = 1 \\text{ h } 15 \\text{ min}$", "note": "Add minutes" } ] },
      { "q": "A walk starts at $8{:}30$ am and ends at $9{:}00$ am. How long is it?", "a": "$30$ min",
        "solution": [ { "math": "$8{:}30 \\to 9{:}00$", "note": "Count up to the hour" }, { "math": "$= 30 \\text{ min}$", "note": "" } ] }
    ],
    "development": [
      { "q": "A train leaves at $9{:}40$ am and arrives at $11{:}10$ am. How long is the trip?", "a": "$1$ h $30$ min",
        "solution": [ { "math": "$9{:}40 \\to 11{:}40$", "note": "$2$ h is too far" }, { "math": "$9{:}40 \\to 11{:}10 = 1 \\text{ h } 30 \\text{ min}$", "note": "Count on" } ] },
      { "q": "A movie starts at $7{:}50$ pm and finishes at $9{:}35$ pm. How long is it?", "a": "$1$ h $45$ min",
        "solution": [ { "math": "$7{:}50 \\to 8{:}00 = 10 \\text{ min}$", "note": "Up to the hour" }, { "math": "$8{:}00 \\to 9{:}35 = 1 \\text{ h } 35 \\text{ min}$", "note": "Total $1$ h $45$ min" } ] },
      { "q": "A flight departs $14{:}25$ and lands $16{:}05$. How long is it?", "a": "$1$ h $40$ min",
        "solution": [ { "math": "$14{:}25 \\to 16{:}25 = 2 \\text{ h}$", "note": "Too far by $20$ min" }, { "math": "$16{:}25 - 16{:}05 = 20 \\text{ min} \\Rightarrow 1 \\text{ h } 40 \\text{ min}$", "note": "" } ] },
      { "q": "School runs $8{:}55$ am to $3{:}10$ pm. How long is the school day?", "a": "$6$ h $15$ min",
        "solution": [ { "math": "$8{:}55 \\to 3{:}55 = 7 \\text{ h}$", "note": "Too far" }, { "math": "$3{:}55 - 3{:}10 = 45 \\text{ min} \\Rightarrow 6 \\text{ h } 15 \\text{ min}$", "note": "" } ] },
      { "q": "A bus leaves $10{:}45$ and arrives $12{:}20$. How long is the trip?", "a": "$1$ h $35$ min",
        "solution": [ { "math": "$10{:}45 \\to 12{:}00 = 1 \\text{ h } 15 \\text{ min}$", "note": "Up to noon" }, { "math": "$12{:}00 \\to 12{:}20 = 20 \\text{ min} \\Rightarrow 1 \\text{ h } 35 \\text{ min}$", "note": "" } ] },
      { "q": "A train ride is from $13{:}50$ to $15{:}25$. How long is it?", "a": "$1$ h $35$ min",
        "solution": [ { "math": "$13{:}50 \\to 15{:}50 = 2 \\text{ h}$", "note": "Too far by $25$ min" }, { "math": "$15{:}50 - 15{:}25 = 25 \\text{ min} \\Rightarrow 1 \\text{ h } 35 \\text{ min}$", "note": "" } ] },
      { "q": "A concert starts $7{:}40$ pm and ends $10{:}15$ pm. How long is it?", "a": "$2$ h $35$ min",
        "solution": [ { "math": "$7{:}40 \\to 10{:}40 = 3 \\text{ h}$", "note": "Too far by $25$ min" }, { "math": "$10{:}40 - 10{:}15 = 25 \\text{ min} \\Rightarrow 2 \\text{ h } 35 \\text{ min}$", "note": "" } ] },
      { "q": "A flight departs $11{:}35$ am and lands $1{:}05$ pm. How long is it?", "a": "$1$ h $30$ min",
        "solution": [ { "math": "$11{:}35 \\to 12{:}35 = 1 \\text{ h}$", "note": "Past noon" }, { "math": "$12{:}35 \\to 1{:}05 = 30 \\text{ min} \\Rightarrow 1 \\text{ h } 30 \\text{ min}$", "note": "" } ] },
      { "q": "A class starts $9{:}25$ am and runs for the morning, ending $12{:}40$ pm. How long is it?", "a": "$3$ h $15$ min",
        "solution": [ { "math": "$9{:}25 \\to 12{:}25 = 3 \\text{ h}$", "note": "" }, { "math": "$12{:}25 \\to 12{:}40 = 15 \\text{ min} \\Rightarrow 3 \\text{ h } 15 \\text{ min}$", "note": "" } ] },
      { "q": "A ferry leaves $16{:}50$ and arrives $18{:}30$. How long is the crossing?", "a": "$1$ h $40$ min",
        "solution": [ { "math": "$16{:}50 \\to 18{:}50 = 2 \\text{ h}$", "note": "Too far by $20$ min" }, { "math": "$18{:}50 - 18{:}30 = 20 \\text{ min} \\Rightarrow 1 \\text{ h } 40 \\text{ min}$", "note": "" } ] }
    ],
    "mastery": [
      { "q": "A train leaves at $11{:}48$ am and arrives at $2{:}33$ pm. How long is the journey?", "a": "$2$ h $45$ min",
        "solution": [ { "math": "$11{:}48 \\to 12{:}00 = 12 \\text{ min}$", "note": "Up to noon" }, { "math": "$12{:}00 \\to 2{:}33 = 2 \\text{ h } 33 \\text{ min} \\Rightarrow 2 \\text{ h } 45 \\text{ min}$", "note": "" } ] },
      { "q": "A flight departs Sydney $22{:}15$ and lands $1{:}40$ the next morning. How long is it?", "a": "$3$ h $25$ min",
        "solution": [ { "math": "$22{:}15 \\to 24{:}00 = 1 \\text{ h } 45 \\text{ min}$", "note": "Up to midnight" }, { "math": "$00{:}00 \\to 1{:}40 = 1 \\text{ h } 40 \\text{ min} \\Rightarrow 3 \\text{ h } 25 \\text{ min}$", "note": "" } ] },
      { "q": "A movie marathon runs from $6{:}50$ pm to $11{:}05$ pm. How long is it?", "a": "$4$ h $15$ min",
        "solution": [ { "math": "$6{:}50 \\to 11{:}50 = 5 \\text{ h}$", "note": "Too far by $45$ min" }, { "math": "$11{:}50 - 11{:}05 = 45 \\text{ min} \\Rightarrow 4 \\text{ h } 15 \\text{ min}$", "note": "" } ] },
      { "q": "A bus leaves $13{:}37$ and arrives $16{:}12$. How long is the trip?", "a": "$2$ h $35$ min",
        "solution": [ { "math": "$13{:}37 \\to 16{:}37 = 3 \\text{ h}$", "note": "Too far by $25$ min" }, { "math": "$16{:}37 - 16{:}12 = 25 \\text{ min} \\Rightarrow 2 \\text{ h } 35 \\text{ min}$", "note": "" } ] },
      { "q": "A worker starts at $8{:}45$ am, takes a $45$-minute break, and finishes at $5{:}15$ pm. How long do they actually work?", "a": "$7$ h $45$ min",
        "solution": [ { "math": "$8{:}45 \\to 17{:}15 = 8 \\text{ h } 30 \\text{ min}$", "note": "Total time at work" }, { "math": "$8 \\text{ h } 30 - 45 \\text{ min} = 7 \\text{ h } 45 \\text{ min}$", "note": "Subtract break" } ] },
      { "q": "A flight departs $23{:}55$ and lands $4{:}25$ next day. How long is it?", "a": "$4$ h $30$ min",
        "solution": [ { "math": "$23{:}55 \\to 24{:}00 = 5 \\text{ min}$", "note": "Up to midnight" }, { "math": "$00{:}00 \\to 4{:}25 = 4 \\text{ h } 25 \\text{ min} \\Rightarrow 4 \\text{ h } 30 \\text{ min}$", "note": "" } ] },
      { "q": "A train trip from $9{:}38$ am to $12{:}06$ pm includes a $14$-minute stop. How long is it moving?", "a": "$2$ h $14$ min",
        "solution": [ { "math": "$9{:}38 \\to 12{:}06 = 2 \\text{ h } 28 \\text{ min}$", "note": "Total" }, { "math": "$2 \\text{ h } 28 - 14 \\text{ min} = 2 \\text{ h } 14 \\text{ min}$", "note": "Subtract stop" } ] },
      { "q": "A school excursion leaves $8{:}20$ am and returns $2{:}55$ pm. How long is the excursion?", "a": "$6$ h $35$ min",
        "solution": [ { "math": "$8{:}20 \\to 2{:}20 \\text{ pm} = 6 \\text{ h}$", "note": "" }, { "math": "$2{:}20 \\to 2{:}55 = 35 \\text{ min} \\Rightarrow 6 \\text{ h } 35 \\text{ min}$", "note": "" } ] },
      { "q": "Two events: A runs $14{:}05$ to $15{:}50$, B runs $16{:}10$ to $17{:}40$. Which is longer, and by how much?", "a": "A, by $15$ min",
        "solution": [ { "math": "A $= 1 \\text{ h } 45 \\text{ min},\\ \\text{B} = 1 \\text{ h } 30 \\text{ min}$", "note": "Each duration" }, { "math": "$1\\text{ h }45 - 1\\text{ h }30 = 15 \\text{ min}$", "note": "A is longer" } ] },
      { "q": "A ferry leaves $10{:}52$ am and the next one is $3$ h $20$ min later. What time does the next leave?", "a": "$2{:}12$ pm",
        "solution": [ { "math": "$10{:}52 + 3 \\text{ h} = 1{:}52 \\text{ pm}$", "note": "Add hours" }, { "math": "$1{:}52 + 20 \\text{ min} = 2{:}12 \\text{ pm}$", "note": "Add minutes" } ] }
    ]
  }
}
