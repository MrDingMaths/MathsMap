{
  "skillId": "perimeter-area-same-comparison",
  "atomType": "R",
  "theory": {
    "intro": "Two rectangles can have the **same area** but **different perimeters**. A long, thin rectangle has a larger perimeter than a more square one of equal area.",
    "facts": [
      "**Area** of a rectangle $= \\text{length} \\times \\text{width}$.",
      "**Perimeter** $= 2 \\times (\\text{length} + \\text{width})$.",
      "For a fixed area, the closer the rectangle is to a **square**, the **smaller** its perimeter."
    ],
    "steps": [
      "Find the area of each rectangle (should match).",
      "Find the perimeter of each rectangle.",
      "Compare the perimeters."
    ]
  },
  "practice": {
    "foundation": [
      { "q": "Find the perimeter of this rectangle.", "a": "$16$ units",
        "tikz": "\\begin{tikzpicture}[x=0.5cm,y=0.5cm]\n\\draw (0,0) rectangle (6,2);\n\\node[below] at (3,0) {$6$};\n\\node[left] at (0,1) {$2$};\n\\end{tikzpicture}",
        "solution": [ { "math": "$2 \\times (6 + 2)$", "note": "Perimeter formula" }, { "math": "$= 16$", "note": "" } ] },
      { "q": "Find the area of this rectangle.", "a": "$12$ square units",
        "tikz": "\\begin{tikzpicture}[x=0.5cm,y=0.5cm]\n\\draw (0,0) rectangle (6,2);\n\\node[below] at (3,0) {$6$};\n\\node[left] at (0,1) {$2$};\n\\end{tikzpicture}",
        "solution": [ { "math": "$6 \\times 2$", "note": "Area formula" }, { "math": "$= 12$", "note": "" } ] },
      { "q": "Find the perimeter of this rectangle.", "a": "$14$ units",
        "tikz": "\\begin{tikzpicture}[x=0.5cm,y=0.5cm]\n\\draw (0,0) rectangle (4,3);\n\\node[below] at (2,0) {$4$};\n\\node[left] at (0,1.5) {$3$};\n\\end{tikzpicture}",
        "solution": [ { "math": "$2 \\times (4 + 3)$", "note": "Perimeter formula" }, { "math": "$= 14$", "note": "" } ] },
      { "q": "Find the area of this rectangle.", "a": "$12$ square units",
        "tikz": "\\begin{tikzpicture}[x=0.5cm,y=0.5cm]\n\\draw (0,0) rectangle (4,3);\n\\node[below] at (2,0) {$4$};\n\\node[left] at (0,1.5) {$3$};\n\\end{tikzpicture}",
        "solution": [ { "math": "$4 \\times 3$", "note": "Area formula" }, { "math": "$= 12$", "note": "" } ] },
      { "q": "Two rectangles each have area $12$. One is $6 \\times 2$, the other $4 \\times 3$. Which has the larger perimeter?", "a": "The $6 \\times 2$ rectangle",
        "solution": [ { "math": "$P_1 = 16,\\ P_2 = 14$", "note": "Perimeters" }, { "math": "$16 > 14$", "note": "Long-thin is larger" } ] },
      { "q": "Find the perimeter of this rectangle.", "a": "$20$ units",
        "tikz": "\\begin{tikzpicture}[x=0.5cm,y=0.5cm]\n\\draw (0,0) rectangle (8,2);\n\\node[below] at (4,0) {$8$};\n\\node[left] at (0,1) {$2$};\n\\end{tikzpicture}",
        "solution": [ { "math": "$2 \\times (8 + 2)$", "note": "Perimeter formula" }, { "math": "$= 20$", "note": "" } ] },
      { "q": "Find the perimeter of this square.", "a": "$16$ units",
        "tikz": "\\begin{tikzpicture}[x=0.5cm,y=0.5cm]\n\\draw (0,0) rectangle (4,4);\n\\node[below] at (2,0) {$4$};\n\\node[left] at (0,2) {$4$};\n\\end{tikzpicture}",
        "solution": [ { "math": "$4 \\times 4$", "note": "Four equal sides" }, { "math": "$= 16$", "note": "" } ] },
      { "q": "Two rectangles each have area $16$. One is $8 \\times 2$, the other $4 \\times 4$. Which has the smaller perimeter?", "a": "The $4 \\times 4$ square",
        "solution": [ { "math": "$P_1 = 20,\\ P_2 = 16$", "note": "Perimeters" }, { "math": "$16 < 20$", "note": "Square is smaller" } ] },
      { "q": "Find the area of this rectangle.", "a": "$16$ square units",
        "tikz": "\\begin{tikzpicture}[x=0.5cm,y=0.5cm]\n\\draw (0,0) rectangle (8,2);\n\\node[below] at (4,0) {$8$};\n\\node[left] at (0,1) {$2$};\n\\end{tikzpicture}",
        "solution": [ { "math": "$8 \\times 2$", "note": "Area formula" }, { "math": "$= 16$", "note": "" } ] },
      { "q": "Find the perimeter of this rectangle.", "a": "$22$ units",
        "tikz": "\\begin{tikzpicture}[x=0.5cm,y=0.5cm]\n\\draw (0,0) rectangle (9,2);\n\\node[below] at (4.5,0) {$9$};\n\\node[left] at (0,1) {$2$};\n\\end{tikzpicture}",
        "solution": [ { "math": "$2 \\times (9 + 2)$", "note": "Perimeter formula" }, { "math": "$= 22$", "note": "" } ] }
    ],
    "development": [
      { "q": "Both rectangles have area $24$. Find each perimeter and say which is larger.", "a": "$12 \\times 2$: $P = 28$; $6 \\times 4$: $P = 20$. The $12 \\times 2$ is larger.",
        "tikz": "\\begin{tikzpicture}[x=0.4cm,y=0.4cm]\n\\draw (0,0) rectangle (12,2);\n\\node[below] at (6,0) {$12$}; \\node[left] at (0,1) {$2$};\n\\draw (0,-5) rectangle (6,-1);\n\\node[below] at (3,-5) {$6$}; \\node[left] at (0,-3) {$4$};\n\\end{tikzpicture}",
        "solution": [ { "math": "$2(12+2)=28$", "note": "Long-thin" }, { "math": "$2(6+4)=20$", "note": "$28 > 20$" } ] },
      { "q": "A rectangle is $10 \\times 3$. Find its area and perimeter.", "a": "Area $30$, perimeter $26$",
        "tikz": "\\begin{tikzpicture}[x=0.4cm,y=0.4cm]\n\\draw (0,0) rectangle (10,3);\n\\node[below] at (5,0) {$10$};\n\\node[left] at (0,1.5) {$3$};\n\\end{tikzpicture}",
        "solution": [ { "math": "$10 \\times 3 = 30$", "note": "Area" }, { "math": "$2(10+3)=26$", "note": "Perimeter" } ] },
      { "q": "Another rectangle with area $30$ is $6 \\times 5$. Find its perimeter and compare with a $10 \\times 3$ ($P = 26$).", "a": "$P = 22$, smaller than $26$",
        "tikz": "\\begin{tikzpicture}[x=0.4cm,y=0.4cm]\n\\draw (0,0) rectangle (6,5);\n\\node[below] at (3,0) {$6$};\n\\node[left] at (0,2.5) {$5$};\n\\end{tikzpicture}",
        "solution": [ { "math": "$2(6+5)=22$", "note": "Perimeter" }, { "math": "$22 < 26$", "note": "Closer to square" } ] },
      { "q": "List the whole-number rectangles with area $18$ and find which has the smallest perimeter.", "a": "$1\\times18, 2\\times9, 3\\times6$; smallest is $3\\times6$ ($P=18$)",
        "solution": [ { "math": "$P: 38,\\ 22,\\ 18$", "note": "Perimeters" }, { "math": "$3 \\times 6 \\Rightarrow 18$", "note": "Closest to square" } ] },
      { "q": "Two rectangles have area $20$. One is $5 \\times 4$. The other is $10 \\times 2$. Which uses more fencing?", "a": "The $10 \\times 2$ ($P = 24$ vs $18$)",
        "solution": [ { "math": "$2(10+2)=24$", "note": "Long-thin" }, { "math": "$2(5+4)=18$", "note": "$24 > 18$" } ] },
      { "q": "A $7 \\times 2$ rectangle has area $14$. What is its perimeter?", "a": "$18$ units",
        "tikz": "\\begin{tikzpicture}[x=0.4cm,y=0.4cm]\n\\draw (0,0) rectangle (7,2);\n\\node[below] at (3.5,0) {$7$};\n\\node[left] at (0,1) {$2$};\n\\end{tikzpicture}",
        "solution": [ { "math": "$2(7+2)$", "note": "Perimeter" }, { "math": "$= 18$", "note": "" } ] },
      { "q": "For area $36$, compare the perimeters of $36 \\times 1$ and $6 \\times 6$.", "a": "$36\\times1$: $74$; $6\\times6$: $24$. Square is far smaller.",
        "solution": [ { "math": "$2(36+1)=74$", "note": "Very long-thin" }, { "math": "$2(6+6)=24$", "note": "Square smallest" } ] },
      { "q": "Two rectangles have area $48$: $8 \\times 6$ and $16 \\times 3$. Which has the larger perimeter?", "a": "The $16 \\times 3$ ($P = 38$ vs $28$)",
        "solution": [ { "math": "$2(16+3)=38$", "note": "Long-thin" }, { "math": "$2(8+6)=28$", "note": "$38 > 28$" } ] },
      { "q": "A square has area $25$. What is its perimeter?", "a": "$20$ units",
        "tikz": "\\begin{tikzpicture}[x=0.4cm,y=0.4cm]\n\\draw (0,0) rectangle (5,5);\n\\node[below] at (2.5,0) {$5$};\n\\node[left] at (0,2.5) {$5$};\n\\end{tikzpicture}",
        "solution": [ { "math": "$\\text{side} = \\sqrt{25} = 5$", "note": "Square side" }, { "math": "$4 \\times 5 = 20$", "note": "Perimeter" } ] },
      { "q": "True or false: rectangles with equal areas always have equal perimeters.", "a": "False",
        "solution": [ { "math": "$6\\times2: P=16$", "note": "Area 12" }, { "math": "$4\\times3: P=14$", "note": "Different perimeter" } ] }
    ],
    "mastery": [
      { "q": "A farmer has $40$ m of fencing for a rectangular pen of area $96$ m². The pen is $12$ m by $8$ m. Is $40$ m enough?", "a": "Yes — perimeter is exactly $40$ m",
        "solution": [ { "math": "$2(12+8)$", "note": "Perimeter" }, { "math": "$= 40 \\text{ m}$", "note": "Just enough" } ] },
      { "q": "Of all whole-number rectangles with area $100$, which has the smallest perimeter?", "a": "$10 \\times 10$, perimeter $40$",
        "solution": [ { "math": "$\\text{closest to square}$", "note": "$10 \\times 10$" }, { "math": "$4 \\times 10 = 40$", "note": "Smallest perimeter" } ] },
      { "q": "Two gardens each cover $60$ m². One is $20 \\times 3$, one is $10 \\times 6$. How much more edging does the first need?", "a": "$14$ m more",
        "solution": [ { "math": "$2(20+3)=46,\\ 2(10+6)=32$", "note": "Perimeters" }, { "math": "$46 - 32 = 14 \\text{ m}$", "note": "" } ] },
      { "q": "A $4 \\times 9$ rug and a $6 \\times 6$ rug both have area $36$. Which needs more braid around the edge?", "a": "The $4 \\times 9$ ($P = 26$ vs $24$)",
        "solution": [ { "math": "$2(4+9)=26$", "note": "First rug" }, { "math": "$2(6+6)=24$", "note": "$26 > 24$" } ] },
      { "q": "A rectangle has area $20$ and perimeter $18$. Find its dimensions.", "a": "$5 \\times 4$",
        "solution": [ { "math": "$l + w = 9,\\ lw = 20$", "note": "From $P$ and area" }, { "math": "$5 \\times 4$", "note": "Fits both" } ] },
      { "q": "Why does a long thin rectangle waste more fencing than a square of the same area?", "a": "It has a larger perimeter for the same area",
        "solution": [ { "math": "$\\text{e.g. } 1\\times16 \\text{ vs } 4\\times4$", "note": "Both area 16" }, { "math": "$34 > 16$", "note": "More edge" } ] },
      { "q": "A path borders a $15 \\times 4$ vegetable patch (area $60$). Compare its perimeter with a $12 \\times 5$ patch.", "a": "$15\\times4$: $38$ m; $12\\times5$: $34$ m. The first is longer.",
        "solution": [ { "math": "$2(15+4)=38$", "note": "First patch" }, { "math": "$2(12+5)=34$", "note": "$38 > 34$" } ] },
      { "q": "List whole-number rectangles of area $16$ and order them by perimeter, smallest first.", "a": "$4\\times4$ ($16$), $2\\times8$ ($20$), $1\\times16$ ($34$)",
        "solution": [ { "math": "$P: 16,\\ 20,\\ 34$", "note": "Perimeters" }, { "math": "$\\text{square smallest}$", "note": "" } ] },
      { "q": "A $9 \\times 4$ flag and a $6 \\times 6$ flag both have area $36$. If braid costs $\\$2$ per metre, how much more does the $9\\times4$ flag cost to edge?", "a": "$\\$4$ more",
        "solution": [ { "math": "$P: 26 \\text{ vs } 24 \\Rightarrow 2 \\text{ m}$", "note": "Extra length" }, { "math": "$2 \\times \\$2 = \\$4$", "note": "" } ] },
      { "q": "A rectangle with area $48$ has the largest possible perimeter using whole numbers. Find it.", "a": "$48 \\times 1$, perimeter $98$",
        "solution": [ { "math": "$\\text{thinnest rectangle}$", "note": "$48 \\times 1$" }, { "math": "$2(48+1)=98$", "note": "Largest perimeter" } ] }
    ]
  }
}
