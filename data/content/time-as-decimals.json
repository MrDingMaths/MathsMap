{
  "skillId": "time-as-decimals",
  "atomType": "R",
  "theory": {
    "intro": "A part of an hour can be written as a fraction or a decimal of an hour. Since $60$ minutes make $1$ hour, each minute is $\\tfrac{1}{60}$ of an hour.",
    "facts": [
      "$15$ min $= \\tfrac{15}{60} = \\tfrac{1}{4}$ h $= 0.25$ h; $30$ min $= \\tfrac{1}{2}$ h $= 0.5$ h; $45$ min $= \\tfrac{3}{4}$ h $= 0.75$ h.",
      "To convert minutes to a decimal of an hour, **divide the minutes by $60$**.",
      "Beware: $2$ h $15$ min is **not** $2.15$ h — it is $2.25$ h, because $15$ min $= 0.25$ h."
    ],
    "steps": [
      "Take the minutes part and divide by $60$ to get a decimal.",
      "Add this to the whole number of hours.",
      "Write the total as a decimal number of hours."
    ]
  },
  "practice": {
    "foundation": [
      { "q": "Write $30$ min as a decimal of an hour.", "a": "$0.5$ h",
        "solution": [ { "math": "$\\tfrac{30}{60} = \\tfrac{1}{2}$", "note": "Half an hour" }, { "math": "$= 0.5 \\text{ h}$", "note": "" } ] },
      { "q": "Write $15$ min as a decimal of an hour.", "a": "$0.25$ h",
        "solution": [ { "math": "$\\tfrac{15}{60} = \\tfrac{1}{4}$", "note": "Quarter hour" }, { "math": "$= 0.25 \\text{ h}$", "note": "" } ] },
      { "q": "Write $45$ min as a decimal of an hour.", "a": "$0.75$ h",
        "solution": [ { "math": "$\\tfrac{45}{60} = \\tfrac{3}{4}$", "note": "Three quarters" }, { "math": "$= 0.75 \\text{ h}$", "note": "" } ] },
      { "q": "Write $2$ h $30$ min as a decimal.", "a": "$2.5$ h",
        "solution": [ { "math": "$30 \\text{ min} = 0.5 \\text{ h}$", "note": "Half hour" }, { "math": "$2 + 0.5 = 2.5 \\text{ h}$", "note": "" } ] },
      { "q": "Write $1$ h $15$ min as a decimal.", "a": "$1.25$ h",
        "solution": [ { "math": "$15 \\text{ min} = 0.25 \\text{ h}$", "note": "Quarter hour" }, { "math": "$1 + 0.25 = 1.25 \\text{ h}$", "note": "" } ] },
      { "q": "Write $3$ h $45$ min as a decimal.", "a": "$3.75$ h",
        "solution": [ { "math": "$45 \\text{ min} = 0.75 \\text{ h}$", "note": "Three quarters" }, { "math": "$3 + 0.75 = 3.75 \\text{ h}$", "note": "" } ] },
      { "q": "Write $0.5$ h in minutes.", "a": "$30$ min",
        "solution": [ { "math": "$0.5 \\times 60$", "note": "Decimal to minutes" }, { "math": "$= 30 \\text{ min}$", "note": "" } ] },
      { "q": "Write $0.25$ h in minutes.", "a": "$15$ min",
        "solution": [ { "math": "$0.25 \\times 60$", "note": "Decimal to minutes" }, { "math": "$= 15 \\text{ min}$", "note": "" } ] },
      { "q": "Write $6$ min as a decimal of an hour.", "a": "$0.1$ h",
        "solution": [ { "math": "$\\tfrac{6}{60} = \\tfrac{1}{10}$", "note": "One tenth" }, { "math": "$= 0.1 \\text{ h}$", "note": "" } ] },
      { "q": "Write $1$ h $30$ min as a decimal.", "a": "$1.5$ h",
        "solution": [ { "math": "$30 \\text{ min} = 0.5 \\text{ h}$", "note": "Half hour" }, { "math": "$1 + 0.5 = 1.5 \\text{ h}$", "note": "" } ] }
    ],
    "development": [
      { "q": "Write $12$ min as a decimal of an hour.", "a": "$0.2$ h",
        "solution": [ { "math": "$\\tfrac{12}{60} = \\tfrac{1}{5}$", "note": "One fifth" }, { "math": "$= 0.2 \\text{ h}$", "note": "" } ] },
      { "q": "Write $2$ h $12$ min as a decimal.", "a": "$2.2$ h",
        "solution": [ { "math": "$12 \\text{ min} = 0.2 \\text{ h}$", "note": "$\\tfrac{12}{60}$" }, { "math": "$2 + 0.2 = 2.2 \\text{ h}$", "note": "" } ] },
      { "q": "Write $36$ min as a decimal of an hour.", "a": "$0.6$ h",
        "solution": [ { "math": "$\\tfrac{36}{60} = \\tfrac{3}{5}$", "note": "Three fifths" }, { "math": "$= 0.6 \\text{ h}$", "note": "" } ] },
      { "q": "Write $0.75$ h in minutes.", "a": "$45$ min",
        "solution": [ { "math": "$0.75 \\times 60$", "note": "Decimal to minutes" }, { "math": "$= 45 \\text{ min}$", "note": "" } ] },
      { "q": "Write $1.4$ h in hours and minutes.", "a": "$1$ h $24$ min",
        "solution": [ { "math": "$0.4 \\times 60 = 24$", "note": "Decimal part" }, { "math": "$= 1 \\text{ h } 24 \\text{ min}$", "note": "" } ] },
      { "q": "Write $3$ h $6$ min as a decimal.", "a": "$3.1$ h",
        "solution": [ { "math": "$6 \\text{ min} = 0.1 \\text{ h}$", "note": "$\\tfrac{6}{60}$" }, { "math": "$3 + 0.1 = 3.1 \\text{ h}$", "note": "" } ] },
      { "q": "Write $48$ min as a decimal of an hour.", "a": "$0.8$ h",
        "solution": [ { "math": "$\\tfrac{48}{60} = \\tfrac{4}{5}$", "note": "Four fifths" }, { "math": "$= 0.8 \\text{ h}$", "note": "" } ] },
      { "q": "Write $2.25$ h in hours and minutes.", "a": "$2$ h $15$ min",
        "solution": [ { "math": "$0.25 \\times 60 = 15$", "note": "Decimal part" }, { "math": "$= 2 \\text{ h } 15 \\text{ min}$", "note": "" } ] },
      { "q": "A run takes $1$ h $45$ min. Write this as a decimal of an hour.", "a": "$1.75$ h",
        "solution": [ { "math": "$45 \\text{ min} = 0.75 \\text{ h}$", "note": "Three quarters" }, { "math": "$1 + 0.75 = 1.75 \\text{ h}$", "note": "" } ] },
      { "q": "Write $24$ min as a decimal of an hour.", "a": "$0.4$ h",
        "solution": [ { "math": "$\\tfrac{24}{60} = \\tfrac{2}{5}$", "note": "Two fifths" }, { "math": "$= 0.4 \\text{ h}$", "note": "" } ] }
    ],
    "mastery": [
      { "q": "A worker is paid for $7$ h $30$ min at $\\$24$ per hour. How much is earned?", "a": "$\\$180$",
        "solution": [ { "math": "$7 \\text{ h } 30 \\text{ min} = 7.5 \\text{ h}$", "note": "$30$ min $= 0.5$ h" }, { "math": "$7.5 \\times 24 = \\$180$", "note": "" } ] },
      { "q": "Write $10$ min as a decimal of an hour, to two places.", "a": "$0.17$ h",
        "solution": [ { "math": "$\\tfrac{10}{60} = 0.1\\overline{6}$", "note": "Divide by $60$" }, { "math": "$\\approx 0.17 \\text{ h}$", "note": "Two decimal places" } ] },
      { "q": "A flight lasts $2.75$ h. Write this in hours and minutes.", "a": "$2$ h $45$ min",
        "solution": [ { "math": "$0.75 \\times 60 = 45$", "note": "Decimal part" }, { "math": "$= 2 \\text{ h } 45 \\text{ min}$", "note": "" } ] },
      { "q": "A car is hired for $3$ h $15$ min at $\\$12$ per hour. What is the cost?", "a": "$\\$39$",
        "solution": [ { "math": "$3 \\text{ h } 15 \\text{ min} = 3.25 \\text{ h}$", "note": "$15$ min $= 0.25$ h" }, { "math": "$3.25 \\times 12 = \\$39$", "note": "" } ] },
      { "q": "Write $1.8$ h in hours and minutes.", "a": "$1$ h $48$ min",
        "solution": [ { "math": "$0.8 \\times 60 = 48$", "note": "Decimal part" }, { "math": "$= 1 \\text{ h } 48 \\text{ min}$", "note": "" } ] },
      { "q": "A student claims $4$ h $30$ min $= 4.30$ h. Correct this.", "a": "$4.5$ h",
        "solution": [ { "math": "$30 \\text{ min} = \\tfrac{30}{60} = 0.5 \\text{ h}$", "note": "Not $0.30$" }, { "math": "$4 + 0.5 = 4.5 \\text{ h}$", "note": "" } ] },
      { "q": "Two tasks take $1.25$ h and $0.75$ h. What is the total in hours and minutes?", "a": "$2$ h",
        "solution": [ { "math": "$1.25 + 0.75 = 2.0 \\text{ h}$", "note": "Add decimals" }, { "math": "$= 2 \\text{ h } 0 \\text{ min}$", "note": "" } ] },
      { "q": "A movie of $2.5$ h starts at $7{:}45$ pm. When does it finish?", "a": "$10{:}15$ pm",
        "solution": [ { "math": "$2.5 \\text{ h} = 2 \\text{ h } 30 \\text{ min}$", "note": "Convert" }, { "math": "$7{:}45 + 2{:}30 = 10{:}15 \\text{ pm}$", "note": "" } ] },
      { "q": "Write $50$ min as a decimal of an hour, to two places.", "a": "$0.83$ h",
        "solution": [ { "math": "$\\tfrac{50}{60} = 0.8\\overline{3}$", "note": "Divide by $60$" }, { "math": "$\\approx 0.83 \\text{ h}$", "note": "Two decimal places" } ] },
      { "q": "A train timetable lists a trip as $1.5$ h. The actual ride is $1$ h $40$ min. By how many minutes does it run over?", "a": "$10$ min",
        "solution": [ { "math": "$1.5 \\text{ h} = 1 \\text{ h } 30 \\text{ min}$", "note": "Scheduled" }, { "math": "$1{:}40 - 1{:}30 = 10 \\text{ min}$", "note": "Over time" } ] }
    ]
  }
}
