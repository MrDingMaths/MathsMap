{
  "skillId": "order-of-operations-integers",
  "atomType": "R",
  "theory": {
    "intro": "Apply the usual order of operations, watching the signs as you go.",
    "facts": [
      "**Brackets** first, then **× and ÷**, then **+ and −**.",
      "Work × and ÷ (and + and −) **left to right**.",
      "Rewrite touching signs whenever they appear."
    ],
    "steps": [
      "Do anything inside brackets first.",
      "Then multiplication and division, left to right.",
      "Then addition and subtraction, left to right.",
      "Rewrite touching signs as you go."
    ]
  },
  "practice": {
    "foundation": [
      {
        "q": "Evaluate $2 + 3 \\times (-3)$", "a": "$-7$",
        "solution": [
          { "math": "$2 + 3 \\times (-3)$", "note": "" },
          { "math": "$= 2 + (-9)$", "note": "Multiply first" },
          { "math": "$= -7$", "note": "Add" }
        ]
      },
      {
        "q": "Evaluate $-4 + 2 \\times 5$", "a": "$6$",
        "solution": [
          { "math": "$-4 + 2 \\times 5$", "note": "" },
          { "math": "$= -4 + 10$", "note": "Multiply first" },
          { "math": "$= 6$", "note": "Add" }
        ]
      },
      {
        "q": "Evaluate $7 \\times (3 - 5)$", "a": "$-14$",
        "solution": [
          { "math": "$7 \\times (3 - 5)$", "note": "" },
          { "math": "$= 7 \\times (-2)$", "note": "Brackets first" },
          { "math": "$= -14$", "note": "Multiply" }
        ]
      },
      {
        "q": "Evaluate $5 + 10 \\times (-2)$", "a": "$-15$",
        "solution": [
          { "math": "$5 + 10 \\times (-2)$", "note": "" },
          { "math": "$= 5 + (-20)$", "note": "Multiply first" },
          { "math": "$= -15$", "note": "Add" }
        ]
      },
      {
        "q": "Evaluate $6 - 3 \\times 5$", "a": "$-9$",
        "solution": [
          { "math": "$6 - 3 \\times 5$", "note": "" },
          { "math": "$= 6 - 15$", "note": "Multiply first" },
          { "math": "$= -9$", "note": "Subtract" }
        ]
      },
      {
        "q": "Evaluate $-6 - 3 \\times 5$", "a": "$-21$",
        "solution": [
          { "math": "$-6 - 3 \\times 5$", "note": "" },
          { "math": "$= -6 - 15$", "note": "Multiply first" },
          { "math": "$= -21$", "note": "Subtract" }
        ]
      },
      {
        "q": "Which operation is done first in $-3 + 2 \\times (-6)$? (Do not evaluate.)", "a": "$2 \\times (-6)$",
        "solution": [
          { "math": "$-3 + 2 \\times (-6)$", "note": "× before +" },
          { "math": "$2 \\times (-6)$", "note": "Done first" }
        ]
      },
      {
        "q": "Which operation is done first in $(8 - 4) \\div 2$? (Do not evaluate.)", "a": "$8 - 4$",
        "solution": [
          { "math": "$(8 - 4) \\div 2$", "note": "Brackets first" },
          { "math": "$8 - 4$", "note": "Done first" }
        ]
      },
      {
        "q": "Evaluate $20 + (-4) \\div 4$", "a": "$19$",
        "solution": [
          { "math": "$20 + (-4) \\div 4$", "note": "" },
          { "math": "$= 20 + (-1)$", "note": "Divide first" },
          { "math": "$= 19$", "note": "Add" }
        ]
      },
      {
        "q": "Evaluate $10 - 2 \\times (-3)$", "a": "$16$",
        "solution": [
          { "math": "$10 - 2 \\times (-3)$", "note": "" },
          { "math": "$= 10 - (-6)$", "note": "Multiply first" },
          { "math": "$= 10 + 6 = 16$", "note": "Rewrite signs" }
        ]
      }
    ],
    "development": [
      {
        "q": "Evaluate $(3 + 2) \\times (-2)$", "a": "$-10$",
        "solution": [
          { "math": "$(3 + 2) \\times (-2)$", "note": "" },
          { "math": "$= 5 \\times (-2)$", "note": "Brackets first" },
          { "math": "$= -10$", "note": "Multiply" }
        ]
      },
      {
        "q": "Evaluate $-3 \\times (-2 + 4)$", "a": "$-6$",
        "solution": [
          { "math": "$-3 \\times (-2 + 4)$", "note": "" },
          { "math": "$= -3 \\times 2$", "note": "Brackets first" },
          { "math": "$= -6$", "note": "Multiply" }
        ]
      },
      {
        "q": "Evaluate $(8 - 4) \\div (-2)$", "a": "$-2$",
        "solution": [
          { "math": "$(8 - 4) \\div (-2)$", "note": "" },
          { "math": "$= 4 \\div (-2)$", "note": "Brackets first" },
          { "math": "$= -2$", "note": "Divide" }
        ]
      },
      {
        "q": "Evaluate $11 + 10 \\div (-2)$", "a": "$6$",
        "solution": [
          { "math": "$11 + 10 \\div (-2)$", "note": "" },
          { "math": "$= 11 + (-5)$", "note": "Divide first" },
          { "math": "$= 11 - 5$", "note": "Rewrite signs" },
          { "math": "$= 6$", "note": "" }
        ]
      },
      {
        "q": "Evaluate $4 - 10 \\div (-5)$", "a": "$6$",
        "solution": [
          { "math": "$4 - 10 \\div (-5)$", "note": "" },
          { "math": "$= 4 - (-2)$", "note": "Divide first" },
          { "math": "$= 4 + 2$", "note": "Rewrite signs" },
          { "math": "$= 6$", "note": "" }
        ]
      },
      {
        "q": "Evaluate $3 - 4 \\times (-6) \\div 2$", "a": "$15$",
        "solution": [
          { "math": "$3 - 4 \\times (-6) \\div 2$", "note": "" },
          { "math": "$= 3 - (-24) \\div 2$", "note": "Multiply" },
          { "math": "$= 3 + 12$", "note": "Divide, rewrite" },
          { "math": "$= 15$", "note": "" }
        ]
      },
      {
        "q": "Evaluate $4 \\times (-2) + 3 \\times 5$", "a": "$7$",
        "solution": [
          { "math": "$4 \\times (-2) + 3 \\times 5$", "note": "" },
          { "math": "$= -8 + 15$", "note": "Multiply first" },
          { "math": "$= 7$", "note": "Add" }
        ]
      },
      {
        "q": "Evaluate $4 \\times (-2) - 3 \\times 5$", "a": "$-23$",
        "solution": [
          { "math": "$4 \\times (-2) - 3 \\times 5$", "note": "" },
          { "math": "$= -8 - 15$", "note": "Multiply first" },
          { "math": "$= -23$", "note": "Subtract" }
        ]
      },
      {
        "q": "Evaluate $-30 \\div 5 - 6 \\times 2$", "a": "$-18$",
        "solution": [
          { "math": "$-30 \\div 5 - 6 \\times 2$", "note": "" },
          { "math": "$= -6 - 12$", "note": "× and ÷ first" },
          { "math": "$= -18$", "note": "Subtract" }
        ]
      },
      {
        "q": "Evaluate $-2 \\times 3 - 4 \\div (-2)$", "a": "$-4$",
        "solution": [
          { "math": "$-2 \\times 3 - 4 \\div (-2)$", "note": "" },
          { "math": "$= -6 - (-2)$", "note": "× and ÷ first" },
          { "math": "$= -6 + 2 = -4$", "note": "Rewrite signs" }
        ]
      },
      {
        "q": "Evaluate $8 \\times (-2) - (-3) \\times 2$", "a": "$-10$",
        "solution": [
          { "math": "$8 \\times (-2) - (-3) \\times 2$", "note": "" },
          { "math": "$= -16 - (-6)$", "note": "Multiply first" },
          { "math": "$= -16 + 6 = -10$", "note": "Rewrite signs" }
        ]
      },
      {
        "q": "Evaluate $\\dfrac{8 - 4}{-2}$", "a": "$-2$",
        "solution": [
          { "math": "$\\dfrac{8 - 4}{-2}$", "note": "Numerator first" },
          { "math": "$= \\dfrac{4}{-2} = -2$", "note": "Then divide" }
        ]
      },
      {
        "q": "Evaluate $\\dfrac{10}{4 - (-1)}$", "a": "$2$",
        "solution": [
          { "math": "$\\dfrac{10}{4 - (-1)}$", "note": "Denominator first" },
          { "math": "$= \\dfrac{10}{5} = 2$", "note": "Then divide" }
        ]
      },
      {
        "q": "Evaluate $\\dfrac{-135}{75 - 30}$", "a": "$-3$",
        "solution": [
          { "math": "$\\dfrac{-135}{75 - 30}$", "note": "Denominator first" },
          { "math": "$= \\dfrac{-135}{45} = -3$", "note": "Then divide" }
        ]
      },
      {
        "q": "Evaluate $-1 \\times (7 - 8)$", "a": "$1$",
        "solution": [
          { "math": "$-1 \\times (7 - 8)$", "note": "" },
          { "math": "$= -1 \\times (-1)$", "note": "Brackets first" },
          { "math": "$= 1$", "note": "Multiply" }
        ]
      },
      {
        "q": "Evaluate $(8 - 4) \\div (-2)$", "a": "$-2$",
        "solution": [
          { "math": "$(8 - 4) \\div (-2)$", "note": "" },
          { "math": "$= 4 \\div (-2)$", "note": "Brackets first" },
          { "math": "$= -2$", "note": "Divide" }
        ]
      },
      {
        "q": "True or false: $-4 + 2 \\times 3 = (-4 + 2) \\times 3$?", "a": "False",
        "solution": [
          { "math": "$-4 + 2 \\times 3 = -4 + 6 = 2$", "note": "× first" },
          { "math": "$(-4 + 2) \\times 3 = -6$", "note": "Not equal → false" }
        ]
      },
      {
        "q": "True or false: $-4 + 2 \\times 3 = -4 + (2 \\times 3)$?", "a": "True",
        "solution": [
          { "math": "$-4 + 2 \\times 3$", "note": "× is done first anyway" },
          { "math": "$= -4 + (2 \\times 3)$", "note": "Same → true" }
        ]
      },
      {
        "q": "True or false: $-40 - 20 \\div (-5) = -40 - (20 \\div (-5))$?", "a": "True",
        "solution": [
          { "math": "$-40 - 20 \\div (-5)$", "note": "÷ is done first anyway" },
          { "math": "$= -40 - (20 \\div (-5))$", "note": "Same → true" }
        ]
      },
      {
        "q": "Evaluate $-2 \\times (8 - 4) + (-6)$", "a": "$-14$",
        "solution": [
          { "math": "$-2 \\times (8 - 4) + (-6)$", "note": "" },
          { "math": "$= -2 \\times 4 + (-6)$", "note": "Brackets first" },
          { "math": "$= -8 - 6 = -14$", "note": "Multiply, then add" }
        ]
      }
    ],
    "mastery": [
      {
        "q": "Evaluate $-2 - 3 \\times (-1 + 7)$", "a": "$-20$",
        "solution": [
          { "math": "$-2 - 3 \\times (-1 + 7)$", "note": "" },
          { "math": "$= -2 - 3 \\times 6$", "note": "Brackets first" },
          { "math": "$= -2 - 18$", "note": "Multiply" },
          { "math": "$= -20$", "note": "Subtract" }
        ]
      },
      {
        "q": "Evaluate $(-3 + (-5)) \\times (-2 - (-1))$", "a": "$8$",
        "solution": [
          { "math": "$(-3 + (-5)) \\times (-2 - (-1))$", "note": "" },
          { "math": "$= (-8) \\times (-1)$", "note": "Brackets first" },
          { "math": "$= 8$", "note": "Multiply" }
        ]
      },
      {
        "q": "Evaluate $3 + 4 \\times (-6) \\div (-2)$", "a": "$15$",
        "solution": [
          { "math": "$3 + 4 \\times (-6) \\div (-2)$", "note": "" },
          { "math": "$= 3 + (-24) \\div (-2)$", "note": "Multiply first" },
          { "math": "$= 3 + 12$", "note": "Divide" },
          { "math": "$= 15$", "note": "Add" }
        ]
      },
      {
        "q": "Evaluate $4 \\times (-2) + 3 \\times (-5)$", "a": "$-23$",
        "solution": [
          { "math": "$4 \\times (-2) + 3 \\times (-5)$", "note": "" },
          { "math": "$= -8 + (-15)$", "note": "Multiply first" },
          { "math": "$= -23$", "note": "Add" }
        ]
      },
      {
        "q": "Evaluate $(2 - 10) \\div (7 - 9)$", "a": "$4$",
        "solution": [
          { "math": "$(2 - 10) \\div (7 - 9)$", "note": "" },
          { "math": "$= -8 \\div (-2)$", "note": "Brackets first" },
          { "math": "$= 4$", "note": "Divide" }
        ]
      },
      {
        "q": "Evaluate $-2 \\times 4 + 8 \\times (-3)$", "a": "$-32$",
        "solution": [
          { "math": "$-2 \\times 4 + 8 \\times (-3)$", "note": "" },
          { "math": "$= -8 + (-24)$", "note": "Multiply first" },
          { "math": "$= -32$", "note": "Add" }
        ]
      },
      {
        "q": "Insert brackets to make it true: $-10 \\div 4 + 1 = -2$", "a": "$-10 \\div (4 + 1) = -2$",
        "solution": [
          { "math": "$-10 \\div (4 + 1)$", "note": "Add inside brackets first" },
          { "math": "$= -10 \\div 5 = -2$", "note": "Then divide" }
        ]
      },
      {
        "q": "Insert brackets to make it true: $2 + 3 \\times (-4) = -20$", "a": "$(2 + 3) \\times (-4) = -20$",
        "solution": [
          { "math": "$(2 + 3) \\times (-4)$", "note": "Add inside brackets first" },
          { "math": "$= 5 \\times (-4) = -20$", "note": "Then multiply" }
        ]
      },
      {
        "q": "Evaluate $(-3)^2 \\times 4$", "a": "$36$",
        "solution": [
          { "math": "$(-3)^2 \\times 4$", "note": "Power first" },
          { "math": "$= 9 \\times 4$", "note": "$(-3)^2 = 9$" },
          { "math": "$= 36$", "note": "Multiply" }
        ]
      },
      {
        "q": "A debt of $\\$550$ is doubled, then $\\$350$ of the debt is paid off each month for $3$ months. Final balance? Use $-550 \\times 2 + 350 \\times 3$.", "a": "$-\\$50$",
        "solution": [
          { "math": "$-550 \\times 2 + 350 \\times 3$", "note": "× first" },
          { "math": "$= -1100 + 1050$", "note": "Then add" },
          { "math": "$= -50$", "note": "Owes $\\$50$" }
        ]
      }
    ]
  }
}
