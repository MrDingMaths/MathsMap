      { "q": "Order from smallest to largest: $\\tfrac{1}{2}, \\tfrac{1}{4}, \\tfrac{5}{8}$.", "a": "$\\tfrac{1}{4}, \\tfrac{1}{2}, \\tfrac{5}{8}$",
        "tikz": "\\begin{tikzpicture}[x=8cm,y=0.7cm]\n\\draw[thick,-{Stealth[length=2mm]}] (-0.05,0) -- (1.08,0);\n\\foreach \\v in {0,1,...,8} \\draw (\\v/8,0.1) -- (\\v/8,-0.1);\n\\node[below=3pt] at (0,0) {$0$}; \\node[below=3pt] at (1,0) {$1$};\n\\fill (0.25,0) circle (2.2pt); \\node[above=4pt] at (0.25,0) {$\\tfrac{1}{4}$};\n\\fill (0.5,0) circle (2.2pt); \\node[above=4pt] at (0.5,0) {$\\tfrac{1}{2}$};\n\\fill (0.625,0) circle (2.2pt); \\node[above=4pt] at (0.625,0) {$\\tfrac{5}{8}$};\n\\end{tikzpicture}",
        "solution": [ { "math": "$\\tfrac{2}{8}, \\tfrac{4}{8}, \\tfrac{5}{8}$", "note": "Over eighths" }, { "math": "$\\tfrac{1}{4} < \\tfrac{1}{2} < \\tfrac{5}{8}$", "note": "" } ] },
      { "q": "Compare with $<$ or $>$: $\\tfrac{3}{4}$ and $\\tfrac{5}{8}$.", "a": "$\\tfrac{3}{4} > \\tfrac{5}{8}$",
