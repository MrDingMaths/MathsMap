      { "q": "Order from smallest to largest: $\\tfrac{1}{3}, \\tfrac{1}{6}, \\tfrac{5}{6}, \\tfrac{1}{2}$.", "a": "$\\tfrac{1}{6}, \\tfrac{1}{3}, \\tfrac{1}{2}, \\tfrac{5}{6}$",
        "solution": [ { "math": "$\\tfrac{2}{6}, \\tfrac{1}{6}, \\tfrac{5}{6}, \\tfrac{3}{6}$", "note": "Over sixths" }, { "math": "$\\tfrac{1}{6} < \\tfrac{1}{3} < \\tfrac{1}{2} < \\tfrac{5}{6}$", "note": "" } ] }
    ],
