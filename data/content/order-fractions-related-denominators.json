      { "q": "Place $\\tfrac{3}{8}$ on the marked number line. Between which eighths does it lie?", "a": "at the $3$rd eighth mark",
        "tikz": "\\begin{tikzpicture}[x=8cm,y=0.7cm]\n\\draw[thick,-{Stealth[length=2mm]}] (-0.05,0) -- (1.08,0);\n\\foreach \\v in {0,1,...,8} \\draw (\\v/8,0.1) -- (\\v/8,-0.1);\n\\node[below=3pt] at (0,0) {$0$}; \\node[below=3pt] at (1,0) {$1$};\n\\fill (0.375,0) circle (2.2pt);\n\\end{tikzpicture}",
        "solution": [ { "math": "$\\tfrac{3}{8} = 3 \\times \\tfrac{1}{8}$", "note": "3 eighths from 0" }, { "math": "$\\text{at the 3rd mark}$", "note": "" } ] },
      { "q": "Compare with $<$, $>$ or $=$: $\\tfrac{6}{8}$ and $\\tfrac{3}{4}$.", "a": "$\\tfrac{6}{8} = \\tfrac{3}{4}$",
        "solution": [ { "math": "$\\tfrac{6}{8} = \\tfrac{6 \\div 2}{8 \\div 2}$", "note": "Simplify" }, { "math": "$= \\tfrac{3}{4}$", "note": "Equal" } ] },
      { "q": "Order from smallest to largest: $\\tfrac{1}{4}, \\tfrac{3}{8}, \\tfrac{1}{2}, \\tfrac{5}{8}$.", "a": "$\\tfrac{1}{4}, \\tfrac{3}{8}, \\tfrac{1}{2}, \\tfrac{5}{8}$",
        "solution": [ { "math": "$\\tfrac{2}{8}, \\tfrac{3}{8}, \\tfrac{4}{8}, \\tfrac{5}{8}$", "note": "Over eighths" }, { "math": "$\\tfrac{1}{4} < \\tfrac{3}{8} < \\tfrac{1}{2} < \\tfrac{5}{8}$", "note": "" } ] },
      { "q": "Which is closest to $\\tfrac{1}{2}$: $\\tfrac{3}{8}$ or $\\tfrac{5}{8}$?", "a": "both equally close",
