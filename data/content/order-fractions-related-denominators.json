{
  "skillId": "order-fractions-related-denominators",
  "atomType": "R",
  "theory": {
    "intro": "When denominators are related (one is a multiple of another), rewrite the fractions with a common denominator, then order them. A number line makes the order clear.",
    "facts": [
      "Related denominators share a common multiple, e.g. $2$, $4$ and $8$ all divide into $8$.",
      "Rewrite each fraction over the **common denominator** using equivalence.",
      "With a common denominator, order by the numerators — smaller numerator sits further left."
    ],
    "steps": [
      "Find a common denominator (often the largest one).",
      "Rewrite each fraction with that denominator.",
      "Order by numerator and place on a number line."
    ]
  },
  "practice": {
    "foundation": [
      { "q": "Which is further right on the number line: $\\tfrac{1}{2}$ or $\\tfrac{3}{4}$?", "a": "$\\tfrac{3}{4}$",
        "tikz": "\\begin{tikzpicture}[x=8cm,y=0.7cm]\n\\draw[thick,-{Stealth[length=2mm]}] (-0.05,0) -- (1.08,0);\n\\foreach \\v in {0,1,...,4} \\draw (\\v/4,0.1) -- (\\v/4,-0.1);\n\\node[below=3pt] at (0,0) {$0$}; \\node[below=3pt] at (1,0) {$1$};\n\\fill (0.5,0) circle (2.2pt); \\node[above=4pt] at (0.5,0) {$\\tfrac{1}{2}$};\n\\fill (0.75,0) circle (2.2pt); \\node[above=4pt] at (0.75,0) {$\\tfrac{3}{4}$};\n\\end{tikzpicture}",
        "solution": [ { "math": "$\\tfrac{1}{2} = \\tfrac{2}{4}$", "note": "Common denominator" }, { "math": "$\\tfrac{3}{4} > \\tfrac{2}{4}$", "note": "Further right" } ] },
      { "q": "Order from smallest to largest: $\\tfrac{1}{4}, \\tfrac{1}{2}, \\tfrac{3}{4}$.", "a": "$\\tfrac{1}{4}, \\tfrac{1}{2}, \\tfrac{3}{4}$",
        "tikz": "\\begin{tikzpicture}[x=8cm,y=0.7cm]\n\\draw[thick,-{Stealth[length=2mm]}] (-0.05,0) -- (1.08,0);\n\\foreach \\v in {0,1,...,4} \\draw (\\v/4,0.1) -- (\\v/4,-0.1);\n\\node[below=3pt] at (0,0) {$0$}; \\node[below=3pt] at (1,0) {$1$};\n\\fill (0.25,0) circle (2.2pt); \\node[above=4pt] at (0.25,0) {$\\tfrac{1}{4}$};\n\\fill (0.5,0) circle (2.2pt); \\node[above=4pt] at (0.5,0) {$\\tfrac{1}{2}$};\n\\fill (0.75,0) circle (2.2pt); \\node[above=4pt] at (0.75,0) {$\\tfrac{3}{4}$};\n\\end{tikzpicture}",
        "solution": [ { "math": "$\\tfrac{1}{4}, \\tfrac{2}{4}, \\tfrac{3}{4}$", "note": "Over quarters" }, { "math": "$\\tfrac{1}{4} < \\tfrac{1}{2} < \\tfrac{3}{4}$", "note": "" } ] },
      { "q": "Order from smallest to largest: $\\tfrac{1}{2}, \\tfrac{1}{8}, \\tfrac{5}{8}$.", "a": "$\\tfrac{1}{8}, \\tfrac{1}{2}, \\tfrac{5}{8}$",
        "tikz": "\\begin{tikzpicture}[x=8cm,y=0.7cm]\n\\draw[thick,-{Stealth[length=2mm]}] (-0.05,0) -- (1.08,0);\n\\foreach \\v in {0,1,...,8} \\draw (\\v/8,0.1) -- (\\v/8,-0.1);\n\\node[below=3pt] at (0,0) {$0$}; \\node[below=3pt] at (1,0) {$1$};\n\\fill (0.125,0) circle (2.2pt); \\node[above=4pt] at (0.125,0) {$\\tfrac{1}{8}$};\n\\fill (0.5,0) circle (2.2pt); \\node[above=4pt] at (0.5,0) {$\\tfrac{1}{2}$};\n\\fill (0.625,0) circle (2.2pt); \\node[above=4pt] at (0.625,0) {$\\tfrac{5}{8}$};\n\\end{tikzpicture}",
        "solution": [ { "math": "$\\tfrac{1}{2} = \\tfrac{4}{8}$", "note": "Over eighths" }, { "math": "$\\tfrac{1}{8} < \\tfrac{4}{8} < \\tfrac{5}{8}$", "note": "" } ] },
      { "q": "Compare with $<$ or $>$: $\\tfrac{2}{3}$ and $\\tfrac{5}{6}$.", "a": "$\\tfrac{2}{3} < \\tfrac{5}{6}$",
        "solution": [ { "math": "$\\tfrac{2}{3} = \\tfrac{4}{6}$", "note": "Over sixths" }, { "math": "$\\tfrac{4}{6} < \\tfrac{5}{6}$", "note": "" } ] },
      { "q": "Order from smallest to largest: $\\tfrac{3}{4}, \\tfrac{1}{4}, \\tfrac{1}{2}$.", "a": "$\\tfrac{1}{4}, \\tfrac{1}{2}, \\tfrac{3}{4}$",
        "solution": [ { "math": "$\\tfrac{1}{4}, \\tfrac{2}{4}, \\tfrac{3}{4}$", "note": "Over quarters" }, { "math": "$\\tfrac{1}{4} < \\tfrac{1}{2} < \\tfrac{3}{4}$", "note": "" } ] },
      { "q": "Compare with $<$ or $>$: $\\tfrac{1}{2}$ and $\\tfrac{3}{8}$.", "a": "$\\tfrac{1}{2} > \\tfrac{3}{8}$",
        "tikz": "\\begin{tikzpicture}[x=8cm,y=0.7cm]\n\\draw[thick,-{Stealth[length=2mm]}] (-0.05,0) -- (1.08,0);\n\\foreach \\v in {0,1,...,8} \\draw (\\v/8,0.1) -- (\\v/8,-0.1);\n\\node[below=3pt] at (0,0) {$0$}; \\node[below=3pt] at (1,0) {$1$};\n\\fill (0.375,0) circle (2.2pt); \\node[above=4pt] at (0.375,0) {$\\tfrac{3}{8}$};\n\\fill (0.5,0) circle (2.2pt); \\node[above=4pt] at (0.5,0) {$\\tfrac{1}{2}$};\n\\end{tikzpicture}",
        "solution": [ { "math": "$\\tfrac{1}{2} = \\tfrac{4}{8}$", "note": "Over eighths" }, { "math": "$\\tfrac{4}{8} > \\tfrac{3}{8}$", "note": "" } ] },
      { "q": "Order from smallest to largest: $\\tfrac{1}{3}, \\tfrac{2}{3}, \\tfrac{1}{6}$.", "a": "$\\tfrac{1}{6}, \\tfrac{1}{3}, \\tfrac{2}{3}$",
