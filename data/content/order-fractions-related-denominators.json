        "solution": [ { "math": "$\\tfrac{3}{4} = \\tfrac{9}{12},\\ \\tfrac{5}{6} = \\tfrac{10}{12}$", "note": "Over twelfths" }, { "math": "$\\tfrac{7}{12} < \\tfrac{9}{12} < \\tfrac{10}{12}$", "note": "" } ] },
