{
  "skillId": "metre-kilometre-relationship",
  "atomType": "R",
  "theory": {
    "intro": "Kilometres measure long distances. A kilometre is just $1000$ metres, so we can change between the two units by multiplying or dividing by $1000$.",
    "facts": [
      "$1000 \\text{ m} = 1 \\text{ km}$.",
      "To change **metres to kilometres**, divide by $1000$.",
      "To change **kilometres to metres**, multiply by $1000$."
    ],
    "steps": [
      "Decide which unit is larger (km) and which is smaller (m).",
      "Multiply by $1000$ to go km $\\to$ m; divide by $1000$ to go m $\\to$ km.",
      "Write the answer with the correct unit."
    ]
  },
  "practice": {
    "foundation": [
      { "q": "How many metres are in $1$ km?", "a": "$1000$ m",
        "solution": [ { "math": "$1 \\text{ km}$", "note": "" }, { "math": "$= 1000 \\text{ m}$", "note": "By definition" } ] },
      { "q": "Convert $2$ km to metres.", "a": "$2000$ m",
        "solution": [ { "math": "$2 \\times 1000$", "note": "km $\\to$ m" }, { "math": "$= 2000 \\text{ m}$", "note": "" } ] },
      { "q": "Convert $5$ km to metres.", "a": "$5000$ m",
        "solution": [ { "math": "$5 \\times 1000$", "note": "km $\\to$ m" }, { "math": "$= 5000 \\text{ m}$", "note": "" } ] },
      { "q": "Convert $3000$ m to kilometres.", "a": "$3$ km",
        "solution": [ { "math": "$3000 \\div 1000$", "note": "m $\\to$ km" }, { "math": "$= 3 \\text{ km}$", "note": "" } ] },
      { "q": "Convert $7000$ m to kilometres.", "a": "$7$ km",
        "solution": [ { "math": "$7000 \\div 1000$", "note": "m $\\to$ km" }, { "math": "$= 7 \\text{ km}$", "note": "" } ] },
      { "q": "How many metres is half a kilometre?", "a": "$500$ m",
        "solution": [ { "math": "$\\tfrac{1}{2} \\times 1000$", "note": "Half of 1000" }, { "math": "$= 500 \\text{ m}$", "note": "" } ] },
      { "q": "Convert $4$ km to metres.", "a": "$4000$ m",
        "solution": [ { "math": "$4 \\times 1000$", "note": "km $\\to$ m" }, { "math": "$= 4000 \\text{ m}$", "note": "" } ] },
      { "q": "Convert $9000$ m to kilometres.", "a": "$9$ km",
        "solution": [ { "math": "$9000 \\div 1000$", "note": "m $\\to$ km" }, { "math": "$= 9 \\text{ km}$", "note": "" } ] },
      { "q": "Convert $10$ km to metres.", "a": "$10\\,000$ m",
        "solution": [ { "math": "$10 \\times 1000$", "note": "km $\\to$ m" }, { "math": "$= 10\\,000 \\text{ m}$", "note": "" } ] },
      { "q": "Which is longer: $1$ km or $900$ m?", "a": "$1$ km",
        "solution": [ { "math": "$1 \\text{ km} = 1000 \\text{ m}$", "note": "Same unit" }, { "math": "$1000 > 900 \\Rightarrow 1 \\text{ km}$", "note": "" } ] }
    ],
    "development": [
      { "q": "Convert $1500$ m to kilometres.", "a": "$1.5$ km",
        "solution": [ { "math": "$1500 \\div 1000$", "note": "m $\\to$ km" }, { "math": "$= 1.5 \\text{ km}$", "note": "" } ] },
      { "q": "Convert $2.5$ km to metres.", "a": "$2500$ m",
        "solution": [ { "math": "$2.5 \\times 1000$", "note": "km $\\to$ m" }, { "math": "$= 2500 \\text{ m}$", "note": "" } ] },
      { "q": "Convert $250$ m to kilometres.", "a": "$0.25$ km",
        "solution": [ { "math": "$250 \\div 1000$", "note": "m $\\to$ km" }, { "math": "$= 0.25 \\text{ km}$", "note": "" } ] },
      { "q": "Convert $0.8$ km to metres.", "a": "$800$ m",
        "solution": [ { "math": "$0.8 \\times 1000$", "note": "km $\\to$ m" }, { "math": "$= 800 \\text{ m}$", "note": "" } ] },
      { "q": "Convert $3250$ m to kilometres.", "a": "$3.25$ km",
        "solution": [ { "math": "$3250 \\div 1000$", "note": "m $\\to$ km" }, { "math": "$= 3.25 \\text{ km}$", "note": "" } ] },
      { "q": "Which is longer: $1200$ m or $1$ km?", "a": "$1200$ m",
        "solution": [ { "math": "$1 \\text{ km} = 1000 \\text{ m}$", "note": "Same unit" }, { "math": "$1200 > 1000 \\Rightarrow 1200 \\text{ m}$", "note": "" } ] },
      { "q": "Convert $6.4$ km to metres.", "a": "$6400$ m",
        "solution": [ { "math": "$6.4 \\times 1000$", "note": "km $\\to$ m" }, { "math": "$= 6400 \\text{ m}$", "note": "" } ] },
      { "q": "A track is $400$ m long. How many laps make $2$ km?", "a": "$5$ laps",
        "solution": [ { "math": "$2 \\text{ km} = 2000 \\text{ m}$", "note": "km $\\to$ m" }, { "math": "$2000 \\div 400 = 5$", "note": "" } ] },
      { "q": "Convert $75$ m to kilometres.", "a": "$0.075$ km",
        "solution": [ { "math": "$75 \\div 1000$", "note": "m $\\to$ km" }, { "math": "$= 0.075 \\text{ km}$", "note": "" } ] },
      { "q": "Order from shortest to longest: $1.2$ km, $900$ m, $1$ km.", "a": "$900$ m, $1$ km, $1.2$ km",
        "solution": [ { "math": "$900, 1000, 1200 \\text{ (m)}$", "note": "Convert all to m" }, { "math": "$900 \\text{ m} < 1 \\text{ km} < 1.2 \\text{ km}$", "note": "" } ] }
    ],
    "mastery": [
      { "q": "A runner does three laps of $1.5$ km each. How many metres in total?", "a": "$4500$ m",
        "solution": [ { "math": "$3 \\times 1.5 = 4.5 \\text{ km}$", "note": "Total in km" }, { "math": "$4.5 \\times 1000 = 4500 \\text{ m}$", "note": "km $\\to$ m" } ] },
      { "q": "A walk is $2$ km then $750$ m. What is the total distance in kilometres?", "a": "$2.75$ km",
        "solution": [ { "math": "$750 \\text{ m} = 0.75 \\text{ km}$", "note": "m $\\to$ km" }, { "math": "$2 + 0.75 = 2.75 \\text{ km}$", "note": "" } ] },
      { "q": "A road sign reads $3500$ m to town. A car has driven $1.2$ km. How many metres are left?", "a": "$2300$ m",
        "solution": [ { "math": "$1.2 \\text{ km} = 1200 \\text{ m}$", "note": "km $\\to$ m" }, { "math": "$3500 - 1200 = 2300 \\text{ m}$", "note": "" } ] },
      { "q": "A relay is $4$ km, split equally between $8$ runners. How many metres does each run?", "a": "$500$ m",
        "solution": [ { "math": "$4 \\text{ km} = 4000 \\text{ m}$", "note": "km $\\to$ m" }, { "math": "$4000 \\div 8 = 500 \\text{ m}$", "note": "" } ] },
      { "q": "A path is $1250$ m. Express this in kilometres, then say how much short of $2$ km it is (in metres).", "a": "$1.25$ km; $750$ m short",
        "solution": [ { "math": "$1250 \\div 1000 = 1.25 \\text{ km}$", "note": "m $\\to$ km" }, { "math": "$2000 - 1250 = 750 \\text{ m}$", "note": "" } ] },
      { "q": "Three fences are $600$ m, $0.9$ km and $450$ m. What is the total length in kilometres?", "a": "$1.95$ km",
        "solution": [ { "math": "$0.9 \\text{ km} = 900 \\text{ m}$", "note": "km $\\to$ m" }, { "math": "$\\tfrac{600+900+450}{1000} = 1.95 \\text{ km}$", "note": "" } ] },
      { "q": "A drone flies $2.4$ km out and the same distance back. Total distance in metres?", "a": "$4800$ m",
        "solution": [ { "math": "$2 \\times 2.4 = 4.8 \\text{ km}$", "note": "Out and back" }, { "math": "$4.8 \\times 1000 = 4800 \\text{ m}$", "note": "km $\\to$ m" } ] },
      { "q": "A school is $0.65$ km from home. A student walks there and back each day. How many metres in $5$ days?", "a": "$6500$ m",
        "solution": [ { "math": "$2 \\times 0.65 = 1.3 \\text{ km/day}$", "note": "There and back" }, { "math": "$5 \\times 1.3 \\times 1000 = 6500 \\text{ m}$", "note": "" } ] },
      { "q": "A trail is marked every $250$ m. How many markers (including start and finish) along a $2$ km trail?", "a": "$9$ markers",
        "solution": [ { "math": "$2000 \\div 250 = 8 \\text{ gaps}$", "note": "Number of intervals" }, { "math": "$8 + 1 = 9 \\text{ markers}$", "note": "Include the start" } ] },
      { "q": "A cyclist rides $12\\,500$ m. How many kilometres is this?", "a": "$12.5$ km",
        "solution": [ { "math": "$12\\,500 \\div 1000$", "note": "m $\\to$ km" }, { "math": "$= 12.5 \\text{ km}$", "note": "" } ] }
    ]
  }
}
