  "theory": {
    "intro": "When multiplying or dividing, work out the sign separately from the size.",
    "facts": [
      "**Same signs → positive** — e.g. $(-) \\times (-) = (+)$ and $(+) \\times (+) = (+)$",
      "**Different signs → negative** — e.g. $(+) \\times (-) = (-)$"
    ]
  },
