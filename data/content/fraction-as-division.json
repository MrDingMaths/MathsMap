      { "q": "Six friends share $2$ identical cakes equally. What fraction of a cake does each get?", "a": "$\\tfrac{1}{3}$",
        "solution": [ { "math": "$2 \\div 6 = \\tfrac{2}{6}$", "note": "Share" }, { "math": "$= \\tfrac{1}{3}$", "note": "Simplify" } ] },
      { "q": "A $10$ m rope is cut into $4$ equal lengths. How long is each, as a decimal?", "a": "$2.5$ m",
