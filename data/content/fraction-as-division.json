        "solution": [ { "math": "$\\tfrac{3}{4} = 3 \\div 4$", "note": "Top $\\div$ bottom" }, { "math": "$= 3 \\div 4$", "note": "" } ] },
      { "q": "Write $\\tfrac{5}{8}$ as a division.", "a": "$5 \\div 8$",
        "solution": [ { "math": "$\\tfrac{5}{8} = 5 \\div 8$", "note": "Top $\\div$ bottom" }, { "math": "$= 5 \\div 8$", "note": "" } ] },
      { "q": "Three pizzas are shared equally between $4$ children. Write each child's share as a fraction.", "a": "$\\tfrac{3}{4}$",
