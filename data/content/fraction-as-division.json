        "solution": [ { "math": "$3 \\times 2 = 6 \\text{ L};\\ 6 \\div 8 = \\tfrac{6}{8}$", "note": "Total then share" }, { "math": "$= \\tfrac{3}{4} = 0.75 \\text{ L}$", "note": "" } ] },
      { "q": "Express $\\tfrac{17}{5}$ as a division and as a mixed number.", "a": "$17 \\div 5 = 3\\tfrac{2}{5}$",
