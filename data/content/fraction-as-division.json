      { "q": "One cake is shared equally between $5$ people. Write one share as a fraction.", "a": "$\\tfrac{1}{5}$",
        "tikz": "\\begin{tikzpicture}[x=0.5cm,y=0.5cm]\n\\draw (0,0) rectangle (5,2); \\foreach \\i in {1,2,3,4} \\draw (\\i,0)--(\\i,2);\n\\fill[gray!45] (0,0) rectangle (1,2);\n\\node[below=2pt] at (2.5,0) {$1 \\div 5 = \\tfrac{1}{5}$};\n\\end{tikzpicture}",
        "solution": [ { "math": "$1 \\div 5$", "note": "1 shared among 5" }, { "math": "$= \\tfrac{1}{5}$", "note": "" } ] },
      { "q": "Calculate $\\tfrac{1}{4}$ as a decimal.", "a": "$0.25$",
