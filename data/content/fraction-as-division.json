{
  "skillId": "fraction-as-division",
  "atomType": "R",
  "theory": {
    "intro": "A fraction is another way to write a division. The fraction $\\tfrac{a}{b}$ means $a$ wholes shared equally into $b$ parts, which is $a \\div b$.",
    "facts": [
      "$\\tfrac{a}{b} = a \\div b$, for example $\\tfrac{3}{4} = 3 \\div 4 = 0.75$.",
      "Sharing $a$ items between $b$ people gives each person $\\tfrac{a}{b}$.",
      "If $a < b$ the answer is less than $1$; if $a > b$ it is more than $1$."
    ],
    "steps": [
      "Read the fraction as 'numerator $\\div$ denominator'.",
      "Divide to find the value (a decimal or a whole number).",
      "Check: a smaller top over a bigger bottom gives less than $1$."
    ]
  },
  "practice": {
    "foundation": [
