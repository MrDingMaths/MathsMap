        "solution": [ { "math": "$3 \\div 4$", "note": "3 shared among 4" }, { "math": "$= \\tfrac{3}{4}$", "note": "" } ] },
      { "q": "Write $6 \\div 7$ as a fraction.", "a": "$\\tfrac{6}{7}$",
