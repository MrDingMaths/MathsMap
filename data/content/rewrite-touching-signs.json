  "skillId": "rewrite-touching-signs",
  "atomType": "T",
  "theory": {
    "intro": "When two signs touch between numbers, replace them with a single sign.",
    "facts": [
      "$a + (-b) = a - b$",
      "$a - (-b) = a + b$",
      "**Same signs → +**, **different signs → −**"
    ],
    "steps": [
      "Find the two touching signs between the numbers.",
      "Same signs (− and −) → write a single +.",
      "Different signs (+ and −) → write a single −."
    ]
  },
