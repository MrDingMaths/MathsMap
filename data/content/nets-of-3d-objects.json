{
  "skillId": "nets-of-3d-objects",
  "atomType": "R",
  "theory": {
    "intro": "A **net** is a flat pattern of polygons that folds up to make a 3-D object. The polygons in the net are the **faces** of the solid.",
    "facts": [
      "A net of a **cube** is $6$ squares (e.g. a cross or T shape).",
      "A net of a **rectangular prism** is $6$ rectangles.",
      "A net of a **square pyramid** is $1$ square with a triangle on each of its $4$ sides.",
      "A net of a **triangular prism** is $2$ triangles and $3$ rectangles."
    ],
    "steps": [
      "Count how many polygons there are and name each shape.",
      "Two matching polygons + rectangles → a prism; one polygon + triangles → a pyramid.",
      "Name the solid after that base shape."
    ]
  },
  "practice": {
    "foundation": [
      { "q": "Which solid folds from this net of $6$ squares?", "a": "cube",
        "tikz": "\\begin{tikzpicture}[x=0.6cm,y=0.6cm]\n\\foreach \\y in {0,1,2,3} \\draw (1,\\y) rectangle (2,\\y+1);\n\\draw (0,1) rectangle (1,2); \\draw (2,1) rectangle (3,2);\n\\end{tikzpicture}",
        "solution": [ { "math": "$6 \\text{ equal squares}$", "note": "Cross net" }, { "math": "$\\text{cube}$", "note": "" } ] },
      { "q": "Which solid folds from this net: $1$ square with a triangle on each side?", "a": "square pyramid",
        "tikz": "\\begin{tikzpicture}[x=0.6cm,y=0.6cm]\n\\draw (0,0) rectangle (2,2);\n\\draw (0,2)--(1,3.5)--(2,2); \\draw (0,0)--(1,-1.5)--(2,0);\n\\draw (0,0)--(-1.5,1)--(0,2); \\draw (2,0)--(3.5,1)--(2,2);\n\\end{tikzpicture}",
        "solution": [ { "math": "$1 \\text{ square} + 4 \\text{ triangles}$", "note": "Triangles meet at apex" }, { "math": "$\\text{square pyramid}$", "note": "" } ] },
      { "q": "Which solid folds from this net of $6$ rectangles?", "a": "rectangular prism",
        "tikz": "\\begin{tikzpicture}[x=0.5cm,y=0.5cm]\n\\foreach \\y in {0,1.4,2.8,4.2} \\draw (1,\\y) rectangle (3,\\y+1.4);\n\\draw (0,1.4) rectangle (1,2.8); \\draw (3,1.4) rectangle (4,2.8);\n\\end{tikzpicture}",
        "solution": [ { "math": "$6 \\text{ rectangles}$", "note": "Opposite faces match" }, { "math": "$\\text{rectangular prism}$", "note": "" } ] },
      { "q": "Which solid folds from this net: $2$ triangles and $3$ rectangles?", "a": "triangular prism",
        "tikz": "\\begin{tikzpicture}[x=0.6cm,y=0.6cm]\n\\draw (0,0) rectangle (1.4,2); \\draw (1.4,0) rectangle (2.8,2); \\draw (2.8,0) rectangle (4.2,2);\n\\draw (1.4,2)--(2.1,3)--(2.8,2); \\draw (1.4,0)--(2.1,-1)--(2.8,0);\n\\end{tikzpicture}",
        "solution": [ { "math": "$2 \\text{ triangles} + 3 \\text{ rectangles}$", "note": "Triangle ends" }, { "math": "$\\text{triangular prism}$", "note": "" } ] },
      { "q": "How many squares are in the net of a cube?", "a": "$6$",
        "solution": [ { "math": "$\\text{a cube has 6 faces}$", "note": "All squares" }, { "math": "$6$", "note": "" } ] },
      { "q": "A net has $1$ pentagon and $5$ triangles. Which solid folds from it?", "a": "pentagonal pyramid",
        "solution": [ { "math": "$1 \\text{ base} + 5 \\text{ triangles}$", "note": "Meet at apex" }, { "math": "$\\text{pentagonal pyramid}$", "note": "" } ] },
      { "q": "Which solid folds from this T-shaped net of $6$ squares?", "a": "cube",
        "tikz": "\\begin{tikzpicture}[x=0.6cm,y=0.6cm]\n\\foreach \\x in {0,1,2} \\draw (\\x,2) rectangle (\\x+1,3);\n\\foreach \\y in {0,1,2} \\draw (1,\\y) rectangle (2,\\y+1);\n\\end{tikzpicture}",
        "solution": [ { "math": "$6 \\text{ equal squares}$", "note": "T net" }, { "math": "$\\text{cube}$", "note": "" } ] },
      { "q": "A net has $2$ hexagons and $6$ rectangles. Which solid folds from it?", "a": "hexagonal prism",
        "solution": [ { "math": "$2 \\text{ matching ends} + 6 \\text{ rectangles}$", "note": "Prism" }, { "math": "$\\text{hexagonal prism}$", "note": "" } ] },
      { "q": "How many triangles are in the net of a square pyramid?", "a": "$4$",
        "solution": [ { "math": "$\\text{square has 4 sides}$", "note": "One triangle each" }, { "math": "$4$", "note": "" } ] },
      { "q": "Which solid folds from this net: $1$ rectangle base with $4$ triangles?", "a": "rectangular pyramid",
        "solution": [ { "math": "$1 \\text{ base} + 4 \\text{ triangles}$", "note": "Apex" }, { "math": "$\\text{rectangular pyramid}$", "note": "" } ] }
    ],
    "development": [
      { "q": "Name the solid this net folds into and count its faces.", "a": "square pyramid; $5$ faces",
        "tikz": "\\begin{tikzpicture}[x=0.6cm,y=0.6cm]\n\\draw (0,0) rectangle (2,2);\n\\draw (0,2)--(1,3.5)--(2,2); \\draw (0,0)--(1,-1.5)--(2,0);\n\\draw (0,0)--(-1.5,1)--(0,2); \\draw (2,0)--(3.5,1)--(2,2);\n\\end{tikzpicture}",
        "solution": [ { "math": "$1 \\text{ square} + 4 \\text{ triangles}$", "note": "" }, { "math": "$\\text{square pyramid, } 5 \\text{ faces}$", "note": "" } ] },
      { "q": "Name the solid this net folds into and count its faces.", "a": "triangular prism; $5$ faces",
        "tikz": "\\begin{tikzpicture}[x=0.6cm,y=0.6cm]\n\\draw (0,0) rectangle (1.4,2); \\draw (1.4,0) rectangle (2.8,2); \\draw (2.8,0) rectangle (4.2,2);\n\\draw (1.4,2)--(2.1,3)--(2.8,2); \\draw (1.4,0)--(2.1,-1)--(2.8,0);\n\\end{tikzpicture}",
        "solution": [ { "math": "$2 \\text{ triangles} + 3 \\text{ rectangles}$", "note": "" }, { "math": "$\\text{triangular prism, } 5 \\text{ faces}$", "note": "" } ] },
      { "q": "Does this net fold into a cube? (Count the squares.)", "a": "Yes — it has $6$ squares",
        "tikz": "\\begin{tikzpicture}[x=0.6cm,y=0.6cm]\n\\foreach \\y in {0,1,2,3} \\draw (1,\\y) rectangle (2,\\y+1);\n\\draw (0,1) rectangle (1,2); \\draw (2,1) rectangle (3,2);\n\\end{tikzpicture}",
        "solution": [ { "math": "$6 \\text{ squares}$", "note": "Right count and arrangement" }, { "math": "$\\text{folds into a cube}$", "note": "" } ] },
      { "q": "A net has $5$ squares only. Can it fold into a cube? Why?", "a": "No — a cube needs $6$ faces",
        "solution": [ { "math": "$\\text{cube has 6 faces}$", "note": "5 is too few" }, { "math": "$\\text{cannot fold into a cube}$", "note": "" } ] },
      { "q": "Which net belongs to a pyramid: $6$ squares, or $1$ square with $4$ triangles?", "a": "$1$ square with $4$ triangles",
        "solution": [ { "math": "$\\text{pyramid: one base} + \\text{triangles}$", "note": "" }, { "math": "$1 \\text{ square} + 4 \\text{ triangles}$", "note": "" } ] },
      { "q": "A net has $2$ squares and $4$ rectangles. Which solid does it fold into?", "a": "rectangular prism (square ends)",
        "solution": [ { "math": "$2 \\text{ matching ends} + 4 \\text{ rectangles}$", "note": "Prism" }, { "math": "$\\text{rectangular prism}$", "note": "" } ] },
      { "q": "Sketch in words the net of a triangular prism: how many of each shape?", "a": "$2$ triangles and $3$ rectangles",
        "solution": [ { "math": "$\\text{2 triangle ends}$", "note": "Bases" }, { "math": "$+ 3 \\text{ rectangles}$", "note": "Side faces" } ] },
      { "q": "Name the solid this net folds into.", "a": "cube",
        "tikz": "\\begin{tikzpicture}[x=0.6cm,y=0.6cm]\n\\foreach \\x in {0,1,2} \\draw (\\x,2) rectangle (\\x+1,3);\n\\foreach \\y in {0,1,2} \\draw (1,\\y) rectangle (2,\\y+1);\n\\end{tikzpicture}",
        "solution": [ { "math": "$6 \\text{ equal squares}$", "note": "" }, { "math": "$\\text{cube}$", "note": "" } ] },
      { "q": "A net has $1$ hexagon and $6$ triangles. Which solid folds from it?", "a": "hexagonal pyramid",
        "solution": [ { "math": "$1 \\text{ base} + 6 \\text{ triangles}$", "note": "Apex" }, { "math": "$\\text{hexagonal pyramid}$", "note": "" } ] },
      { "q": "How many rectangles are in the net of a pentagonal prism?", "a": "$5$",
        "solution": [ { "math": "$\\text{pentagon has 5 sides}$", "note": "One rectangle per side" }, { "math": "$5$", "note": "" } ] }
    ],
    "mastery": [
      { "q": "A net is made of $2$ octagons and $8$ rectangles. Name the solid and count its faces.", "a": "octagonal prism; $10$ faces",
        "solution": [ { "math": "$2 \\text{ ends} + 8 \\text{ rectangles}$", "note": "Prism" }, { "math": "$2 + 8 = 10 \\text{ faces}$", "note": "" } ] },
      { "q": "A net folds into a solid with $5$ faces, $8$ edges and $5$ vertices. Name the solid.", "a": "square pyramid",
        "solution": [ { "math": "$1 \\text{ square} + 4 \\text{ triangles} = 5$", "note": "5 vertices, 8 edges" }, { "math": "$\\text{square pyramid}$", "note": "" } ] },
      { "q": "A net has $2$ triangles and $3$ rectangles, all of different rectangle sizes. Will it still fold into a triangular prism?", "a": "Yes, if the rectangle lengths match the triangle's sides",
        "solution": [ { "math": "$\\text{each rectangle meets a triangle edge}$", "note": "Lengths must match" }, { "math": "$\\text{triangular prism}$", "note": "" } ] },
      { "q": "Tom draws $6$ squares in a row. Will it fold into a cube? Explain.", "a": "No — a straight line of 6 squares overlaps when folded",
        "solution": [ { "math": "$6 \\text{ squares, wrong layout}$", "note": "Faces overlap" }, { "math": "$\\text{not a valid cube net}$", "note": "" } ] },
      { "q": "A net folds into a solid with $7$ faces, $2$ of which are pentagons. Name it.", "a": "pentagonal prism",
        "solution": [ { "math": "$2 \\text{ pentagons} + 5 \\text{ rectangles}$", "note": "7 faces" }, { "math": "$\\text{pentagonal prism}$", "note": "" } ] },
      { "q": "Which solid has a net of exactly $1$ square and $4$ congruent triangles, and how many edges?", "a": "square pyramid; $8$ edges",
        "solution": [ { "math": "$4 \\text{ base} + 4 \\text{ slant edges}$", "note": "" }, { "math": "$\\text{square pyramid, } 8 \\text{ edges}$", "note": "" } ] },
      { "q": "A net has $1$ triangle base and $3$ triangles. Name the solid and count its faces.", "a": "triangular pyramid; $4$ faces",
        "solution": [ { "math": "$1 + 3 = 4 \\text{ triangles}$", "note": "All triangular" }, { "math": "$\\text{triangular pyramid}$", "note": "" } ] },
      { "q": "Identify the solid this net folds into and say whether it is a prism or pyramid.", "a": "rectangular prism (prism)",
        "tikz": "\\begin{tikzpicture}[x=0.5cm,y=0.5cm]\n\\foreach \\y in {0,1.4,2.8,4.2} \\draw (1,\\y) rectangle (3,\\y+1.4);\n\\draw (0,1.4) rectangle (1,2.8); \\draw (3,1.4) rectangle (4,2.8);\n\\end{tikzpicture}",
        "solution": [ { "math": "$6 \\text{ rectangles}$", "note": "Two matching ends" }, { "math": "$\\text{rectangular prism (prism)}$", "note": "" } ] },
      { "q": "How many faces, edges and vertices does the cube from a $6$-square net have?", "a": "$6$ faces, $12$ edges, $8$ vertices",
        "solution": [ { "math": "$6 \\text{ squares fold up}$", "note": "" }, { "math": "$F=6,\\ E=12,\\ V=8$", "note": "" } ] },
      { "q": "A pyramid's net has $1$ base and $n$ triangles, with $5$ triangles. Name the solid.", "a": "pentagonal pyramid",
        "solution": [ { "math": "$5 \\text{ triangles} \\to 5\\text{-sided base}$", "note": "" }, { "math": "$\\text{pentagonal pyramid}$", "note": "" } ] }
    ]
  }
}
