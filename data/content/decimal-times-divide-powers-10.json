{
  "skillId": "decimal-times-divide-powers-10",
  "atomType": "R",
  "theory": {
    "intro": "Multiplying or dividing by $10$, $100$ or $1000$ shifts every digit along the place-value columns. The decimal point appears to move.",
    "facts": [
      "$\\times 10$ moves each digit **one place left** (bigger); $\\times 100$ moves it **two**; $\\times 1000$ **three**.",
      "$\\div 10$ moves each digit **one place right** (smaller); $\\div 100$ **two**; $\\div 1000$ **three**.",
      "Count the **zeros** in the power of $10$ — that is how many places to shift."
    ],
    "steps": [
      "Count the zeros in $10$, $100$ or $1000$.",
      "Multiplying makes it bigger (shift left); dividing makes it smaller (shift right).",
      "Move the decimal point that many places, adding zeros if needed."
    ]
  },
  "practice": {
