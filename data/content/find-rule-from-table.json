{
  "skillId": "find-rule-from-table",
  "atomType": "R",
  "theory": {
    "intro": "A table of values has two rows. The rule tells you how to get the bottom row from the top row.",
    "facts": [
      "For a multiplicative rule, **divide** a bottom value by the matching top value to find the multiplier.",
      "The same multiplier should work for **every** column.",
      "Write the rule as 'bottom $= n \\times$ top'."
    ],
    "steps": [
      "Pick one column and divide the bottom number by the top number.",
      "Check that this multiplier works for the other columns.",
      "State the rule connecting the two rows."
    ]
  },
  "practice": {
    "foundation": [
      { "q": "Find the rule: $\\begin{array}{c|cccc} \\text{Top} & 1 & 2 & 3 & 4 \\\\ \\hline \\text{Bottom} & 3 & 6 & 9 & 12 \\end{array}$", "a": "bottom $= 3 \\times$ top",
        "tikz": "\\begin{tikzpicture}[scale=0.4]\n\\foreach \\x in {0,1,2} \\draw (\\x,0) rectangle (\\x+0.9,0.9);\n\\node at (1.4,-0.8) {Top 1};\n\\foreach \\x in {5,6,7,8,9,10} \\draw (\\x,0) rectangle (\\x+0.9,0.9);\n\\node at (7.9,-0.8) {Top 2};\n\\end{tikzpicture}",
        "solution": [ { "math": "$3 \\div 1 = 3$", "note": "Multiplier" }, { "math": "$\\text{bottom} = 3 \\times \\text{top}$", "note": "Works for all" } ] },
      { "q": "Find the rule: $\\begin{array}{c|cccc} \\text{Top} & 1 & 2 & 3 & 4 \\\\ \\hline \\text{Bottom} & 2 & 4 & 6 & 8 \\end{array}$", "a": "bottom $= 2 \\times$ top",
        "tikz": "\\begin{tikzpicture}[scale=0.5]\n\\foreach \\x in {0,1} \\fill (\\x,0) circle (5pt);\n\\node at (0.5,-1) {Top 1};\n\\foreach \\x in {3,4,5,6} \\fill (\\x,0) circle (5pt);\n\\node at (4.5,-1) {Top 2};\n\\end{tikzpicture}",
        "solution": [ { "math": "$2 \\div 1 = 2$", "note": "Multiplier" }, { "math": "$\\text{bottom} = 2 \\times \\text{top}$", "note": "Works for all" } ] },
      { "q": "Find the rule: $\\begin{array}{c|cccc} \\text{Top} & 1 & 2 & 3 & 4 \\\\ \\hline \\text{Bottom} & 5 & 10 & 15 & 20 \\end{array}$", "a": "bottom $= 5 \\times$ top",
        "solution": [ { "math": "$5 \\div 1 = 5$", "note": "Multiplier" }, { "math": "$\\text{bottom} = 5 \\times \\text{top}$", "note": "Works for all" } ] },
      { "q": "Find the rule: $\\begin{array}{c|cccc} \\text{Top} & 1 & 2 & 3 & 4 \\\\ \\hline \\text{Bottom} & 4 & 8 & 12 & 16 \\end{array}$", "a": "bottom $= 4 \\times$ top",
        "tikz": "\\begin{tikzpicture}[scale=0.4]\n\\foreach \\x in {0,1,2,3} \\draw (\\x,0) rectangle (\\x+0.9,0.9);\n\\node at (1.9,-0.8) {Top 1};\n\\end{tikzpicture}",
        "solution": [ { "math": "$4 \\div 1 = 4$", "note": "Multiplier" }, { "math": "$\\text{bottom} = 4 \\times \\text{top}$", "note": "Works for all" } ] },
      { "q": "Find the rule: $\\begin{array}{c|cccc} \\text{Top} & 1 & 2 & 3 & 4 \\\\ \\hline \\text{Bottom} & 6 & 12 & 18 & 24 \\end{array}$", "a": "bottom $= 6 \\times$ top",
        "solution": [ { "math": "$6 \\div 1 = 6$", "note": "Multiplier" }, { "math": "$\\text{bottom} = 6 \\times \\text{top}$", "note": "Works for all" } ] },
      { "q": "Find the rule: $\\begin{array}{c|cccc} \\text{Top} & 1 & 2 & 3 & 4 \\\\ \\hline \\text{Bottom} & 7 & 14 & 21 & 28 \\end{array}$", "a": "bottom $= 7 \\times$ top",
        "solution": [ { "math": "$7 \\div 1 = 7$", "note": "Multiplier" }, { "math": "$\\text{bottom} = 7 \\times \\text{top}$", "note": "Works for all" } ] },
      { "q": "Find the rule: $\\begin{array}{c|cccc} \\text{Top} & 1 & 2 & 3 & 4 \\\\ \\hline \\text{Bottom} & 10 & 20 & 30 & 40 \\end{array}$", "a": "bottom $= 10 \\times$ top",
        "solution": [ { "math": "$10 \\div 1 = 10$", "note": "Multiplier" }, { "math": "$\\text{bottom} = 10 \\times \\text{top}$", "note": "Works for all" } ] },
      { "q": "Find the rule: $\\begin{array}{c|cccc} \\text{Top} & 1 & 2 & 3 & 4 \\\\ \\hline \\text{Bottom} & 8 & 16 & 24 & 32 \\end{array}$", "a": "bottom $= 8 \\times$ top",
        "solution": [ { "math": "$8 \\div 1 = 8$", "note": "Multiplier" }, { "math": "$\\text{bottom} = 8 \\times \\text{top}$", "note": "Works for all" } ] },
      { "q": "Find the rule: $\\begin{array}{c|cccc} \\text{Top} & 1 & 2 & 3 & 4 \\\\ \\hline \\text{Bottom} & 9 & 18 & 27 & 36 \\end{array}$", "a": "bottom $= 9 \\times$ top",
        "solution": [ { "math": "$9 \\div 1 = 9$", "note": "Multiplier" }, { "math": "$\\text{bottom} = 9 \\times \\text{top}$", "note": "Works for all" } ] },
      { "q": "Find the rule: $\\begin{array}{c|cccc} \\text{Top} & 1 & 2 & 3 & 4 \\\\ \\hline \\text{Bottom} & 12 & 24 & 36 & 48 \\end{array}$", "a": "bottom $= 12 \\times$ top",
        "solution": [ { "math": "$12 \\div 1 = 12$", "note": "Multiplier" }, { "math": "$\\text{bottom} = 12 \\times \\text{top}$", "note": "Works for all" } ] }
    ],
    "development": [
      { "q": "Find the rule: $\\begin{array}{c|cccc} \\text{Top} & 2 & 4 & 6 & 8 \\\\ \\hline \\text{Bottom} & 6 & 12 & 18 & 24 \\end{array}$", "a": "bottom $= 3 \\times$ top",
        "solution": [ { "math": "$6 \\div 2 = 3$", "note": "Multiplier" }, { "math": "$\\text{bottom} = 3 \\times \\text{top}$", "note": "Check $4 \\times 3 = 12$" } ] },
      { "q": "Find the rule: $\\begin{array}{c|cccc} \\text{Top} & 3 & 5 & 7 & 10 \\\\ \\hline \\text{Bottom} & 12 & 20 & 28 & 40 \\end{array}$", "a": "bottom $= 4 \\times$ top",
        "solution": [ { "math": "$12 \\div 3 = 4$", "note": "Multiplier" }, { "math": "$\\text{bottom} = 4 \\times \\text{top}$", "note": "Check $5 \\times 4 = 20$" } ] },
      { "q": "Find the rule and the missing value: $\\begin{array}{c|cccc} \\text{Top} & 1 & 2 & 3 & 4 \\\\ \\hline \\text{Bottom} & 6 & 12 & 18 & ? \\end{array}$", "a": "bottom $= 6 \\times$ top; $24$",
        "solution": [ { "math": "$\\text{bottom} = 6 \\times \\text{top}$", "note": "$6 \\div 1 = 6$" }, { "math": "$6 \\times 4 = 24$", "note": "Missing value" } ] },
      { "q": "Hours to wages: $\\begin{array}{c|cccc} \\text{Hours} & 1 & 2 & 3 & 4 \\\\ \\hline \\text{Wage (\\$)} & 18 & 36 & 54 & 72 \\end{array}$. Find the rule.", "a": "wage $= 18 \\times$ hours",
        "solution": [ { "math": "$18 \\div 1 = 18$", "note": "Per hour" }, { "math": "$\\text{wage} = 18 \\times \\text{hours}$", "note": "$\\$18$/hr" } ] },
      { "q": "Find the rule: $\\begin{array}{c|cccc} \\text{Top} & 5 & 10 & 15 & 20 \\\\ \\hline \\text{Bottom} & 10 & 20 & 30 & 40 \\end{array}$", "a": "bottom $= 2 \\times$ top",
        "solution": [ { "math": "$10 \\div 5 = 2$", "note": "Multiplier" }, { "math": "$\\text{bottom} = 2 \\times \\text{top}$", "note": "Check $10 \\times 2 = 20$" } ] },
      { "q": "Boxes to eggs: $\\begin{array}{c|cccc} \\text{Boxes} & 2 & 3 & 5 & 8 \\\\ \\hline \\text{Eggs} & 24 & 36 & 60 & 96 \\end{array}$. Find the rule.", "a": "eggs $= 12 \\times$ boxes",
        "solution": [ { "math": "$24 \\div 2 = 12$", "note": "Per box" }, { "math": "$\\text{eggs} = 12 \\times \\text{boxes}$", "note": "Check $3 \\times 12 = 36$" } ] },
      { "q": "Find the rule and missing value: $\\begin{array}{c|cccc} \\text{Top} & 2 & 4 & 6 & 9 \\\\ \\hline \\text{Bottom} & 10 & 20 & 30 & ? \\end{array}$", "a": "bottom $= 5 \\times$ top; $45$",
        "solution": [ { "math": "$10 \\div 2 = 5$", "note": "Multiplier" }, { "math": "$5 \\times 9 = 45$", "note": "Missing value" } ] },
      { "q": "Find the rule: $\\begin{array}{c|cccc} \\text{Top} & 1 & 3 & 5 & 7 \\\\ \\hline \\text{Bottom} & 11 & 33 & 55 & 77 \\end{array}$", "a": "bottom $= 11 \\times$ top",
        "solution": [ { "math": "$11 \\div 1 = 11$", "note": "Multiplier" }, { "math": "$\\text{bottom} = 11 \\times \\text{top}$", "note": "Check $3 \\times 11 = 33$" } ] },
      { "q": "Litres per minute: $\\begin{array}{c|cccc} \\text{Min} & 2 & 4 & 6 & 10 \\\\ \\hline \\text{Litres} & 30 & 60 & 90 & 150 \\end{array}$. Find the rule.", "a": "litres $= 15 \\times$ min",
        "solution": [ { "math": "$30 \\div 2 = 15$", "note": "Per minute" }, { "math": "$\\text{litres} = 15 \\times \\text{min}$", "note": "Check $4 \\times 15 = 60$" } ] },
      { "q": "Find the rule: $\\begin{array}{c|cccc} \\text{Top} & 4 & 8 & 12 & 20 \\\\ \\hline \\text{Bottom} & 100 & 200 & 300 & 500 \\end{array}$", "a": "bottom $= 25 \\times$ top",
        "solution": [ { "math": "$100 \\div 4 = 25$", "note": "Multiplier" }, { "math": "$\\text{bottom} = 25 \\times \\text{top}$", "note": "Check $8 \\times 25 = 200$" } ] }
    ],
    "mastery": [
      { "q": "Using the rule from $\\begin{array}{c|ccc} \\text{Top} & 2 & 4 & 6 \\\\ \\hline \\text{Bottom} & 14 & 28 & 42 \\end{array}$, find the bottom when the top is $10$.", "a": "$70$",
        "solution": [ { "math": "$14 \\div 2 = 7$", "note": "Multiplier" }, { "math": "$7 \\times 10 = 70$", "note": "Top $= 10$" } ] },
      { "q": "A table follows bottom $= 8 \\times$ top. If the bottom is $96$, what is the top?", "a": "$12$",
        "solution": [ { "math": "$8 \\times \\square = 96$", "note": "Work backwards" }, { "math": "$\\square = 12$", "note": "Top is $12$" } ] },
      { "q": "Find the rule, then the top when the bottom is $108$: $\\begin{array}{c|ccc} \\text{Top} & 1 & 2 & 3 \\\\ \\hline \\text{Bottom} & 9 & 18 & 27 \\end{array}$", "a": "$9 \\times$ top; top $= 12$",
        "solution": [ { "math": "$\\text{bottom} = 9 \\times \\text{top}$", "note": "Multiplier $9$" }, { "math": "$108 \\div 9 = 12$", "note": "Top is $12$" } ] },
      { "q": "A worker is paid bottom $= 22 \\times$ top (hours). How much for $7$ hours?", "a": "$\\$154$",
        "solution": [ { "math": "$22 \\times 7$", "note": "Apply rule" }, { "math": "$= 154$", "note": "$\\$154$" } ] },
      { "q": "A student claims the rule for $\\begin{array}{c|ccc} \\text{Top} & 2 & 4 & 6 \\\\ \\hline \\text{Bottom} & 6 & 12 & 18 \\end{array}$ is 'add $4$'. Show the multiplicative rule.", "a": "bottom $= 3 \\times$ top",
        "solution": [ { "math": "$6 \\div 2 = 3$", "note": "Same for all columns" }, { "math": "$\\text{bottom} = 3 \\times \\text{top}$", "note": "Not 'add $4$'" } ] },
      { "q": "Find the rule, then complete: $\\begin{array}{c|cccc} \\text{Top} & 3 & 6 & 9 & ? \\\\ \\hline \\text{Bottom} & 21 & 42 & 63 & 105 \\end{array}$", "a": "$7 \\times$ top; top $= 15$",
        "solution": [ { "math": "$21 \\div 3 = 7$", "note": "Multiplier" }, { "math": "$105 \\div 7 = 15$", "note": "Top is $15$" } ] },
      { "q": "A recipe scales bottom $= 4 \\times$ top (people). How many people does $60$ on the bottom serve?", "a": "$15$ people",
        "solution": [ { "math": "$4 \\times \\square = 60$", "note": "Work backwards" }, { "math": "$\\square = 15$", "note": "$15$ people" } ] },
      { "q": "Two tables: A is bottom $= 5 \\times$ top, B is bottom $= 8 \\times$ top. At top $= 6$, which bottom is larger and by how much?", "a": "B, by $18$",
        "solution": [ { "math": "$5 \\times 6 = 30,\\ 8 \\times 6 = 48$", "note": "Both at top $6$" }, { "math": "$48 - 30 = 18$", "note": "B larger by $18$" } ] },
      { "q": "Find the rule, then the bottom at top $= 100$: $\\begin{array}{c|ccc} \\text{Top} & 5 & 10 & 15 \\\\ \\hline \\text{Bottom} & 60 & 120 & 180 \\end{array}$", "a": "$12 \\times$ top; $1\\,200$",
        "solution": [ { "math": "$60 \\div 5 = 12$", "note": "Multiplier" }, { "math": "$12 \\times 100 = 1\\,200$", "note": "Top $= 100$" } ] },
      { "q": "A table follows bottom $= 15 \\times$ top. The bottom values are $30, 45, 60$. Find the matching top values.", "a": "$2, 3, 4$",
        "solution": [ { "math": "$30 \\div 15, 45 \\div 15, 60 \\div 15$", "note": "Divide by $15$" }, { "math": "$= 2, 3, 4$", "note": "Top values" } ] }
    ]
  }
}
