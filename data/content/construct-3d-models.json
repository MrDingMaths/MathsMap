{
  "skillId": "construct-3d-models",
  "atomType": "R",
  "theory": {
    "intro": "Prisms and pyramids can be built from their flat parts (faces and edges). Counting the faces, edges and vertices helps you name and construct a solid.",
    "facts": [
      "A **prism** has two identical end faces joined by rectangles; a **pyramid** has one base and triangular faces meeting at an apex.",
      "A prism is named by its end face: a triangular prism has $2$ triangular and $3$ rectangular faces.",
      "**Faces** are flat surfaces, **edges** are where two faces meet, **vertices** are corner points.",
      "A skeletal (edges-only) model is built from straws for edges and joiners for vertices."
    ],
    "steps": [
      "Look at the end (or base) face to decide the solid's name.",
      "Count the faces, edges and vertices from the drawing or net.",
      "Build it: connect edges at the vertices to form the faces."
    ]
  },
  "practice": {
    "foundation": [
      { "q": "How many faces does this triangular prism have?", "a": "$5$ faces",
        "tikz": "\\begin{tikzpicture}[x=1cm,y=1cm]\n\\draw[thick] (0,0)--(2,0)--(1,1.5)--cycle;\n\\draw[thick] (1.2,0.6)--(3.2,0.6)--(2.2,2.1)--cycle;\n\\draw[thick] (0,0)--(1.2,0.6);\n\\draw[thick] (2,0)--(3.2,0.6);\n\\draw[thick] (1,1.5)--(2.2,2.1);\n\\end{tikzpicture}",
        "solution": [ { "math": "$2 \\text{ triangles} + 3 \\text{ rectangles}$", "note": "Ends and sides" }, { "math": "$= 5 \\text{ faces}$", "note": "" } ] },
      { "q": "How many vertices does a cube have?", "a": "$8$ vertices",
        "tikz": "\\begin{tikzpicture}[x=1cm,y=1cm]\n\\draw[thick] (0,0) rectangle (2,2);\n\\draw[thick] (0,2)--(0.7,2.6)--(2.7,2.6)--(2,2);\n\\draw[thick] (2,0)--(2.7,0.6)--(2.7,2.6);\n\\draw[dashed] (0,0)--(0.7,0.6)--(2.7,0.6);\n\\draw[dashed] (0.7,0.6)--(0.7,2.6);\n\\end{tikzpicture}",
        "solution": [ { "math": "$4 \\text{ top} + 4 \\text{ bottom}$", "note": "Corners" }, { "math": "$= 8 \\text{ vertices}$", "note": "" } ] },
      { "q": "Which solid does this net build?", "a": "A square pyramid",
        "tikz": "\\begin{tikzpicture}[x=1cm,y=1cm]\n\\draw[thick] (0,0) rectangle (1.5,1.5);\n\\draw[thick] (0,1.5)--(0.75,2.6)--(1.5,1.5);\n\\draw[thick] (1.5,0)--(2.6,0.75)--(1.5,1.5);\n\\draw[thick] (0,0)--(-1.1,0.75)--(0,1.5);\n\\draw[thick] (0,0)--(0.75,-1.1)--(1.5,0);\n\\end{tikzpicture}",
        "solution": [ { "math": "$1 \\text{ square} + 4 \\text{ triangles}$", "note": "Base + sides" }, { "math": "$= \\text{square pyramid}$", "note": "" } ] },
      { "q": "How many edges does a triangular prism have?", "a": "$9$ edges",
        "tikz": "\\begin{tikzpicture}[x=1cm,y=1cm]\n\\draw[thick] (0,0)--(2,0)--(1,1.5)--cycle;\n\\draw[thick] (1.2,0.6)--(3.2,0.6)--(2.2,2.1)--cycle;\n\\draw[thick] (0,0)--(1.2,0.6);\n\\draw[thick] (2,0)--(3.2,0.6);\n\\draw[thick] (1,1.5)--(2.2,2.1);\n\\end{tikzpicture}",
        "solution": [ { "math": "$3 + 3 + 3$", "note": "Two triangles + joining edges" }, { "math": "$= 9 \\text{ edges}$", "note": "" } ] },
      { "q": "How many faces does a square pyramid have?", "a": "$5$ faces",
        "tikz": "\\begin{tikzpicture}[x=1cm,y=1cm]\n\\draw[thick] (0,0)--(2,0)--(2.6,0.6)--(0.6,0.6)--cycle;\n\\draw[thick] (0,0)--(1.3,2)--(2,0);\n\\draw[thick] (2,0)--(1.3,2)--(2.6,0.6);\n\\draw[dashed] (0.6,0.6)--(1.3,2);\n\\end{tikzpicture}",
        "solution": [ { "math": "$1 \\text{ square} + 4 \\text{ triangles}$", "note": "Base + sides" }, { "math": "$= 5 \\text{ faces}$", "note": "" } ] },
      { "q": "How many vertices does a triangular pyramid (tetrahedron) have?", "a": "$4$ vertices",
        "tikz": "\\begin{tikzpicture}[x=1cm,y=1cm]\n\\draw[thick] (0,0)--(2,0)--(1.2,0.6)--cycle;\n\\draw[thick] (0,0)--(1,2)--(2,0);\n\\draw[dashed] (1.2,0.6)--(1,2);\n\\end{tikzpicture}",
        "solution": [ { "math": "$3 \\text{ base} + 1 \\text{ apex}$", "note": "Corners" }, { "math": "$= 4 \\text{ vertices}$", "note": "" } ] },
      { "q": "A prism has a hexagonal end face. What is its name?", "a": "Hexagonal prism",
        "solution": [ { "math": "$\\text{end face} = \\text{hexagon}$", "note": "Name by the end" }, { "math": "$= \\text{hexagonal prism}$", "note": "" } ] },
      { "q": "How many faces does a cube have?", "a": "$6$ faces",
        "tikz": "\\begin{tikzpicture}[x=1cm,y=1cm]\n\\draw[thick] (0,0) rectangle (2,2);\n\\draw[thick] (0,2)--(0.7,2.6)--(2.7,2.6)--(2,2);\n\\draw[thick] (2,0)--(2.7,0.6)--(2.7,2.6);\n\\end{tikzpicture}",
        "solution": [ { "math": "$\\text{top, bottom, } 4 \\text{ sides}$", "note": "Square faces" }, { "math": "$= 6 \\text{ faces}$", "note": "" } ] },
      { "q": "Which solid does this net build?", "a": "A triangular prism",
        "tikz": "\\begin{tikzpicture}[x=1cm,y=1cm]\n\\draw[thick] (0,0) rectangle (3,1);\n\\draw[thick] (0,1) rectangle (3,2);\n\\draw[thick] (0,2) rectangle (3,3);\n\\draw[thick] (0,1)--(-0.9,1.5)--(0,2);\n\\draw[thick] (3,1)--(3.9,1.5)--(3,2);\n\\end{tikzpicture}",
        "solution": [ { "math": "$3 \\text{ rectangles} + 2 \\text{ triangles}$", "note": "Sides + ends" }, { "math": "$= \\text{triangular prism}$", "note": "" } ] },
      { "q": "How many edges does a square pyramid have?", "a": "$8$ edges",
        "tikz": "\\begin{tikzpicture}[x=1cm,y=1cm]\n\\draw[thick] (0,0)--(2,0)--(2.6,0.6)--(0.6,0.6)--cycle;\n\\draw[thick] (0,0)--(1.3,2)--(2,0);\n\\draw[thick] (2,0)--(1.3,2)--(2.6,0.6);\n\\draw[dashed] (0.6,0.6)--(1.3,2);\n\\end{tikzpicture}",
        "solution": [ { "math": "$4 \\text{ base} + 4 \\text{ sloping}$", "note": "Base + to apex" }, { "math": "$= 8 \\text{ edges}$", "note": "" } ] }
    ],
    "development": [
      { "q": "A skeletal model uses straws for edges. How many straws are needed for a cube?", "a": "$12$ straws",
        "tikz": "\\begin{tikzpicture}[x=1cm,y=1cm]\n\\draw[thick] (0,0) rectangle (2,2);\n\\draw[thick] (0,2)--(0.7,2.6)--(2.7,2.6)--(2,2);\n\\draw[thick] (2,0)--(2.7,0.6)--(2.7,2.6);\n\\draw[dashed] (0,0)--(0.7,0.6)--(2.7,0.6);\n\\draw[dashed] (0.7,0.6)--(0.7,2.6);\n\\end{tikzpicture}",
        "solution": [ { "math": "$4 \\text{ top} + 4 \\text{ bottom} + 4 \\text{ uprights}$", "note": "Each edge = a straw" }, { "math": "$= 12 \\text{ straws}$", "note": "" } ] },
      { "q": "How many joiners (vertices) are needed for a skeletal triangular prism?", "a": "$6$ joiners",
        "tikz": "\\begin{tikzpicture}[x=1cm,y=1cm]\n\\draw[thick] (0,0)--(2,0)--(1,1.5)--cycle;\n\\draw[thick] (1.2,0.6)--(3.2,0.6)--(2.2,2.1)--cycle;\n\\draw[thick] (0,0)--(1.2,0.6);\n\\draw[thick] (2,0)--(3.2,0.6);\n\\draw[thick] (1,1.5)--(2.2,2.1);\n\\end{tikzpicture}",
        "solution": [ { "math": "$3 \\text{ per triangle} \\times 2$", "note": "Two end faces" }, { "math": "$= 6 \\text{ joiners}$", "note": "" } ] },
      { "q": "A pentagonal prism has how many faces?", "a": "$7$ faces",
        "solution": [ { "math": "$2 \\text{ pentagons} + 5 \\text{ rectangles}$", "note": "Ends + sides" }, { "math": "$= 7 \\text{ faces}$", "note": "" } ] },
      { "q": "Which solid does this net build?", "a": "A rectangular prism (cuboid)",
        "tikz": "\\begin{tikzpicture}[x=1cm,y=1cm]\n\\draw[thick] (1,0) rectangle (3,1);\n\\draw[thick] (1,1) rectangle (3,2.5);\n\\draw[thick] (1,2.5) rectangle (3,3.5);\n\\draw[thick] (1,3.5) rectangle (3,5);\n\\draw[thick] (0,1) rectangle (1,2.5);\n\\draw[thick] (3,1) rectangle (4,2.5);\n\\end{tikzpicture}",
        "solution": [ { "math": "$6 \\text{ rectangles}$", "note": "Opposite faces match" }, { "math": "$= \\text{rectangular prism}$", "note": "" } ] },
      { "q": "A pentagonal pyramid has how many edges?", "a": "$10$ edges",
        "solution": [ { "math": "$5 \\text{ base} + 5 \\text{ sloping}$", "note": "Base + to apex" }, { "math": "$= 10 \\text{ edges}$", "note": "" } ] },
      { "q": "How many straws are needed for a skeletal square pyramid?", "a": "$8$ straws",
        "tikz": "\\begin{tikzpicture}[x=1cm,y=1cm]\n\\draw[thick] (0,0)--(2,0)--(2.6,0.6)--(0.6,0.6)--cycle;\n\\draw[thick] (0,0)--(1.3,2)--(2,0);\n\\draw[thick] (2,0)--(1.3,2)--(2.6,0.6);\n\\draw[dashed] (0.6,0.6)--(1.3,2);\n\\end{tikzpicture}",
        "solution": [ { "math": "$4 \\text{ base} + 4 \\text{ to apex}$", "note": "Each edge = a straw" }, { "math": "$= 8 \\text{ straws}$", "note": "" } ] },
      { "q": "A hexagonal prism has how many vertices?", "a": "$12$ vertices",
        "solution": [ { "math": "$6 \\text{ top} + 6 \\text{ bottom}$", "note": "Two hexagons" }, { "math": "$= 12 \\text{ vertices}$", "note": "" } ] },
      { "q": "A solid has $1$ square base and $4$ triangular faces meeting at a point. Name it.", "a": "Square pyramid",
        "solution": [ { "math": "$\\text{base} = \\text{square, apex above}$", "note": "Faces meet at apex" }, { "math": "$= \\text{square pyramid}$", "note": "" } ] },
      { "q": "How many faces does a hexagonal pyramid have?", "a": "$7$ faces",
        "solution": [ { "math": "$1 \\text{ hexagon} + 6 \\text{ triangles}$", "note": "Base + sides" }, { "math": "$= 7 \\text{ faces}$", "note": "" } ] },
      { "q": "A skeletal triangular pyramid is built. How many straws and joiners are used?", "a": "$6$ straws, $4$ joiners",
        "tikz": "\\begin{tikzpicture}[x=1cm,y=1cm]\n\\draw[thick] (0,0)--(2,0)--(1.2,0.6)--cycle;\n\\draw[thick] (0,0)--(1,2)--(2,0);\n\\draw[dashed] (1.2,0.6)--(1,2);\n\\end{tikzpicture}",
        "solution": [ { "math": "$6 \\text{ edges, } 4 \\text{ vertices}$", "note": "Tetrahedron" }, { "math": "$= 6 \\text{ straws, } 4 \\text{ joiners}$", "note": "" } ] }
    ],
    "mastery": [
      { "q": "A prism has $2$ octagonal ends. How many faces, edges and vertices does it have?", "a": "$10$ faces, $24$ edges, $16$ vertices",
        "solution": [ { "math": "$2 + 8 = 10 \\text{ faces}$", "note": "Ends + sides" }, { "math": "$8\\times3 = 24 \\text{ edges},\\ 8\\times2 = 16 \\text{ vertices}$", "note": "" } ] },
      { "q": "A pyramid has a base with $n$ sides. Write a rule for the number of faces.", "a": "$n + 1$ faces",
        "solution": [ { "math": "$1 \\text{ base} + n \\text{ triangles}$", "note": "One per base edge" }, { "math": "$= n + 1 \\text{ faces}$", "note": "" } ] },
      { "q": "A prism has a base with $n$ sides. Write a rule for the number of edges.", "a": "$3n$ edges",
        "solution": [ { "math": "$n + n + n$", "note": "Two ends + joining edges" }, { "math": "$= 3n \\text{ edges}$", "note": "" } ] },
      { "q": "Check Euler's rule $F + V = E + 2$ for a square pyramid.", "a": "Yes — $5 + 5 = 8 + 2$",
        "solution": [ { "math": "$F = 5,\\ V = 5,\\ E = 8$", "note": "Count each" }, { "math": "$5 + 5 = 8 + 2 = 10$", "note": "Rule holds" } ] },
      { "q": "A solid has $6$ faces, $12$ edges and $8$ vertices, with all faces rectangles. Name it.", "a": "Rectangular prism (cuboid)",
        "solution": [ { "math": "$6 \\text{ rectangular faces}$", "note": "Two ends + 4 sides" }, { "math": "$= \\text{rectangular prism}$", "note": "" } ] },
      { "q": "How many more edges does a hexagonal prism have than a hexagonal pyramid?", "a": "$6$ more edges",
        "solution": [ { "math": "$\\text{prism } 18,\\ \\text{pyramid } 12$", "note": "$3\\times6$ and $2\\times6$" }, { "math": "$18 - 12 = 6$", "note": "" } ] },
      { "q": "A pyramid has $14$ edges. How many sides does its base have?", "a": "$7$ sides",
        "solution": [ { "math": "$\\text{edges} = 2n$", "note": "$n$ base + $n$ sloping" }, { "math": "$2n = 14 \\Rightarrow n = 7$", "note": "Heptagonal base" } ] },
      { "q": "A net is made of $1$ pentagon and $5$ triangles. What solid does it build, and how many vertices?", "a": "Pentagonal pyramid; $6$ vertices",
        "solution": [ { "math": "$\\text{base} = \\text{pentagon, } 5 \\text{ sides}$", "note": "Triangles meet at apex" }, { "math": "$5 \\text{ base} + 1 \\text{ apex} = 6$", "note": "" } ] },
      { "q": "You have $9$ straws and $6$ joiners. Which prism can you build exactly?", "a": "Triangular prism",
        "solution": [ { "math": "$\\text{edges} = 3n = 9 \\Rightarrow n = 3$", "note": "Triangular ends" }, { "math": "$\\text{vertices} = 2n = 6$", "note": "Matches" } ] },
      { "q": "Compare the number of vertices of a triangular prism and a square pyramid. Which has more, and by how many?", "a": "Prism $6$, pyramid $5$ — prism has $1$ more",
        "solution": [ { "math": "$\\text{prism } 6,\\ \\text{pyramid } 5$", "note": "Count corners" }, { "math": "$6 - 5 = 1$", "note": "Prism has one more" } ] }
    ]
  }
}
