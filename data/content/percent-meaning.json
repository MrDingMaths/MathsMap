{
  "skillId": "percent-meaning",
  "atomType": "R",
  "theory": {
    "intro": "Per cent means 'per hundred'. A percentage tells you how many parts out of $100$ you have.",
    "facts": [
      "$\\%$ means **out of $100$**, so $37\\% = \\dfrac{37}{100}$.",
      "$100\\%$ is the **whole**; $50\\%$ is half; $0\\%$ is none.",
      "On a $10 \\times 10$ grid ($100$ squares), each shaded square is $1\\%$."
    ],
    "steps": [
      "Count (or read) how many parts out of $100$.",
      "Write that number with a $\\%$ sign.",
      "Compare with the whole: more than $100\\%$ is more than one whole."
    ]
  },
  "practice": {
    "foundation": [
      { "q": "What percentage of this $100$-square grid is shaded?", "a": "$30\\%$",
        "tikz": "\\begin{tikzpicture}[x=0.32cm,y=0.32cm]\n\\fill[gray!45] (0,0) rectangle (3,10);\n\\draw (0,0) rectangle (10,10);\n\\foreach \\i in {1,...,9} \\draw (\\i,0)--(\\i,10);\n\\foreach \\j in {1,...,9} \\draw (0,\\j)--(10,\\j);\n\\end{tikzpicture}",
        "solution": [ { "math": "$3 \\text{ columns} = 30 \\text{ squares}$", "note": "Each square is $1\\%$" }, { "math": "$= 30\\%$", "note": "" } ] },
      { "q": "What percentage of this $100$-square grid is shaded?", "a": "$70\\%$",
        "tikz": "\\begin{tikzpicture}[x=0.32cm,y=0.32cm]\n\\fill[gray!45] (0,0) rectangle (7,10);\n\\draw (0,0) rectangle (10,10);\n\\foreach \\i in {1,...,9} \\draw (\\i,0)--(\\i,10);\n\\foreach \\j in {1,...,9} \\draw (0,\\j)--(10,\\j);\n\\end{tikzpicture}",
        "solution": [ { "math": "$7 \\text{ columns} = 70 \\text{ squares}$", "note": "Each square is $1\\%$" }, { "math": "$= 70\\%$", "note": "" } ] },
      { "q": "Write $45\\%$ as a fraction out of $100$.", "a": "$\\dfrac{45}{100}$",
        "solution": [ { "math": "$45\\% = 45 \\text{ per } 100$", "note": "Meaning of %" }, { "math": "$= \\dfrac{45}{100}$", "note": "" } ] },
      { "q": "What percentage of a whole is $100\\%$?", "a": "the whole (all of it)",
        "solution": [ { "math": "$100\\% = \\dfrac{100}{100}$", "note": "All 100 parts" }, { "math": "$= 1 \\text{ whole}$", "note": "" } ] },
      { "q": "What percentage of this $100$-square grid is shaded?", "a": "$50\\%$",
        "tikz": "\\begin{tikzpicture}[x=0.32cm,y=0.32cm]\n\\fill[gray!45] (0,0) rectangle (5,10);\n\\draw (0,0) rectangle (10,10);\n\\foreach \\i in {1,...,9} \\draw (\\i,0)--(\\i,10);\n\\foreach \\j in {1,...,9} \\draw (0,\\j)--(10,\\j);\n\\end{tikzpicture}",
        "solution": [ { "math": "$5 \\text{ columns} = 50 \\text{ squares}$", "note": "Half the grid" }, { "math": "$= 50\\%$", "note": "" } ] },
      { "q": "Write $9\\%$ as a fraction out of $100$.", "a": "$\\dfrac{9}{100}$",
        "solution": [ { "math": "$9\\% = 9 \\text{ per } 100$", "note": "Meaning of %" }, { "math": "$= \\dfrac{9}{100}$", "note": "" } ] },
      { "q": "If $40\\%$ of a class are boys, what percentage are girls?", "a": "$60\\%$",
        "solution": [ { "math": "$100\\% - 40\\%$", "note": "The rest of the whole" }, { "math": "$= 60\\%$", "note": "" } ] },
      { "q": "What percentage is shaded if none of the grid is shaded?", "a": "$0\\%$",
        "solution": [ { "math": "$0 \\text{ squares}$", "note": "Nothing shaded" }, { "math": "$= 0\\%$", "note": "" } ] },
      { "q": "A test is marked out of $100$. A student scores $82$. What percentage is this?", "a": "$82\\%$",
        "solution": [ { "math": "$\\dfrac{82}{100}$", "note": "Out of 100" }, { "math": "$= 82\\%$", "note": "" } ] },
      { "q": "Write $25\\%$ as a fraction out of $100$.", "a": "$\\dfrac{25}{100}$",
        "solution": [ { "math": "$25\\% = 25 \\text{ per } 100$", "note": "Meaning of %" }, { "math": "$= \\dfrac{25}{100}$", "note": "" } ] }
    ],
    "development": [
      { "q": "A jar has $100$ beads; $23$ are red. What percentage are red?", "a": "$23\\%$",
        "solution": [ { "math": "$\\dfrac{23}{100}$", "note": "Out of 100" }, { "math": "$= 23\\%$", "note": "" } ] },
      { "q": "If $65\\%$ of a phone battery is used, what percentage is left?", "a": "$35\\%$",
        "solution": [ { "math": "$100\\% - 65\\%$", "note": "Whole minus used" }, { "math": "$= 35\\%$", "note": "" } ] },
      { "q": "A grid has $100$ squares with $8$ shaded. What percentage is shaded?", "a": "$8\\%$",
        "solution": [ { "math": "$\\dfrac{8}{100}$", "note": "Out of 100" }, { "math": "$= 8\\%$", "note": "" } ] },
      { "q": "Can a percentage be more than $100\\%$? Give an example in context.", "a": "yes, e.g. sales rose to $120\\%$ of last year",
        "solution": [ { "math": "$120\\% = \\dfrac{120}{100}$", "note": "More than one whole" }, { "math": "$= 1.2 \\text{ wholes}$", "note": "" } ] },
      { "q": "$30\\%$ of a grid is grey and $20\\%$ is black. What percentage is unshaded?", "a": "$50\\%$",
        "solution": [ { "math": "$30\\% + 20\\% = 50\\%$", "note": "Total shaded" }, { "math": "$100\\% - 50\\% = 50\\%$", "note": "Unshaded" } ] },
      { "q": "Three parts of a whole are $25\\%$, $25\\%$ and $\\square$. What is the missing percentage?", "a": "$50\\%$",
        "solution": [ { "math": "$25\\% + 25\\% = 50\\%$", "note": "So far" }, { "math": "$100\\% - 50\\% = 50\\%$", "note": "The rest" } ] },
      { "q": "Write $\\dfrac{17}{100}$ as a percentage.", "a": "$17\\%$",
        "solution": [ { "math": "$\\dfrac{17}{100} = 17 \\text{ per } 100$", "note": "Per hundred" }, { "math": "$= 17\\%$", "note": "" } ] },
      { "q": "A survey of $100$ people found $54$ liked tea, $31$ liked coffee, the rest liked neither. What percentage liked neither?", "a": "$15\\%$",
        "solution": [ { "math": "$54 + 31 = 85$", "note": "Tea or coffee" }, { "math": "$100 - 85 = 15 \\Rightarrow 15\\%$", "note": "Neither" } ] },
      { "q": "If $100\\%$ of a pizza is eaten, how many pizzas were eaten?", "a": "$1$ whole pizza",
        "solution": [ { "math": "$100\\% = 1 \\text{ whole}$", "note": "All of it" }, { "math": "$= 1 \\text{ pizza}$", "note": "" } ] },
      { "q": "A grid shows $40$ squares shaded out of $100$. Write this as a percentage and as a fraction.", "a": "$40\\%$, $\\dfrac{40}{100}$",
        "solution": [ { "math": "$\\dfrac{40}{100}$", "note": "Out of 100" }, { "math": "$= 40\\%$", "note": "" } ] }
    ],
    "mastery": [
      { "q": "In an election, $48\\%$ voted for A, $37\\%$ for B and the rest did not vote. What percentage did not vote?", "a": "$15\\%$",
        "solution": [ { "math": "$48\\% + 37\\% = 85\\%$", "note": "Voted" }, { "math": "$100\\% - 85\\% = 15\\%$", "note": "Did not vote" } ] },
      { "q": "A shop sells $200\\%$ of its target. How many times the target is this?", "a": "$2$ times",
        "solution": [ { "math": "$200\\% = \\dfrac{200}{100}$", "note": "Per hundred" }, { "math": "$= 2 \\text{ wholes}$", "note": "Twice the target" } ] },
      { "q": "A grid is split: $\\dfrac{1}{2}$ grey, $\\dfrac{1}{4}$ black, the rest white. What percentage is white?", "a": "$25\\%$",
        "solution": [ { "math": "$50\\% + 25\\% = 75\\%$", "note": "Grey + black" }, { "math": "$100\\% - 75\\% = 25\\%$", "note": "White" } ] },
      { "q": "If $1\\%$ of a number is $7$, what is $100\\%$ of it?", "a": "$700$",
        "solution": [ { "math": "$1\\% = 7$", "note": "One hundredth" }, { "math": "$100 \\times 7 = 700$", "note": "Whole = 100 parts" } ] },
      { "q": "Two grids are each $100$ squares. The first is $90\\%$ shaded, the second $30\\%$. Altogether, out of $200$ squares, what percentage is shaded?", "a": "$60\\%$",
        "solution": [ { "math": "$90 + 30 = 120 \\text{ squares}$", "note": "Total shaded" }, { "math": "$\\dfrac{120}{200} = 60\\%$", "note": "Out of 200" } ] },
      { "q": "A battery shows $100\\%$ when full. It drops $35\\%$, then a further $40\\%$. What percentage remains?", "a": "$25\\%$",
        "solution": [ { "math": "$35\\% + 40\\% = 75\\%$", "note": "Total used" }, { "math": "$100\\% - 75\\% = 25\\%$", "note": "Remaining" } ] },
      { "q": "If $50\\%$ of a class is $15$ students, the whole class is how many?", "a": "$30$ students",
        "solution": [ { "math": "$50\\% = \\text{half} = 15$", "note": "Half the class" }, { "math": "$2 \\times 15 = 30$", "note": "Whole class" } ] },
      { "q": "A recipe is doubled, giving $200\\%$ of the original. The original used $3$ eggs. How many eggs now?", "a": "$6$ eggs",
        "solution": [ { "math": "$200\\% = 2 \\times \\text{original}$", "note": "Doubled" }, { "math": "$2 \\times 3 = 6$", "note": "" } ] },
      { "q": "Of $100$ matches, a team won $55\\%$ and drew $20\\%$. How many did they lose?", "a": "$25$ matches",
        "solution": [ { "math": "$55\\% + 20\\% = 75\\%$", "note": "Won or drew" }, { "math": "$100 - 75 = 25$", "note": "Lost" } ] },
      { "q": "Explain why $50\\%$ of $20$ and $20\\%$ of $50$ are equal.", "a": "both equal $10$",
        "solution": [ { "math": "$50\\% \\text{ of } 20 = 10$", "note": "Half of 20" }, { "math": "$20\\% \\text{ of } 50 = 10$", "note": "Same product" } ] }
    ]
  }
}
