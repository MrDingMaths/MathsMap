  "theory": {
    "intro": "To **estimate** a product, round each factor to a nearby multiple of $10$ or $100$, then multiply the rounded numbers. This gives a quick, approximate answer.",
    "facts": [
      "Round each factor to the nearest $10$ or $100$ first.",
      "$\\approx$ means 'is approximately equal to'.",
      "$48 \\times 21 \\approx 50 \\times 20 = 1000$."
    ],
    "steps": [
      "Round each factor to a convenient multiple of $10$ or $100$.",
      "Multiply the rounded numbers mentally.",
      "Write the estimate with $\\approx$."
    ]
  },
  "practice": {
