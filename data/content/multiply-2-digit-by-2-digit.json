{
  "skillId": "multiply-2-digit-by-2-digit",
  "atomType": "R",
  "theory": {
    "intro": "To multiply by a 2-digit number, partition **both** numbers by place value (the area model gives four part-products) or use the standard algorithm.",
    "facts": [
      "The area model for $2 \\times 2$ digits gives **four** part-products.",
      "e.g. $34 \\times 26 = (30+4)(20+6)$ has parts $600, 180, 80, 24$.",
      "The algorithm multiplies by the ones, then the tens (shifted one place), then adds."
    ],
    "steps": [
      "Split each number into tens and ones.",
      "Multiply every part of one by every part of the other.",
      "Add all the part-products for the total."
    ]
  },
  "practice": {
    "foundation": [
      { "q": "Use the area model to find $23 \\times 14$.", "a": "$322$",
        "tikz": "\\begin{tikzpicture}[x=0.95cm,y=0.95cm]\n\\draw (0,0) rectangle (3,2);\n\\draw (2,0) -- (2,2); \\draw (0,1) -- (3,1);\n\\node at (1,2.3) {$20$}; \\node at (2.5,2.3) {$3$};\n\\node[left] at (0,1.5) {$10$}; \\node[left] at (0,0.5) {$4$};\n\\node at (1,1.5) {$200$}; \\node at (2.5,1.5) {$30$};\n\\node at (1,0.5) {$80$}; \\node at (2.5,0.5) {$12$};\n\\end{tikzpicture}",
        "solution": [ { "math": "$200 + 30 + 80 + 12$", "note": "Four part-products" }, { "math": "$= 322$", "note": "Add them" } ] },
      { "q": "Use the area model to find $32 \\times 21$.", "a": "$672$",
