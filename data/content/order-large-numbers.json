{
  "skillId": "order-large-numbers",
  "atomType": "R",
  "theory": {
    "intro": "To order large numbers, compare them by place value, starting from the highest place (the left-most digit).",
    "facts": [
      "The number with **more digits** is larger (ignoring leading zeros).",
      "With the same number of digits, compare from the **left**: the first column that differs decides it.",
      "**Ascending** = smallest to largest; **descending** = largest to smallest."
    ],
    "steps": [
      "Line the numbers up by place value (or count their digits).",
      "Compare the highest place; if equal, move one place right.",
      "List them in the order asked for."
    ]
  },
  "practice": {
    "foundation": [
      { "q": "Order from smallest to largest: $3\\,200\\,000$, $1\\,800\\,000$, $5\\,400\\,000$.", "a": "$1\\,800\\,000,\\ 3\\,200\\,000,\\ 5\\,400\\,000$",
        "solution": [ { "math": "$\\text{compare millions: } 1, 3, 5$", "note": "Highest place differs" }, { "math": "$1\\,800\\,000 < 3\\,200\\,000 < 5\\,400\\,000$", "note": "Ascending" } ] },
      { "q": "Order from largest to smallest: $620\\,000$, $260\\,000$, $602\\,000$.", "a": "$620\\,000,\\ 602\\,000,\\ 260\\,000$",
        "solution": [ { "math": "$6,\\ 2,\\ 6 \\to \\text{compare next place}$", "note": "Two start with 6" }, { "math": "$620\\,000 > 602\\,000 > 260\\,000$", "note": "Descending" } ] },
      { "q": "Order from smallest to largest: $4\\,050\\,000$, $4\\,500\\,000$, $4\\,005\\,000$.", "a": "$4\\,005\\,000,\\ 4\\,050\\,000,\\ 4\\,500\\,000$",
        "solution": [ { "math": "$\\text{millions equal: compare next places}$", "note": "All start with 4" }, { "math": "$005 < 050 < 500$", "note": "Hundred-thousands decide" } ] },
      { "q": "Which is larger: $980\\,000$ or $1\\,050\\,000$?", "a": "$1\\,050\\,000$",
        "solution": [ { "math": "$6\\text{ digits} < 7\\text{ digits}$", "note": "Count digits" }, { "math": "$1\\,050\\,000 > 980\\,000$", "note": "More digits is larger" } ] },
      { "q": "Order from smallest to largest: $750\\,000$, $7\\,500\\,000$, $75\\,000$.", "a": "$75\\,000,\\ 750\\,000,\\ 7\\,500\\,000$",
        "solution": [ { "math": "$5,\\ 7,\\ 6 \\text{ digits}$", "note": "Count digits" }, { "math": "$75\\,000 < 750\\,000 < 7\\,500\\,000$", "note": "Fewest digits first" } ] },
      { "q": "Which is smaller: $3\\,400\\,000$ or $3\\,040\\,000$?", "a": "$3\\,040\\,000$",
        "solution": [ { "math": "$3 = 3 \\to \\text{next place}$", "note": "Millions equal" }, { "math": "$040 < 400$", "note": "Hundred-thousands decide" } ] },
      { "q": "Order from largest to smallest: $2\\,100\\,000$, $2\\,010\\,000$, $2\\,110\\,000$.", "a": "$2\\,110\\,000,\\ 2\\,100\\,000,\\ 2\\,010\\,000$",
        "solution": [ { "math": "$\\text{compare from the left}$", "note": "All start 2" }, { "math": "$110 > 100 > 010$", "note": "Thousands groups" } ] },
      { "q": "Order from smallest to largest: $6\\,000\\,000$, $600\\,000$, $60\\,000$.", "a": "$60\\,000,\\ 600\\,000,\\ 6\\,000\\,000$",
        "solution": [ { "math": "$5,\\ 6,\\ 7 \\text{ digits}$", "note": "Count digits" }, { "math": "$60\\,000 < 600\\,000 < 6\\,000\\,000$", "note": "Fewest digits first" } ] },
      { "q": "Which is larger: $8\\,250\\,000$ or $8\\,205\\,000$?", "a": "$8\\,250\\,000$",
        "solution": [ { "math": "$8 = 8,\\ 2 = 2 \\to \\text{next place}$", "note": "Compare left to right" }, { "math": "$50 > 05$", "note": "Ten-thousands decide" } ] },
      { "q": "Order from largest to smallest: $5\\,600\\,000$, $6\\,500\\,000$, $5\\,060\\,000$.", "a": "$6\\,500\\,000,\\ 5\\,600\\,000,\\ 5\\,060\\,000$",
        "solution": [ { "math": "$6 > 5$", "note": "Largest millions first" }, { "math": "$600 > 060$", "note": "Then compare the two 5s" } ] }
    ],
    "development": [
      { "q": "Order from smallest to largest: $12\\,300\\,000$, $1\\,230\\,000$, $12\\,030\\,000$.", "a": "$1\\,230\\,000,\\ 12\\,030\\,000,\\ 12\\,300\\,000$",
        "solution": [ { "math": "$7,\\ 8,\\ 8 \\text{ digits}$", "note": "Fewest digits first" }, { "math": "$12\\,030\\,000 < 12\\,300\\,000$", "note": "Compare the two 8-digit numbers" } ] },
      { "q": "Order from largest to smallest: $45\\,800\\,000$, $45\\,080\\,000$, $45\\,808\\,000$.", "a": "$45\\,808\\,000,\\ 45\\,800\\,000,\\ 45\\,080\\,000$",
        "solution": [ { "math": "$45 = 45 \\to \\text{next place}$", "note": "Millions equal" }, { "math": "$808 > 800 > 080$", "note": "Thousands groups" } ] },
      { "q": "Insert $<$ or $>$: $9\\,999\\,000 \\ \\square\\ 10\\,001\\,000$.", "a": "$9\\,999\\,000 < 10\\,001\\,000$",
        "solution": [ { "math": "$7\\text{ digits} < 8\\text{ digits}$", "note": "Count digits" }, { "math": "$9\\,999\\,000 < 10\\,001\\,000$", "note": "More digits is larger" } ] },
      { "q": "Order from smallest to largest: $307\\,000$, $370\\,000$, $3\\,070\\,000$, $37\\,000$.", "a": "$37\\,000,\\ 307\\,000,\\ 370\\,000,\\ 3\\,070\\,000$",
        "solution": [ { "math": "$5,\\ 6,\\ 6,\\ 7 \\text{ digits}$", "note": "Count digits" }, { "math": "$307\\,000 < 370\\,000$", "note": "Compare the two 6-digit numbers" } ] },
      { "q": "Which is largest: $80\\,400\\,000$, $84\\,000\\,000$ or $8\\,400\\,000$?", "a": "$84\\,000\\,000$",
        "solution": [ { "math": "$7\\text{ vs }8\\text{ digits}$", "note": "Drop the 7-digit one" }, { "math": "$84 > 80$", "note": "Compare millions" } ] },
      { "q": "Insert $<$ or $>$: $6\\,540\\,000 \\ \\square\\ 6\\,504\\,000$.", "a": "$6\\,540\\,000 > 6\\,504\\,000$",
        "solution": [ { "math": "$6 = 6,\\ 5 = 5 \\to \\text{next place}$", "note": "Compare left to right" }, { "math": "$40 > 04$", "note": "Ten-thousands decide" } ] },
      { "q": "Order from largest to smallest: $1\\,001\\,000$, $1\\,010\\,000$, $1\\,000\\,100$.", "a": "$1\\,010\\,000,\\ 1\\,001\\,000,\\ 1\\,000\\,100$",
        "solution": [ { "math": "$\\text{all start } 1\\,0$", "note": "Compare next place" }, { "math": "$010 > 001\\,000 > 000\\,100$", "note": "First difference wins" } ] },
      { "q": "Order from smallest to largest: $23\\,456\\,000$, $23\\,465\\,000$, $23\\,400\\,000$.", "a": "$23\\,400\\,000,\\ 23\\,456\\,000,\\ 23\\,465\\,000$",
        "solution": [ { "math": "$23 = 23 \\to \\text{compare thousands}$", "note": "Millions equal" }, { "math": "$400 < 456 < 465$", "note": "Thousands groups" } ] },
      { "q": "Which is smaller: $100\\,500\\,000$ or $99\\,900\\,000$?", "a": "$99\\,900\\,000$",
        "solution": [ { "math": "$8\\text{ digits} < 9\\text{ digits}$", "note": "Count digits" }, { "math": "$99\\,900\\,000 < 100\\,500\\,000$", "note": "Fewer digits is smaller" } ] },
      { "q": "Order from largest to smallest: $5\\,055\\,000$, $5\\,505\\,000$, $5\\,550\\,000$, $5\\,005\\,000$.", "a": "$5\\,550\\,000,\\ 5\\,505\\,000,\\ 5\\,055\\,000,\\ 5\\,005\\,000$",
        "solution": [ { "math": "$\\text{all start } 5 \\to \\text{compare next places}$", "note": "Work left to right" }, { "math": "$550 > 505 > 055 > 005$", "note": "Thousands groups" } ] }
    ],
    "mastery": [
      { "q": "Three cities have populations $4\\,250\\,000$, $4\\,025\\,000$ and $4\\,520\\,000$. Which city is the most populous?", "a": "the city with $4\\,520\\,000$",
        "solution": [ { "math": "$4 = 4 \\to \\text{next place}$", "note": "Millions equal" }, { "math": "$520 > 250 > 025$", "note": "Largest is $4\\,520\\,000$" } ] },
      { "q": "Rivers have lengths $6\\,650$ km, $6\\,275$ km and $6\\,400$ km. List them from longest to shortest.", "a": "$6\\,650,\\ 6\\,400,\\ 6\\,275$",
        "solution": [ { "math": "$6 = 6 \\to \\text{next place}$", "note": "Thousands equal" }, { "math": "$650 > 400 > 275$", "note": "Hundreds decide" } ] },
      { "q": "What is the largest 7-digit number you can make using the digits $3, 0, 5, 1, 9, 2, 4$ once each?", "a": "$9\\,543\\,210$",
        "solution": [ { "math": "$\\text{put biggest digit on the left}$", "note": "Largest place first" }, { "math": "$9,5,4,3,2,1,0$", "note": "Descending digits" } ] },
      { "q": "What is the smallest 7-digit number using $3, 0, 5, 1, 9, 2, 4$ once each?", "a": "$1\\,023\\,459$",
        "solution": [ { "math": "$0 \\text{ cannot lead}$", "note": "Leading zero loses a digit" }, { "math": "$1,0,2,3,4,5,9$", "note": "Smallest non-zero first, then ascending" } ] },
      { "q": "Order the planet distances from the Sun (millions of km): $228$, $150$, $778$, $58$. Smallest to largest.", "a": "$58,\\ 150,\\ 228,\\ 778$",
        "solution": [ { "math": "$2,\\ 3,\\ 3,\\ 2 \\text{ digits}$", "note": "Count digits" }, { "math": "$58 < 150 < 228 < 778$", "note": "Ascending" } ] },
      { "q": "A number is greater than $5\\,400\\,000$ but less than $5\\,410\\,000$. Could it be $5\\,409\\,999$?", "a": "yes",
        "solution": [ { "math": "$5\\,400\\,000 < 5\\,409\\,999$", "note": "Above the lower bound" }, { "math": "$5\\,409\\,999 < 5\\,410\\,000$", "note": "Below the upper bound" } ] },
      { "q": "Four stadiums hold $52\\,500$, $50\\,250$, $52\\,050$ and $50\\,520$. List capacities from smallest to largest.", "a": "$50\\,250,\\ 50\\,520,\\ 52\\,050,\\ 52\\,500$",
        "solution": [ { "math": "$50 < 52$", "note": "Compare ten-thousands/thousands" }, { "math": "$250 < 520,\\ 050 < 500$", "note": "Then within each pair" } ] },
      { "q": "Insert the numbers $7\\,800\\,000$, $7\\,080\\,000$ and $7\\,808\\,000$ into: smallest $<\\ \\square\\ <$ largest.", "a": "$7\\,080\\,000 < 7\\,800\\,000 < 7\\,808\\,000$",
        "solution": [ { "math": "$7 = 7 \\to \\text{thousands group}$", "note": "Millions equal" }, { "math": "$080 < 800 < 808$", "note": "Order the groups" } ] },
      { "q": "Year sales were Jan $1\\,205\\,000$, Feb $1\\,250\\,000$, Mar $1\\,025\\,000$. In which month were sales lowest?", "a": "March ($1\\,025\\,000$)",
        "solution": [ { "math": "$1 = 1 \\to \\text{next place}$", "note": "Millions equal" }, { "math": "$025 < 205 < 250$", "note": "Smallest is March" } ] },
      { "q": "Which is larger and by how much: $3\\,000\\,000$ or $2\\,999\\,000$?", "a": "$3\\,000\\,000$, by $1\\,000$",
        "solution": [ { "math": "$3\\,000\\,000 > 2\\,999\\,000$", "note": "Compare millions" }, { "math": "$3\\,000\\,000 - 2\\,999\\,000 = 1\\,000$", "note": "Find the gap" } ] }
    ]
  }
}
