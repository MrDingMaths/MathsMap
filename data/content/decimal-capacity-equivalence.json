      { "q": "Insert $<$, $>$ or $=$: $0.6$ L $\\;\\square\\;$ $600$ mL.", "a": "$=$",
        "solution": [ { "math": "$0.6\\text{ L} = 600\\text{ mL}$", "note": "Convert to mL" }, { "math": "$600 = 600$", "note": "Equal" } ] },
      { "q": "Insert $<$, $>$ or $=$: $0.45$ L $\\;\\square\\;$ $500$ mL.", "a": "$<$",
        "solution": [ { "math": "$0.45\\text{ L} = 450\\text{ mL}$", "note": "Convert" }, { "math": "$450 < 500$", "note": "" } ] },
      { "q": "Write $3050$ mL in litres.", "a": "$3.05$ L",
