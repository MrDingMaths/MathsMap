{
  "skillId": "decimal-capacity-equivalence",
  "atomType": "R",
  "theory": {
    "intro": "Because $1\\text{ L} = 1000\\text{ mL}$, a capacity in millilitres can be written as a decimal number of litres.",
    "facts": [
      "$1\\text{ L} = 1000\\text{ mL}$, so $1\\text{ mL} = \\tfrac{1}{1000}\\text{ L} = 0.001\\text{ L}$.",
      "To change **mL to L**, divide by $1000$ (move the point $3$ places left).",
      "To change **L to mL**, multiply by $1000$ (move the point $3$ places right).",
      "$500\\text{ mL} = 0.5\\text{ L}$ and $250\\text{ mL} = 0.25\\text{ L}$ are useful to remember."
    ],
    "steps": [
      "Decide which way you are converting.",
      "mL → L: divide by $1000$.  L → mL: multiply by $1000$.",
      "Write the answer with the correct unit."
    ]
  },
  "practice": {
    "foundation": [
      { "q": "Write $375$ mL in litres.", "a": "$0.375$ L",
        "solution": [ { "math": "$375 \\div 1000$", "note": "mL to L" }, { "math": "$= 0.375\\text{ L}$", "note": "" } ] },
      { "q": "Write $500$ mL in litres.", "a": "$0.5$ L",
        "solution": [ { "math": "$500 \\div 1000$", "note": "mL to L" }, { "math": "$= 0.5\\text{ L}$", "note": "" } ] },
      { "q": "Write $250$ mL in litres.", "a": "$0.25$ L",
        "solution": [ { "math": "$250 \\div 1000$", "note": "mL to L" }, { "math": "$= 0.25\\text{ L}$", "note": "" } ] },
      { "q": "Write $750$ mL in litres.", "a": "$0.75$ L",
        "solution": [ { "math": "$750 \\div 1000$", "note": "mL to L" }, { "math": "$= 0.75\\text{ L}$", "note": "" } ] },
      { "q": "Write $100$ mL in litres.", "a": "$0.1$ L",
        "solution": [ { "math": "$100 \\div 1000$", "note": "mL to L" }, { "math": "$= 0.1\\text{ L}$", "note": "" } ] },
      { "q": "Write $0.4$ L in millilitres.", "a": "$400$ mL",
        "solution": [ { "math": "$0.4 \\times 1000$", "note": "L to mL" }, { "math": "$= 400\\text{ mL}$", "note": "" } ] },
      { "q": "Write $0.9$ L in millilitres.", "a": "$900$ mL",
        "solution": [ { "math": "$0.9 \\times 1000$", "note": "L to mL" }, { "math": "$= 900\\text{ mL}$", "note": "" } ] },
      { "q": "Write $50$ mL in litres.", "a": "$0.05$ L",
        "solution": [ { "math": "$50 \\div 1000$", "note": "mL to L" }, { "math": "$= 0.05\\text{ L}$", "note": "" } ] },
      { "q": "Write $0.6$ L in millilitres.", "a": "$600$ mL",
        "solution": [ { "math": "$0.6 \\times 1000$", "note": "L to mL" }, { "math": "$= 600\\text{ mL}$", "note": "" } ] },
      { "q": "Write $125$ mL in litres.", "a": "$0.125$ L",
        "solution": [ { "math": "$125 \\div 1000$", "note": "mL to L" }, { "math": "$= 0.125\\text{ L}$", "note": "" } ] }
    ],
    "development": [
      { "q": "Write $1250$ mL in litres.", "a": "$1.25$ L",
        "solution": [ { "math": "$1250 \\div 1000$", "note": "mL to L" }, { "math": "$= 1.25\\text{ L}$", "note": "" } ] },
      { "q": "Write $1.5$ L in millilitres.", "a": "$1500$ mL",
        "solution": [ { "math": "$1.5 \\times 1000$", "note": "L to mL" }, { "math": "$= 1500\\text{ mL}$", "note": "" } ] },
      { "q": "Write $2750$ mL in litres.", "a": "$2.75$ L",
        "solution": [ { "math": "$2750 \\div 1000$", "note": "mL to L" }, { "math": "$= 2.75\\text{ L}$", "note": "" } ] },
      { "q": "Write $2.4$ L in millilitres.", "a": "$2400$ mL",
        "solution": [ { "math": "$2.4 \\times 1000$", "note": "L to mL" }, { "math": "$= 2400\\text{ mL}$", "note": "" } ] },
      { "q": "Write $25$ mL in litres.", "a": "$0.025$ L",
        "solution": [ { "math": "$25 \\div 1000$", "note": "mL to L" }, { "math": "$= 0.025\\text{ L}$", "note": "" } ] },
      { "q": "Write $0.08$ L in millilitres.", "a": "$80$ mL",
