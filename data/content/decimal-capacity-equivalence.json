      { "q": "Write $0.125$ L in millilitres.", "a": "$125$ mL",
        "solution": [ { "math": "$0.125 \\times 1000$", "note": "L to mL" }, { "math": "$= 125\\text{ mL}$", "note": "" } ] }
    ],
    "mastery": [
      { "q": "A bottle holds $1.5$ L. After $400$ mL is poured out, how much is left, in litres?", "a": "$1.1$ L",
        "solution": [ { "math": "$1.5\\text{ L} = 1500\\text{ mL}$", "note": "Convert" }, { "math": "$1500 - 400 = 1100\\text{ mL} = 1.1\\text{ L}$", "note": "" } ] },
      { "q": "Three cartons hold $250$ mL, $0.4$ L and $300$ mL. What is the total in litres?", "a": "$0.95$ L",
        "solution": [ { "math": "$250 + 400 + 300 = 950\\text{ mL}$", "note": "All in mL" }, { "math": "$= 0.95\\text{ L}$", "note": "" } ] },
      { "q": "A jug holds $2$ L. It is filled to $1.35$ L. How many more mL fit?", "a": "$650$ mL",
        "solution": [ { "math": "$2 - 1.35 = 0.65\\text{ L}$", "note": "Space left" }, { "math": "$0.65 \\times 1000 = 650\\text{ mL}$", "note": "" } ] },
      { "q": "Order from smallest to largest: $0.5$ L, $450$ mL, $0.05$ L, $550$ mL.", "a": "$0.05$ L, $450$ mL, $0.5$ L, $550$ mL",
        "solution": [ { "math": "$50,\\ 450,\\ 500,\\ 550\\text{ mL}$", "note": "All in mL" }, { "math": "$0.05\\text{ L} < 450\\text{ mL} < 0.5\\text{ L} < 550\\text{ mL}$", "note": "" } ] },
      { "q": "A drink is sold as '$0.375$ L'. Write this capacity in millilitres.", "a": "$375$ mL",
        "solution": [ { "math": "$0.375 \\times 1000$", "note": "L to mL" }, { "math": "$= 375\\text{ mL}$", "note": "" } ] },
      { "q": "Four $250$ mL glasses are filled from a $1$ L bottle. Is the bottle empty? Show in litres.", "a": "Yes — exactly $1$ L used",
        "solution": [ { "math": "$4 \\times 250 = 1000\\text{ mL}$", "note": "Total poured" }, { "math": "$1000\\text{ mL} = 1\\text{ L}$", "note": "Empty" } ] },
      { "q": "A tank holds $4.2$ L. Write this in millilitres, then as litres after $1750$ mL leaks out.", "a": "$4200$ mL; $2.45$ L left",
        "solution": [ { "math": "$4.2\\text{ L} = 4200\\text{ mL}$", "note": "Convert" }, { "math": "$4200 - 1750 = 2450\\text{ mL} = 2.45\\text{ L}$", "note": "" } ] },
      { "q": "Which is larger and by how much: $0.8$ L or $850$ mL?", "a": "$850$ mL, by $50$ mL",
        "solution": [ { "math": "$0.8\\text{ L} = 800\\text{ mL}$", "note": "Convert" }, { "math": "$850 - 800 = 50\\text{ mL}$", "note": "" } ] },
      { "q": "A recipe needs $1.25$ L of stock. You have a $300$ mL and a $0.95$ L container. Is that enough?", "a": "Yes — exactly $1.25$ L",
        "solution": [ { "math": "$300\\text{ mL} = 0.3\\text{ L}$", "note": "Convert" }, { "math": "$0.3 + 0.95 = 1.25\\text{ L}$", "note": "Just enough" } ] },
      { "q": "Write the missing value: $2.6$ L $= \\;?$ mL $=$ ____ L when $100$ mL is added.", "a": "$2600$ mL; $2.7$ L",
        "solution": [ { "math": "$2.6 \\times 1000 = 2600\\text{ mL}$", "note": "Convert" }, { "math": "$2600 + 100 = 2700\\text{ mL} = 2.7\\text{ L}$", "note": "" } ] }
    ]
  }
}
