{
  "skillId": "estimate-angles-benchmarks",
  "atomType": "R",
  "theory": {
    "intro": "You can estimate an angle's size by comparing it with familiar **benchmark** angles before measuring.",
    "facts": [
      "Key benchmarks: $90^{\\circ}$ (right angle), $180^{\\circ}$ (straight), $45^{\\circ}$ (half a right angle), $360^{\\circ}$ (full turn).",
      "Smaller than the square corner $\\Rightarrow$ less than $90^{\\circ}$; wider $\\Rightarrow$ more.",
      "A good estimate is usually within about $10^{\\circ}$ of the true value."
    ],
    "steps": [
      "Compare the angle with the nearest benchmark.",
      "Decide if it is a bit more or a bit less.",
      "Give a sensible whole-degree estimate."
    ]
  },
  "practice": {
    "foundation": [
      { "q": "Estimate the marked angle (close to a right angle).", "a": "about $90^{\\circ}$",
        "tikz": "\\begin{tikzpicture}[scale=1]\n\\coordinate (O) at (0,0);\n\\draw[thick] (O)--(2.2,0);\n\\draw[thick] (O)--(88:2.2);\n\\draw (0.8,0) arc (0:88:0.8);\n\\node at (44:1.15) {$x$};\n\\end{tikzpicture}",
        "solution": [ { "math": "$\\text{looks like a square corner}$", "note": "Benchmark $90^{\\circ}$" }, { "math": "$\\approx 90^{\\circ}$", "note": "" } ] },
      { "q": "Estimate the marked angle (about half a right angle).", "a": "about $45^{\\circ}$",
        "tikz": "\\begin{tikzpicture}[scale=1]\n\\coordinate (O) at (0,0);\n\\draw[thick] (O)--(2.2,0);\n\\draw[thick] (O)--(45:2.2);\n\\draw (0.8,0) arc (0:45:0.8);\n\\node at (22:1.1) {$x$};\n\\end{tikzpicture}",
        "solution": [ { "math": "$\\tfrac{1}{2} \\times 90^{\\circ}$", "note": "Half a right angle" }, { "math": "$\\approx 45^{\\circ}$", "note": "" } ] },
      { "q": "Estimate the marked angle (close to straight).", "a": "about $180^{\\circ}$",
        "tikz": "\\begin{tikzpicture}[scale=1]\n\\coordinate (O) at (0,0);\n\\draw[thick] (O)--(2.2,0);\n\\draw[thick] (O)--(175:2.2);\n\\draw (0.8,0) arc (0:175:0.8);\n\\node at (88:1.1) {$x$};\n\\end{tikzpicture}",
        "solution": [ { "math": "$\\text{nearly a straight line}$", "note": "Benchmark $180^{\\circ}$" }, { "math": "$\\approx 180^{\\circ}$", "note": "" } ] },
      { "q": "Estimate the marked angle (a small opening).", "a": "about $30^{\\circ}$",
        "tikz": "\\begin{tikzpicture}[scale=1]\n\\coordinate (O) at (0,0);\n\\draw[thick] (O)--(2.2,0);\n\\draw[thick] (O)--(30:2.2);\n\\draw (0.8,0) arc (0:30:0.8);\n\\node at (15:1.15) {$x$};\n\\end{tikzpicture}",
        "solution": [ { "math": "$\\text{about a third of } 90^{\\circ}$", "note": "Well under a right angle" }, { "math": "$\\approx 30^{\\circ}$", "note": "" } ] },
      { "q": "Estimate the marked angle (a bit more than a right angle).", "a": "about $120^{\\circ}$",
        "tikz": "\\begin{tikzpicture}[scale=1]\n\\coordinate (O) at (0,0);\n\\draw[thick] (O)--(2.2,0);\n\\draw[thick] (O)--(120:2.2);\n\\draw (0.8,0) arc (0:120:0.8);\n\\node at (60:1.1) {$x$};\n\\end{tikzpicture}",
        "solution": [ { "math": "$\\text{wider than } 90^{\\circ}$", "note": "Between right and straight" }, { "math": "$\\approx 120^{\\circ}$", "note": "" } ] },
      { "q": "Is an angle that opens just less than a square corner closer to $45^{\\circ}$ or $90^{\\circ}$?", "a": "$90^{\\circ}$",
        "solution": [ { "math": "$\\text{just under the corner}$", "note": "Near the right angle" }, { "math": "$\\approx 90^{\\circ}$", "note": "" } ] },
      { "q": "Estimate the marked angle (about two-thirds of a right angle).", "a": "about $60^{\\circ}$",
        "tikz": "\\begin{tikzpicture}[scale=1]\n\\coordinate (O) at (0,0);\n\\draw[thick] (O)--(2.2,0);\n\\draw[thick] (O)--(60:2.2);\n\\draw (0.8,0) arc (0:60:0.8);\n\\node at (30:1.1) {$x$};\n\\end{tikzpicture}",
        "solution": [ { "math": "$\\tfrac{2}{3} \\times 90^{\\circ}$", "note": "Two-thirds of a right angle" }, { "math": "$\\approx 60^{\\circ}$", "note": "" } ] },
      { "q": "A door swings open to make a quarter turn. Estimate the angle.", "a": "about $90^{\\circ}$",
        "solution": [ { "math": "$\\tfrac{1}{4} \\times 360^{\\circ}$", "note": "Quarter turn" }, { "math": "$\\approx 90^{\\circ}$", "note": "" } ] },
      { "q": "Estimate the marked angle (about $150^{\\circ}$).", "a": "about $150^{\\circ}$",
        "tikz": "\\begin{tikzpicture}[scale=1]\n\\coordinate (O) at (0,0);\n\\draw[thick] (O)--(2.2,0);\n\\draw[thick] (O)--(150:2.2);\n\\draw (0.8,0) arc (0:150:0.8);\n\\node at (75:1.1) {$x$};\n\\end{tikzpicture}",
        "solution": [ { "math": "$\\text{near but under } 180^{\\circ}$", "note": "Close to straight" }, { "math": "$\\approx 150^{\\circ}$", "note": "" } ] },
      { "q": "Half of a right angle is what benchmark estimate?", "a": "about $45^{\\circ}$",
        "solution": [ { "math": "$\\tfrac{1}{2} \\times 90^{\\circ}$", "note": "" }, { "math": "$= 45^{\\circ}$", "note": "" } ] }
    ],
    "development": [
      { "q": "An angle is a little more than a right angle. Which is the best estimate: $100^{\\circ}$ or $160^{\\circ}$?", "a": "$100^{\\circ}$",
        "solution": [ { "math": "$\\text{just past } 90^{\\circ}$", "note": "Only a little more" }, { "math": "$\\approx 100^{\\circ}$", "note": "" } ] },
      { "q": "An angle looks like three-quarters of a straight angle. Estimate it.", "a": "about $135^{\\circ}$",
        "solution": [ { "math": "$\\tfrac{3}{4} \\times 180^{\\circ}$", "note": "Three-quarters of straight" }, { "math": "$\\approx 135^{\\circ}$", "note": "" } ] },
      { "q": "Which is the better estimate for the marked angle: $20^{\\circ}$ or $70^{\\circ}$?", "a": "$20^{\\circ}$",
        "tikz": "\\begin{tikzpicture}[scale=1]\n\\coordinate (O) at (0,0);\n\\draw[thick] (O)--(2.2,0);\n\\draw[thick] (O)--(20:2.2);\n\\draw (0.8,0) arc (0:20:0.8);\n\\node at (10:1.2) {$x$};\n\\end{tikzpicture}",
        "solution": [ { "math": "$\\text{small, well under } 45^{\\circ}$", "note": "A narrow opening" }, { "math": "$\\approx 20^{\\circ}$", "note": "" } ] },
      { "q": "A skateboard ramp turns through about $\\tfrac{1}{8}$ of a full turn. Estimate the angle.", "a": "about $45^{\\circ}$",
        "solution": [ { "math": "$\\tfrac{1}{8} \\times 360^{\\circ}$", "note": "One-eighth of a turn" }, { "math": "$= 45^{\\circ}$", "note": "" } ] },
      { "q": "An angle is just less than straight. Which is the best estimate: $170^{\\circ}$ or $130^{\\circ}$?", "a": "$170^{\\circ}$",
        "solution": [ { "math": "$\\text{nearly } 180^{\\circ}$", "note": "Almost a straight line" }, { "math": "$\\approx 170^{\\circ}$", "note": "" } ] },
      { "q": "Estimate the marked obtuse angle, then say whether it is more or less than $90^{\\circ}$.", "a": "about $110^{\\circ}$; more",
        "tikz": "\\begin{tikzpicture}[scale=1]\n\\coordinate (O) at (0,0);\n\\draw[thick] (O)--(2.2,0);\n\\draw[thick] (O)--(110:2.2);\n\\draw (0.8,0) arc (0:110:0.8);\n\\node at (55:1.1) {$x$};\n\\end{tikzpicture}",
        "solution": [ { "math": "$\\text{wider than the corner}$", "note": "Past $90^{\\circ}$" }, { "math": "$\\approx 110^{\\circ}, \\text{ more}$", "note": "" } ] },
      { "q": "The hands of a clock at $2$ o'clock make about what angle?", "a": "about $60^{\\circ}$",
        "solution": [ { "math": "$\\dfrac{2}{12} \\times 360^{\\circ}$", "note": "Two of twelve marks" }, { "math": "$= 60^{\\circ}$", "note": "" } ] },
      { "q": "Your estimate is $50^{\\circ}$ and the true angle is $58^{\\circ}$. Is your estimate within $10^{\\circ}$?", "a": "yes",
        "solution": [ { "math": "$58^{\\circ} - 50^{\\circ} = 8^{\\circ}$", "note": "Size of the error" }, { "math": "$8^{\\circ} < 10^{\\circ}$", "note": "Within tolerance" } ] },
      { "q": "An angle looks like one and a half right angles. Estimate it.", "a": "about $135^{\\circ}$",
        "solution": [ { "math": "$1\\tfrac{1}{2} \\times 90^{\\circ}$", "note": "One and a half right angles" }, { "math": "$\\approx 135^{\\circ}$", "note": "" } ] },
      { "q": "Estimate the marked angle, then classify it.", "a": "about $40^{\\circ}$, acute",
        "tikz": "\\begin{tikzpicture}[scale=1]\n\\coordinate (O) at (0,0);\n\\draw[thick] (O)--(2.2,0);\n\\draw[thick] (O)--(40:2.2);\n\\draw (0.8,0) arc (0:40:0.8);\n\\node at (20:1.15) {$x$};\n\\end{tikzpicture}",
        "solution": [ { "math": "$\\text{under } 90^{\\circ}$", "note": "Less than a right angle" }, { "math": "$\\approx 40^{\\circ}, \\text{ acute}$", "note": "" } ] }
    ],
    "mastery": [
      { "q": "An estimate of $80^{\\circ}$ was made; the true value is $96^{\\circ}$. By how much was the estimate out, and was it within $10^{\\circ}$?", "a": "$16^{\\circ}$ out; no",
        "solution": [ { "math": "$96^{\\circ} - 80^{\\circ}$", "note": "Size of the error" }, { "math": "$= 16^{\\circ} > 10^{\\circ}$", "note": "Not within tolerance" } ] },
      { "q": "A reflex angle looks like it leaves a small acute gap of about $30^{\\circ}$. Estimate the reflex angle.", "a": "about $330^{\\circ}$",
        "solution": [ { "math": "$360^{\\circ} - 30^{\\circ}$", "note": "Full turn minus the gap" }, { "math": "$\\approx 330^{\\circ}$", "note": "" } ] },
      { "q": "Estimate the angle a clock's hands make at $5$ o'clock.", "a": "about $150^{\\circ}$",
        "solution": [ { "math": "$\\dfrac{5}{12} \\times 360^{\\circ}$", "note": "Five of twelve marks" }, { "math": "$= 150^{\\circ}$", "note": "" } ] },
      { "q": "Three equal angles meet at a point. Estimate each one.", "a": "about $120^{\\circ}$",
        "solution": [ { "math": "$\\dfrac{360^{\\circ}}{3}$", "note": "Share the full turn" }, { "math": "$= 120^{\\circ}$", "note": "" } ] },
      { "q": "A ramp rises at about a quarter of a right angle. Estimate the angle, and classify it.", "a": "about $22^{\\circ}$, acute",
        "solution": [ { "math": "$\\tfrac{1}{4} \\times 90^{\\circ}$", "note": "Quarter of a right angle" }, { "math": "$\\approx 22^{\\circ}, \\text{ acute}$", "note": "" } ] },
      { "q": "You estimate two angles as $40^{\\circ}$ and $50^{\\circ}$ that together form a right angle. Does that make sense?", "a": "yes, they sum to $90^{\\circ}$",
        "solution": [ { "math": "$40^{\\circ} + 50^{\\circ}$", "note": "Add the estimates" }, { "math": "$= 90^{\\circ}$", "note": "A right angle" } ] },
      { "q": "An angle is estimated as $\\tfrac{2}{3}$ of a straight angle. Estimate it in degrees.", "a": "about $120^{\\circ}$",
        "solution": [ { "math": "$\\tfrac{2}{3} \\times 180^{\\circ}$", "note": "Two-thirds of straight" }, { "math": "$= 120^{\\circ}$", "note": "" } ] },
      { "q": "A spinner turns one and a quarter full turns. Estimate the total angle turned.", "a": "$450^{\\circ}$",
        "solution": [ { "math": "$1\\tfrac{1}{4} \\times 360^{\\circ}$", "note": "One and a quarter turns" }, { "math": "$= 450^{\\circ}$", "note": "" } ] },
      { "q": "Two estimates of the same angle are $55^{\\circ}$ and $65^{\\circ}$. The true value is $58^{\\circ}$. Which estimate is closer?", "a": "$55^{\\circ}$",
        "solution": [ { "math": "$|58 - 55| = 3$", "note": "First error" }, { "math": "$|58 - 65| = 7$", "note": "$55^{\\circ}$ is closer" } ] },
      { "q": "A pie chart's largest slice looks like about half the circle. Estimate its angle.", "a": "about $180^{\\circ}$",
        "solution": [ { "math": "$\\tfrac{1}{2} \\times 360^{\\circ}$", "note": "Half a full turn" }, { "math": "$= 180^{\\circ}$", "note": "" } ] }
    ]
  }
}
