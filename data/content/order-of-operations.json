{
  "skillId": "order-of-operations",
  "atomType": "R",
  "theory": {
    "intro": "When an expression has several operations, everyone agrees to work them out in a fixed order so the answer is the same.",
    "facts": [
      "Do **brackets** first, then **multiplication and division** (left to right), then **addition and subtraction** (left to right).",
      "Multiplication and division have **equal** priority — work left to right.",
      "Without the agreed order, the same expression could give different answers."
    ],
    "steps": [
      "Work out anything inside brackets.",
      "Do all $\\times$ and $\\div$ from left to right.",
      "Do all $+$ and $-$ from left to right."
    ]
  },
  "practice": {
    "foundation": [
      { "q": "Evaluate $3 + 4 \\times 2$.", "a": "$11$",
        "solution": [ { "math": "$3 + 8$", "note": "$\\times$ before $+$" }, { "math": "$= 11$", "note": "Then add" } ] },
      { "q": "Evaluate $10 - 6 \\div 2$.", "a": "$7$",
        "solution": [ { "math": "$10 - 3$", "note": "$\\div$ before $-$" }, { "math": "$= 7$", "note": "Then subtract" } ] },
      { "q": "Evaluate $5 \\times 2 + 4$.", "a": "$14$",
        "solution": [ { "math": "$10 + 4$", "note": "$\\times$ first" }, { "math": "$= 14$", "note": "Then add" } ] },
      { "q": "Evaluate $12 \\div 4 + 5$.", "a": "$8$",
        "solution": [ { "math": "$3 + 5$", "note": "$\\div$ first" }, { "math": "$= 8$", "note": "Then add" } ] },
      { "q": "Evaluate $20 - 3 \\times 4$.", "a": "$8$",
        "solution": [ { "math": "$20 - 12$", "note": "$\\times$ first" }, { "math": "$= 8$", "note": "Then subtract" } ] },
      { "q": "Evaluate $6 + 2 \\times 5$.", "a": "$16$",
        "solution": [ { "math": "$6 + 10$", "note": "$\\times$ first" }, { "math": "$= 16$", "note": "Then add" } ] },
      { "q": "Evaluate $18 \\div 6 - 1$.", "a": "$2$",
        "solution": [ { "math": "$3 - 1$", "note": "$\\div$ first" }, { "math": "$= 2$", "note": "Then subtract" } ] },
      { "q": "Evaluate $9 + 8 \\div 2$.", "a": "$13$",
        "solution": [ { "math": "$9 + 4$", "note": "$\\div$ first" }, { "math": "$= 13$", "note": "Then add" } ] },
      { "q": "Evaluate $7 \\times 3 - 5$.", "a": "$16$",
        "solution": [ { "math": "$21 - 5$", "note": "$\\times$ first" }, { "math": "$= 16$", "note": "Then subtract" } ] },
      { "q": "Evaluate $4 + 4 \\times 0$.", "a": "$4$",
        "solution": [ { "math": "$4 + 0$", "note": "$\\times$ first" }, { "math": "$= 4$", "note": "Then add" } ] }
    ],
    "development": [
      { "q": "Evaluate $3 \\times 4 + 2 \\times 5$.", "a": "$22$",
        "solution": [ { "math": "$12 + 10$", "note": "Both $\\times$ first" }, { "math": "$= 22$", "note": "Then add" } ] },
      { "q": "Evaluate $24 \\div 6 \\times 2$.", "a": "$8$",
        "solution": [ { "math": "$4 \\times 2$", "note": "Left to right" }, { "math": "$= 8$", "note": "$\\div$ and $\\times$ equal priority" } ] },
      { "q": "Evaluate $20 - 2 \\times 3 + 4$.", "a": "$18$",
        "solution": [ { "math": "$20 - 6 + 4$", "note": "$\\times$ first" }, { "math": "$= 18$", "note": "Then left to right" } ] },
      { "q": "Evaluate $36 \\div 9 + 5 \\times 2$.", "a": "$14$",
        "solution": [ { "math": "$4 + 10$", "note": "$\\div$ and $\\times$ first" }, { "math": "$= 14$", "note": "Then add" } ] },
      { "q": "Evaluate $100 - 6 \\times 7$.", "a": "$58$",
        "solution": [ { "math": "$100 - 42$", "note": "$\\times$ first" }, { "math": "$= 58$", "note": "Then subtract" } ] },
      { "q": "Evaluate $8 \\times 2 \\div 4$.", "a": "$4$",
        "solution": [ { "math": "$16 \\div 4$", "note": "Left to right" }, { "math": "$= 4$", "note": "Equal priority" } ] },
      { "q": "Evaluate $5 + 18 \\div 3 - 2$.", "a": "$9$",
        "solution": [ { "math": "$5 + 6 - 2$", "note": "$\\div$ first" }, { "math": "$= 9$", "note": "Then left to right" } ] },
      { "q": "Evaluate $7 \\times 4 - 12 \\div 3$.", "a": "$24$",
        "solution": [ { "math": "$28 - 4$", "note": "$\\times$ and $\\div$ first" }, { "math": "$= 24$", "note": "Then subtract" } ] },
      { "q": "Evaluate $40 \\div 8 \\div 5$.", "a": "$1$",
        "solution": [ { "math": "$5 \\div 5$", "note": "Left to right" }, { "math": "$= 1$", "note": "Equal priority" } ] },
      { "q": "Evaluate $2 \\times 9 + 3 \\times 4 - 10$.", "a": "$20$",
        "solution": [ { "math": "$18 + 12 - 10$", "note": "All $\\times$ first" }, { "math": "$= 20$", "note": "Then left to right" } ] }
    ],
    "mastery": [
      { "q": "Evaluate $5 + 2 \\times 6 - 8 \\div 4$.", "a": "$15$",
        "solution": [ { "math": "$5 + 12 - 2$", "note": "$\\times$ and $\\div$ first" }, { "math": "$= 15$", "note": "Then left to right" } ] },
      { "q": "A taxi charges $\\$4$ plus $\\$3$ per km. Write and evaluate the cost of a $6$ km trip.", "a": "$\\$22$",
        "solution": [ { "math": "$4 + 3 \\times 6$", "note": "$\\times$ first" }, { "math": "$= 4 + 18 = 22$", "note": "$\\$22$" } ] },
      { "q": "A student writes $6 + 4 \\times 2 = 20$. Is this correct? Give the right answer.", "a": "No — $14$",
        "solution": [ { "math": "$6 + 8$", "note": "$\\times$ before $+$" }, { "math": "$= 14$", "note": "Not $20$" } ] },
      { "q": "Evaluate $48 \\div 6 + 9 \\times 2 - 7$.", "a": "$19$",
        "solution": [ { "math": "$8 + 18 - 7$", "note": "$\\div$ and $\\times$ first" }, { "math": "$= 19$", "note": "Then left to right" } ] },
      { "q": "Three packs of $6$ pens and $4$ loose pens: write and evaluate the total.", "a": "$22$",
        "solution": [ { "math": "$3 \\times 6 + 4$", "note": "$\\times$ first" }, { "math": "$= 18 + 4 = 22$", "note": "$22$ pens" } ] },
      { "q": "Evaluate $60 - 5 \\times 4 \\div 2$.", "a": "$50$",
        "solution": [ { "math": "$60 - 20 \\div 2$", "note": "Left to right for $\\times \\div$" }, { "math": "$= 60 - 10 = 50$", "note": "Then subtract" } ] },
      { "q": "Evaluate $9 \\times 3 - 4 \\times 5 + 1$.", "a": "$8$",
        "solution": [ { "math": "$27 - 20 + 1$", "note": "Both $\\times$ first" }, { "math": "$= 8$", "note": "Then left to right" } ] },
      { "q": "Two students buy $\\$5$ tickets each and share a $\\$6$ snack. Write and evaluate the total.", "a": "$\\$16$",
        "solution": [ { "math": "$2 \\times 5 + 6$", "note": "$\\times$ first" }, { "math": "$= 10 + 6 = 16$", "note": "$\\$16$" } ] },
      { "q": "Evaluate $100 \\div 4 \\div 5 + 8$.", "a": "$13$",
        "solution": [ { "math": "$25 \\div 5 + 8$", "note": "Left to right" }, { "math": "$= 5 + 8 = 13$", "note": "Then add" } ] },
      { "q": "Evaluate $12 + 6 \\times 3 - 30 \\div 5$.", "a": "$24$",
        "solution": [ { "math": "$12 + 18 - 6$", "note": "$\\times$ and $\\div$ first" }, { "math": "$= 24$", "note": "Then left to right" } ] }
    ]
  }
}
