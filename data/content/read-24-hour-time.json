{
  "skillId": "read-24-hour-time",
  "atomType": "R",
  "theory": {
    "intro": "In 24-hour time the day runs from $0000$ to $2359$, so the hours keep counting past noon instead of starting again at $1$.",
    "facts": [
      "24-hour time uses **four digits**: the first two are the hour, the last two the minutes (e.g. $1430$).",
      "Midnight is $0000$, noon is $1200$.",
      "From $1300$ onwards the hour is more than $12$ — these are afternoon and evening times."
    ],
    "steps": [
      "Read the first two digits as the hour ($00$–$23$).",
      "Read the last two digits as the minutes ($00$–$59$).",
      "Hours of $13$ or more are in the afternoon or evening."
    ]
  },
  "practice": {
    "foundation": [
      { "q": "Read $0900$ in words.", "a": "nine o'clock (in the morning)",
        "solution": [ { "math": "$09 \\to 9\\text{ hours}$", "note": "Hour part" }, { "math": "$00 \\to 0\\text{ min}$", "note": "9 o'clock" } ] },
      { "q": "Read $1400$ in words.", "a": "two o'clock in the afternoon",
        "solution": [ { "math": "$14 \\to 2\\text{ pm}$", "note": "$14 - 12 = 2$" }, { "math": "$00 \\to \\text{o'clock}$", "note": "2 pm" } ] },
      { "q": "How many minutes past the hour is $0745$?", "a": "$45$ minutes",
        "solution": [ { "math": "$07 \\to \\text{hour}$", "note": "First two digits" }, { "math": "$45 \\to \\text{minutes}$", "note": "Last two digits" } ] },
      { "q": "What time, in words, is $1800$?", "a": "six o'clock in the evening",
        "solution": [ { "math": "$18 - 12 = 6$", "note": "Evening hour" }, { "math": "$6\\text{ pm}$", "note": "o'clock" } ] },
      { "q": "Read $1215$ in words.", "a": "quarter past twelve (midday)",
        "solution": [ { "math": "$12 \\to \\text{noon hour}$", "note": "12 o'clock" }, { "math": "$15\\text{ min past}$", "note": "Quarter past" } ] },
      { "q": "What is $0000$ in 24-hour time called?", "a": "midnight",
        "solution": [ { "math": "$00\\!:\\!00$", "note": "Start of the day" }, { "math": "$\\text{midnight}$", "note": "Zero hour" } ] },
      { "q": "Read $1030$ in words.", "a": "half past ten in the morning",
        "solution": [ { "math": "$10 \\to \\text{hour}$", "note": "Morning" }, { "math": "$30\\text{ min} = \\text{half past}$", "note": "Half past ten" } ] },
      { "q": "Is $2000$ a morning or evening time? Give the o'clock time.", "a": "evening; $8$ o'clock",
        "solution": [ { "math": "$20 - 12 = 8$", "note": "Past noon" }, { "math": "$8\\text{ pm}$", "note": "Evening" } ] },
      { "q": "How many minutes past the hour is $1605$?", "a": "$5$ minutes",
        "solution": [ { "math": "$16 \\to \\text{hour}$", "note": "First two digits" }, { "math": "$05 \\to 5\\text{ min}$", "note": "Last two digits" } ] },
      { "q": "What time, in words, is $1200$?", "a": "midday (noon)",
        "solution": [ { "math": "$12\\!:\\!00$", "note": "Middle of the day" }, { "math": "$\\text{noon}$", "note": "12 o'clock midday" } ] }
    ],
    "development": [
      { "q": "A train leaves at $1352$. State the hour and minutes.", "a": "$13$ hours, $52$ minutes",
        "solution": [ { "math": "$13 \\to \\text{hour}$", "note": "1 pm hour" }, { "math": "$52 \\to \\text{minutes}$", "note": "Past the hour" } ] },
      { "q": "Which is later: $0915$ or $1130$?", "a": "$1130$",
        "solution": [ { "math": "$0915 \\to 9\\!:\\!15$", "note": "Compare hours" }, { "math": "$11 > 9$", "note": "$1130$ is later" } ] },
      { "q": "Which is later: $1645$ or $1620$?", "a": "$1645$",
        "solution": [ { "math": "$\\text{same hour } 16$", "note": "Compare minutes" }, { "math": "$45 > 20$", "note": "$1645$ later" } ] },
      { "q": "A film starts at $1925$. Write the time in words.", "a": "twenty-five past seven in the evening",
        "solution": [ { "math": "$19 - 12 = 7$", "note": "7 pm" }, { "math": "$25\\text{ min past}$", "note": "Evening" } ] },
      { "q": "Put in order, earliest first: $0805$, $1750$, $1305$.", "a": "$0805, 1305, 1750$",
        "solution": [ { "math": "$08 < 13 < 17$", "note": "Compare hours" }, { "math": "$0805, 1305, 1750$", "note": "Earliest first" } ] },
      { "q": "How would $2359$ read as a clock time, and what happens one minute later?", "a": "$11\\!:\\!59$ pm; then $0000$ (midnight)",
        "solution": [ { "math": "$23 - 12 = 11\\text{ pm}$", "note": "Last minute" }, { "math": "$+1\\text{ min} \\to 0000$", "note": "New day" } ] },
      { "q": "A shop opens at $0830$ and the clock now shows $0815$. Has it opened?", "a": "no — $0815$ is before $0830$",
        "solution": [ { "math": "$\\text{same hour } 08$", "note": "Compare minutes" }, { "math": "$15 < 30$", "note": "Not yet open" } ] },
      { "q": "Read $2245$ in words.", "a": "quarter to eleven at night",
        "solution": [ { "math": "$22 - 12 = 10\\text{ pm}$", "note": "10 o'clock hour" }, { "math": "$45\\text{ min} = \\text{quarter to } 11$", "note": "Quarter to eleven" } ] },
      { "q": "Which is later in the day: $0005$ or $1255$?", "a": "$1255$",
        "solution": [ { "math": "$0005 \\to 12\\!:\\!05\\text{ am}$", "note": "Just after midnight" }, { "math": "$1255 \\to 12\\!:\\!55\\text{ pm}$", "note": "Afternoon is later" } ] },
      { "q": "A bus is due at $1700$. The clock shows $1655$. How many minutes until it is due?", "a": "$5$ minutes",
        "solution": [ { "math": "$1700 - 1655$", "note": "Same hour difference" }, { "math": "$= 5\\text{ min}$", "note": "Almost due" } ] }
    ],
    "mastery": [
      { "q": "A ferry departs $1340$ and the next is $90$ minutes later. Give the next departure in 24-hour time.", "a": "$1510$",
        "solution": [ { "math": "$1340 + 60\\text{ min} = 1440$", "note": "Add 1 hour" }, { "math": "$1440 + 30\\text{ min} = 1510$", "note": "Add 30 more" } ] },
      { "q": "A flight is shown as $0010$. Explain why this is just after midnight, not just after noon.", "a": "$00$ is the midnight hour, so $0010$ is $12\\!:\\!10$ am",
        "solution": [ { "math": "$00 \\to \\text{midnight hour}$", "note": "Day starts at 0000" }, { "math": "$0010 = 12\\!:\\!10\\text{ am}$", "note": "Ten past midnight" } ] },
      { "q": "Sort earliest to latest: $2305$, $0035$, $1145$, $1900$.", "a": "$0035, 1145, 1900, 2305$",
        "solution": [ { "math": "$00 < 11 < 19 < 23$", "note": "Compare hour digits" }, { "math": "$0035, 1145, 1900, 2305$", "note": "Earliest first" } ] },
      { "q": "A clock shows $1648$. How many minutes until $1700$?", "a": "$12$ minutes",
        "solution": [ { "math": "$1700 - 1648$", "note": "To the next hour" }, { "math": "$60 - 48 = 12\\text{ min}$", "note": "Minutes left" } ] },
      { "q": "A program runs from $2030$ to $2115$. In words, when does it start and end?", "a": "starts $8\\!:\\!30$ pm, ends $9\\!:\\!15$ pm",
        "solution": [ { "math": "$20 - 12 = 8\\text{ pm}$", "note": "Start" }, { "math": "$21 - 12 = 9\\text{ pm}$", "note": "End" } ] },
      { "q": "A worker's shift ends at $0015$. Is that late at night or early morning?", "a": "early morning (just after midnight)",
        "solution": [ { "math": "$00 \\to \\text{after midnight}$", "note": "New day" }, { "math": "$0015 = 12\\!:\\!15\\text{ am}$", "note": "Early morning" } ] },
      { "q": "Two alarms are set for $0540$ and $1740$. How are these times different?", "a": "$0540$ is $5\\!:\\!40$ am, $1740$ is $5\\!:\\!40$ pm — twelve hours apart",
        "solution": [ { "math": "$1740 - 1200 = 0540\\text{ pm}$", "note": "Same clock face" }, { "math": "$12\\text{ hours apart}$", "note": "am vs pm" } ] },
      { "q": "A timer reads $1955$ and counts forward $10$ minutes. What does it show?", "a": "$2005$",
        "solution": [ { "math": "$1955 + 5\\text{ min} = 2000$", "note": "Reach next hour" }, { "math": "$2000 + 5\\text{ min} = 2005$", "note": "Final time" } ] },
      { "q": "Explain why $1300$ and $0100$ are different times of day.", "a": "$1300$ is $1$ pm, $0100$ is $1$ am",
        "solution": [ { "math": "$1300 - 12 = 1\\text{ pm}$", "note": "Afternoon" }, { "math": "$0100 = 1\\text{ am}$", "note": "Early morning" } ] },
      { "q": "A movie marathon starts $2245$ and the clock now reads $2250$. Has it started, and by how long?", "a": "yes, by $5$ minutes",
        "solution": [ { "math": "$2250 > 2245$", "note": "Already started" }, { "math": "$2250 - 2245 = 5\\text{ min}$", "note": "Five minutes in" } ] }
    ]
  }
}
