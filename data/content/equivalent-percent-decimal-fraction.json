{
  "skillId": "equivalent-percent-decimal-fraction",
  "atomType": "R",
  "theory": {
    "intro": "Percentages, decimals and fractions are three ways of writing the same value. Knowing the benchmark values lets you switch between them quickly.",
    "facts": [
      "$\\tfrac{1}{2} = 0.5 = 50\\%$,$\\ \\tfrac{1}{4} = 0.25 = 25\\%$,$\\ \\tfrac{3}{4} = 0.75 = 75\\%$.",
      "$\\tfrac{1}{10} = 0.1 = 10\\%$,$\\ \\tfrac{1}{5} = 0.2 = 20\\%$,$\\ 1 = 100\\%$.",
      "Percent → decimal: $\\div 100$. Decimal → percent: $\\times 100$."
    ],
    "steps": [
      "To go from $\\%$ to a decimal, divide by $100$ (move the point two places left).",
      "To go from a decimal to $\\%$, multiply by $100$.",
      "Write a fraction over $100$, then simplify."
    ]
  },
  "practice": {
    "foundation": [
      { "q": "Write $\\tfrac{1}{2}$ as a percentage.", "a": "$50\\%$",
        "solution": [ { "math": "$\\tfrac{1}{2} = \\tfrac{50}{100}$", "note": "Equivalent over 100" }, { "math": "$= 50\\%$", "note": "" } ] },
      { "q": "Write $25\\%$ as a decimal.", "a": "$0.25$",
        "solution": [ { "math": "$25 \\div 100$", "note": "Percent → decimal" }, { "math": "$= 0.25$", "note": "" } ] },
      { "q": "Write $0.5$ as a percentage.", "a": "$50\\%$",
        "solution": [ { "math": "$0.5 \\times 100$", "note": "Decimal → percent" }, { "math": "$= 50\\%$", "note": "" } ] },
      { "q": "Write $\\tfrac{3}{4}$ as a percentage.", "a": "$75\\%$",
        "solution": [ { "math": "$\\tfrac{3}{4} = \\tfrac{75}{100}$", "note": "Equivalent over 100" }, { "math": "$= 75\\%$", "note": "" } ] },
      { "q": "Write $10\\%$ as a fraction in simplest form.", "a": "$\\dfrac{1}{10}$",
        "solution": [ { "math": "$10\\% = \\tfrac{10}{100}$", "note": "Out of 100" }, { "math": "$= \\tfrac{1}{10}$", "note": "Simplify" } ] },
      { "q": "Write $0.75$ as a percentage.", "a": "$75\\%$",
        "solution": [ { "math": "$0.75 \\times 100$", "note": "Decimal → percent" }, { "math": "$= 75\\%$", "note": "" } ] },
      { "q": "Write $\\tfrac{1}{4}$ as a decimal.", "a": "$0.25$",
        "solution": [ { "math": "$\\tfrac{1}{4} = \\tfrac{25}{100}$", "note": "Equivalent over 100" }, { "math": "$= 0.25$", "note": "" } ] },
      { "q": "Write $100\\%$ as a decimal.", "a": "$1$",
        "solution": [ { "math": "$100 \\div 100$", "note": "Percent → decimal" }, { "math": "$= 1$", "note": "One whole" } ] },
      { "q": "Write $\\tfrac{1}{5}$ as a percentage.", "a": "$20\\%$",
        "solution": [ { "math": "$\\tfrac{1}{5} = \\tfrac{20}{100}$", "note": "Equivalent over 100" }, { "math": "$= 20\\%$", "note": "" } ] },
      { "q": "Write $0.1$ as a percentage.", "a": "$10\\%$",
        "solution": [ { "math": "$0.1 \\times 100$", "note": "Decimal → percent" }, { "math": "$= 10\\%$", "note": "" } ] }
    ],
    "development": [
      { "q": "Write $30\\%$ as a fraction in simplest form.", "a": "$\\dfrac{3}{10}$",
        "solution": [ { "math": "$30\\% = \\tfrac{30}{100}$", "note": "Out of 100" }, { "math": "$= \\tfrac{3}{10}$", "note": "Divide by 10" } ] },
      { "q": "Write $0.6$ as a percentage and as a fraction.", "a": "$60\\%$, $\\dfrac{3}{5}$",
        "solution": [ { "math": "$0.6 \\times 100 = 60\\%$", "note": "Decimal → percent" }, { "math": "$\\tfrac{60}{100} = \\tfrac{3}{5}$", "note": "Simplify" } ] },
      { "q": "Write $5\\%$ as a decimal.", "a": "$0.05$",
        "solution": [ { "math": "$5 \\div 100$", "note": "Percent → decimal" }, { "math": "$= 0.05$", "note": "Two places left" } ] },
      { "q": "Write $\\tfrac{2}{5}$ as a percentage.", "a": "$40\\%$",
        "solution": [ { "math": "$\\tfrac{2}{5} = \\tfrac{40}{100}$", "note": "Multiply by $\\tfrac{20}{20}$" }, { "math": "$= 40\\%$", "note": "" } ] },
      { "q": "Write $0.08$ as a percentage.", "a": "$8\\%$",
        "solution": [ { "math": "$0.08 \\times 100$", "note": "Decimal → percent" }, { "math": "$= 8\\%$", "note": "" } ] },
      { "q": "Write $90\\%$ as a fraction in simplest form.", "a": "$\\dfrac{9}{10}$",
        "solution": [ { "math": "$90\\% = \\tfrac{90}{100}$", "note": "Out of 100" }, { "math": "$= \\tfrac{9}{10}$", "note": "Divide by 10" } ] },
      { "q": "Write $1\\%$ as a decimal.", "a": "$0.01$",
        "solution": [ { "math": "$1 \\div 100$", "note": "Percent → decimal" }, { "math": "$= 0.01$", "note": "" } ] },
      { "q": "Write $\\tfrac{7}{10}$ as a decimal and a percentage.", "a": "$0.7$, $70\\%$",
        "solution": [ { "math": "$\\tfrac{7}{10} = 0.7$", "note": "Tenths" }, { "math": "$0.7 \\times 100 = 70\\%$", "note": "" } ] },
      { "q": "Write $150\\%$ as a decimal.", "a": "$1.5$",
        "solution": [ { "math": "$150 \\div 100$", "note": "Percent → decimal" }, { "math": "$= 1.5$", "note": "More than one whole" } ] },
      { "q": "Write $0.45$ as a percentage and as a fraction.", "a": "$45\\%$, $\\dfrac{9}{20}$",
        "solution": [ { "math": "$0.45 \\times 100 = 45\\%$", "note": "Decimal → percent" }, { "math": "$\\tfrac{45}{100} = \\tfrac{9}{20}$", "note": "Divide by 5" } ] }
    ],
    "mastery": [
      { "q": "Order from smallest to largest: $\\tfrac{1}{2}$, $0.4$, $45\\%$.", "a": "$0.4, 45\\%, \\tfrac{1}{2}$",
        "solution": [ { "math": "$0.40,\\ 0.45,\\ 0.50$", "note": "Convert all to decimals" }, { "math": "$0.4 < 45\\% < \\tfrac{1}{2}$", "note": "Ascending" } ] },
      { "q": "Which is larger: $\\tfrac{3}{4}$ or $70\\%$?", "a": "$\\tfrac{3}{4}$ ($75\\%$)",
        "solution": [ { "math": "$\\tfrac{3}{4} = 75\\%$", "note": "Convert" }, { "math": "$75\\% > 70\\%$", "note": "" } ] },
      { "q": "A test result of $\\tfrac{4}{5}$ is reported as a percentage. What is it?", "a": "$80\\%$",
        "solution": [ { "math": "$\\tfrac{4}{5} = \\tfrac{80}{100}$", "note": "Equivalent over 100" }, { "math": "$= 80\\%$", "note": "" } ] },
      { "q": "Shade is $0.2$ of a wall. Express this fraction and percentage.", "a": "$\\dfrac{1}{5}$, $20\\%$",
        "solution": [ { "math": "$0.2 = \\tfrac{2}{10} = \\tfrac{1}{5}$", "note": "Simplify" }, { "math": "$0.2 \\times 100 = 20\\%$", "note": "" } ] },
      { "q": "Order from largest to smallest: $0.65$, $\\tfrac{3}{5}$, $70\\%$.", "a": "$70\\%, 0.65, \\tfrac{3}{5}$",
        "solution": [ { "math": "$0.70,\\ 0.65,\\ 0.60$", "note": "Convert all to decimals" }, { "math": "$70\\% > 0.65 > \\tfrac{3}{5}$", "note": "Descending" } ] },
      { "q": "A jacket is $\\tfrac{1}{4}$ off. What percentage discount is this?", "a": "$25\\%$",
        "solution": [ { "math": "$\\tfrac{1}{4} = \\tfrac{25}{100}$", "note": "Equivalent over 100" }, { "math": "$= 25\\%$", "note": "" } ] },
      { "q": "Which three are equal: $\\tfrac{1}{2}$, $0.5$, $5\\%$, $50\\%$?", "a": "$\\tfrac{1}{2}$, $0.5$ and $50\\%$",
        "solution": [ { "math": "$\\tfrac{1}{2} = 0.5 = 50\\%$", "note": "All equal" }, { "math": "$5\\% = 0.05$", "note": "The odd one out" } ] },
      { "q": "A phone is $0.9$ charged. Express as a percentage and a fraction.", "a": "$90\\%$, $\\dfrac{9}{10}$",
        "solution": [ { "math": "$0.9 \\times 100 = 90\\%$", "note": "Decimal → percent" }, { "math": "$\\tfrac{90}{100} = \\tfrac{9}{10}$", "note": "Simplify" } ] },
      { "q": "Is $\\tfrac{1}{3}$ exactly $33\\%$?", "a": "no — it is $33.3\\ldots\\%$",
        "solution": [ { "math": "$\\tfrac{1}{3} = 0.333\\ldots$", "note": "Recurring" }, { "math": "$\\approx 33.3\\%$", "note": "Not exactly 33%" } ] },
      { "q": "Three shops offer $\\tfrac{1}{5}$ off, $0.15$ off, and $25\\%$ off. Which is the best discount?", "a": "$25\\%$ off",
        "solution": [ { "math": "$\\tfrac{1}{5} = 20\\%,\\ 0.15 = 15\\%$", "note": "Convert all to %" }, { "math": "$25\\% > 20\\% > 15\\%$", "note": "Biggest discount" } ] }
    ]
  }
}
