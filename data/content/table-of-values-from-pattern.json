{
  "skillId": "table-of-values-from-pattern",
  "atomType": "R",
  "theory": {
    "intro": "A growing pattern can be recorded in a table of values, linking the step number to the number of items used.",
    "facts": [
      "Each row of the pattern gives a pair: the **step number** and the **count**.",
      "If each step adds the same amount, the counts are **multiples**.",
      "A table makes the connection between the two quantities easy to see."
    ],
    "steps": [
      "Count the items in the first few steps of the pattern.",
      "Record each step number and its count as a column in the table.",
      "Continue the pattern to fill in further values."
    ]
  },
  "practice": {
    "foundation": [
      { "q": "Each step adds $2$ dots. Complete the table for steps $1$ to $4$: $\\begin{array}{c|cccc} \\text{Step} & 1 & 2 & 3 & 4 \\\\ \\hline \\text{Dots} & 2 & 4 & ? & ? \\end{array}$", "a": "$6, 8$",
        "tikz": "\\begin{tikzpicture}[scale=0.5]\n\\foreach \\x in {0,1} \\fill (\\x,0) circle (5pt);\n\\node at (0.5,-1) {Step 1};\n\\foreach \\x in {3,4,5,6} \\fill (\\x,0) circle (5pt);\n\\node at (4.5,-1) {Step 2};\n\\end{tikzpicture}",
        "solution": [ { "math": "$3 \\times 2 = 6$", "note": "Step $3$" }, { "math": "$4 \\times 2 = 8$", "note": "Step $4$" } ] },
      { "q": "Each step adds $3$ squares. Complete: $\\begin{array}{c|cccc} \\text{Step} & 1 & 2 & 3 & 4 \\\\ \\hline \\text{Squares} & 3 & 6 & ? & ? \\end{array}$", "a": "$9, 12$",
        "tikz": "\\begin{tikzpicture}[scale=0.4]\n\\foreach \\x in {0,1,2} \\draw (\\x,0) rectangle (\\x+0.9,0.9);\n\\node at (1.4,-0.8) {Step 1};\n\\foreach \\x in {5,6,7,8,9,10} \\draw (\\x,0) rectangle (\\x+0.9,0.9);\n\\node at (7.9,-0.8) {Step 2};\n\\end{tikzpicture}",
        "solution": [ { "math": "$3 \\times 3 = 9$", "note": "Step $3$" }, { "math": "$4 \\times 3 = 12$", "note": "Step $4$" } ] },
      { "q": "Each step adds $5$ counters. Complete: $\\begin{array}{c|cccc} \\text{Step} & 1 & 2 & 3 & 4 \\\\ \\hline \\text{Counters} & 5 & 10 & ? & ? \\end{array}$", "a": "$15, 20$",
        "solution": [ { "math": "$3 \\times 5 = 15$", "note": "Step $3$" }, { "math": "$4 \\times 5 = 20$", "note": "Step $4$" } ] },
      { "q": "Each step adds $4$ tiles. Complete: $\\begin{array}{c|cccc} \\text{Step} & 1 & 2 & 3 & 4 \\\\ \\hline \\text{Tiles} & 4 & 8 & ? & ? \\end{array}$", "a": "$12, 16$",
        "tikz": "\\begin{tikzpicture}[scale=0.4]\n\\foreach \\x in {0,1,2,3} \\draw (\\x,0) rectangle (\\x+0.9,0.9);\n\\node at (1.9,-0.8) {Step 1};\n\\end{tikzpicture}",
        "solution": [ { "math": "$3 \\times 4 = 12$", "note": "Step $3$" }, { "math": "$4 \\times 4 = 16$", "note": "Step $4$" } ] },
      { "q": "Each step adds $10$ beads. Complete: $\\begin{array}{c|cccc} \\text{Step} & 1 & 2 & 3 & 4 \\\\ \\hline \\text{Beads} & 10 & 20 & ? & ? \\end{array}$", "a": "$30, 40$",
        "solution": [ { "math": "$3 \\times 10 = 30$", "note": "Step $3$" }, { "math": "$4 \\times 10 = 40$", "note": "Step $4$" } ] },
      { "q": "Each step adds $6$ dots. Complete: $\\begin{array}{c|cccc} \\text{Step} & 1 & 2 & 3 & 4 \\\\ \\hline \\text{Dots} & 6 & 12 & ? & ? \\end{array}$", "a": "$18, 24$",
        "solution": [ { "math": "$3 \\times 6 = 18$", "note": "Step $3$" }, { "math": "$4 \\times 6 = 24$", "note": "Step $4$" } ] },
      { "q": "Each step adds $1$ dot. Complete: $\\begin{array}{c|cccc} \\text{Step} & 1 & 2 & 3 & 4 \\\\ \\hline \\text{Dots} & 1 & 2 & ? & ? \\end{array}$", "a": "$3, 4$",
        "tikz": "\\begin{tikzpicture}[scale=0.5]\n\\fill (0,0) circle (5pt); \\node at (0,-1) {Step 1};\n\\fill (2,0) circle (5pt); \\fill (3,0) circle (5pt); \\node at (2.5,-1) {Step 2};\n\\end{tikzpicture}",
        "solution": [ { "math": "$3 \\times 1 = 3$", "note": "Step $3$" }, { "math": "$4 \\times 1 = 4$", "note": "Step $4$" } ] },
      { "q": "Each step adds $7$ marbles. Complete: $\\begin{array}{c|cccc} \\text{Step} & 1 & 2 & 3 & 4 \\\\ \\hline \\text{Marbles} & 7 & 14 & ? & ? \\end{array}$", "a": "$21, 28$",
        "solution": [ { "math": "$3 \\times 7 = 21$", "note": "Step $3$" }, { "math": "$4 \\times 7 = 28$", "note": "Step $4$" } ] },
      { "q": "Each step adds $8$ stickers. Complete: $\\begin{array}{c|cccc} \\text{Step} & 1 & 2 & 3 & 4 \\\\ \\hline \\text{Stickers} & 8 & 16 & ? & ? \\end{array}$", "a": "$24, 32$",
        "solution": [ { "math": "$3 \\times 8 = 24$", "note": "Step $3$" }, { "math": "$4 \\times 8 = 32$", "note": "Step $4$" } ] },
      { "q": "Each step adds $9$ dots. Complete: $\\begin{array}{c|cccc} \\text{Step} & 1 & 2 & 3 & 4 \\\\ \\hline \\text{Dots} & 9 & 18 & ? & ? \\end{array}$", "a": "$27, 36$",
        "solution": [ { "math": "$3 \\times 9 = 27$", "note": "Step $3$" }, { "math": "$4 \\times 9 = 36$", "note": "Step $4$" } ] }
    ],
    "development": [
      { "q": "A pattern uses $3$ matchsticks per square in a row. Complete: $\\begin{array}{c|ccccc} \\text{Squares} & 1 & 2 & 3 & 4 & 5 \\\\ \\hline \\text{Matches} & 3 & 6 & 9 & ? & ? \\end{array}$", "a": "$12, 15$",
        "solution": [ { "math": "$4 \\times 3 = 12$", "note": "$4$ squares" }, { "math": "$5 \\times 3 = 15$", "note": "$5$ squares" } ] },
      { "q": "Each box holds $6$ eggs. Complete: $\\begin{array}{c|ccccc} \\text{Boxes} & 1 & 2 & 3 & 4 & 5 \\\\ \\hline \\text{Eggs} & 6 & 12 & 18 & ? & ? \\end{array}$", "a": "$24, 30$",
        "solution": [ { "math": "$4 \\times 6 = 24$", "note": "$4$ boxes" }, { "math": "$5 \\times 6 = 30$", "note": "$5$ boxes" } ] },
      { "q": "Each table seats $4$. Complete: $\\begin{array}{c|cccc} \\text{Tables} & 2 & 4 & 6 & 8 \\\\ \\hline \\text{Seats} & 8 & 16 & ? & ? \\end{array}$", "a": "$24, 32$",
        "solution": [ { "math": "$6 \\times 4 = 24$", "note": "$6$ tables" }, { "math": "$8 \\times 4 = 32$", "note": "$8$ tables" } ] },
      { "q": "A car travels $80$ km per hour. Complete: $\\begin{array}{c|cccc} \\text{Hours} & 1 & 2 & 3 & 4 \\\\ \\hline \\text{km} & 80 & 160 & ? & ? \\end{array}$", "a": "$240, 320$",
        "solution": [ { "math": "$3 \\times 80 = 240$", "note": "$3$ hours" }, { "math": "$4 \\times 80 = 320$", "note": "$4$ hours" } ] },
      { "q": "Pencils come in packs of $12$. Complete: $\\begin{array}{c|cccc} \\text{Packs} & 1 & 2 & 3 & 5 \\\\ \\hline \\text{Pencils} & 12 & 24 & 36 & ? \\end{array}$", "a": "$60$",
        "solution": [ { "math": "$5 \\times 12 = 60$", "note": "$5$ packs" }, { "math": "$= 60$", "note": "Multiply by $12$" } ] },
      { "q": "Each hexagon needs $6$ sticks. Complete: $\\begin{array}{c|cccc} \\text{Hexagons} & 1 & 3 & 5 & 10 \\\\ \\hline \\text{Sticks} & 6 & 18 & 30 & ? \\end{array}$", "a": "$60$",
        "solution": [ { "math": "$10 \\times 6 = 60$", "note": "$10$ hexagons" }, { "math": "$= 60$", "note": "Multiply by $6$" } ] },
      { "q": "A tap fills $15$ L per minute. Complete: $\\begin{array}{c|cccc} \\text{Minutes} & 2 & 4 & 6 & 10 \\\\ \\hline \\text{Litres} & 30 & 60 & ? & ? \\end{array}$", "a": "$90, 150$",
        "solution": [ { "math": "$6 \\times 15 = 90$", "note": "$6$ minutes" }, { "math": "$10 \\times 15 = 150$", "note": "$10$ minutes" } ] },
      { "q": "Each row of a theatre has $20$ seats. Complete: $\\begin{array}{c|cccc} \\text{Rows} & 1 & 2 & 5 & 10 \\\\ \\hline \\text{Seats} & 20 & 40 & ? & ? \\end{array}$", "a": "$100, 200$",
        "solution": [ { "math": "$5 \\times 20 = 100$", "note": "$5$ rows" }, { "math": "$10 \\times 20 = 200$", "note": "$10$ rows" } ] },
      { "q": "A pattern adds $11$ dots per step. Complete: $\\begin{array}{c|cccc} \\text{Step} & 1 & 2 & 3 & 4 \\\\ \\hline \\text{Dots} & 11 & 22 & ? & ? \\end{array}$", "a": "$33, 44$",
        "solution": [ { "math": "$3 \\times 11 = 33$", "note": "Step $3$" }, { "math": "$4 \\times 11 = 44$", "note": "Step $4$" } ] },
      { "q": "Each ticket costs $\\$25$. Complete: $\\begin{array}{c|cccc} \\text{Tickets} & 1 & 2 & 4 & 6 \\\\ \\hline \\text{Cost (\\$)} & 25 & 50 & ? & ? \\end{array}$", "a": "$100, 150$",
        "solution": [ { "math": "$4 \\times 25 = 100$", "note": "$4$ tickets" }, { "math": "$6 \\times 25 = 150$", "note": "$6$ tickets" } ] }
    ],
    "mastery": [
      { "q": "A pattern follows $\\text{dots} = 4 \\times \\text{step}$. Find the dots at step $7$.", "a": "$28$",
        "solution": [ { "math": "$4 \\times 7$", "note": "Use the rule" }, { "math": "$= 28$", "note": "Step $7$" } ] },
      { "q": "Tiles follow $\\text{tiles} = 5 \\times \\text{step}$. Which step has $45$ tiles?", "a": "step $9$",
        "solution": [ { "math": "$5 \\times \\square = 45$", "note": "Work backwards" }, { "math": "$\\square = 9$", "note": "Step $9$" } ] },
      { "q": "A table shows $\\begin{array}{c|ccc} \\text{Step} & 1 & 2 & 3 \\\\ \\hline \\text{Dots} & 6 & 12 & 18 \\end{array}$. Predict the dots at step $10$.", "a": "$60$",
        "solution": [ { "math": "$\\text{dots} = 6 \\times \\text{step}$", "note": "Each step adds $6$" }, { "math": "$6 \\times 10 = 60$", "note": "Step $10$" } ] },
      { "q": "Matches per square is $3$. How many squares can be built with $36$ matches?", "a": "$12$ squares",
        "solution": [ { "math": "$3 \\times \\square = 36$", "note": "Work backwards" }, { "math": "$\\square = 12$", "note": "$12$ squares" } ] },
      { "q": "A pattern has $\\begin{array}{c|ccc} \\text{Step} & 2 & 4 & 6 \\\\ \\hline \\text{Dots} & 14 & 28 & 42 \\end{array}$. Find the dots at step $1$.", "a": "$7$",
        "solution": [ { "math": "$\\text{dots} = 7 \\times \\text{step}$", "note": "$14 \\div 2 = 7$" }, { "math": "$7 \\times 1 = 7$", "note": "Step $1$" } ] },
      { "q": "Each minute a printer prints $9$ pages. Build the rule and find pages in $8$ minutes.", "a": "$72$ pages",
        "solution": [ { "math": "$\\text{pages} = 9 \\times \\text{minutes}$", "note": "Build rule" }, { "math": "$9 \\times 8 = 72$", "note": "$8$ minutes" } ] },
      { "q": "A table shows $\\begin{array}{c|ccc} \\text{Bags} & 3 & 5 & 8 \\\\ \\hline \\text{Apples} & 24 & 40 & 64 \\end{array}$. How many apples per bag?", "a": "$8$",
        "solution": [ { "math": "$24 \\div 3 = 8$", "note": "Apples per bag" }, { "math": "$= 8$", "note": "Check $5 \\times 8 = 40$" } ] },
      { "q": "Dots follow $\\text{dots} = 12 \\times \\text{step}$. How many dots at steps $1$ and $5$ combined?", "a": "$72$",
        "solution": [ { "math": "$12 \\times 1 + 12 \\times 5$", "note": "Two steps" }, { "math": "$= 12 + 60 = 72$", "note": "Total" } ] },
      { "q": "A staircase pattern adds $4$ blocks per step, starting at $4$. How many blocks for a $6$-step staircase?", "a": "$24$",
        "solution": [ { "math": "$\\text{blocks} = 4 \\times \\text{step}$", "note": "Build rule" }, { "math": "$4 \\times 6 = 24$", "note": "$6$ steps" } ] },
      { "q": "A table shows $\\begin{array}{c|ccc} \\text{Step} & 1 & 2 & 3 \\\\ \\hline \\text{Sticks} & 5 & 10 & 15 \\end{array}$. At which step are there $35$ sticks?", "a": "step $7$",
        "solution": [ { "math": "$5 \\times \\square = 35$", "note": "Work backwards" }, { "math": "$\\square = 7$", "note": "Step $7$" } ] }
    ]
  }
}
