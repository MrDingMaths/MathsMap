      { "q": "The angles lie on a straight line. Find $x$.", "a": "$85^{\\circ}$",
        "tikz": "\\begin{tikzpicture}[scale=1]\n\\coordinate (O) at (0,0);\n\\draw[thick] (-2.4,0)--(2.4,0);\n\\draw[thick] (O)--(95:2.2);\n\\node at (47:1.3) {$95^{\\circ}$};\n\\node at (138:1.3) {$x$};\n\\fill (O) circle (1.4pt);\n\\end{tikzpicture}",
        "solution": [ { "math": "$x + 95^{\\circ} = 180^{\\circ}$", "note": "Straight line" }, { "math": "$x = 85^{\\circ}$", "note": "" } ] },
      { "q": "Two angles that add to $180^{\\circ}$ are called what?", "a": "supplementary",
        "solution": [ { "math": "$\\text{sum} = 180^{\\circ}$", "note": "Fill a straight line" }, { "math": "$\\text{supplementary}$", "note": "" } ] }
    ],
    "development": [
      { "q": "Find the supplement of $63^{\\circ}$.", "a": "$117^{\\circ}$",
        "solution": [ { "math": "$180^{\\circ} - 63^{\\circ}$", "note": "Adds to $180^{\\circ}$" }, { "math": "$= 117^{\\circ}$", "note": "" } ] },
      { "q": "On a straight line, three angles are $50^{\\circ}$, $x$ and $70^{\\circ}$. Find $x$.", "a": "$60^{\\circ}$",
        "tikz": "\\begin{tikzpicture}[scale=1]\n\\coordinate (O) at (0,0);\n\\draw[thick] (-2.4,0)--(2.4,0);\n\\draw[thick] (O)--(50:2.2);\n\\draw[thick] (O)--(110:2.2);\n\\node at (25:1.3) {$50^{\\circ}$};\n\\node at (80:1.3) {$x$};\n\\node at (145:1.3) {$70^{\\circ}$};\n\\fill (O) circle (1.4pt);\n\\end{tikzpicture}",
        "solution": [ { "math": "$50^{\\circ} + x + 70^{\\circ} = 180^{\\circ}$", "note": "Straight line" }, { "math": "$x = 60^{\\circ}$", "note": "" } ] },
      { "q": "On a straight line, two angles are $x$ and $2x$. Find $x$.", "a": "$60^{\\circ}$",
        "tikz": "\\begin{tikzpicture}[scale=1]\n\\coordinate (O) at (0,0);\n\\draw[thick] (-2.4,0)--(2.4,0);\n\\draw[thick] (O)--(60:2.2);\n\\node at (30:1.3) {$2x$};\n\\node at (120:1.3) {$x$};\n\\fill (O) circle (1.4pt);\n\\end{tikzpicture}",
        "solution": [ { "math": "$x + 2x = 180^{\\circ}$", "note": "Straight line" }, { "math": "$3x = 180^{\\circ},\\ x = 60^{\\circ}$", "note": "" } ] },
      { "q": "Two supplementary angles are equal. Find each.", "a": "$90^{\\circ}$",
        "solution": [ { "math": "$2x = 180^{\\circ}$", "note": "Equal halves" }, { "math": "$x = 90^{\\circ}$", "note": "" } ] },
      { "q": "On a straight line, one angle is $5$ times the other. Find the smaller angle.", "a": "$30^{\\circ}$",
        "solution": [ { "math": "$x + 5x = 180^{\\circ}$", "note": "Straight line" }, { "math": "$6x = 180^{\\circ},\\ x = 30^{\\circ}$", "note": "" } ] },
      { "q": "An angle on a straight line is $48^{\\circ}$. Find its supplement.", "a": "$132^{\\circ}$",
        "tikz": "\\begin{tikzpicture}[scale=1]\n\\coordinate (O) at (0,0);\n\\draw[thick] (-2.4,0)--(2.4,0);\n\\draw[thick] (O)--(48:2.2);\n\\node at (24:1.3) {$48^{\\circ}$};\n\\node at (120:1.3) {$x$};\n\\fill (O) circle (1.4pt);\n\\end{tikzpicture}",
        "solution": [ { "math": "$x + 48^{\\circ} = 180^{\\circ}$", "note": "Straight line" }, { "math": "$x = 132^{\\circ}$", "note": "" } ] },
      { "q": "Find the supplement of $1^{\\circ}$.", "a": "$179^{\\circ}$",
        "solution": [ { "math": "$180^{\\circ} - 1^{\\circ}$", "note": "Adds to $180^{\\circ}$" }, { "math": "$= 179^{\\circ}$", "note": "" } ] },
      { "q": "On a straight line the larger angle is $40^{\\circ}$ more than the smaller. Find the smaller.", "a": "$70^{\\circ}$",
        "solution": [ { "math": "$x + (x + 40^{\\circ}) = 180^{\\circ}$", "note": "Straight line" }, { "math": "$2x = 140^{\\circ},\\ x = 70^{\\circ}$", "note": "" } ] },
      { "q": "An angle and its supplement differ by $50^{\\circ}$. Find the larger angle.", "a": "$115^{\\circ}$",
        "solution": [ { "math": "$x + (x - 50^{\\circ}) = 180^{\\circ}$", "note": "Sum is $180^{\\circ}$" }, { "math": "$2x = 230^{\\circ},\\ x = 115^{\\circ}$", "note": "" } ] },
      { "q": "Two adjacent angles on a straight line are $x + 30^{\\circ}$ and $2x$. Find $x$.", "a": "$50^{\\circ}$",
        "solution": [ { "math": "$(x + 30^{\\circ}) + 2x = 180^{\\circ}$", "note": "Straight line" }, { "math": "$3x = 150^{\\circ},\\ x = 50^{\\circ}$", "note": "" } ] }
    ],
    "mastery": [
      { "q": "Two supplementary angles are in the ratio $2:7$. Find the larger angle.", "a": "$140^{\\circ}$",
        "solution": [ { "math": "$2x + 7x = 180^{\\circ}$", "note": "Ratio parts" }, { "math": "$9x = 180^{\\circ},\\ 7x = 140^{\\circ}$", "note": "" } ] },
      { "q": "An angle is $24^{\\circ}$ more than its supplement. Find the angle.", "a": "$102^{\\circ}$",
        "solution": [ { "math": "$x + (x - 24^{\\circ}) = 180^{\\circ}$", "note": "Supplement is $x - 24^{\\circ}$" }, { "math": "$2x = 204^{\\circ},\\ x = 102^{\\circ}$", "note": "" } ] },
      { "q": "A see-saw beam makes an angle of $35^{\\circ}$ with the ground on one side. What angle does it make on the other side along the straight ground line?", "a": "$145^{\\circ}$",
