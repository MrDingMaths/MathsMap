      { "q": "The supplement of an angle is two-thirds of the angle. Find the angle.", "a": "$108^{\\circ}$",
        "solution": [ { "math": "$x + \\tfrac{2}{3}x = 180^{\\circ}$", "note": "Supplement is $\\tfrac{2}{3}x$" }, { "math": "$\\tfrac{5}{3}x = 180^{\\circ},\\ x = 108^{\\circ}$", "note": "" } ] },
      { "q": "Two angles are supplementary; one is $30^{\\circ}$ less than twice the other. Find the smaller angle.", "a": "$70^{\\circ}$",
        "solution": [ { "math": "$x + (2x - 30^{\\circ}) = 180^{\\circ}$", "note": "Sum is $180^{\\circ}$" }, { "math": "$3x = 210^{\\circ},\\ x = 70^{\\circ}$", "note": "" } ] },
      { "q": "On a straight line, angles are $4x$, $x$ and $30^{\\circ}$. Find $x$.", "a": "$30^{\\circ}$",
        "solution": [ { "math": "$4x + x + 30^{\\circ} = 180^{\\circ}$", "note": "Straight line" }, { "math": "$5x = 150^{\\circ},\\ x = 30^{\\circ}$", "note": "" } ] },
      { "q": "An angle's supplement is $58^{\\circ}$. By how much is the angle larger than its supplement?", "a": "$64^{\\circ}$",
        "solution": [ { "math": "$180^{\\circ} - 58^{\\circ} = 122^{\\circ}$", "note": "The angle" }, { "math": "$122^{\\circ} - 58^{\\circ} = 64^{\\circ}$", "note": "Difference" } ] },
      { "q": "A straight line is split into $x$, $x + 20^{\\circ}$ and $x + 40^{\\circ}$. Find $x$.", "a": "$40^{\\circ}$",
        "solution": [ { "math": "$3x + 60^{\\circ} = 180^{\\circ}$", "note": "Straight line" }, { "math": "$3x = 120^{\\circ},\\ x = 40^{\\circ}$", "note": "" } ] },
      { "q": "Two supplementary angles sum to a straight line. If each is decreased by $10^{\\circ}$, what is their new total?", "a": "$160^{\\circ}$",
        "solution": [ { "math": "$180^{\\circ} - 10^{\\circ} - 10^{\\circ}$", "note": "Each shrinks by $10^{\\circ}$" }, { "math": "$= 160^{\\circ}$", "note": "" } ] }
    ]
  }
}
