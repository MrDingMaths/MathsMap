{
  "skillId": "angles-add-to-180",
  "atomType": "R",
  "theory": {
    "intro": "When angles sit side by side along a straight line, they fill a half turn, so together they add to $180^{\\circ}$. These are called **supplementary** angles.",
    "facts": [
      "Adjacent angles on a **straight line** add to $180^{\\circ}$.",
      "A straight line is a half turn, which measures $180^{\\circ}$.",
      "If one angle is known, subtract it from $180^{\\circ}$ to find the other."
    ],
    "steps": [
      "Check the angles sit along a straight line (a half turn).",
      "Write 'known angle $+$ unknown $= 180^{\\circ}$'.",
      "Subtract the known angle from $180^{\\circ}$."
    ]
  },
  "practice": {
    "foundation": [
      { "q": "The angles lie on a straight line. Find $x$.", "a": "$60^{\\circ}$",
        "tikz": "\\begin{tikzpicture}[scale=1]\n\\coordinate (O) at (0,0);\n\\draw[thick] (-2.4,0)--(2.4,0);\n\\draw[thick] (O)--(120:2.2);\n\\node at (60:1.3) {$120^{\\circ}$};\n\\node at (150:1.3) {$x$};\n\\fill (O) circle (1.4pt);\n\\end{tikzpicture}",
        "solution": [ { "math": "$x + 120^{\\circ} = 180^{\\circ}$", "note": "Straight line" }, { "math": "$x = 60^{\\circ}$", "note": "" } ] },
      { "q": "The angles lie on a straight line. Find $x$.", "a": "$110^{\\circ}$",
        "tikz": "\\begin{tikzpicture}[scale=1]\n\\coordinate (O) at (0,0);\n\\draw[thick] (-2.4,0)--(2.4,0);\n\\draw[thick] (O)--(70:2.2);\n\\node at (35:1.3) {$70^{\\circ}$};\n\\node at (125:1.3) {$x$};\n\\fill (O) circle (1.4pt);\n\\end{tikzpicture}",
        "solution": [ { "math": "$x + 70^{\\circ} = 180^{\\circ}$", "note": "Straight line" }, { "math": "$x = 110^{\\circ}$", "note": "" } ] },
      { "q": "The angles lie on a straight line. Find $x$.", "a": "$45^{\\circ}$",
        "tikz": "\\begin{tikzpicture}[scale=1]\n\\coordinate (O) at (0,0);\n\\draw[thick] (-2.4,0)--(2.4,0);\n\\draw[thick] (O)--(135:2.2);\n\\node at (67:1.3) {$135^{\\circ}$};\n\\node at (157:1.3) {$x$};\n\\fill (O) circle (1.4pt);\n\\end{tikzpicture}",
        "solution": [ { "math": "$x + 135^{\\circ} = 180^{\\circ}$", "note": "Straight line" }, { "math": "$x = 45^{\\circ}$", "note": "" } ] },
      { "q": "Find the angle that adds to $80^{\\circ}$ to make $180^{\\circ}$.", "a": "$100^{\\circ}$",
        "solution": [ { "math": "$180^{\\circ} - 80^{\\circ}$", "note": "Supplement of $80^{\\circ}$" }, { "math": "$= 100^{\\circ}$", "note": "" } ] },
      { "q": "The angles lie on a straight line. Find $x$.", "a": "$25^{\\circ}$",
        "tikz": "\\begin{tikzpicture}[scale=1]\n\\coordinate (O) at (0,0);\n\\draw[thick] (-2.4,0)--(2.4,0);\n\\draw[thick] (O)--(155:2.2);\n\\node at (77:1.3) {$155^{\\circ}$};\n\\node at (167:1.3) {$x$};\n\\fill (O) circle (1.4pt);\n\\end{tikzpicture}",
        "solution": [ { "math": "$x + 155^{\\circ} = 180^{\\circ}$", "note": "Straight line" }, { "math": "$x = 25^{\\circ}$", "note": "" } ] },
      { "q": "Find the angle that adds to $90^{\\circ}$ to make $180^{\\circ}$.", "a": "$90^{\\circ}$",
        "solution": [ { "math": "$180^{\\circ} - 90^{\\circ}$", "note": "Supplement of $90^{\\circ}$" }, { "math": "$= 90^{\\circ}$", "note": "" } ] },
      { "q": "The angles lie on a straight line. Find $x$.", "a": "$140^{\\circ}$",
        "tikz": "\\begin{tikzpicture}[scale=1]\n\\coordinate (O) at (0,0);\n\\draw[thick] (-2.4,0)--(2.4,0);\n\\draw[thick] (O)--(40:2.2);\n\\node at (20:1.3) {$40^{\\circ}$};\n\\node at (115:1.3) {$x$};\n\\fill (O) circle (1.4pt);\n\\end{tikzpicture}",
        "solution": [ { "math": "$x + 40^{\\circ} = 180^{\\circ}$", "note": "Straight line" }, { "math": "$x = 140^{\\circ}$", "note": "" } ] },
      { "q": "What is the supplement of $30^{\\circ}$?", "a": "$150^{\\circ}$",
