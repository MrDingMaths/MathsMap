{
  "skillId": "decimal-length-equivalence",
  "atomType": "R",
  "theory": {
    "intro": "A length can be written in two ways: as a whole number of small units, or as a decimal of larger units. For example $165$ cm $= 1.65$ m.",
    "facts": [
      "There are $100$ cm in $1$ m, so each centimetre is $\\tfrac{1}{100}$ of a metre ($0.01$ m).",
      "There are $1000$ mm in $1$ m and $10$ mm in $1$ cm.",
      "Place value carries the meaning: $1.65$ m is $1$ whole metre and $65$ hundredths of a metre."
    ],
    "steps": [
      "Decide how many small units make one large unit ($100$ cm $= 1$ m).",
      "Split the small-unit total into whole large units and a remainder.",
      "Write the remainder as the decimal part."
    ]
  },
  "practice": {
    "foundation": [
      { "q": "Write $165$ cm in metres.", "a": "$1.65$ m",
        "solution": [ { "math": "$165 \\div 100$", "note": "$100$ cm $= 1$ m" }, { "math": "$= 1.65 \\text{ m}$", "note": "" } ] },
      { "q": "Write $250$ cm in metres.", "a": "$2.5$ m",
        "solution": [ { "math": "$250 \\div 100$", "note": "$100$ cm $= 1$ m" }, { "math": "$= 2.5 \\text{ m}$", "note": "" } ] },
      { "q": "Write $80$ cm in metres.", "a": "$0.8$ m",
        "solution": [ { "math": "$80 \\div 100$", "note": "Less than a metre" }, { "math": "$= 0.8 \\text{ m}$", "note": "" } ] },
      { "q": "Write $1.4$ m in centimetres.", "a": "$140$ cm",
        "solution": [ { "math": "$1.4 \\times 100$", "note": "$1$ m $= 100$ cm" }, { "math": "$= 140 \\text{ cm}$", "note": "" } ] },
      { "q": "Write $3$ cm in millimetres.", "a": "$30$ mm",
        "solution": [ { "math": "$3 \\times 10$", "note": "$1$ cm $= 10$ mm" }, { "math": "$= 30 \\text{ mm}$", "note": "" } ] },
      { "q": "Write $45$ mm in centimetres.", "a": "$4.5$ cm",
        "solution": [ { "math": "$45 \\div 10$", "note": "$10$ mm $= 1$ cm" }, { "math": "$= 4.5 \\text{ cm}$", "note": "" } ] },
      { "q": "Write $307$ cm in metres.", "a": "$3.07$ m",
        "solution": [ { "math": "$307 \\div 100$", "note": "$100$ cm $= 1$ m" }, { "math": "$= 3.07 \\text{ m}$", "note": "" } ] },
      { "q": "Write $0.6$ m in centimetres.", "a": "$60$ cm",
        "solution": [ { "math": "$0.6 \\times 100$", "note": "$1$ m $= 100$ cm" }, { "math": "$= 60 \\text{ cm}$", "note": "" } ] },
      { "q": "Write $5$ cm in metres.", "a": "$0.05$ m",
        "solution": [ { "math": "$5 \\div 100$", "note": "$5$ hundredths" }, { "math": "$= 0.05 \\text{ m}$", "note": "" } ] },
      { "q": "Write $120$ mm in centimetres.", "a": "$12$ cm",
        "solution": [ { "math": "$120 \\div 10$", "note": "$10$ mm $= 1$ cm" }, { "math": "$= 12 \\text{ cm}$", "note": "" } ] }
    ],
    "development": [
      { "q": "Write $2$ m $35$ cm as a decimal number of metres.", "a": "$2.35$ m",
        "solution": [ { "math": "$2 \\text{ m} + 35 \\text{ cm}$", "note": "$35$ cm $= 0.35$ m" }, { "math": "$= 2.35 \\text{ m}$", "note": "" } ] },
      { "q": "Write $1$ m $9$ cm as a decimal number of metres.", "a": "$1.09$ m",
        "solution": [ { "math": "$9 \\text{ cm} = 0.09 \\text{ m}$", "note": "Single cm = hundredths" }, { "math": "$= 1.09 \\text{ m}$", "note": "" } ] },
      { "q": "Write $4.06$ m in centimetres.", "a": "$406$ cm",
        "solution": [ { "math": "$4.06 \\times 100$", "note": "$1$ m $= 100$ cm" }, { "math": "$= 406 \\text{ cm}$", "note": "" } ] },
      { "q": "Write $7$ cm $4$ mm as a decimal number of centimetres.", "a": "$7.4$ cm",
        "solution": [ { "math": "$4 \\text{ mm} = 0.4 \\text{ cm}$", "note": "$10$ mm $= 1$ cm" }, { "math": "$= 7.4 \\text{ cm}$", "note": "" } ] },
      { "q": "Write $1\\,250$ mm in metres.", "a": "$1.25$ m",
        "solution": [ { "math": "$1\\,250 \\div 1000$", "note": "$1000$ mm $= 1$ m" }, { "math": "$= 1.25 \\text{ m}$", "note": "" } ] },
      { "q": "Write $3.2$ m in millimetres.", "a": "$3\\,200$ mm",
        "solution": [ { "math": "$3.2 \\times 1000$", "note": "$1$ m $= 1000$ mm" }, { "math": "$= 3\\,200 \\text{ mm}$", "note": "" } ] },
      { "q": "A board is $98$ cm long. Write this in metres.", "a": "$0.98$ m",
        "solution": [ { "math": "$98 \\div 100$", "note": "Just under a metre" }, { "math": "$= 0.98 \\text{ m}$", "note": "" } ] },
      { "q": "Write $0.4$ cm in millimetres.", "a": "$4$ mm",
        "solution": [ { "math": "$0.4 \\times 10$", "note": "$1$ cm $= 10$ mm" }, { "math": "$= 4 \\text{ mm}$", "note": "" } ] },
      { "q": "Write $2$ m $5$ cm in centimetres.", "a": "$205$ cm",
        "solution": [ { "math": "$2 \\times 100 + 5$", "note": "$2$ m $= 200$ cm" }, { "math": "$= 205 \\text{ cm}$", "note": "" } ] },
      { "q": "Write $560$ cm in metres.", "a": "$5.6$ m",
        "solution": [ { "math": "$560 \\div 100$", "note": "$100$ cm $= 1$ m" }, { "math": "$= 5.6 \\text{ m}$", "note": "" } ] }
    ],
    "mastery": [
      { "q": "A person is $1.72$ m tall. Express their height in centimetres.", "a": "$172$ cm",
        "solution": [ { "math": "$1.72 \\times 100$", "note": "$1$ m $= 100$ cm" }, { "math": "$= 172 \\text{ cm}$", "note": "" } ] },
      { "q": "A ribbon is $2$ m $48$ cm long. Write this length in metres, then in centimetres.", "a": "$2.48$ m $= 248$ cm",
        "solution": [ { "math": "$48 \\text{ cm} = 0.48 \\text{ m}$", "note": "Hundredths" }, { "math": "$2.48 \\text{ m} = 248 \\text{ cm}$", "note": "" } ] },
      { "q": "Which is longer: $1.5$ m or $145$ cm?", "a": "$1.5$ m",
        "solution": [ { "math": "$1.5 \\text{ m} = 150 \\text{ cm}$", "note": "Same unit" }, { "math": "$150 > 145$", "note": "So $1.5$ m" } ] },
      { "q": "A pencil measures $87$ mm. Write this in centimetres and in metres.", "a": "$8.7$ cm $= 0.087$ m",
        "solution": [ { "math": "$87 \\div 10 = 8.7 \\text{ cm}$", "note": "$10$ mm $= 1$ cm" }, { "math": "$87 \\div 1000 = 0.087 \\text{ m}$", "note": "" } ] },
      { "q": "A door is $2.04$ m tall. How many centimetres is that?", "a": "$204$ cm",
        "solution": [ { "math": "$2.04 \\times 100$", "note": "$1$ m $= 100$ cm" }, { "math": "$= 204 \\text{ cm}$", "note": "" } ] },
      { "q": "Express $3$ m $7$ cm $5$ mm as a decimal number of metres.", "a": "$3.075$ m",
        "solution": [ { "math": "$7 \\text{ cm} = 0.07,\\ 5 \\text{ mm} = 0.005$", "note": "In metres" }, { "math": "$3 + 0.07 + 0.005 = 3.075 \\text{ m}$", "note": "" } ] },
      { "q": "A snake is $0.95$ m long. Write its length in centimetres.", "a": "$95$ cm",
        "solution": [ { "math": "$0.95 \\times 100$", "note": "$1$ m $= 100$ cm" }, { "math": "$= 95 \\text{ cm}$", "note": "" } ] },
      { "q": "Two pieces of wire are $1.2$ m and $85$ cm. Write both in metres.", "a": "$1.2$ m and $0.85$ m",
        "solution": [ { "math": "$85 \\div 100 = 0.85 \\text{ m}$", "note": "Convert cm" }, { "math": "$1.2 \\text{ m},\\ 0.85 \\text{ m}$", "note": "" } ] },
      { "q": "A table is $1\\,650$ mm wide. Write this in metres.", "a": "$1.65$ m",
        "solution": [ { "math": "$1\\,650 \\div 1000$", "note": "$1000$ mm $= 1$ m" }, { "math": "$= 1.65 \\text{ m}$", "note": "" } ] },
      { "q": "A length is recorded as $0.305$ m. Write this in centimetres.", "a": "$30.5$ cm",
        "solution": [ { "math": "$0.305 \\times 100$", "note": "$1$ m $= 100$ cm" }, { "math": "$= 30.5 \\text{ cm}$", "note": "" } ] }
    ]
  }
}
