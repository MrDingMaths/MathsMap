{
  "skillId": "directed-number-sentences",
  "atomType": "R",
  "theory": {
    "intro": "Translate a real situation into a number sentence using positive and negative integers, then evaluate it.",
    "facts": [
      "**Down / below / loss / debt → negative.**",
      "**Up / above / gain → positive.**",
      "Write the starting value, then each change in order, then evaluate."
    ],
    "steps": [
      "Decide what each direction means (e.g. up = +, down = −).",
      "Write the starting value, then each change as + or −.",
      "Rewrite touching signs and evaluate left to right."
    ]
  },
  "practice": {
    "foundation": [
      {
        "q": "Todd enters the elevator $4$ floors below ground then rises $8$ floors. What floor is his office?", "a": "$-4 + 8 = 4$",
        "solution": [
          { "math": "$-4 + 8$", "note": "Translate" },
          { "math": "$= 4$", "note": "Evaluate" }
        ]
      },
      {
        "q": "Minh owes $\\$300$ on his credit card and pays off $\\$120$. New balance?", "a": "$-300 + 120 = -\\$180$",
        "solution": [
          { "math": "$-300 + 120$", "note": "Translate" },
          { "math": "$= -180$", "note": "Evaluate" }
        ]
      },
      {
        "q": "James receives $\\$5$ then spends $\\$8$. Net change?", "a": "$5 - 8 = -\\$3$",
        "solution": [
          { "math": "$5 - 8$", "note": "Translate" },
          { "math": "$= -3$", "note": "Evaluate" }
        ]
      },
      {
        "q": "From $0$, a lift goes down $2$ then down $3$. Final floor?", "a": "$0 - 2 - 3 = -5$",
        "solution": [
          { "math": "$0 - 2 - 3$", "note": "Translate" },
          { "math": "$= -5$", "note": "Evaluate" }
        ]
      },
      {
        "q": "The temperature rises from $-4$°C by $6$°C. New temperature?", "a": "$-4 + 6 = 2$°C",
        "solution": [
          { "math": "$-4 + 6$", "note": "Translate" },
          { "math": "$= 2$", "note": "Evaluate" }
        ]
      },
      {
        "q": "A diver at the surface descends $8$ m. Position?", "a": "$0 - 8 = -8$ m",
        "solution": [
          { "math": "$0 - 8$", "note": "Translate" },
          { "math": "$= -8$", "note": "Evaluate" }
        ]
      }
    ],
    "development": [
      {
        "q": "The temperature at midnight was $-12$°C. By noon it rose $27$°C. Noon temperature?", "a": "$-12 + 27 = 15$°C",
