        ]
      },
      {
        "q": "Find the difference between $35$°C and $-26$°C.", "a": "$35 - (-26) = 61$°C",
        "solution": [
          { "math": "$35 - (-26)$", "note": "Translate" },
          { "math": "$= 35 + 26$", "note": "Rewrite signs" },
          { "math": "$= 61$", "note": "Evaluate" }
        ]
      },
      {
        "q": "Mt Fujiyama is $3776$ m; Lake Hachirogata is $-4$ m. Height difference?", "a": "$3776 - (-4) = 3780$ m",
        "solution": [
          { "math": "$3776 - (-4)$", "note": "Translate" },
          { "math": "$= 3776 + 4$", "note": "Rewrite signs" },
          { "math": "$= 3780$", "note": "Evaluate" }
        ]
      },
      {
        "q": "James owed $\\$30$, repaid $\\$12$, then borrowed $\\$5$ more. Net balance?", "a": "$-30 + 12 - 5 = -23$ (owes $\\$23$)",
        "solution": [
          { "math": "$-30 + 12 - 5$", "note": "Translate" },
          { "math": "$= -23$", "note": "Evaluate" }
        ]
      }
    ]
  }
