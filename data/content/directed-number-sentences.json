    "mastery": [
      {
        "q": "Bundaberg was $39$°C; Salt Lake City was $-15$°C. Temperature difference?", "a": "$39 - (-15) = 54$°C",
        "solution": [
          { "math": "$39 - (-15)$", "note": "Translate" },
          { "math": "$= 39 + 15$", "note": "Rewrite signs" },
