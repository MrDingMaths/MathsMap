          { "math": "$85 - 220$", "note": "Translate" },
          { "math": "$= -135$", "note": "Evaluate" }
        ]
      },
      {
        "q": "From ground level a lift goes down $3$, up $5$, down $4$. Final floor?", "a": "$0 - 3 + 5 - 4 = -2$",
        "solution": [
          { "math": "$0 - 3 + 5 - 4$", "note": "Translate" },
          { "math": "$= -2$", "note": "Evaluate" }
