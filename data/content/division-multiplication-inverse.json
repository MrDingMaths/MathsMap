{
  "skillId": "division-multiplication-inverse",
  "atomType": "R",
  "theory": {
    "intro": "Division and multiplication are inverse operations. Every division with a remainder can be written as a multiplication plus the remainder.",
    "facts": [
      "If $a \\div b = q$ remainder $r$, then $a = b \\times q + r$.",
      "e.g. $25 \\div 6 = 4$ r $1$ because $25 = 4 \\times 6 + 1$.",
      "This lets you **check** a division or find a missing value."
    ],
    "steps": [
      "Identify the divisor, quotient and remainder.",
      "Multiply divisor $\\times$ quotient.",
      "Add the remainder to recover the original number."
    ]
  },
  "practice": {
    "foundation": [
      { "q": "Write $25 \\div 6 = 4$ r $1$ as a multiplication statement.", "a": "$25 = 4 \\times 6 + 1$",
        "solution": [ { "math": "$25 = (\\text{quotient} \\times \\text{divisor}) + r$", "note": "Inverse form" }, { "math": "$= 4 \\times 6 + 1$", "note": "" } ] },
      { "q": "Write $17 \\div 5 = 3$ r $2$ as a multiplication statement.", "a": "$17 = 3 \\times 5 + 2$",
        "solution": [ { "math": "$17 = 3 \\times 5 + 2$", "note": "$15 + 2 = 17$" }, { "math": "$= 17$", "note": "Checks" } ] },
      { "q": "Write $23 \\div 4 = 5$ r $3$ as a multiplication statement.", "a": "$23 = 5 \\times 4 + 3$",
        "solution": [ { "math": "$23 = 5 \\times 4 + 3$", "note": "$20 + 3 = 23$" }, { "math": "$= 23$", "note": "Checks" } ] },
      { "q": "A number is $3 \\times 7 + 2$. What is it?", "a": "$23$",
        "solution": [ { "math": "$3 \\times 7 + 2$", "note": "Multiply first" }, { "math": "$= 21 + 2 = 23$", "note": "" } ] },
      { "q": "A number is $4 \\times 5 + 1$. What is it?", "a": "$21$",
        "solution": [ { "math": "$4 \\times 5 + 1$", "note": "Multiply first" }, { "math": "$= 20 + 1 = 21$", "note": "" } ] },
      { "q": "Write $19 \\div 3 = 6$ r $1$ as a multiplication statement.", "a": "$19 = 6 \\times 3 + 1$",
        "solution": [ { "math": "$19 = 6 \\times 3 + 1$", "note": "$18 + 1 = 19$" }, { "math": "$= 19$", "note": "Checks" } ] },
      { "q": "A number is $2 \\times 9 + 4$. What is it?", "a": "$22$",
        "solution": [ { "math": "$2 \\times 9 + 4$", "note": "Multiply first" }, { "math": "$= 18 + 4 = 22$", "note": "" } ] },
      { "q": "Write $30 \\div 7 = 4$ r $2$ as a multiplication statement.", "a": "$30 = 4 \\times 7 + 2$",
        "solution": [ { "math": "$30 = 4 \\times 7 + 2$", "note": "$28 + 2 = 30$" }, { "math": "$= 30$", "note": "Checks" } ] },
      { "q": "A number is $5 \\times 6 + 3$. What is it?", "a": "$33$",
        "solution": [ { "math": "$5 \\times 6 + 3$", "note": "Multiply first" }, { "math": "$= 30 + 3 = 33$", "note": "" } ] },
      { "q": "Write $14 \\div 4 = 3$ r $2$ as a multiplication statement.", "a": "$14 = 3 \\times 4 + 2$",
        "solution": [ { "math": "$14 = 3 \\times 4 + 2$", "note": "$12 + 2 = 14$" }, { "math": "$= 14$", "note": "Checks" } ] }
    ],
    "development": [
      { "q": "A division by $6$ gives quotient $7$ and remainder $4$. What was the number?", "a": "$46$",
        "solution": [ { "math": "$6 \\times 7 + 4$", "note": "$a = bq + r$" }, { "math": "$= 42 + 4 = 46$", "note": "" } ] },
      { "q": "A division by $8$ gives quotient $5$ and remainder $7$. What was the number?", "a": "$47$",
        "solution": [ { "math": "$8 \\times 5 + 7$", "note": "$a = bq + r$" }, { "math": "$= 40 + 7 = 47$", "note": "" } ] },
      { "q": "Use $43 = 7 \\times 6 + 1$ to state $43 \\div 7$.", "a": "$6$ r $1$",
        "solution": [ { "math": "$43 = 7 \\times 6 + 1$", "note": "Given" }, { "math": "$43 \\div 7 = 6 \\text{ r } 1$", "note": "Read off" } ] },
      { "q": "Use $50 = 8 \\times 6 + 2$ to state $50 \\div 8$.", "a": "$6$ r $2$",
        "solution": [ { "math": "$50 = 8 \\times 6 + 2$", "note": "Given" }, { "math": "$50 \\div 8 = 6 \\text{ r } 2$", "note": "Read off" } ] },
      { "q": "A division by $9$ gives quotient $8$ and remainder $5$. What was the number?", "a": "$77$",
        "solution": [ { "math": "$9 \\times 8 + 5$", "note": "$a = bq + r$" }, { "math": "$= 72 + 5 = 77$", "note": "" } ] },
      { "q": "Check that $58 \\div 7 = 8$ r $2$ is correct.", "a": "Correct — $7 \\times 8 + 2 = 58$",
        "solution": [ { "math": "$7 \\times 8 + 2$", "note": "Reverse" }, { "math": "$= 56 + 2 = 58$", "note": "Matches" } ] },
      { "q": "A division by $5$ gives quotient $12$ and remainder $3$. What was the number?", "a": "$63$",
        "solution": [ { "math": "$5 \\times 12 + 3$", "note": "$a = bq + r$" }, { "math": "$= 60 + 3 = 63$", "note": "" } ] },
      { "q": "Use $89 = 9 \\times 9 + 8$ to state $89 \\div 9$.", "a": "$9$ r $8$",
        "solution": [ { "math": "$89 = 9 \\times 9 + 8$", "note": "Given" }, { "math": "$89 \\div 9 = 9 \\text{ r } 8$", "note": "Read off" } ] },
      { "q": "A division by $6$ gives quotient $11$ and remainder $5$. What was the number?", "a": "$71$",
        "solution": [ { "math": "$6 \\times 11 + 5$", "note": "$a = bq + r$" }, { "math": "$= 66 + 5 = 71$", "note": "" } ] },
      { "q": "Check whether $61 \\div 8 = 7$ r $6$ is correct.", "a": "No — it is $7$ r $5$",
        "solution": [ { "math": "$8 \\times 7 + 6 = 62 \\neq 61$", "note": "Too big" }, { "math": "$8 \\times 7 + 5 = 61$", "note": "So $7 \\text{ r } 5$" } ] }
    ],
    "mastery": [
      { "q": "A whole number leaves remainder $4$ when divided by $7$, with quotient $9$. Find the number.", "a": "$67$",
        "solution": [ { "math": "$7 \\times 9 + 4$", "note": "$a = bq + r$" }, { "math": "$= 63 + 4 = 67$", "note": "" } ] },
      { "q": "When a number is divided by $6$, the quotient equals the remainder, both $5$... is that valid? Explain.", "a": "No — remainder must be less than $6$, and $5 < 6$ is valid; number $= 35$",
        "solution": [ { "math": "$r = 5 < 6$", "note": "Valid remainder" }, { "math": "$6 \\times 5 + 5 = 35$", "note": "The number" } ] },
      { "q": "$n \\div 8$ gives quotient $7$ remainder $r$. If $n = 59$, find $r$.", "a": "$3$",
        "solution": [ { "math": "$8 \\times 7 = 56$", "note": "Quotient part" }, { "math": "$59 - 56 = 3$", "note": "Remainder" } ] },
      { "q": "Eggs packed in sixes used $9$ full cartons with $4$ left over. How many eggs?", "a": "$58$",
        "solution": [ { "math": "$6 \\times 9 + 4$", "note": "Cartons plus leftovers" }, { "math": "$= 54 + 4 = 58$", "note": "" } ] },
      { "q": "$a \\div 9 = 6$ r $r$ and $a = 60$. Find $r$, and check $r < 9$.", "a": "$r = 6$",
        "solution": [ { "math": "$9 \\times 6 = 54$", "note": "Quotient part" }, { "math": "$60 - 54 = 6 < 9$", "note": "Valid remainder" } ] },
      { "q": "A number divided by $7$ has quotient $8$ and the largest possible remainder. Find the number.", "a": "$62$",
        "solution": [ { "math": "$\\text{largest } r = 6$", "note": "$r < 7$" }, { "math": "$7 \\times 8 + 6 = 62$", "note": "" } ] },
      { "q": "$53$ pencils are bundled in sevens. Use $53 = 7 \\times q + r$ to find $q$ and $r$.", "a": "$q = 7$, $r = 4$",
        "solution": [ { "math": "$7 \\times 7 = 49$", "note": "Largest multiple" }, { "math": "$53 - 49 = 4 \\Rightarrow 7 \\text{ r } 4$", "note": "" } ] },
      { "q": "A division by $8$ gives quotient $12$ remainder $7$. Find the number, then confirm $r < 8$.", "a": "$103$",
        "solution": [ { "math": "$8 \\times 12 + 7$", "note": "$a = bq + r$" }, { "math": "$= 96 + 7 = 103,\\ 7 < 8$", "note": "Valid" } ] },
      { "q": "When divided by $5$ a number gives quotient $14$ and remainder $0$. What is it?", "a": "$70$",
        "solution": [ { "math": "$5 \\times 14 + 0$", "note": "No remainder" }, { "math": "$= 70$", "note": "Exact multiple" } ] },
      { "q": "A number between $40$ and $50$ leaves remainder $1$ when divided by $9$. Find it.", "a": "$46$",
        "solution": [ { "math": "$9 \\times 5 + 1 = 46$", "note": "Try quotient $5$" }, { "math": "$40 < 46 < 50$", "note": "In range" } ] }
    ]
  }
}
