{
  "skillId": "use-grouping-symbols",
  "atomType": "R",
  "theory": {
    "intro": "Brackets (grouping symbols) tell you to work out part of an expression first, even ahead of multiplication and division.",
    "facts": [
      "Whatever is inside **brackets** is calculated **first**.",
      "Brackets can change the answer: $2 \\times (3 + 4) \\neq 2 \\times 3 + 4$.",
      "Insert brackets to force an addition or subtraction to happen before a multiplication."
    ],
    "steps": [
      "Evaluate inside the brackets first.",
      "Then apply $\\times$ and $\\div$, then $+$ and $-$.",
      "To insert brackets, decide which part must be done first and enclose it."
    ]
  },
  "practice": {
    "foundation": [
      { "q": "Evaluate $(3 + 4) \\times 2$.", "a": "$14$",
        "solution": [ { "math": "$7 \\times 2$", "note": "Brackets first" }, { "math": "$= 14$", "note": "Then multiply" } ] },
      { "q": "Evaluate $2 \\times (5 + 1)$.", "a": "$12$",
        "solution": [ { "math": "$2 \\times 6$", "note": "Brackets first" }, { "math": "$= 12$", "note": "Then multiply" } ] },
      { "q": "Evaluate $(10 - 4) \\div 3$.", "a": "$2$",
        "solution": [ { "math": "$6 \\div 3$", "note": "Brackets first" }, { "math": "$= 2$", "note": "Then divide" } ] },
      { "q": "Evaluate $(8 + 2) \\times 5$.", "a": "$50$",
        "solution": [ { "math": "$10 \\times 5$", "note": "Brackets first" }, { "math": "$= 50$", "note": "Then multiply" } ] },
      { "q": "Evaluate $4 \\times (9 - 6)$.", "a": "$12$",
        "solution": [ { "math": "$4 \\times 3$", "note": "Brackets first" }, { "math": "$= 12$", "note": "Then multiply" } ] },
      { "q": "Evaluate $(12 + 8) \\div 4$.", "a": "$5$",
        "solution": [ { "math": "$20 \\div 4$", "note": "Brackets first" }, { "math": "$= 5$", "note": "Then divide" } ] },
      { "q": "Evaluate $(7 - 2) \\times 3$.", "a": "$15$",
        "solution": [ { "math": "$5 \\times 3$", "note": "Brackets first" }, { "math": "$= 15$", "note": "Then multiply" } ] },
      { "q": "Evaluate $6 \\times (2 + 2)$.", "a": "$24$",
        "solution": [ { "math": "$6 \\times 4$", "note": "Brackets first" }, { "math": "$= 24$", "note": "Then multiply" } ] },
      { "q": "Evaluate $(15 - 5) \\div 2$.", "a": "$5$",
        "solution": [ { "math": "$10 \\div 2$", "note": "Brackets first" }, { "math": "$= 5$", "note": "Then divide" } ] },
      { "q": "Evaluate $(1 + 9) \\times 4$.", "a": "$40$",
        "solution": [ { "math": "$10 \\times 4$", "note": "Brackets first" }, { "math": "$= 40$", "note": "Then multiply" } ] }
    ],
    "development": [
      { "q": "Compare $3 + 4 \\times 2$ and $(3 + 4) \\times 2$.", "a": "$11$ and $14$",
        "solution": [ { "math": "$3 + 8 = 11$", "note": "No brackets" }, { "math": "$7 \\times 2 = 14$", "note": "With brackets" } ] },
      { "q": "Evaluate $2 \\times (3 + 5) - 4$.", "a": "$12$",
        "solution": [ { "math": "$2 \\times 8 - 4$", "note": "Brackets first" }, { "math": "$= 16 - 4 = 12$", "note": "Then $\\times$, then $-$" } ] },
      { "q": "Evaluate $(20 - 8) \\div (1 + 2)$.", "a": "$4$",
        "solution": [ { "math": "$12 \\div 3$", "note": "Both brackets first" }, { "math": "$= 4$", "note": "Then divide" } ] },
      { "q": "Insert brackets to make $6 + 4 \\times 2 = 20$ true.", "a": "$(6 + 4) \\times 2$",
        "solution": [ { "math": "$(6 + 4) \\times 2$", "note": "Force the $+$ first" }, { "math": "$= 10 \\times 2 = 20$", "note": "Now true" } ] },
      { "q": "Evaluate $30 \\div (2 + 3) + 1$.", "a": "$7$",
        "solution": [ { "math": "$30 \\div 5 + 1$", "note": "Brackets first" }, { "math": "$= 6 + 1 = 7$", "note": "Then $\\div$, then $+$" } ] },
      { "q": "Insert brackets to make $12 - 4 \\div 2 = 4$ true.", "a": "$(12 - 4) \\div 2$",
        "solution": [ { "math": "$(12 - 4) \\div 2$", "note": "Force the $-$ first" }, { "math": "$= 8 \\div 2 = 4$", "note": "Now true" } ] },
      { "q": "Evaluate $5 \\times (10 - 3 \\times 2)$.", "a": "$20$",
        "solution": [ { "math": "$5 \\times (10 - 6)$", "note": "$\\times$ inside bracket first" }, { "math": "$= 5 \\times 4 = 20$", "note": "Then multiply" } ] },
      { "q": "Evaluate $(4 + 6) \\times (7 - 2)$.", "a": "$50$",
        "solution": [ { "math": "$10 \\times 5$", "note": "Both brackets first" }, { "math": "$= 50$", "note": "Then multiply" } ] },
      { "q": "Insert brackets to make $8 - 3 + 1 = 4$ true.", "a": "$8 - (3 + 1)$",
        "solution": [ { "math": "$8 - (3 + 1)$", "note": "Force the $+$ first" }, { "math": "$= 8 - 4 = 4$", "note": "Now true" } ] },
      { "q": "Evaluate $100 \\div (4 \\times 5)$.", "a": "$5$",
        "solution": [ { "math": "$100 \\div 20$", "note": "Bracket first" }, { "math": "$= 5$", "note": "Then divide" } ] }
    ],
    "mastery": [
      { "q": "A shop sells $3$ shirts at $\\$20$ and gives a $\\$15$ discount. Write with brackets and evaluate.", "a": "$\\$45$",
        "solution": [ { "math": "$3 \\times 20 - 15$", "note": "No brackets needed here" }, { "math": "$= 60 - 15 = 45$", "note": "$\\$45$" } ] },
      { "q": "Two friends each buy a $\\$6$ meal and a $\\$2$ drink. Write with brackets and evaluate the total.", "a": "$\\$16$",
        "solution": [ { "math": "$2 \\times (6 + 2)$", "note": "Group the cost per person" }, { "math": "$= 2 \\times 8 = 16$", "note": "$\\$16$" } ] },
      { "q": "Insert brackets to make $24 \\div 6 + 2 = 3$ true.", "a": "$24 \\div (6 + 2)$",
        "solution": [ { "math": "$24 \\div (6 + 2)$", "note": "Force the $+$ first" }, { "math": "$= 24 \\div 8 = 3$", "note": "Now true" } ] },
      { "q": "Evaluate $((2 + 3) \\times 4) - 6$.", "a": "$14$",
        "solution": [ { "math": "$(5 \\times 4) - 6$", "note": "Inner bracket first" }, { "math": "$= 20 - 6 = 14$", "note": "Then subtract" } ] },
      { "q": "A box holds $5$ rows of $4$ apples; $3$ are removed. Write with brackets and evaluate.", "a": "$17$",
        "solution": [ { "math": "$(5 \\times 4) - 3$", "note": "Group the multiplication" }, { "math": "$= 20 - 3 = 17$", "note": "$17$ apples" } ] },
      { "q": "Insert brackets to make $5 + 5 \\div 5 = 2$ true.", "a": "$(5 + 5) \\div 5$",
        "solution": [ { "math": "$(5 + 5) \\div 5$", "note": "Force the $+$ first" }, { "math": "$= 10 \\div 5 = 2$", "note": "Now true" } ] },
      { "q": "Evaluate $40 - (3 + 2) \\times 4$.", "a": "$20$",
        "solution": [ { "math": "$40 - 5 \\times 4$", "note": "Bracket first" }, { "math": "$= 40 - 20 = 20$", "note": "Then $\\times$, then $-$" } ] },
      { "q": "A recipe doubles $(2 + 1)$ cups of flour. Write with brackets and evaluate.", "a": "$6$ cups",
        "solution": [ { "math": "$2 \\times (2 + 1)$", "note": "Double the total" }, { "math": "$= 2 \\times 3 = 6$", "note": "$6$ cups" } ] },
      { "q": "Insert brackets to make $18 - 6 \\times 2 = 24$ true.", "a": "$(18 - 6) \\times 2$",
        "solution": [ { "math": "$(18 - 6) \\times 2$", "note": "Force the $-$ first" }, { "math": "$= 12 \\times 2 = 24$", "note": "Now true" } ] },
      { "q": "Evaluate $(50 - 2 \\times 5) \\div (4 + 6)$.", "a": "$4$",
        "solution": [ { "math": "$(50 - 10) \\div 10$", "note": "Inside brackets first" }, { "math": "$= 40 \\div 10 = 4$", "note": "Then divide" } ] }
    ]
  }
}
