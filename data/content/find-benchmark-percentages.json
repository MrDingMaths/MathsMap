{
  "skillId": "find-benchmark-percentages",
  "atomType": "R",
  "theory": {
    "intro": "Three benchmark percentages have quick mental shortcuts because they are simple fractions.",
    "facts": [
      "$50\\% = \\tfrac{1}{2}$ → **halve** the amount.",
      "$25\\% = \\tfrac{1}{4}$ → **divide by $4$** (or halve, then halve again).",
      "$10\\% = \\tfrac{1}{10}$ → **divide by $10$**."
    ],
    "steps": [
      "Match the percentage to its fraction ($50\\% = \\tfrac12$, $25\\% = \\tfrac14$, $10\\% = \\tfrac{1}{10}$).",
      "Divide the amount by $2$, $4$ or $10$.",
      "Combine benchmarks for other percentages if needed."
    ]
  },
  "practice": {
    "foundation": [
      { "q": "Find $50\\%$ of $60$.", "a": "$30$",
        "solution": [ { "math": "$50\\% = \\tfrac{1}{2}$", "note": "Halve it" }, { "math": "$60 \\div 2 = 30$", "note": "" } ] },
      { "q": "Find $25\\%$ of $40$.", "a": "$10$",
        "solution": [ { "math": "$25\\% = \\tfrac{1}{4}$", "note": "Divide by 4" }, { "math": "$40 \\div 4 = 10$", "note": "" } ] },
      { "q": "Find $10\\%$ of $90$.", "a": "$9$",
        "solution": [ { "math": "$10\\% = \\tfrac{1}{10}$", "note": "Divide by 10" }, { "math": "$90 \\div 10 = 9$", "note": "" } ] },
      { "q": "Find $50\\%$ of $\\$24$.", "a": "$\\$12$",
        "solution": [ { "math": "$50\\% = \\tfrac{1}{2}$", "note": "Halve it" }, { "math": "$24 \\div 2 = 12$", "note": "" } ] },
      { "q": "Find $25\\%$ of $\\$80$.", "a": "$\\$20$",
        "solution": [ { "math": "$25\\% = \\tfrac{1}{4}$", "note": "Divide by 4" }, { "math": "$80 \\div 4 = 20$", "note": "" } ] },
      { "q": "Find $50\\%$ of $150$.", "a": "$75$",
        "solution": [ { "math": "$50\\% = \\tfrac{1}{2}$", "note": "Halve it" }, { "math": "$150 \\div 2 = 75$", "note": "" } ] },
      { "q": "Find $10\\%$ of $\\$250$.", "a": "$\\$25$",
        "solution": [ { "math": "$10\\% = \\tfrac{1}{10}$", "note": "Divide by 10" }, { "math": "$250 \\div 10 = 25$", "note": "" } ] },
      { "q": "Find $25\\%$ of $100$.", "a": "$25$",
        "solution": [ { "math": "$25\\% = \\tfrac{1}{4}$", "note": "Divide by 4" }, { "math": "$100 \\div 4 = 25$", "note": "" } ] },
      { "q": "Find $50\\%$ of $\\$18$.", "a": "$\\$9$",
        "solution": [ { "math": "$50\\% = \\tfrac{1}{2}$", "note": "Halve it" }, { "math": "$18 \\div 2 = 9$", "note": "" } ] },
      { "q": "Find $25\\%$ of $12$.", "a": "$3$",
        "solution": [ { "math": "$25\\% = \\tfrac{1}{4}$", "note": "Divide by 4" }, { "math": "$12 \\div 4 = 3$", "note": "" } ] }
    ],
    "development": [
      { "q": "Find $25\\%$ of $\\$120$.", "a": "$\\$30$",
        "solution": [ { "math": "$120 \\div 2 = 60$", "note": "Halve" }, { "math": "$60 \\div 2 = 30$", "note": "Halve again = ÷4" } ] },
      { "q": "Find $50\\%$ of $\\$370$.", "a": "$\\$185$",
        "solution": [ { "math": "$50\\% = \\tfrac{1}{2}$", "note": "Halve it" }, { "math": "$370 \\div 2 = 185$", "note": "" } ] },
      { "q": "Find $75\\%$ of $\\$40$ using $25\\%$.", "a": "$\\$30$",
        "solution": [ { "math": "$25\\% \\text{ of } 40 = 10$", "note": "Divide by 4" }, { "math": "$3 \\times 10 = 30$", "note": "Three quarters" } ] },
      { "q": "Find $10\\%$ of $\\$45$.", "a": "$\\$4.50$",
        "solution": [ { "math": "$10\\% = \\tfrac{1}{10}$", "note": "Divide by 10" }, { "math": "$45 \\div 10 = 4.50$", "note": "" } ] },
      { "q": "Find $25\\%$ of $\\$50$.", "a": "$\\$12.50$",
        "solution": [ { "math": "$50 \\div 4$", "note": "$25\\% = \\tfrac14$" }, { "math": "$= 12.50$", "note": "" } ] },
      { "q": "Find $50\\%$ of $\\$96$.", "a": "$\\$48$",
        "solution": [ { "math": "$96 \\div 2$", "note": "Halve it" }, { "math": "$= 48$", "note": "" } ] },
      { "q": "Find $60\\%$ of $\\$50$ using $10\\%$.", "a": "$\\$30$",
        "solution": [ { "math": "$10\\% \\text{ of } 50 = 5$", "note": "Divide by 10" }, { "math": "$6 \\times 5 = 30$", "note": "Six lots of 10%" } ] },
      { "q": "$25\\%$ of a number is $7$. What is the number?", "a": "$28$",
        "solution": [ { "math": "$25\\% = \\tfrac{1}{4}$", "note": "Whole is 4 quarters" }, { "math": "$4 \\times 7 = 28$", "note": "" } ] },
      { "q": "Find $75\\%$ of $\\$200$.", "a": "$\\$150$",
        "solution": [ { "math": "$25\\% \\text{ of } 200 = 50$", "note": "Divide by 4" }, { "math": "$3 \\times 50 = 150$", "note": "Three quarters" } ] },
      { "q": "Find $50\\%$ of $\\$13$.", "a": "$\\$6.50$",
        "solution": [ { "math": "$13 \\div 2$", "note": "Halve it" }, { "math": "$= 6.50$", "note": "" } ] }
    ],
    "mastery": [
      { "q": "A $\\$240$ bike is reduced by $25\\%$. What is the sale price?", "a": "$\\$180$",
        "solution": [ { "math": "$240 \\div 4 = 60$", "note": "25% discount" }, { "math": "$240 - 60 = 180$", "note": "Sale price" } ] },
      { "q": "Half a class of $32$ play sport; a quarter of the class play music. How many do each?", "a": "$16$ sport, $8$ music",
        "solution": [ { "math": "$50\\% \\text{ of } 32 = 16$", "note": "Halve" }, { "math": "$25\\% \\text{ of } 32 = 8$", "note": "Divide by 4" } ] },
      { "q": "A $\\$60$ meal has $10\\%$ added as service, then a $50\\%$-off voucher applied to that total. What is the final cost?", "a": "$\\$33$",
        "solution": [ { "math": "$60 + 6 = 66$", "note": "Add 10% service" }, { "math": "$66 \\div 2 = 33$", "note": "50% off" } ] },
      { "q": "$10\\%$ of a bill is $\\$8.50$. What is $50\\%$ of the bill?", "a": "$\\$42.50$",
        "solution": [ { "math": "$10\\% = 8.50 \\Rightarrow 100\\% = 85$", "note": "Whole bill" }, { "math": "$85 \\div 2 = 42.50$", "note": "Half of it" } ] },
      { "q": "Find $35\\%$ of $\\$80$ using $25\\%$ and $10\\%$.", "a": "$\\$28$",
        "solution": [ { "math": "$25\\% = 20,\\ 10\\% = 8$", "note": "Divide by 4 and by 10" }, { "math": "$20 + 8 = 28$", "note": "Add the parts" } ] },
      { "q": "A tank holds $400$ L. It is $25\\%$ full. How many more litres fill it?", "a": "$300$ L",
        "solution": [ { "math": "$25\\% \\text{ of } 400 = 100$", "note": "Current amount" }, { "math": "$400 - 100 = 300$", "note": "To fill it" } ] },
      { "q": "A $\\$150$ jacket is $50\\%$ off, then a further $10\\%$ off the reduced price. What is the final price?", "a": "$\\$67.50$",
        "solution": [ { "math": "$150 \\div 2 = 75$", "note": "50% off" }, { "math": "$75 - 7.50 = 67.50$", "note": "10% off the new price" } ] },
      { "q": "Of $\\$60$ saved, a student spends $25\\%$ and saves $50\\%$. How much is left over?", "a": "$\\$15$",
        "solution": [ { "math": "$25\\% + 50\\% = 75\\%$", "note": "Used or saved" }, { "math": "$25\\% \\text{ of } 60 = 15$", "note": "The remaining 25%" } ] },
      { "q": "A book has $320$ pages. A reader finishes $75\\%$. How many pages are left?", "a": "$80$ pages",
        "solution": [ { "math": "$25\\% \\text{ of } 320 = 80$", "note": "The unread quarter" }, { "math": "$= 80$", "note": "$100\\% - 75\\% = 25\\%$" } ] },
      { "q": "Two deposits are $50\\%$ and $10\\%$ of $\\$900$. What is the total deposited?", "a": "$\\$540$",
        "solution": [ { "math": "$50\\% = 450,\\ 10\\% = 90$", "note": "Halve and ÷10" }, { "math": "$450 + 90 = 540$", "note": "Total" } ] }
    ]
  }
}
