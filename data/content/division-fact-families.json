{
  "skillId": "division-fact-families",
  "atomType": "R",
  "theory": {
    "intro": "A fact family links multiplication and division. Knowing the times tables lets you find division answers with remainders quickly.",
    "facts": [
      "For $a \\div b$, find the **largest multiple** of $b$ that fits inside $a$.",
      "e.g. $27 \\div 6$: $6 \\times 4 = 24$, so $27 \\div 6 = 4$ remainder $3$.",
      "The remainder is what is left after subtracting that multiple."
    ],
    "steps": [
      "Recall multiples of the divisor.",
      "Pick the largest one not exceeding the number — that gives the quotient.",
      "Subtract to find the remainder."
    ]
  },
  "practice": {
    "foundation": [
      { "q": "Find $27 \\div 6$.", "a": "$4$ r $3$",
        "solution": [ { "math": "$6 \\times 4 = 24$", "note": "Largest multiple" }, { "math": "$27 - 24 = 3 \\Rightarrow 4 \\text{ r } 3$", "note": "Remainder" } ] },
      { "q": "Find $19 \\div 4$.", "a": "$4$ r $3$",
        "solution": [ { "math": "$4 \\times 4 = 16$", "note": "Largest multiple" }, { "math": "$19 - 16 = 3 \\Rightarrow 4 \\text{ r } 3$", "note": "Remainder" } ] },
      { "q": "Find $23 \\div 5$.", "a": "$4$ r $3$",
        "solution": [ { "math": "$5 \\times 4 = 20$", "note": "Largest multiple" }, { "math": "$23 - 20 = 3 \\Rightarrow 4 \\text{ r } 3$", "note": "Remainder" } ] },
      { "q": "Find $17 \\div 3$.", "a": "$5$ r $2$",
        "solution": [ { "math": "$3 \\times 5 = 15$", "note": "Largest multiple" }, { "math": "$17 - 15 = 2 \\Rightarrow 5 \\text{ r } 2$", "note": "Remainder" } ] },
      { "q": "Find $30 \\div 7$.", "a": "$4$ r $2$",
        "solution": [ { "math": "$7 \\times 4 = 28$", "note": "Largest multiple" }, { "math": "$30 - 28 = 2 \\Rightarrow 4 \\text{ r } 2$", "note": "Remainder" } ] },
      { "q": "Find $25 \\div 4$.", "a": "$6$ r $1$",
        "solution": [ { "math": "$4 \\times 6 = 24$", "note": "Largest multiple" }, { "math": "$25 - 24 = 1 \\Rightarrow 6 \\text{ r } 1$", "note": "Remainder" } ] },
      { "q": "Find $20 \\div 6$.", "a": "$3$ r $2$",
        "solution": [ { "math": "$6 \\times 3 = 18$", "note": "Largest multiple" }, { "math": "$20 - 18 = 2 \\Rightarrow 3 \\text{ r } 2$", "note": "Remainder" } ] },
      { "q": "Find $29 \\div 5$.", "a": "$5$ r $4$",
        "solution": [ { "math": "$5 \\times 5 = 25$", "note": "Largest multiple" }, { "math": "$29 - 25 = 4 \\Rightarrow 5 \\text{ r } 4$", "note": "Remainder" } ] },
      { "q": "Find $22 \\div 3$.", "a": "$7$ r $1$",
        "solution": [ { "math": "$3 \\times 7 = 21$", "note": "Largest multiple" }, { "math": "$22 - 21 = 1 \\Rightarrow 7 \\text{ r } 1$", "note": "Remainder" } ] },
      { "q": "Find $33 \\div 8$.", "a": "$4$ r $1$",
        "solution": [ { "math": "$8 \\times 4 = 32$", "note": "Largest multiple" }, { "math": "$33 - 32 = 1 \\Rightarrow 4 \\text{ r } 1$", "note": "Remainder" } ] }
    ],
    "development": [
      { "q": "Find $44 \\div 6$.", "a": "$7$ r $2$",
        "solution": [ { "math": "$6 \\times 7 = 42$", "note": "Largest multiple" }, { "math": "$44 - 42 = 2 \\Rightarrow 7 \\text{ r } 2$", "note": "Remainder" } ] },
      { "q": "Find $53 \\div 7$.", "a": "$7$ r $4$",
        "solution": [ { "math": "$7 \\times 7 = 49$", "note": "Largest multiple" }, { "math": "$53 - 49 = 4 \\Rightarrow 7 \\text{ r } 4$", "note": "Remainder" } ] },
      { "q": "Find $61 \\div 8$.", "a": "$7$ r $5$",
        "solution": [ { "math": "$8 \\times 7 = 56$", "note": "Largest multiple" }, { "math": "$61 - 56 = 5 \\Rightarrow 7 \\text{ r } 5$", "note": "Remainder" } ] },
      { "q": "Find $47 \\div 9$.", "a": "$5$ r $2$",
        "solution": [ { "math": "$9 \\times 5 = 45$", "note": "Largest multiple" }, { "math": "$47 - 45 = 2 \\Rightarrow 5 \\text{ r } 2$", "note": "Remainder" } ] },
      { "q": "Find $58 \\div 6$.", "a": "$9$ r $4$",
        "solution": [ { "math": "$6 \\times 9 = 54$", "note": "Largest multiple" }, { "math": "$58 - 54 = 4 \\Rightarrow 9 \\text{ r } 4$", "note": "Remainder" } ] },
      { "q": "Find $70 \\div 8$.", "a": "$8$ r $6$",
        "solution": [ { "math": "$8 \\times 8 = 64$", "note": "Largest multiple" }, { "math": "$70 - 64 = 6 \\Rightarrow 8 \\text{ r } 6$", "note": "Remainder" } ] },
      { "q": "Find $39 \\div 7$.", "a": "$5$ r $4$",
        "solution": [ { "math": "$7 \\times 5 = 35$", "note": "Largest multiple" }, { "math": "$39 - 35 = 4 \\Rightarrow 5 \\text{ r } 4$", "note": "Remainder" } ] },
      { "q": "Find $50 \\div 9$.", "a": "$5$ r $5$",
        "solution": [ { "math": "$9 \\times 5 = 45$", "note": "Largest multiple" }, { "math": "$50 - 45 = 5 \\Rightarrow 5 \\text{ r } 5$", "note": "Remainder" } ] },
      { "q": "Find $65 \\div 7$.", "a": "$9$ r $2$",
        "solution": [ { "math": "$7 \\times 9 = 63$", "note": "Largest multiple" }, { "math": "$65 - 63 = 2 \\Rightarrow 9 \\text{ r } 2$", "note": "Remainder" } ] },
      { "q": "Find $76 \\div 9$.", "a": "$8$ r $4$",
        "solution": [ { "math": "$9 \\times 8 = 72$", "note": "Largest multiple" }, { "math": "$76 - 72 = 4 \\Rightarrow 8 \\text{ r } 4$", "note": "Remainder" } ] }
    ],
    "mastery": [
      { "q": "Which multiplication fact helps find $50 \\div 8$? State the result.", "a": "$8 \\times 6 = 48$; $6$ r $2$",
        "solution": [ { "math": "$8 \\times 6 = 48$", "note": "Closest below $50$" }, { "math": "$50 - 48 = 2 \\Rightarrow 6 \\text{ r } 2$", "note": "Remainder" } ] },
      { "q": "Find $83 \\div 9$ and state the remainder.", "a": "$9$ r $2$",
        "solution": [ { "math": "$9 \\times 9 = 81$", "note": "Largest multiple" }, { "math": "$83 - 81 = 2 \\Rightarrow 9 \\text{ r } 2$", "note": "Remainder" } ] },
      { "q": "$49 \\div 6$ gives a remainder. What is it, and what is the quotient?", "a": "$8$ r $1$",
        "solution": [ { "math": "$6 \\times 8 = 48$", "note": "Largest multiple" }, { "math": "$49 - 48 = 1 \\Rightarrow 8 \\text{ r } 1$", "note": "Remainder" } ] },
      { "q": "A number divided by $7$ gives $6$ remainder $4$. What is the number?", "a": "$46$",
        "solution": [ { "math": "$7 \\times 6 + 4$", "note": "Divisor $\\times$ quotient $+$ remainder" }, { "math": "$= 42 + 4 = 46$", "note": "" } ] },
      { "q": "A number divided by $8$ gives $5$ remainder $3$. What is the number?", "a": "$43$",
        "solution": [ { "math": "$8 \\times 5 + 3$", "note": "Reverse the division" }, { "math": "$= 40 + 3 = 43$", "note": "" } ] },
      { "q": "Find $92 \\div 8$ and state the remainder.", "a": "$11$ r $4$",
        "solution": [ { "math": "$8 \\times 11 = 88$", "note": "Largest multiple" }, { "math": "$92 - 88 = 4 \\Rightarrow 11 \\text{ r } 4$", "note": "Remainder" } ] },
      { "q": "Find $75 \\div 6$ and state the remainder.", "a": "$12$ r $3$",
        "solution": [ { "math": "$6 \\times 12 = 72$", "note": "Largest multiple" }, { "math": "$75 - 72 = 3 \\Rightarrow 12 \\text{ r } 3$", "note": "Remainder" } ] },
      { "q": "When $n$ is divided by $9$ the remainder is $0$. Give a value of $n$ between $40$ and $50$.", "a": "$45$",
        "solution": [ { "math": "$9 \\times 5 = 45$", "note": "A multiple of $9$" }, { "math": "$45 \\div 9 = 5 \\text{ r } 0$", "note": "No remainder" } ] },
      { "q": "Find $100 \\div 7$ and state the remainder.", "a": "$14$ r $2$",
        "solution": [ { "math": "$7 \\times 14 = 98$", "note": "Largest multiple" }, { "math": "$100 - 98 = 2 \\Rightarrow 14 \\text{ r } 2$", "note": "Remainder" } ] },
      { "q": "A number divided by $6$ gives $9$ remainder $5$. Check by reversing the division.", "a": "$59$",
        "solution": [ { "math": "$6 \\times 9 + 5$", "note": "Reverse" }, { "math": "$= 54 + 5 = 59$", "note": "" } ] }
    ]
  }
}
