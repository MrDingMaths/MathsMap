{
  "skillId": "round-whole-numbers",
  "atomType": "R",
  "theory": {
    "intro": "Rounding replaces a number with the nearest 'round' number — a multiple of $10$, $100$, $1000$ and so on.",
    "facts": [
      "Look at the digit **just to the right** of the rounding place.",
      "If it is $5$ or more, round **up**; if it is $4$ or less, round **down**.",
      "Every digit after the rounding place becomes $0$."
    ],
    "steps": [
      "Underline the digit in the place you are rounding to.",
      "Check the next digit on its right.",
      "Round up or stay, then fill the rest with zeros."
    ]
  },
  "practice": {
    "foundation": [
      { "q": "Round $4\\,837$ to the nearest hundred.", "a": "$4\\,800$",
        "solution": [ { "math": "$48\\underline{3}7 \\to \\text{hundreds place is } 8$", "note": "Next digit is 3" }, { "math": "$3 < 5 \\Rightarrow 4\\,800$", "note": "Round down" } ] },
      { "q": "Round $2\\,650$ to the nearest hundred.", "a": "$2\\,700$",
        "solution": [ { "math": "$26\\underline{5}0$", "note": "Next digit is 5" }, { "math": "$5 \\geq 5 \\Rightarrow 2\\,700$", "note": "Round up" } ] },
      { "q": "Round $7\\,294$ to the nearest thousand.", "a": "$7\\,000$",
        "solution": [ { "math": "$7\\underline{2}94$", "note": "Next digit is 2" }, { "math": "$2 < 5 \\Rightarrow 7\\,000$", "note": "Round down" } ] },
      { "q": "Round $3\\,500$ to the nearest thousand.", "a": "$4\\,000$",
        "solution": [ { "math": "$3\\underline{5}00$", "note": "Next digit is 5" }, { "math": "$5 \\geq 5 \\Rightarrow 4\\,000$", "note": "Round up" } ] },
      { "q": "Round $86$ to the nearest ten.", "a": "$90$",
        "solution": [ { "math": "$8\\underline{6}$", "note": "Next digit is 6" }, { "math": "$6 \\geq 5 \\Rightarrow 90$", "note": "Round up" } ] },
      { "q": "Round $1\\,432$ to the nearest hundred.", "a": "$1\\,400$",
        "solution": [ { "math": "$14\\underline{3}2$", "note": "Next digit is 3" }, { "math": "$3 < 5 \\Rightarrow 1\\,400$", "note": "Round down" } ] },
      { "q": "Round $9\\,180$ to the nearest thousand.", "a": "$9\\,000$",
        "solution": [ { "math": "$9\\underline{1}80$", "note": "Next digit is 1" }, { "math": "$1 < 5 \\Rightarrow 9\\,000$", "note": "Round down" } ] },
      { "q": "Round $645$ to the nearest hundred.", "a": "$600$",
        "solution": [ { "math": "$6\\underline{4}5$", "note": "Next digit is 4" }, { "math": "$4 < 5 \\Rightarrow 600$", "note": "Round down" } ] },
      { "q": "Round $5\\,500$ to the nearest thousand.", "a": "$6\\,000$",
        "solution": [ { "math": "$5\\underline{5}00$", "note": "Next digit is 5" }, { "math": "$5 \\geq 5 \\Rightarrow 6\\,000$", "note": "Round up" } ] },
      { "q": "Round $238$ to the nearest ten.", "a": "$240$",
        "solution": [ { "math": "$23\\underline{8}$", "note": "Next digit is 8" }, { "math": "$8 \\geq 5 \\Rightarrow 240$", "note": "Round up" } ] }
    ],
    "development": [
      { "q": "Round $46\\,820$ to the nearest thousand.", "a": "$47\\,000$",
        "solution": [ { "math": "$46\\underline{8}20$", "note": "Next digit is 8" }, { "math": "$8 \\geq 5 \\Rightarrow 47\\,000$", "note": "Round up" } ] },
      { "q": "Round $352\\,400$ to the nearest ten-thousand.", "a": "$350\\,000$",
        "solution": [ { "math": "$35\\underline{2}\\,400$", "note": "Next digit is 2" }, { "math": "$2 < 5 \\Rightarrow 350\\,000$", "note": "Round down" } ] },
      { "q": "Round $4\\,628\\,000$ to the nearest million.", "a": "$5\\,000\\,000$",
        "solution": [ { "math": "$4\\underline{6}28\\,000$", "note": "Next digit is 6" }, { "math": "$6 \\geq 5 \\Rightarrow 5\\,000\\,000$", "note": "Round up" } ] },
      { "q": "Round $3\\,140\\,000$ to the nearest million.", "a": "$3\\,000\\,000$",
        "solution": [ { "math": "$3\\underline{1}40\\,000$", "note": "Next digit is 1" }, { "math": "$1 < 5 \\Rightarrow 3\\,000\\,000$", "note": "Round down" } ] },
      { "q": "Round $87\\,650$ to the nearest hundred.", "a": "$87\\,700$",
        "solution": [ { "math": "$876\\underline{5}0$", "note": "Next digit is 5" }, { "math": "$5 \\geq 5 \\Rightarrow 87\\,700$", "note": "Round up" } ] },
      { "q": "Round $9\\,962$ to the nearest hundred.", "a": "$10\\,000$",
        "solution": [ { "math": "$99\\underline{6}2$", "note": "Next digit is 6, round up" }, { "math": "$9\\,900 + 100 = 10\\,000$", "note": "The carry rolls over" } ] },
      { "q": "Round $124\\,500$ to the nearest thousand.", "a": "$125\\,000$",
        "solution": [ { "math": "$124\\underline{5}00$", "note": "Next digit is 5" }, { "math": "$5 \\geq 5 \\Rightarrow 125\\,000$", "note": "Round up" } ] },
      { "q": "Round $7\\,499\\,000$ to the nearest million.", "a": "$7\\,000\\,000$",
        "solution": [ { "math": "$7\\underline{4}99\\,000$", "note": "Next digit is 4" }, { "math": "$4 < 5 \\Rightarrow 7\\,000\\,000$", "note": "Round down" } ] },
      { "q": "Round $618\\,200$ to the nearest hundred-thousand.", "a": "$600\\,000$",
        "solution": [ { "math": "$6\\underline{1}8\\,200$", "note": "Next digit is 1" }, { "math": "$1 < 5 \\Rightarrow 600\\,000$", "note": "Round down" } ] },
      { "q": "Round $2\\,950\\,000$ to the nearest hundred-thousand.", "a": "$3\\,000\\,000$",
        "solution": [ { "math": "$29\\underline{5}0\\,000$", "note": "Next digit is 5, round up" }, { "math": "$2\\,900\\,000 + 100\\,000 = 3\\,000\\,000$", "note": "Carry rolls over" } ] }
    ],
    "mastery": [
      { "q": "A crowd of $48\\,612$ is reported 'to the nearest thousand'. What figure is reported?", "a": "$49\\,000$",
        "solution": [ { "math": "$48\\underline{6}12$", "note": "Next digit is 6" }, { "math": "$6 \\geq 5 \\Rightarrow 49\\,000$", "note": "Round up" } ] },
      { "q": "Round $999\\,500$ to the nearest thousand.", "a": "$1\\,000\\,000$",
        "solution": [ { "math": "$999\\underline{5}00 \\to \\text{round up}$", "note": "Next digit is 5" }, { "math": "$999\\,000 + 1\\,000 = 1\\,000\\,000$", "note": "Carry cascades to a million" } ] },
      { "q": "A number rounds to $5\\,000$ to the nearest thousand. What is the smallest whole number it could be?", "a": "$4\\,500$",
        "solution": [ { "math": "$\\text{rounds up from } 4\\,500$", "note": "Halfway rounds up" }, { "math": "$4\\,500 \\to 5\\,000$", "note": "Smallest that rounds up" } ] },
      { "q": "A number rounds to $5\\,000$ to the nearest thousand. What is the largest whole number it could be?", "a": "$5\\,499$",
        "solution": [ { "math": "$5\\,499 \\to 5\\,000$", "note": "Still rounds down" }, { "math": "$5\\,500 \\to 6\\,000$", "note": "So the largest is $5\\,499$" } ] },
      { "q": "Round $7\\,648$ to the nearest hundred, then to the nearest thousand.", "a": "$7\\,600$ and $8\\,000$",
        "solution": [ { "math": "$76\\underline{4}8 \\Rightarrow 7\\,600$", "note": "Nearest hundred" }, { "math": "$7\\underline{6}48 \\Rightarrow 8\\,000$", "note": "Nearest thousand" } ] },
      { "q": "Two towns have $12\\,400$ and $12\\,600$ people. Rounded to the nearest thousand, are their populations equal?", "a": "no — $12\\,000$ and $13\\,000$",
        "solution": [ { "math": "$12\\underline{4}00 \\Rightarrow 12\\,000$", "note": "Rounds down" }, { "math": "$12\\underline{6}00 \\Rightarrow 13\\,000$", "note": "Rounds up" } ] },
      { "q": "Estimate $4\\,180 + 2\\,790$ by first rounding each number to the nearest thousand.", "a": "$7\\,000$",
        "solution": [ { "math": "$4\\,180 \\to 4\\,000,\\ 2\\,790 \\to 3\\,000$", "note": "Round each" }, { "math": "$4\\,000 + 3\\,000 = 7\\,000$", "note": "Add the rounded values" } ] },
      { "q": "A salary of $\\$86\\,500$ is rounded to the nearest ten-thousand for a report. What value is used?", "a": "$\\$90\\,000$",
        "solution": [ { "math": "$8\\underline{6}\\,500$", "note": "Next digit is 6" }, { "math": "$6 \\geq 5 \\Rightarrow 90\\,000$", "note": "Round up" } ] },
      { "q": "Round $3\\,499\\,500$ to the nearest hundred-thousand.", "a": "$3\\,500\\,000$",
        "solution": [ { "math": "$34\\underline{9}9\\,500$", "note": "Next digit is 9" }, { "math": "$9 \\geq 5 \\Rightarrow 3\\,500\\,000$", "note": "Round up" } ] },
      { "q": "A distance is given as $384\\,400$ km. Rounded to the nearest hundred-thousand, how far is it?", "a": "$400\\,000$ km",
        "solution": [ { "math": "$3\\underline{8}4\\,400$", "note": "Next digit is 8" }, { "math": "$8 \\geq 5 \\Rightarrow 400\\,000$", "note": "Round up" } ] }
    ]
  }
}
