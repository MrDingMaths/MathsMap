{
  "skillId": "order-decimals-3dp",
  "atomType": "R",
  "theory": {
    "intro": "To compare decimals, line them up by place value and compare from the left, starting at the tenths.",
    "facts": [
      "Give the decimals the **same number of places** by adding trailing zeros: $0.17 = 0.170$.",
      "Trailing zeros after the last non-zero digit **do not change** the value.",
      "Compare tenths first, then hundredths, then thousandths."
    ],
    "steps": [
      "Write each decimal with the same number of places.",
      "Compare digits from the left; the first column that differs decides it.",
      "List in the order asked: ascending (smallest first) or descending."
    ]
  },
  "practice": {
    "foundation": [
      { "q": "Which is larger: $0.3$ or $0.7$?", "a": "$0.7$",
        "tikz": "\\begin{tikzpicture}[x=10cm,y=0.7cm]\n\\draw[thick,-{Stealth[length=2mm]}] (-0.05,0) -- (1.08,0);\n\\foreach \\v in {0,1,...,10} \\draw (\\v/10,0.1) -- (\\v/10,-0.1);\n\\foreach \\v in {0,5,10} \\draw (\\v/10,0.18) -- (\\v/10,-0.18);\n\\node[below=2pt] at (0,0) {$0$}; \\node[below=2pt] at (0.5,0) {$0.5$}; \\node[below=2pt] at (1,0) {$1$};\n\\fill (0.3,0) circle (2.4pt); \\node[above=4pt] at (0.3,0) {$0.3$};\n\\fill (0.7,0) circle (2.4pt); \\node[above=4pt] at (0.7,0) {$0.7$};\n\\end{tikzpicture}",
        "solution": [ { "math": "$0.3 \\quad 0.7$", "note": "Compare tenths" }, { "math": "$0.7 > 0.3$", "note": "Further right is larger" } ] },
      { "q": "Insert $<$ or $>$: $0.45 \\ \\square\\ 0.54$.", "a": "$0.45 < 0.54$",
        "solution": [ { "math": "$0.\\underline{4}5 \\text{ vs } 0.\\underline{5}4$", "note": "Compare tenths" }, { "math": "$4 < 5 \\Rightarrow 0.45 < 0.54$", "note": "Tenths decide" } ] },
      { "q": "Is $0.17 = 0.170$?", "a": "yes",
        "solution": [ { "math": "$0.170 = 0.17$", "note": "Trailing zero added" }, { "math": "$\\text{same value}$", "note": "Zero changes nothing" } ] },
      { "q": "Which is smaller: $0.6$ or $0.2$?", "a": "$0.2$",
        "tikz": "\\begin{tikzpicture}[x=10cm,y=0.7cm]\n\\draw[thick,-{Stealth[length=2mm]}] (-0.05,0) -- (1.08,0);\n\\foreach \\v in {0,1,...,10} \\draw (\\v/10,0.1) -- (\\v/10,-0.1);\n\\foreach \\v in {0,5,10} \\draw (\\v/10,0.18) -- (\\v/10,-0.18);\n\\node[below=2pt] at (0,0) {$0$}; \\node[below=2pt] at (0.5,0) {$0.5$}; \\node[below=2pt] at (1,0) {$1$};\n\\fill (0.2,0) circle (2.4pt); \\node[above=4pt] at (0.2,0) {$0.2$};\n\\fill (0.6,0) circle (2.4pt); \\node[above=4pt] at (0.6,0) {$0.6$};\n\\end{tikzpicture}",
        "solution": [ { "math": "$0.2 \\quad 0.6$", "note": "Compare tenths" }, { "math": "$0.2 < 0.6$", "note": "Further left is smaller" } ] },
      { "q": "Order from smallest to largest: $0.5, 0.05, 0.55$.", "a": "$0.05, 0.5, 0.55$",
        "solution": [ { "math": "$0.50,\\ 0.05,\\ 0.55$", "note": "Same number of places" }, { "math": "$0.05 < 0.50 < 0.55$", "note": "Compare from the left" } ] },
      { "q": "Insert $<$ or $>$: $0.8 \\ \\square\\ 0.79$.", "a": "$0.8 > 0.79$",
        "solution": [ { "math": "$0.80 \\text{ vs } 0.79$", "note": "Add a trailing zero" }, { "math": "$80 > 79 \\Rightarrow 0.8 > 0.79$", "note": "Compare hundredths" } ] },
      { "q": "Order from largest to smallest: $0.4, 0.04, 0.44$.", "a": "$0.44, 0.4, 0.04$",
        "solution": [ { "math": "$0.40,\\ 0.04,\\ 0.44$", "note": "Same number of places" }, { "math": "$0.44 > 0.40 > 0.04$", "note": "Descending" } ] },
      { "q": "Which is larger: $0.25$ or $0.3$?", "a": "$0.3$",
        "solution": [ { "math": "$0.25 \\text{ vs } 0.30$", "note": "Add a trailing zero" }, { "math": "$2 < 3 \\Rightarrow 0.3 > 0.25$", "note": "Tenths decide" } ] },
      { "q": "Is $0.5$ equal to, larger than, or smaller than $0.50$?", "a": "equal",
        "solution": [ { "math": "$0.50 = 0.5$", "note": "Trailing zero" }, { "math": "$\\text{equal}$", "note": "Same value" } ] },
      { "q": "Order from smallest to largest: $0.9, 0.19, 0.91$.", "a": "$0.19, 0.9, 0.91$",
        "solution": [ { "math": "$0.90,\\ 0.19,\\ 0.91$", "note": "Same number of places" }, { "math": "$0.19 < 0.90 < 0.91$", "note": "Compare from the left" } ] }
    ],
    "development": [
      { "q": "Order from smallest to largest: $0.305, 0.35, 0.3$.", "a": "$0.3, 0.305, 0.35$",
        "solution": [ { "math": "$0.300,\\ 0.305,\\ 0.350$", "note": "Three places each" }, { "math": "$300 < 305 < 350$", "note": "Compare thousandths" } ] },
      { "q": "Insert $<$ or $>$: $0.246 \\ \\square\\ 0.264$.", "a": "$0.246 < 0.264$",
        "solution": [ { "math": "$0.2\\underline{4}6 \\text{ vs } 0.2\\underline{6}4$", "note": "Tenths equal; compare hundredths" }, { "math": "$4 < 6 \\Rightarrow 0.246 < 0.264$", "note": "Hundredths decide" } ] },
      { "q": "Order from largest to smallest: $0.7, 0.708, 0.78$.", "a": "$0.78, 0.708, 0.7$",
        "solution": [ { "math": "$0.700,\\ 0.708,\\ 0.780$", "note": "Three places each" }, { "math": "$780 > 708 > 700$", "note": "Descending" } ] },
      { "q": "Which is smaller: $0.109$ or $0.11$?", "a": "$0.109$",
        "solution": [ { "math": "$0.109 \\text{ vs } 0.110$", "note": "Add a trailing zero" }, { "math": "$109 < 110 \\Rightarrow 0.109 < 0.11$", "note": "Compare thousandths" } ] },
      { "q": "Order from smallest to largest: $1.2, 1.02, 1.22, 1.022$.", "a": "$1.02, 1.022, 1.2, 1.22$",
        "solution": [ { "math": "$1.200,\\ 1.020,\\ 1.220,\\ 1.022$", "note": "Three places each" }, { "math": "$020 < 022 < 200 < 220$", "note": "Compare decimal parts" } ] },
      { "q": "Insert $<$ or $>$: $0.5 \\ \\square\\ 0.499$.", "a": "$0.5 > 0.499$",
        "solution": [ { "math": "$0.500 \\text{ vs } 0.499$", "note": "Three places each" }, { "math": "$500 > 499 \\Rightarrow 0.5 > 0.499$", "note": "Compare" } ] },
      { "q": "Order from largest to smallest: $3.06, 3.6, 3.066$.", "a": "$3.6, 3.066, 3.06$",
        "solution": [ { "math": "$3.600,\\ 3.060,\\ 3.066$", "note": "Three places each" }, { "math": "$600 > 066 > 060$", "note": "Descending" } ] },
      { "q": "Which is larger: $0.08$ or $0.075$?", "a": "$0.08$",
        "solution": [ { "math": "$0.080 \\text{ vs } 0.075$", "note": "Three places each" }, { "math": "$80 > 75 \\Rightarrow 0.08 > 0.075$", "note": "Compare hundredths" } ] },
      { "q": "Order from smallest to largest: $0.404, 0.044, 0.44$.", "a": "$0.044, 0.404, 0.44$",
        "solution": [ { "math": "$0.404,\\ 0.044,\\ 0.440$", "note": "Three places each" }, { "math": "$044 < 404 < 440$", "note": "Compare decimal parts" } ] },
      { "q": "True or false: $0.250 > 0.25$.", "a": "false (they are equal)",
        "solution": [ { "math": "$0.250 = 0.25$", "note": "Trailing zero" }, { "math": "$\\text{equal, not greater}$", "note": "So false" } ] }
    ],
    "mastery": [
      { "q": "Four runners record $9.81$, $9.808$, $9.9$ and $9.18$ seconds. Who is fastest (smallest time)?", "a": "the runner with $9.18$ s",
        "solution": [ { "math": "$9.810,\\ 9.808,\\ 9.900,\\ 9.180$", "note": "Three places each" }, { "math": "$9.180 < 9.808 < 9.810 < 9.900$", "note": "Smallest time wins" } ] },
      { "q": "Order these lengths (m) from longest to shortest: $1.5, 1.05, 1.505, 1.55$.", "a": "$1.55, 1.505, 1.5, 1.05$",
        "solution": [ { "math": "$1.500,\\ 1.050,\\ 1.505,\\ 1.550$", "note": "Three places each" }, { "math": "$550 > 505 > 500 > 050$", "note": "Descending" } ] },
      { "q": "Write a decimal that lies between $0.3$ and $0.31$.", "a": "$0.305$ (any value such as $0.301$–$0.309$)",
        "solution": [ { "math": "$0.300 < \\square < 0.310$", "note": "Use thousandths" }, { "math": "$0.305$", "note": "Sits between them" } ] },
      { "q": "A high-jump bar is set at $1.85$ m, $1.805$ m and $1.85$0 m on three days. Were any two settings equal?", "a": "yes — $1.85$ and $1.850$",
        "solution": [ { "math": "$1.850 = 1.85$", "note": "Trailing zero" }, { "math": "$1.805 \\neq 1.85$", "note": "The middle one differs" } ] },
      { "q": "Insert into $0.62, 0.6, 0.626$: smallest $<\\ \\square\\ <$ largest.", "a": "$0.6 < 0.62 < 0.626$",
        "solution": [ { "math": "$0.600,\\ 0.620,\\ 0.626$", "note": "Three places each" }, { "math": "$600 < 620 < 626$", "note": "Order them" } ] },
      { "q": "Which is closer to $0.5$: $0.45$ or $0.55$?", "a": "equally close (both $0.05$ away)",
        "solution": [ { "math": "$0.50 - 0.45 = 0.05$", "note": "Distance below" }, { "math": "$0.55 - 0.50 = 0.05$", "note": "Distance above — same" } ] },
      { "q": "Order from smallest to largest: $0.1, 0.099, 0.11, 0.101$.", "a": "$0.099, 0.1, 0.101, 0.11$",
        "solution": [ { "math": "$0.100,\\ 0.099,\\ 0.110,\\ 0.101$", "note": "Three places each" }, { "math": "$099 < 100 < 101 < 110$", "note": "Compare decimal parts" } ] },
      { "q": "A digit is missing: $0.7\\square < 0.74$. What digits make this true?", "a": "$0, 1, 2, 3$",
        "solution": [ { "math": "$0.7\\square < 0.74$", "note": "Compare hundredths" }, { "math": "$\\square < 4$", "note": "So $0, 1, 2$ or $3$" } ] },
      { "q": "Three masses are $2.5$ kg, $2.05$ kg and $2.055$ kg. List from heaviest to lightest.", "a": "$2.5, 2.055, 2.05$",
        "solution": [ { "math": "$2.500,\\ 2.050,\\ 2.055$", "note": "Three places each" }, { "math": "$500 > 055 > 050$", "note": "Descending" } ] },
      { "q": "Place $0.6$, $0.06$ and $0.66$ in order, smallest first, then state which is ten times another.", "a": "$0.06, 0.6, 0.66$; $0.6 = 10 \\times 0.06$",
        "solution": [ { "math": "$0.06 < 0.60 < 0.66$", "note": "Order them" }, { "math": "$0.06 \\times 10 = 0.6$", "note": "Ten times larger" } ] }
    ]
  }
}
