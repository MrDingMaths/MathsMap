{
  "skillId": "check-reasonableness-estimation",
  "atomType": "R",
  "theory": {
    "intro": "After a calculation, use estimation and place value to decide whether the answer is reasonable — close to what you expected.",
    "facts": [
      "Estimate the answer first; a result far from the estimate is probably **wrong**.",
      "Check the **size** (number of digits) using place value: $\\text{thousands} + \\text{thousands}$ should be in the thousands.",
      "Check the **last digit**: ones add to a predictable ones digit.",
      "An answer can be reasonable in size but still need an exact check."
    ],
    "steps": [
      "Round the numbers and estimate the answer.",
      "Compare the given answer with your estimate.",
      "Decide reasonable or not, and explain why."
    ]
  },
  "practice": {
    "foundation": [
      { "q": "Is $48 + 39 = 87$ reasonable? Estimate to check.", "a": "Yes",
        "solution": [ { "math": "$50 + 40 = 90$", "note": "Estimate" }, { "math": "$87 \\approx 90$", "note": "Reasonable" } ] },
      { "q": "Is $63 - 28 = 91$ reasonable? Estimate to check.", "a": "No (should be $\\approx 30$)",
        "solution": [ { "math": "$60 - 30 = 30$", "note": "Estimate" }, { "math": "$91 \\ne 30$", "note": "Not reasonable" } ] },
      { "q": "Is $412 + 295 = 707$ reasonable?", "a": "Yes",
        "solution": [ { "math": "$400 + 300 = 700$", "note": "Estimate" }, { "math": "$707 \\approx 700$", "note": "Reasonable" } ] },
      { "q": "Is $850 - 240 = 610$ reasonable?", "a": "Yes",
        "solution": [ { "math": "$900 - 200 = 700$", "note": "Estimate" }, { "math": "$610 \\approx 700$", "note": "Reasonable" } ] },
      { "q": "Is $76 + 58 = 34$ reasonable?", "a": "No (a sum cannot be smaller than its parts)",
        "solution": [ { "math": "$80 + 60 = 140$", "note": "Estimate" }, { "math": "$34 \\ne 140$", "note": "Not reasonable" } ] },
      { "q": "Using the ones digit, could $37 + 46$ end in $3$?", "a": "Yes",
        "solution": [ { "math": "$7 + 6 = 13$", "note": "Ones digit is 3" }, { "math": "$37 + 46 = 83$", "note": "Ends in 3" } ] },
      { "q": "Is $304 - 188 = 116$ reasonable?", "a": "Yes",
        "solution": [ { "math": "$300 - 200 = 100$", "note": "Estimate" }, { "math": "$116 \\approx 100$", "note": "Reasonable" } ] },
      { "q": "Is $19 + 22 = 410$ reasonable?", "a": "No (too many digits)",
        "solution": [ { "math": "$20 + 20 = 40$", "note": "Estimate" }, { "math": "$410$ is in the hundreds", "note": "Place value is wrong" } ] },
      { "q": "Is $560 + 380 = 940$ reasonable?", "a": "Yes",
        "solution": [ { "math": "$600 + 400 = 1\\,000$", "note": "Estimate" }, { "math": "$940 \\approx 1\\,000$", "note": "Reasonable" } ] },
      { "q": "Using the ones digit, could $54 - 27$ end in $7$?", "a": "Yes",
        "solution": [ { "math": "$54 - 27 = 27$", "note": "Compute" }, { "math": "ends in $7$", "note": "Consistent" } ] }
    ],
    "development": [
      { "q": "Is $4\\,820 + 3\\,150 = 7\\,970$ reasonable?", "a": "Yes",
        "solution": [ { "math": "$5\\,000 + 3\\,000 = 8\\,000$", "note": "Estimate" }, { "math": "$7\\,970 \\approx 8\\,000$", "note": "Reasonable" } ] },
      { "q": "A student got $9\\,150 - 2\\,780 = 11\\,930$. Is this reasonable?", "a": "No (subtraction cannot increase)",
        "solution": [ { "math": "$9\\,000 - 3\\,000 = 6\\,000$", "note": "Estimate" }, { "math": "$11\\,930 \\ne 6\\,000$", "note": "They added instead" } ] },
      { "q": "Is $\\$19.95 + \\$8.50 = \\$28.45$ reasonable?", "a": "Yes",
        "solution": [ { "math": "$20 + 9 = 29$", "note": "Estimate" }, { "math": "$28.45 \\approx 29$", "note": "Reasonable" } ] },
      { "q": "Is $12\\,400 + 7\\,650 = 20\\,050$ reasonable?", "a": "Yes",
        "solution": [ { "math": "$12\\,000 + 8\\,000 = 20\\,000$", "note": "Estimate" }, { "math": "$20\\,050 \\approx 20\\,000$", "note": "Reasonable" } ] },
      { "q": "A calculator shows $6\\,038 - 1\\,962 = 4\\,076$. Check by estimation.", "a": "Reasonable",
        "solution": [ { "math": "$6\\,000 - 2\\,000 = 4\\,000$", "note": "Estimate" }, { "math": "$4\\,076 \\approx 4\\,000$", "note": "Reasonable" } ] },
      { "q": "Is $317 + 482 + 195 = 1\\,994$ reasonable?", "a": "No (should be $\\approx 1\\,000$)",
        "solution": [ { "math": "$300 + 500 + 200 = 1\\,000$", "note": "Estimate" }, { "math": "$1\\,994 \\ne 1\\,000$", "note": "Not reasonable" } ] },
      { "q": "Using place value, how many digits should $48\\,000 + 36\\,000$ have?", "a": "$5$ digits (in the ten-thousands)",
        "solution": [ { "math": "$48\\,000 + 36\\,000 = 84\\,000$", "note": "Compute" }, { "math": "$84\\,000$ has 5 digits", "note": "As expected" } ] },
      { "q": "Is $\\$148 + \\$96 + \\$53 = \\$297$ reasonable?", "a": "Yes",
        "solution": [ { "math": "$150 + 100 + 50 = 300$", "note": "Estimate" }, { "math": "$297 \\approx 300$", "note": "Reasonable" } ] },
      { "q": "A till total is given as $\\$1\\,294$ from $\\$1\\,200 + \\$85 + \\$9$. Check by estimation.", "a": "Reasonable",
        "solution": [ { "math": "$1\\,200 + 90 + 10 = 1\\,300$", "note": "Estimate" }, { "math": "$1\\,294 \\approx 1\\,300$", "note": "Reasonable" } ] },
      { "q": "Is $7\\,499 + 2\\,505 = 4\\,994$ reasonable?", "a": "No (should be $\\approx 10\\,000$)",
        "solution": [ { "math": "$7\\,000 + 3\\,000 = 10\\,000$", "note": "Estimate" }, { "math": "$4\\,994 \\ne 10\\,000$", "note": "They subtracted instead" } ] }
    ],
    "mastery": [
      { "q": "A receipt lists items $\\$12.80$, $\\$7.95$, $\\$4.20$ with total $\\$24.95$. Is the total reasonable?", "a": "Yes",
        "solution": [ { "math": "$13 + 8 + 4 = 25$", "note": "Estimate" }, { "math": "$24.95 \\approx 25$", "note": "Reasonable" } ] },
      { "q": "A shop reports profit $\\$23\\,600 + \\$48\\,400 = \\$71\\,000$. Use estimation and place value to check.", "a": "Reasonable",
        "solution": [ { "math": "$20\\,000 + 50\\,000 = 70\\,000$", "note": "Estimate" }, { "math": "$71\\,000 \\approx 70\\,000$", "note": "Reasonable" } ] },
      { "q": "A student writes $1\\,840 + 1\\,840 = 368$ for a round trip. What error is likely?", "a": "Misplaced digits / missed a place; should be $\\approx 4\\,000$",
        "solution": [ { "math": "$2\\,000 + 2\\,000 = 4\\,000$", "note": "Estimate" }, { "math": "$368 \\ne 4\\,000$", "note": "Far too small" } ] },
      { "q": "Expenses $\\$2\\,180 + \\$1\\,470 + \\$890$ are totalled as $\\$4\\,540$. Is this reasonable?", "a": "Yes",
        "solution": [ { "math": "$2\\,000 + 1\\,500 + 900 = 4\\,400$", "note": "Estimate" }, { "math": "$4\\,540 \\approx 4\\,400$", "note": "Reasonable" } ] },
      { "q": "A bill of $\\$50$ less a cost of $\\$31.40$ is said to give change $\\$28.60$. Check it.", "a": "Not reasonable (should be $\\approx \\$19$)",
        "solution": [ { "math": "$50 - 31 = 19$", "note": "Estimate" }, { "math": "$28.60 \\ne 19$", "note": "Likely a subtraction error" } ] },
      { "q": "Using the ones digit only, is $4\\,567 + 2\\,338 = 6\\,904$ possible?", "a": "No (ones should be $5$)",
        "solution": [ { "math": "$7 + 8 = 15$", "note": "Ones digit should be 5" }, { "math": "answer ends in $4$", "note": "Impossible" } ] },
      { "q": "A car costs $\\$28\\,450$, trade-in $\\$11\\,800$, balance quoted $\\$16\\,650$. Reasonable?", "a": "Yes",
        "solution": [ { "math": "$28\\,000 - 12\\,000 = 16\\,000$", "note": "Estimate" }, { "math": "$16\\,650 \\approx 16\\,000$", "note": "Reasonable" } ] },
      { "q": "A reservoir of $58\\,000$ L loses $23\\,450$ L; remaining is given as $81\\,450$ L. What went wrong?", "a": "Added instead of subtracting; should be $\\approx 35\\,000$ L",
        "solution": [ { "math": "$58\\,000 - 23\\,000 = 35\\,000$", "note": "Estimate" }, { "math": "$81\\,450 > 58\\,000$", "note": "Impossible after a loss" } ] },
      { "q": "Three deliveries $1\\,840 + 76 + 2\\,309$ kg are totalled $4\\,225$ kg. Is that reasonable and under $5\\,000$ kg?", "a": "Reasonable; yes, under",
        "solution": [ { "math": "$2\\,000 + 100 + 2\\,000 = 4\\,100$", "note": "Estimate" }, { "math": "$4\\,225 \\approx 4\\,100 < 5\\,000$", "note": "Reasonable and under" } ] },
      { "q": "A budget answer of $\\$8\\,000$ comes from $\\$4\\,950 + \\$2\\,030 + \\$1\\,080$. Without exact addition, argue it is reasonable.", "a": "Reasonable",
        "solution": [ { "math": "$5\\,000 + 2\\,000 + 1\\,000 = 8\\,000$", "note": "Estimate matches" }, { "math": "$\\approx 8\\,000$", "note": "Reasonable" } ] }
    ]
  }
}
