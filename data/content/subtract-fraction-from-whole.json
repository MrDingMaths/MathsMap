{
  "skillId": "subtract-fraction-from-whole",
  "atomType": "R",
  "theory": {
    "intro": "To subtract a fraction from a whole number, rename one whole as a fraction with the same denominator, then subtract.",
    "facts": [
      "One whole equals $\\tfrac{n}{n}$, e.g. $1 = \\tfrac{3}{3} = \\tfrac{5}{5}$.",
      "$1 - \\tfrac{a}{b} = \\tfrac{b}{b} - \\tfrac{a}{b} = \\tfrac{b-a}{b}$ (the **complement**).",
      "For a whole bigger than $1$, keep the extra wholes and only rename one of them."
    ],
    "steps": [
      "Rename one whole as $\\tfrac{b}{b}$ to match the fraction's denominator.",
      "Subtract the numerators.",
      "Combine with any remaining wholes and simplify."
    ]
  },
  "practice": {
    "foundation": [
      { "q": "Work out $1 - \\tfrac{1}{3}$.", "a": "$\\tfrac{2}{3}$",
        "tikz": "\\begin{tikzpicture}[x=0.9cm,y=0.7cm]\n\\draw (0,0) rectangle (3,1);\n\\foreach \\i in {1,2} \\draw (\\i,0) -- (\\i,1);\n\\fill[gray!40] (0,0) rectangle (2,1);\n\\draw[pattern=north east lines] (2,0) rectangle (3,1);\n\\end{tikzpicture}",
        "solution": [ { "math": "$1 = \\tfrac{3}{3}$", "note": "Rename the whole" }, { "math": "$\\tfrac{3}{3} - \\tfrac{1}{3} = \\tfrac{2}{3}$", "note": "" } ] },
      { "q": "Work out $1 - \\tfrac{2}{5}$.", "a": "$\\tfrac{3}{5}$",
        "tikz": "\\begin{tikzpicture}[x=0.7cm,y=0.7cm]\n\\draw (0,0) rectangle (5,1);\n\\foreach \\i in {1,2,3,4} \\draw (\\i,0) -- (\\i,1);\n\\fill[gray!40] (0,0) rectangle (3,1);\n\\draw[pattern=north east lines] (3,0) rectangle (5,1);\n\\end{tikzpicture}",
        "solution": [ { "math": "$1 = \\tfrac{5}{5}$", "note": "Rename the whole" }, { "math": "$\\tfrac{5}{5} - \\tfrac{2}{5} = \\tfrac{3}{5}$", "note": "" } ] },
      { "q": "Work out $1 - \\tfrac{3}{4}$.", "a": "$\\tfrac{1}{4}$",
        "solution": [ { "math": "$1 = \\tfrac{4}{4}$", "note": "Rename the whole" }, { "math": "$\\tfrac{4}{4} - \\tfrac{3}{4} = \\tfrac{1}{4}$", "note": "" } ] },
      { "q": "Work out $1 - \\tfrac{4}{7}$.", "a": "$\\tfrac{3}{7}$",
        "solution": [ { "math": "$1 = \\tfrac{7}{7}$", "note": "Rename the whole" }, { "math": "$\\tfrac{7}{7} - \\tfrac{4}{7} = \\tfrac{3}{7}$", "note": "" } ] },
      { "q": "Work out $1 - \\tfrac{1}{2}$.", "a": "$\\tfrac{1}{2}$",
        "solution": [ { "math": "$1 = \\tfrac{2}{2}$", "note": "Rename the whole" }, { "math": "$\\tfrac{2}{2} - \\tfrac{1}{2} = \\tfrac{1}{2}$", "note": "" } ] },
      { "q": "Work out $1 - \\tfrac{7}{10}$.", "a": "$\\tfrac{3}{10}$",
        "solution": [ { "math": "$1 = \\tfrac{10}{10}$", "note": "Rename the whole" }, { "math": "$\\tfrac{10}{10} - \\tfrac{7}{10} = \\tfrac{3}{10}$", "note": "" } ] },
      { "q": "Work out $1 - \\tfrac{5}{8}$.", "a": "$\\tfrac{3}{8}$",
        "tikz": "\\begin{tikzpicture}[x=0.6cm,y=0.7cm]\n\\draw (0,0) rectangle (8,1);\n\\foreach \\i in {1,...,7} \\draw (\\i,0) -- (\\i,1);\n\\fill[gray!40] (0,0) rectangle (3,1);\n\\draw[pattern=north east lines] (3,0) rectangle (8,1);\n\\end{tikzpicture}",
        "solution": [ { "math": "$1 = \\tfrac{8}{8}$", "note": "Rename the whole" }, { "math": "$\\tfrac{8}{8} - \\tfrac{5}{8} = \\tfrac{3}{8}$", "note": "" } ] },
      { "q": "Work out $1 - \\tfrac{2}{3}$.", "a": "$\\tfrac{1}{3}$",
        "solution": [ { "math": "$1 = \\tfrac{3}{3}$", "note": "Rename the whole" }, { "math": "$\\tfrac{3}{3} - \\tfrac{2}{3} = \\tfrac{1}{3}$", "note": "" } ] },
      { "q": "Work out $1 - \\tfrac{3}{5}$.", "a": "$\\tfrac{2}{5}$",
        "solution": [ { "math": "$1 = \\tfrac{5}{5}$", "note": "Rename the whole" }, { "math": "$\\tfrac{5}{5} - \\tfrac{3}{5} = \\tfrac{2}{5}$", "note": "" } ] },
      { "q": "Work out $1 - \\tfrac{1}{4}$.", "a": "$\\tfrac{3}{4}$",
        "solution": [ { "math": "$1 = \\tfrac{4}{4}$", "note": "Rename the whole" }, { "math": "$\\tfrac{4}{4} - \\tfrac{1}{4} = \\tfrac{3}{4}$", "note": "" } ] }
    ],
    "development": [
      { "q": "Work out $2 - \\tfrac{1}{3}$.", "a": "$1\\tfrac{2}{3}$",
        "solution": [ { "math": "$2 = 1 + \\tfrac{3}{3}$", "note": "Rename one whole" }, { "math": "$1 + \\tfrac{3}{3} - \\tfrac{1}{3} = 1\\tfrac{2}{3}$", "note": "" } ] },
      { "q": "Work out $3 - \\tfrac{2}{5}$.", "a": "$2\\tfrac{3}{5}$",
        "solution": [ { "math": "$3 = 2 + \\tfrac{5}{5}$", "note": "Rename one whole" }, { "math": "$2 + \\tfrac{5}{5} - \\tfrac{2}{5} = 2\\tfrac{3}{5}$", "note": "" } ] },
      { "q": "Work out $1 - \\tfrac{6}{8}$ and give the answer in simplest form.", "a": "$\\tfrac{1}{4}$",
        "solution": [ { "math": "$\\tfrac{8}{8} - \\tfrac{6}{8} = \\tfrac{2}{8}$", "note": "Subtract" }, { "math": "$= \\tfrac{1}{4}$", "note": "Simplify" } ] },
      { "q": "Work out $4 - \\tfrac{3}{4}$.", "a": "$3\\tfrac{1}{4}$",
        "solution": [ { "math": "$4 = 3 + \\tfrac{4}{4}$", "note": "Rename one whole" }, { "math": "$3 + \\tfrac{4}{4} - \\tfrac{3}{4} = 3\\tfrac{1}{4}$", "note": "" } ] },
      { "q": "Work out $2 - \\tfrac{7}{10}$.", "a": "$1\\tfrac{3}{10}$",
        "solution": [ { "math": "$2 = 1 + \\tfrac{10}{10}$", "note": "Rename one whole" }, { "math": "$1 + \\tfrac{10}{10} - \\tfrac{7}{10} = 1\\tfrac{3}{10}$", "note": "" } ] },
      { "q": "What must be added to $\\tfrac{3}{8}$ to make $1$?", "a": "$\\tfrac{5}{8}$",
        "solution": [ { "math": "$1 - \\tfrac{3}{8} = \\tfrac{8}{8} - \\tfrac{3}{8}$", "note": "Complement" }, { "math": "$= \\tfrac{5}{8}$", "note": "" } ] },
      { "q": "Work out $1 - \\tfrac{4}{6}$ in simplest form.", "a": "$\\tfrac{1}{3}$",
        "solution": [ { "math": "$\\tfrac{6}{6} - \\tfrac{4}{6} = \\tfrac{2}{6}$", "note": "Subtract" }, { "math": "$= \\tfrac{1}{3}$", "note": "Simplify" } ] },
      { "q": "Work out $5 - \\tfrac{1}{2}$.", "a": "$4\\tfrac{1}{2}$",
        "solution": [ { "math": "$5 = 4 + \\tfrac{2}{2}$", "note": "Rename one whole" }, { "math": "$4 + \\tfrac{2}{2} - \\tfrac{1}{2} = 4\\tfrac{1}{2}$", "note": "" } ] },
      { "q": "What must be added to $\\tfrac{2}{5}$ to make $1$?", "a": "$\\tfrac{3}{5}$",
        "solution": [ { "math": "$1 - \\tfrac{2}{5} = \\tfrac{5}{5} - \\tfrac{2}{5}$", "note": "Complement" }, { "math": "$= \\tfrac{3}{5}$", "note": "" } ] },
      { "q": "Work out $3 - \\tfrac{5}{6}$.", "a": "$2\\tfrac{1}{6}$",
        "solution": [ { "math": "$3 = 2 + \\tfrac{6}{6}$", "note": "Rename one whole" }, { "math": "$2 + \\tfrac{6}{6} - \\tfrac{5}{6} = 2\\tfrac{1}{6}$", "note": "" } ] }
    ],
    "mastery": [
      { "q": "A jug holds $1$ L. After $\\tfrac{3}{8}$ L is poured out, how much remains?", "a": "$\\tfrac{5}{8}$ L",
        "solution": [ { "math": "$1 - \\tfrac{3}{8} = \\tfrac{8}{8} - \\tfrac{3}{8}$", "note": "Complement" }, { "math": "$= \\tfrac{5}{8} \\text{ L}$", "note": "" } ] },
      { "q": "A cake is whole. After $\\tfrac{5}{6}$ is eaten, what fraction is left?", "a": "$\\tfrac{1}{6}$",
        "solution": [ { "math": "$1 - \\tfrac{5}{6} = \\tfrac{6}{6} - \\tfrac{5}{6}$", "note": "Complement" }, { "math": "$= \\tfrac{1}{6}$", "note": "" } ] },
      { "q": "Mia had $2$ m of ribbon and used $\\tfrac{3}{4}$ m. How much is left?", "a": "$1\\tfrac{1}{4}$ m",
        "solution": [ { "math": "$2 - \\tfrac{3}{4} = 1 + \\tfrac{4}{4} - \\tfrac{3}{4}$", "note": "Rename one whole" }, { "math": "$= 1\\tfrac{1}{4} \\text{ m}$", "note": "" } ] },
      { "q": "A pizza is shared: $\\tfrac{7}{10}$ is eaten. Two friends split the rest equally. What fraction does each get?", "a": "$\\tfrac{3}{20}$",
        "solution": [ { "math": "$1 - \\tfrac{7}{10} = \\tfrac{3}{10}$", "note": "Left" }, { "math": "$\\tfrac{3}{10} \\div 2 = \\tfrac{3}{20}$", "note": "Each share" } ] },
      { "q": "A tank is full ($1$). $\\tfrac{2}{3}$ is used in the morning. How much is left for the afternoon?", "a": "$\\tfrac{1}{3}$",
        "solution": [ { "math": "$1 - \\tfrac{2}{3} = \\tfrac{3}{3} - \\tfrac{2}{3}$", "note": "Complement" }, { "math": "$= \\tfrac{1}{3}$", "note": "" } ] },
      { "q": "From $3$ whole pies, $\\tfrac{5}{8}$ of one is given away. How much pie remains?", "a": "$2\\tfrac{3}{8}$",
        "solution": [ { "math": "$3 - \\tfrac{5}{8} = 2 + \\tfrac{8}{8} - \\tfrac{5}{8}$", "note": "Rename one whole" }, { "math": "$= 2\\tfrac{3}{8}$", "note": "" } ] },
      { "q": "A board is $1$ m. After cutting off $\\tfrac{2}{5}$ m and then $\\tfrac{1}{5}$ m, how much remains?", "a": "$\\tfrac{2}{5}$ m",
        "solution": [ { "math": "$\\tfrac{2}{5} + \\tfrac{1}{5} = \\tfrac{3}{5}$", "note": "Total cut" }, { "math": "$1 - \\tfrac{3}{5} = \\tfrac{2}{5} \\text{ m}$", "note": "" } ] },
      { "q": "What fraction must be added to $\\tfrac{5}{12}$ to make a whole?", "a": "$\\tfrac{7}{12}$",
        "solution": [ { "math": "$1 - \\tfrac{5}{12} = \\tfrac{12}{12} - \\tfrac{5}{12}$", "note": "Complement" }, { "math": "$= \\tfrac{7}{12}$", "note": "" } ] },
      { "q": "A relay is $1$ lap. The first runner does $\\tfrac{3}{8}$ and the second $\\tfrac{2}{8}$. What fraction is left for the third?", "a": "$\\tfrac{3}{8}$",
        "solution": [ { "math": "$\\tfrac{3}{8} + \\tfrac{2}{8} = \\tfrac{5}{8}$", "note": "Done so far" }, { "math": "$1 - \\tfrac{5}{8} = \\tfrac{3}{8}$", "note": "" } ] },
      { "q": "A wheel of cheese is whole. $\\tfrac{9}{10}$ is sold across the week. Express what is left as a fraction.", "a": "$\\tfrac{1}{10}$",
        "solution": [ { "math": "$1 - \\tfrac{9}{10} = \\tfrac{10}{10} - \\tfrac{9}{10}$", "note": "Complement" }, { "math": "$= \\tfrac{1}{10}$", "note": "" } ] }
    ]
  }
}
