      { "q": "$\\tfrac{3}{5} + \\tfrac{1}{5} = \\;?$", "a": "$\\tfrac{4}{5}$",
        "solution": [ { "math": "$\\tfrac{3+1}{5}$", "note": "Add numerators" }, { "math": "$= \\tfrac{4}{5}$", "note": "" } ] },
