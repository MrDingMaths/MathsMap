{
  "skillId": "add-subtract-same-denominator",
  "atomType": "R",
  "theory": {
    "intro": "When fractions share a denominator, the parts are the same size, so you simply add or subtract the numerators.",
    "facts": [
      "Same denominator means **same-size parts**, so count how many parts in total.",
      "$\\tfrac{a}{d} + \\tfrac{b}{d} = \\tfrac{a+b}{d}$ and $\\tfrac{a}{d} - \\tfrac{b}{d} = \\tfrac{a-b}{d}$.",
      "Keep the **denominator the same** — only the numerators change."
    ],
    "steps": [
      "Check the denominators match.",
      "Add or subtract the numerators.",
      "Keep the denominator; simplify if asked."
    ]
  },
  "practice": {
    "foundation": [
      { "q": "$\\tfrac{1}{5} + \\tfrac{2}{5} = \\;?$", "a": "$\\tfrac{3}{5}$",
        "solution": [ { "math": "$\\tfrac{1+2}{5}$", "note": "Add numerators" }, { "math": "$= \\tfrac{3}{5}$", "note": "" } ] },
      { "q": "$\\tfrac{3}{7} + \\tfrac{2}{7} = \\;?$", "a": "$\\tfrac{5}{7}$",
        "solution": [ { "math": "$\\tfrac{3+2}{7}$", "note": "Add numerators" }, { "math": "$= \\tfrac{5}{7}$", "note": "" } ] },
      { "q": "$\\tfrac{4}{6} - \\tfrac{1}{6} = \\;?$", "a": "$\\tfrac{3}{6}$ (or $\\tfrac{1}{2}$)",
        "tikz": "\\begin{tikzpicture}[x=0.5cm,y=0.5cm]\n\\fill[gray!45] (0,0) rectangle (3,2); \\draw (0,0) rectangle (6,2); \\foreach \\i in {1,...,5} \\draw (\\i,0)--(\\i,2);\n\\node[below=2pt] at (3,0) {$\\tfrac{4}{6}-\\tfrac{1}{6}$};\n\\end{tikzpicture}",
        "solution": [ { "math": "$\\tfrac{4-1}{6}$", "note": "Subtract numerators" }, { "math": "$= \\tfrac{3}{6} = \\tfrac{1}{2}$", "note": "" } ] },
      { "q": "$\\tfrac{2}{9} + \\tfrac{5}{9} = \\;?$", "a": "$\\tfrac{7}{9}$",
        "solution": [ { "math": "$\\tfrac{2+5}{9}$", "note": "Add numerators" }, { "math": "$= \\tfrac{7}{9}$", "note": "" } ] },
      { "q": "$\\tfrac{5}{8} - \\tfrac{2}{8} = \\;?$", "a": "$\\tfrac{3}{8}$",
        "solution": [ { "math": "$\\tfrac{5-2}{8}$", "note": "Subtract numerators" }, { "math": "$= \\tfrac{3}{8}$", "note": "" } ] },
      { "q": "$\\tfrac{1}{4} + \\tfrac{1}{4} = \\;?$", "a": "$\\tfrac{2}{4}$ (or $\\tfrac{1}{2}$)",
        "tikz": "\\begin{tikzpicture}[x=0.5cm,y=0.5cm]\n\\fill[gray!45] (0,0) rectangle (2,2); \\draw (0,0) rectangle (4,2); \\foreach \\i in {1,2,3} \\draw (\\i,0)--(\\i,2);\n\\node[below=2pt] at (2,0) {$\\tfrac{1}{4}+\\tfrac{1}{4}$};\n\\end{tikzpicture}",
        "solution": [ { "math": "$\\tfrac{1+1}{4}$", "note": "Add numerators" }, { "math": "$= \\tfrac{2}{4} = \\tfrac{1}{2}$", "note": "" } ] },
      { "q": "$\\tfrac{6}{10} - \\tfrac{3}{10} = \\;?$", "a": "$\\tfrac{3}{10}$",
