      { "q": "Find the missing numerator: $\\tfrac{\\square}{10} - \\tfrac{3}{10} = \\tfrac{1}{2}$.", "a": "$8$",
        "solution": [ { "math": "$\\tfrac{1}{2} = \\tfrac{5}{10}$", "note": "Common tenths" }, { "math": "$5 + 3 = 8$", "note": "" } ] },
      { "q": "$\\tfrac{3}{4} - \\tfrac{1}{4} + \\tfrac{2}{4} = \\;?$ Give as a mixed number.", "a": "$1$",
        "solution": [ { "math": "$\\tfrac{3-1+2}{4} = \\tfrac{4}{4}$", "note": "Combine" }, { "math": "$= 1$", "note": "" } ] },
      { "q": "A length of $\\tfrac{7}{8}$ m has $\\tfrac{3}{8}$ m cut off, then $\\tfrac{1}{8}$ m more. What remains?", "a": "$\\tfrac{3}{8}$ m",
        "solution": [ { "math": "$\\tfrac{7}{8} - \\tfrac{3}{8} - \\tfrac{1}{8}$", "note": "Subtract both" }, { "math": "$= \\tfrac{3}{8}$ m", "note": "" } ] },
      { "q": "$\\tfrac{9}{10} + \\tfrac{7}{10} = \\;?$ Give as a mixed number, simplified.", "a": "$1\\tfrac{3}{5}$",
        "solution": [ { "math": "$\\tfrac{9+7}{10} = \\tfrac{16}{10}$", "note": "Add" }, { "math": "$= 1\\tfrac{6}{10} = 1\\tfrac{3}{5}$", "note": "Mixed, simplified" } ] },
      { "q": "Three pieces $\\tfrac{2}{6}, \\tfrac{3}{6}, \\tfrac{4}{6}$ are joined. Total as a mixed number, simplified?", "a": "$1\\tfrac{1}{2}$",
        "solution": [ { "math": "$\\tfrac{2+3+4}{6} = \\tfrac{9}{6}$", "note": "Add" }, { "math": "$= 1\\tfrac{3}{6} = 1\\tfrac{1}{2}$", "note": "Simplify" } ] },
      { "q": "From $\\tfrac{11}{8}$, subtract $\\tfrac{5}{8}$. Give the answer as a fraction and decide if it is less than $1$.", "a": "$\\tfrac{6}{8} = \\tfrac{3}{4}$, less than $1$",
        "solution": [ { "math": "$\\tfrac{11-5}{8} = \\tfrac{6}{8}$", "note": "Subtract" }, { "math": "$= \\tfrac{3}{4} < 1$", "note": "" } ] },
      { "q": "Find the missing numerator: $\\tfrac{7}{12} + \\tfrac{\\square}{12} = 1$.", "a": "$5$",
        "solution": [ { "math": "$1 = \\tfrac{12}{12}$", "note": "One whole" }, { "math": "$12 - 7 = 5$", "note": "" } ] },
      { "q": "A jug holds $\\tfrac{5}{6}$ L. You pour in $\\tfrac{4}{6}$ L more. How much over $1$ L, as a fraction?", "a": "$\\tfrac{1}{2}$ L over",
        "solution": [ { "math": "$\\tfrac{5+4}{6} = \\tfrac{9}{6} = 1\\tfrac{3}{6}$", "note": "Add" }, { "math": "$\\tfrac{3}{6} = \\tfrac{1}{2}$ L over", "note": "" } ] }
