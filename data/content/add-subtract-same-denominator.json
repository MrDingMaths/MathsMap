      { "q": "Find the missing numerator: $\\tfrac{2}{9} + \\tfrac{\\square}{9} = \\tfrac{7}{9}$.", "a": "$5$",
        "solution": [ { "math": "$7 - 2 = 5$", "note": "Numerators" }, { "math": "$\\tfrac{5}{9}$", "note": "" } ] },
      { "q": "$\\tfrac{11}{12} - \\tfrac{7}{12} = \\;?$ Simplify.", "a": "$\\tfrac{1}{3}$",
        "solution": [ { "math": "$\\tfrac{11-7}{12} = \\tfrac{4}{12}$", "note": "Subtract" }, { "math": "$= \\tfrac{1}{3}$", "note": "Simplify" } ] }
    ],
    "mastery": [
      { "q": "$\\tfrac{5}{8} + \\tfrac{7}{8} = \\;?$ Give as a mixed number.", "a": "$1\\tfrac{1}{2}$",
        "solution": [ { "math": "$\\tfrac{5+7}{8} = \\tfrac{12}{8}$", "note": "Add" }, { "math": "$= 1\\tfrac{4}{8} = 1\\tfrac{1}{2}$", "note": "Mixed, simplified" } ] },
      { "q": "$\\tfrac{4}{5} + \\tfrac{3}{5} = \\;?$ Give as a mixed number.", "a": "$1\\tfrac{2}{5}$",
