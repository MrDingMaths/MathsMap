{
  "skillId": "area-of-parallelogram",
  "atomType": "R",
  "theory": {
    "intro": "A parallelogram can be cut and rearranged into a rectangle with the same base and height, so its area is base times perpendicular height.",
    "facts": [
      "**Area $=$ base $\\times$ height**, where height is the **perpendicular** distance between the base and the opposite side.",
      "The height is **not** the slanted side; it is measured at a right angle to the base.",
      "Area is measured in square units: cm$^{2}$, m$^{2}$."
    ],
    "steps": [
      "Identify the base and the perpendicular height (the dashed line at a right angle).",
      "Multiply base $\\times$ height.",
      "Write the answer with squared units."
    ]
  },
  "practice": {
    "foundation": [
      { "q": "Find the area of this parallelogram.", "a": "$24\\text{ cm}^{2}$",
        "tikz": "\\begin{tikzpicture}[x=1cm,y=1cm]\n\\draw[thick] (0,0)--(4,0)--(5,2)--(1,2)--cycle;\n\\draw[dashed] (1,2)--(1,0);\n\\draw (1,0) rectangle (1.25,0.25);\n\\node[below] at (2,0) {$6$ cm};\n\\node[left] at (1,1) {$4$ cm};\n\\end{tikzpicture}",
        "solution": [ { "math": "$6 \\times 4$", "note": "base × height" }, { "math": "$= 24\\text{ cm}^{2}$", "note": "" } ] },
      { "q": "Find the area of this parallelogram.", "a": "$40\\text{ m}^{2}$",
