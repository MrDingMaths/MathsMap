{
  "skillId": "multiply-area-model-distributive",
  "atomType": "R",
  "theory": {
    "intro": "You can multiply a large number by splitting it into its place-value parts, multiplying each part, then adding. This is the **distributive property**.",
    "facts": [
      "Partition by place value, e.g. $684 = 600 + 80 + 4$.",
      "Multiply **each part** by the multiplier, then add the part-products.",
      "An **area model** shows the parts as rectangles whose areas are the part-products."
    ],
    "steps": [
      "Split the larger number into hundreds, tens and ones.",
      "Multiply each part by the other factor.",
      "Add the part-products to get the total."
    ]
  },
  "practice": {
    "foundation": [
      { "q": "Use the area model to find $23 \\times 4$.", "a": "$92$",
        "tikz": "\\begin{tikzpicture}[x=0.9cm,y=0.9cm]\n\\draw (0,0) rectangle (4,1.4);\n\\draw (3,0) -- (3,1.4);\n\\node at (1.5,1.75) {$20$}; \\node at (3.5,1.75) {$3$};\n\\node[left] at (0,0.7) {$4$};\n\\node at (1.5,0.7) {$80$}; \\node at (3.5,0.7) {$12$};\n\\end{tikzpicture}",
        "solution": [ { "math": "$(20 \\times 4) + (3 \\times 4)$", "note": "Partition $23$" }, { "math": "$= 80 + 12 = 92$", "note": "Add the parts" } ] },
      { "q": "Use the area model to find $32 \\times 3$.", "a": "$96$",
        "tikz": "\\begin{tikzpicture}[x=0.9cm,y=0.9cm]\n\\draw (0,0) rectangle (4,1.4);\n\\draw (3,0) -- (3,1.4);\n\\node at (1.5,1.75) {$30$}; \\node at (3.5,1.75) {$2$};\n\\node[left] at (0,0.7) {$3$};\n\\node at (1.5,0.7) {$90$}; \\node at (3.5,0.7) {$6$};\n\\end{tikzpicture}",
        "solution": [ { "math": "$(30 \\times 3) + (2 \\times 3)$", "note": "Partition $32$" }, { "math": "$= 90 + 6 = 96$", "note": "Add the parts" } ] },
      { "q": "Use the area model to find $45 \\times 2$.", "a": "$90$",
        "tikz": "\\begin{tikzpicture}[x=0.9cm,y=0.9cm]\n\\draw (0,0) rectangle (4,1.4);\n\\draw (2.8,0) -- (2.8,1.4);\n\\node at (1.4,1.75) {$40$}; \\node at (3.4,1.75) {$5$};\n\\node[left] at (0,0.7) {$2$};\n\\node at (1.4,0.7) {$80$}; \\node at (3.4,0.7) {$10$};\n\\end{tikzpicture}",
        "solution": [ { "math": "$(40 \\times 2) + (5 \\times 2)$", "note": "Partition $45$" }, { "math": "$= 80 + 10 = 90$", "note": "Add the parts" } ] },
      { "q": "Find $52 \\times 4$ by partitioning by place value.", "a": "$208$",
