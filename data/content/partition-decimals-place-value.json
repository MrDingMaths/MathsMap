{
  "skillId": "partition-decimals-place-value",
  "atomType": "R",
  "theory": {
    "intro": "A decimal can be split into the sum of its place-value parts: ones, tenths, hundredths and thousandths.",
    "facts": [
      "$5.37 = 5 + 0.3 + 0.07$.",
      "Each digit's part is the digit times its place value.",
      "A non-standard partition regroups, e.g. $0.37 = 0.2 + 0.17$."
    ],
    "steps": [
      "Read each digit's place value.",
      "Write each digit times its place as a separate part.",
      "Drop any part that is zero."
    ]
  },
  "practice": {
    "foundation": [
      { "q": "Partition $5.37$ by place value.", "a": "$5 + 0.3 + 0.07$",
        "solution": [ { "math": "$5,\\ 3,\\ 7$", "note": "Ones, tenths, hundredths" }, { "math": "$5 + 0.3 + 0.07$", "note": "Digit × place" } ] },
      { "q": "Partition $0.64$ by place value.", "a": "$0.6 + 0.04$",
        "solution": [ { "math": "$6,\\ 4$", "note": "Tenths, hundredths" }, { "math": "$0.6 + 0.04$", "note": "Digit × place" } ] },
      { "q": "Write as one number: $4 + 0.2 + 0.05$.", "a": "$4.25$",
        "solution": [ { "math": "$4 + 0.2 + 0.05$", "note": "Line up the places" }, { "math": "$4.25$", "note": "Combine" } ] },
      { "q": "Partition $2.8$ by place value.", "a": "$2 + 0.8$",
        "solution": [ { "math": "$2,\\ 8$", "note": "Ones, tenths" }, { "math": "$2 + 0.8$", "note": "Digit × place" } ] },
      { "q": "Partition $0.305$ by place value.", "a": "$0.3 + 0.005$",
        "solution": [ { "math": "$3,\\ 0,\\ 5$", "note": "Zero hundredths" }, { "math": "$0.3 + 0.005$", "note": "Skip the zero place" } ] },
      { "q": "Write as one number: $7 + 0.09$.", "a": "$7.09$",
        "solution": [ { "math": "$7 + 0.09$", "note": "Line up the places" }, { "math": "$7.09$", "note": "Zero holds the tenths" } ] },
      { "q": "Partition $1.46$ by place value.", "a": "$1 + 0.4 + 0.06$",
        "solution": [ { "math": "$1,\\ 4,\\ 6$", "note": "Ones, tenths, hundredths" }, { "math": "$1 + 0.4 + 0.06$", "note": "Digit × place" } ] },
      { "q": "Partition $0.9$ by place value.", "a": "$0.9$",
        "solution": [ { "math": "$9 \\to \\text{tenths}$", "note": "Only one place" }, { "math": "$0.9$", "note": "" } ] },
      { "q": "Write as one number: $3 + 0.6 + 0.07 + 0.002$.", "a": "$3.672$",
        "solution": [ { "math": "$3 + 0.6 + 0.07 + 0.002$", "note": "Line up the places" }, { "math": "$3.672$", "note": "Combine" } ] },
      { "q": "Partition $6.05$ by place value.", "a": "$6 + 0.05$",
        "solution": [ { "math": "$6,\\ 0,\\ 5$", "note": "Zero tenths" }, { "math": "$6 + 0.05$", "note": "Skip the zero place" } ] }
    ],
    "development": [
      { "q": "Partition $12.408$ by place value.", "a": "$12 + 0.4 + 0.008$",
        "solution": [ { "math": "$12,\\ 4,\\ 0,\\ 8$", "note": "Zero hundredths" }, { "math": "$12 + 0.4 + 0.008$", "note": "Skip the zero place" } ] },
      { "q": "Complete: $0.85 = 0.8 + \\square$.", "a": "$0.05$",
        "solution": [ { "math": "$0.85 - 0.8 = 0.05$", "note": "Find the missing part" }, { "math": "$0.8 + 0.05 = 0.85$", "note": "Check" } ] },
      { "q": "Write as one number: $0.5 + 0.04 + 0.003$.", "a": "$0.543$",
        "solution": [ { "math": "$0.5 + 0.04 + 0.003$", "note": "Line up the places" }, { "math": "$0.543$", "note": "Combine" } ] },
      { "q": "Complete the non-standard partition: $0.6 = 0.5 + \\square$.", "a": "$0.1$",
        "solution": [ { "math": "$0.6 - 0.5 = 0.1$", "note": "Regroup tenths" }, { "math": "$0.5 + 0.1 = 0.6$", "note": "Check" } ] },
      { "q": "Partition $9.072$ by place value.", "a": "$9 + 0.07 + 0.002$",
        "solution": [ { "math": "$9,\\ 0,\\ 7,\\ 2$", "note": "Zero tenths" }, { "math": "$9 + 0.07 + 0.002$", "note": "Skip the zero place" } ] },
      { "q": "Complete: $3.14 = 3 + 0.1 + \\square$.", "a": "$0.04$",
        "solution": [ { "math": "$3.14 - 3 - 0.1 = 0.04$", "note": "Find the missing part" }, { "math": "$3 + 0.1 + 0.04 = 3.14$", "note": "Check" } ] },
      { "q": "Write as one number: $20 + 5 + 0.3 + 0.06$.", "a": "$25.36$",
        "solution": [ { "math": "$20 + 5 = 25$", "note": "Whole part" }, { "math": "$25 + 0.3 + 0.06 = 25.36$", "note": "Add decimal parts" } ] },
      { "q": "Complete the non-standard partition: $0.47 = 0.3 + \\square$.", "a": "$0.17$",
        "solution": [ { "math": "$0.47 - 0.3 = 0.17$", "note": "Regroup" }, { "math": "$0.3 + 0.17 = 0.47$", "note": "Check" } ] },
      { "q": "Partition $0.999$ by place value.", "a": "$0.9 + 0.09 + 0.009$",
        "solution": [ { "math": "$9,\\ 9,\\ 9$", "note": "Each place has a 9" }, { "math": "$0.9 + 0.09 + 0.009$", "note": "Digit × place" } ] },
      { "q": "How many hundredths are in $0.5$?", "a": "$50$",
        "solution": [ { "math": "$0.5 = 0.50$", "note": "Rename to hundredths" }, { "math": "$= 50 \\text{ hundredths}$", "note": "" } ] }
    ],
    "mastery": [
      { "q": "A decimal is made of $2$ ones, $0$ tenths, $7$ hundredths and $5$ thousandths. Write it.", "a": "$2.075$",
        "solution": [ { "math": "$2 + 0.07 + 0.005$", "note": "Place each digit" }, { "math": "$= 2.075$", "note": "Zero holds the tenths" } ] },
      { "q": "Complete the non-standard partition: $1.3 = 0.9 + \\square$.", "a": "$0.4$",
        "solution": [ { "math": "$1.3 - 0.9 = 0.4$", "note": "Regroup across the ones" }, { "math": "$0.9 + 0.4 = 1.3$", "note": "Check" } ] },
      { "q": "Write $4.6$ using only hundredths, e.g. $\\square$ hundredths.", "a": "$460$ hundredths",
        "solution": [ { "math": "$4.6 = 4.60 = \\dfrac{460}{100}$", "note": "Rename to hundredths" }, { "math": "$= 460 \\text{ hundredths}$", "note": "" } ] },
      { "q": "A non-standard partition is $5.62 = 5 + 0.5 + \\square$. Find the missing part.", "a": "$0.12$",
        "solution": [ { "math": "$5.62 - 5 - 0.5 = 0.12$", "note": "Find the missing part" }, { "math": "$5 + 0.5 + 0.12 = 5.62$", "note": "Check" } ] },
      { "q": "Add by partitioning: $0.34 + 0.52$.", "a": "$0.86$",
        "solution": [ { "math": "$(0.3 + 0.5) + (0.04 + 0.02)$", "note": "Group by place" }, { "math": "$0.8 + 0.06 = 0.86$", "note": "Combine" } ] },
      { "q": "A bottle holds $1.25$ L. Partition this volume by place value.", "a": "$1 + 0.2 + 0.05$",
        "solution": [ { "math": "$1,\\ 2,\\ 5$", "note": "Ones, tenths, hundredths" }, { "math": "$1 + 0.2 + 0.05$", "note": "Digit × place" } ] },
      { "q": "Write as one number: $0.8 + 0.15$.", "a": "$0.95$",
        "solution": [ { "math": "$0.8 + 0.15$", "note": "Add by place ($0.1+0.05$ regrouped in)" }, { "math": "$= 0.95$", "note": "Combine" } ] },
      { "q": "Partition $30.405$ by place value.", "a": "$30 + 0.4 + 0.005$",
        "solution": [ { "math": "$30,\\ 4,\\ 0,\\ 5$", "note": "Zero hundredths" }, { "math": "$30 + 0.4 + 0.005$", "note": "Skip the zero place" } ] },
      { "q": "How many thousandths make $0.04$?", "a": "$40$",
        "solution": [ { "math": "$0.04 = 0.040 = \\dfrac{40}{1000}$", "note": "Rename to thousandths" }, { "math": "$= 40 \\text{ thousandths}$", "note": "" } ] },
      { "q": "Subtract by partitioning: $0.9 - 0.35$.", "a": "$0.55$",
        "solution": [ { "math": "$0.90 - 0.35$", "note": "Match decimal places" }, { "math": "$= 0.55$", "note": "Subtract by place" } ] }
    ]
  }
}
