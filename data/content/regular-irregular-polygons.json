{
  "skillId": "regular-irregular-polygons",
  "atomType": "R",
  "theory": {
    "intro": "A polygon is regular if all its sides are equal AND all its angles are equal. If either varies, it is irregular.",
    "facts": [
      "**Regular**: all sides equal and all angles equal (e.g. square, equilateral triangle).",
      "**Irregular**: at least one side or angle is different.",
      "Equal sides are shown by tick marks; equal angles are often shown by matching arc marks."
    ],
    "steps": [
      "Check whether all sides are equal (look at the tick marks or lengths).",
      "Check whether all angles are equal.",
      "If both are equal it is regular; otherwise it is irregular."
    ]
  },
  "practice": {
    "foundation": [
      { "q": "Is this polygon regular or irregular?", "a": "Regular",
        "tikz": "\\begin{tikzpicture}[x=1cm,y=1cm]\n\\draw[thick] (0,0) rectangle (2,2);\n\\foreach \\p in {(1,0),(1,2)} \\draw \\p ++(0,0.07)--++(0,-0.14);\n\\foreach \\p in {(0,1),(2,1)} \\draw \\p ++(0.07,0)--++(-0.14,0);\n\\end{tikzpicture}",
        "solution": [ { "math": "$\\text{4 equal sides + right angles}$", "note": "Regular square" }, { "math": "$= \\text{regular}$", "note": "" } ] },
      { "q": "Is this polygon regular or irregular?", "a": "Irregular",
        "tikz": "\\begin{tikzpicture}[x=1cm,y=1cm]\n\\draw[thick] (0,0) rectangle (3,1.4);\n\\end{tikzpicture}",
        "solution": [ { "math": "$\\text{sides unequal}$", "note": "Long vs short" }, { "math": "$= \\text{irregular}$", "note": "" } ] },
      { "q": "Is this triangle regular or irregular?", "a": "Regular",
        "tikz": "\\begin{tikzpicture}[x=1cm,y=1cm]\n\\coordinate (A) at (0,0); \\coordinate (B) at (2.6,0); \\coordinate (C) at (1.3,2.25);\n\\draw[thick] (A)--(B)--(C)--cycle;\n\\draw ($(A)!0.5!(B)$) ++(0,0.07)--++(0,-0.14);\n\\draw ($(B)!0.5!(C)$) ++(0.07,0.04)--++(-0.14,-0.08);\n\\draw ($(C)!0.5!(A)$) ++(0.07,0.04)--++(-0.14,-0.08);\n\\end{tikzpicture}",
        "solution": [ { "math": "$\\text{equilateral: all equal}$", "note": "" }, { "math": "$= \\text{regular}$", "note": "" } ] },
      { "q": "Is this triangle regular or irregular?", "a": "Irregular",
        "tikz": "\\begin{tikzpicture}[x=1cm,y=1cm]\n\\coordinate (A) at (0,0); \\coordinate (B) at (3.4,0); \\coordinate (C) at (0.9,1.8);\n\\draw[thick] (A)--(B)--(C)--cycle;\n\\end{tikzpicture}",
        "solution": [ { "math": "$\\text{sides all different}$", "note": "Scalene" }, { "math": "$= \\text{irregular}$", "note": "" } ] },
      { "q": "Is this hexagon regular or irregular?", "a": "Regular",
        "tikz": "\\begin{tikzpicture}[x=1cm,y=1cm]\n\\draw[thick] (0:1.2) \\foreach \\a in {60,120,...,300} {--(\\a:1.2)} --cycle;\n\\foreach \\a in {30,90,...,330} \\draw (\\a:1.04) ++(0.05,0.03)--++(-0.1,-0.06);\n\\end{tikzpicture}",
        "solution": [ { "math": "$\\text{6 equal sides + equal angles}$", "note": "" }, { "math": "$= \\text{regular}$", "note": "" } ] },
      { "q": "A polygon has all sides equal and all angles equal. Is it regular?", "a": "Yes, regular",
        "solution": [ { "math": "$\\text{both conditions met}$", "note": "" }, { "math": "$= \\text{regular}$", "note": "" } ] },
      { "q": "Is this pentagon regular or irregular?", "a": "Irregular",
        "tikz": "\\begin{tikzpicture}[x=1cm,y=1cm]\n\\draw[thick] (0,0)--(2.4,0)--(2.8,1.3)--(1.1,2.2)--(-0.4,1)--cycle;\n\\end{tikzpicture}",
        "solution": [ { "math": "$\\text{sides + angles vary}$", "note": "" }, { "math": "$= \\text{irregular}$", "note": "" } ] },
      { "q": "Is this polygon regular or irregular?", "a": "Irregular",
        "tikz": "\\begin{tikzpicture}[x=1cm,y=1cm]\n\\draw[thick] (0,0)--(2.6,0)--(3.2,1.4)--(0.6,1.4)--cycle;\n\\draw[-{Stealth[length=2mm]}] (1.1,0)--(1.3,0);\n\\draw[-{Stealth[length=2mm]}] (1.7,1.4)--(1.9,1.4);\n\\end{tikzpicture}",
        "solution": [ { "math": "$\\text{parallelogram, angles unequal}$", "note": "" }, { "math": "$= \\text{irregular}$", "note": "" } ] },
      { "q": "Is a regular pentagon's side count $5$ with all sides equal? Is it regular?", "a": "Yes, regular",
        "solution": [ { "math": "$\\text{5 equal sides + equal angles}$", "note": "" }, { "math": "$= \\text{regular}$", "note": "" } ] },
      { "q": "Is this square-shaped polygon regular?", "a": "Regular",
        "tikz": "\\begin{tikzpicture}[x=1cm,y=1cm]\n\\draw[thick] (0,0) rectangle (2.2,2.2);\n\\foreach \\p in {(1.1,0),(1.1,2.2)} \\draw \\p ++(0,0.07)--++(0,-0.14);\n\\foreach \\p in {(0,1.1),(2.2,1.1)} \\draw \\p ++(0.07,0)--++(-0.14,0);\n\\end{tikzpicture}",
        "solution": [ { "math": "$\\text{all sides + angles equal}$", "note": "" }, { "math": "$= \\text{regular}$", "note": "" } ] }
    ],
    "development": [
      { "q": "A rhombus has $4$ equal sides but angles of $60^{\\circ}$ and $120^{\\circ}$. Is it regular?", "a": "Irregular",
        "solution": [ { "math": "$\\text{sides equal but angles vary}$", "note": "" }, { "math": "$= \\text{irregular}$", "note": "" } ] },
      { "q": "A rectangle has all angles equal ($90^{\\circ}$) but sides $6$ cm and $3$ cm. Is it regular?", "a": "Irregular",
        "solution": [ { "math": "$\\text{angles equal but sides vary}$", "note": "" }, { "math": "$= \\text{irregular}$", "note": "" } ] },
      { "q": "Why is a rhombus (non-square) NOT a regular polygon?", "a": "Its angles are not all equal",
        "solution": [ { "math": "$\\text{equal sides, unequal angles}$", "note": "" }, { "math": "$= \\text{irregular}$", "note": "" } ] },
      { "q": "Classify this hexagon as regular or irregular.", "a": "Irregular",
        "tikz": "\\begin{tikzpicture}[x=1cm,y=1cm]\n\\draw[thick] (0,0)--(2.2,0)--(2.8,1)--(2,2)--(0.5,1.9)--(-0.4,0.8)--cycle;\n\\end{tikzpicture}",
        "solution": [ { "math": "$\\text{sides + angles vary}$", "note": "" }, { "math": "$= \\text{irregular}$", "note": "" } ] },
      { "q": "A regular octagon has all sides $5$ cm. Find its perimeter.", "a": "$40$ cm",
        "solution": [ { "math": "$8 \\times 5$", "note": "8 equal sides" }, { "math": "$= 40 \\text{ cm}$", "note": "" } ] },
      { "q": "Classify this polygon.", "a": "Regular",
        "tikz": "\\begin{tikzpicture}[x=1cm,y=1cm]\n\\draw[thick] (90:1.3) \\foreach \\a in {162,234,306,378} {--(\\a:1.3)} --cycle;\n\\foreach \\a in {126,198,270,342,54} \\draw (\\a:1.12) ++(0.05,0.04)--++(-0.1,-0.08);\n\\end{tikzpicture}",
        "solution": [ { "math": "$\\text{5 equal sides + equal angles}$", "note": "Regular pentagon" }, { "math": "$= \\text{regular}$", "note": "" } ] },
      { "q": "A regular pentagon has perimeter $35$ cm. Find one side.", "a": "$7$ cm",
        "solution": [ { "math": "$35 \\div 5$", "note": "5 equal sides" }, { "math": "$= 7 \\text{ cm}$", "note": "" } ] },
      { "q": "True or false: all equilateral triangles are regular polygons.", "a": "True",
        "solution": [ { "math": "$\\text{equal sides + equal angles}$", "note": "" }, { "math": "$= \\text{regular}$", "note": "" } ] },
      { "q": "A polygon has $6$ equal sides but two of its angles differ. Regular or irregular?", "a": "Irregular",
        "solution": [ { "math": "$\\text{angles not all equal}$", "note": "" }, { "math": "$= \\text{irregular}$", "note": "" } ] },
      { "q": "Which is regular: a square or a non-square rectangle?", "a": "The square",
        "solution": [ { "math": "$\\text{rectangle sides unequal}$", "note": "" }, { "math": "$= \\text{square is regular}$", "note": "" } ] }
    ],
    "mastery": [
      { "q": "A regular polygon has $9$ sides and perimeter $54$ cm. Find one side.", "a": "$6$ cm",
        "solution": [ { "math": "$54 \\div 9$", "note": "9 equal sides" }, { "math": "$= 6 \\text{ cm}$", "note": "" } ] },
      { "q": "A shape has all angles equal but is irregular. Give an example and explain.", "a": "A non-square rectangle — equal angles but unequal sides",
        "solution": [ { "math": "$\\text{angles } 90^{\\circ}, \\text{ sides differ}$", "note": "" }, { "math": "$= \\text{irregular}$", "note": "" } ] },
      { "q": "A regular hexagon has the same side length as a regular pentagon of perimeter $40$ cm. Find the hexagon's perimeter.", "a": "$48$ cm",
        "solution": [ { "math": "$40 \\div 5 = 8 \\text{ cm side}$", "note": "Pentagon side" }, { "math": "$6 \\times 8 = 48 \\text{ cm}$", "note": "Hexagon perimeter" } ] },
      { "q": "Explain why a regular polygon needs BOTH equal sides and equal angles.", "a": "A shape with equal sides only (rhombus) or equal angles only (rectangle) is still irregular",
        "solution": [ { "math": "$\\text{rhombus: sides equal only}$", "note": "Irregular" }, { "math": "$\\text{rectangle: angles equal only}$", "note": "Irregular" } ] },
      { "q": "A regular polygon has $12$ sides each $4.5$ cm. Find its perimeter.", "a": "$54$ cm",
        "solution": [ { "math": "$12 \\times 4.5$", "note": "12 equal sides" }, { "math": "$= 54 \\text{ cm}$", "note": "" } ] },
      { "q": "Sort as regular (R) or irregular (I): equilateral triangle, scalene triangle, square, rhombus.", "a": "R: equilateral triangle, square; I: scalene triangle, rhombus",
        "solution": [ { "math": "$\\text{equilateral, square} = R$", "note": "All sides + angles equal" }, { "math": "$\\text{scalene, rhombus} = I$", "note": "" } ] },
      { "q": "A regular polygon has perimeter $63$ cm and each side is $9$ cm. How many sides?", "a": "$7$",
        "solution": [ { "math": "$63 \\div 9$", "note": "Total ÷ one side" }, { "math": "$= 7 \\text{ sides}$", "note": "" } ] },
      { "q": "Classify and find the perimeter (regular octagon).", "a": "Regular; $24$ cm",
        "tikz": "\\begin{tikzpicture}[x=1cm,y=1cm]\n\\draw[thick] (22.5:1.2) \\foreach \\a in {67.5,112.5,...,337.5} {--(\\a:1.2)} --cycle;\n\\foreach \\a in {45,90,...,360} \\draw (\\a:1.1) ++(0.04,0.03)--++(-0.08,-0.06);\n\\node at (0,0) {$3$ cm};\n\\end{tikzpicture}",
        "solution": [ { "math": "$\\text{8 equal sides} = \\text{regular}$", "note": "" }, { "math": "$8 \\times 3 = 24 \\text{ cm}$", "note": "Perimeter" } ] },
      { "q": "A regular decagon ($10$ sides) and a regular pentagon have equal side length. The decagon's perimeter is $70$ cm. Find the pentagon's perimeter.", "a": "$35$ cm",
        "solution": [ { "math": "$70 \\div 10 = 7 \\text{ cm side}$", "note": "" }, { "math": "$5 \\times 7 = 35 \\text{ cm}$", "note": "" } ] },
      { "q": "A student claims any shape with equal sides is regular. Give a counterexample.", "a": "A rhombus has equal sides but unequal angles, so it is irregular",
        "solution": [ { "math": "$\\text{rhombus: 4 equal sides}$", "note": "Angles differ" }, { "math": "$= \\text{irregular}$", "note": "Counterexample" } ] }
    ]
  }
}
