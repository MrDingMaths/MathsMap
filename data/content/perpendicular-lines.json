{
  "skillId": "perpendicular-lines",
  "atomType": "R",
  "theory": {
    "intro": "Two lines are **perpendicular** when they meet (or cross) to form a right angle of $90^{\\circ}$.",
    "facts": [
      "Perpendicular lines meet at exactly $90^{\\circ}$ — a square corner.",
      "A small **square** drawn at the meeting point marks the right angle.",
      "The symbol $\\perp$ means 'is perpendicular to', e.g. $AB \\perp CD$."
    ],
    "steps": [
      "Look at the angle where the lines meet.",
      "If it is $90^{\\circ}$ (square mark), the lines are perpendicular.",
      "Otherwise they are not perpendicular."
    ]
  },
  "practice": {
    "foundation": [
      { "q": "Are these two lines perpendicular?", "a": "yes",
        "tikz": "\\begin{tikzpicture}[scale=1]\n\\draw[thick] (-2,0)--(2,0);\n\\draw[thick] (0,-2)--(0,2);\n\\draw (0,0.35)--(0.35,0.35)--(0.35,0);\n\\end{tikzpicture}",
        "solution": [ { "math": "$\\text{angle} = 90^{\\circ}$", "note": "Square mark shown" }, { "math": "$\\text{yes, perpendicular}$", "note": "" } ] },
      { "q": "Are these two lines perpendicular?", "a": "no",
        "tikz": "\\begin{tikzpicture}[scale=1]\n\\draw[thick] (-2,0)--(2,0);\n\\draw[thick] (-1.4,-1.7)--(1.4,1.7);\n\\node at (0.8,0.3) {$60^{\\circ}$};\n\\end{tikzpicture}",
        "solution": [ { "math": "$\\text{angle} = 60^{\\circ}$", "note": "Not a right angle" }, { "math": "$\\text{no}$", "note": "" } ] },
      { "q": "Perpendicular lines meet at what angle?", "a": "$90^{\\circ}$",
        "solution": [ { "math": "$\\text{right angle}$", "note": "A square corner" }, { "math": "$= 90^{\\circ}$", "note": "" } ] },
      { "q": "Are these two lines perpendicular?", "a": "yes",
        "tikz": "\\begin{tikzpicture}[scale=1]\n\\draw[thick] (-1.8,-1.8)--(1.8,1.8);\n\\draw[thick] (-1.8,1.8)--(1.8,-1.8);\n\\draw (0,0)--(0.35,0.35)--(-0.35,0.35) -- cycle;\n\\end{tikzpicture}",
        "solution": [ { "math": "$\\text{angle} = 90^{\\circ}$", "note": "Square mark at the cross" }, { "math": "$\\text{yes}$", "note": "" } ] },
      { "q": "What symbol means 'is perpendicular to'?", "a": "$\\perp$",
        "solution": [ { "math": "$AB \\perp CD$", "note": "Perpendicular symbol" }, { "math": "$\\perp$", "note": "" } ] },
      { "q": "Are these two lines perpendicular?", "a": "no",
        "tikz": "\\begin{tikzpicture}[scale=1]\n\\draw[thick] (-2,0)--(2,0);\n\\draw[thick] (-1,-1.9)--(1,1.9);\n\\node at (0.75,0.35) {$62^{\\circ}$};\n\\end{tikzpicture}",
        "solution": [ { "math": "$62^{\\circ} \\neq 90^{\\circ}$", "note": "Not a right angle" }, { "math": "$\\text{no}$", "note": "" } ] },
      { "q": "Does a capital letter $T$ contain perpendicular lines?", "a": "yes",
        "solution": [ { "math": "$\\text{stem meets bar at } 90^{\\circ}$", "note": "A right angle" }, { "math": "$\\text{yes}$", "note": "" } ] },
      { "q": "Are the sides of a square corner perpendicular?", "a": "yes",
        "solution": [ { "math": "$\\text{corner} = 90^{\\circ}$", "note": "Right angle" }, { "math": "$\\text{yes}$", "note": "" } ] },
      { "q": "Are these two lines perpendicular?", "a": "yes",
        "tikz": "\\begin{tikzpicture}[scale=1]\n\\draw[thick] (0,0)--(2.4,0);\n\\draw[thick] (0,0)--(0,2.4);\n\\draw (0,0.35)--(0.35,0.35)--(0.35,0);\n\\end{tikzpicture}",
        "solution": [ { "math": "$\\text{angle} = 90^{\\circ}$", "note": "Square mark shown" }, { "math": "$\\text{yes}$", "note": "" } ] },
      { "q": "True or false: perpendicular lines can meet at $80^{\\circ}$.", "a": "false",
        "solution": [ { "math": "$80^{\\circ} \\neq 90^{\\circ}$", "note": "Must be exactly $90^{\\circ}$" }, { "math": "$\\text{false}$", "note": "" } ] }
    ],
    "development": [
      { "q": "Two roads cross at $90^{\\circ}$. Are they perpendicular?", "a": "yes",
        "solution": [ { "math": "$\\text{cross at } 90^{\\circ}$", "note": "Right angle" }, { "math": "$\\text{yes}$", "note": "" } ] },
      { "q": "Lines meet so one of the four angles is $90^{\\circ}$. Are they perpendicular?", "a": "yes",
        "tikz": "\\begin{tikzpicture}[scale=1]\n\\draw[thick] (-2,0)--(2,0);\n\\draw[thick] (0,-2)--(0,2);\n\\draw (0,0.35)--(0.35,0.35)--(0.35,0);\n\\node at (-0.45,-0.4) {$?$};\n\\end{tikzpicture}",
        "solution": [ { "math": "$\\text{one angle} = 90^{\\circ}$", "note": "All four are then $90^{\\circ}$" }, { "math": "$\\text{yes}$", "note": "" } ] },
      { "q": "Crossing lines make an angle of $90^{\\circ}$. What are the other three angles?", "a": "all $90^{\\circ}$",
        "solution": [ { "math": "$\\text{vertically opposite and on a line}$", "note": "All right angles" }, { "math": "$\\text{all } 90^{\\circ}$", "note": "" } ] },
      { "q": "A line is perpendicular to the floor. What angle does it make with the floor?", "a": "$90^{\\circ}$",
        "solution": [ { "math": "$\\perp \\Rightarrow 90^{\\circ}$", "note": "Right angle" }, { "math": "$= 90^{\\circ}$", "note": "" } ] },
      { "q": "How many right angles are formed where two perpendicular lines cross?", "a": "$4$",
        "tikz": "\\begin{tikzpicture}[scale=1]\n\\draw[thick] (-2,0)--(2,0);\n\\draw[thick] (0,-2)--(0,2);\n\\draw (0,0.3)--(0.3,0.3)--(0.3,0);\n\\draw (0,0.3)--(-0.3,0.3)--(-0.3,0);\n\\draw (0,-0.3)--(0.3,-0.3)--(0.3,0);\n\\draw (0,-0.3)--(-0.3,-0.3)--(-0.3,0);\n\\end{tikzpicture}",
        "solution": [ { "math": "$\\text{each of the 4 angles}$", "note": "All equal" }, { "math": "$4 \\text{ right angles}$", "note": "" } ] },
      { "q": "Two lines meet at $89^{\\circ}$. Are they perpendicular?", "a": "no",
        "solution": [ { "math": "$89^{\\circ} \\neq 90^{\\circ}$", "note": "Just short of a right angle" }, { "math": "$\\text{no}$", "note": "" } ] },
      { "q": "The hands of a clock at $3$ o'clock — are they perpendicular?", "a": "yes",
        "solution": [ { "math": "$\\tfrac{1}{4} \\text{ turn} = 90^{\\circ}$", "note": "Quarter of the dial" }, { "math": "$\\text{yes}$", "note": "" } ] },
      { "q": "A diagonal of a square — is it perpendicular to a side?", "a": "no",
        "solution": [ { "math": "$\\text{diagonal meets side at } 45^{\\circ}$", "note": "Not $90^{\\circ}$" }, { "math": "$\\text{no}$", "note": "" } ] },
      { "q": "If $AB \\perp BC$, what is the size of angle $ABC$?", "a": "$90^{\\circ}$",
        "solution": [ { "math": "$\\perp \\Rightarrow 90^{\\circ}$", "note": "Definition of perpendicular" }, { "math": "$\\angle ABC = 90^{\\circ}$", "note": "" } ] },
      { "q": "Two perpendicular lines and one more line through the cross make $50^{\\circ}$ with one of them. What angle does it make with the perpendicular?", "a": "$40^{\\circ}$",
        "solution": [ { "math": "$90^{\\circ} - 50^{\\circ}$", "note": "Within the right angle" }, { "math": "$= 40^{\\circ}$", "note": "" } ] }
    ],
    "mastery": [
      { "q": "The diagonals of a rhombus are perpendicular. If one diagonal is horizontal, what angle is the other diagonal to it?", "a": "$90^{\\circ}$",
        "solution": [ { "math": "$\\text{diagonals} \\perp$", "note": "Property of a rhombus" }, { "math": "$= 90^{\\circ}$", "note": "" } ] },
      { "q": "Line $PQ$ is perpendicular to line $RS$. A third line makes $33^{\\circ}$ with $PQ$. What angle does it make with $RS$?", "a": "$57^{\\circ}$",
        "solution": [ { "math": "$90^{\\circ} - 33^{\\circ}$", "note": "$PQ$ and $RS$ are $90^{\\circ}$ apart" }, { "math": "$= 57^{\\circ}$", "note": "" } ] },
      { "q": "A flagpole stands perpendicular to flat ground. A guy wire makes $65^{\\circ}$ with the ground. What angle is the wire to the pole?", "a": "$25^{\\circ}$",
        "solution": [ { "math": "$90^{\\circ} - 65^{\\circ}$", "note": "Pole is $90^{\\circ}$ to ground" }, { "math": "$= 25^{\\circ}$", "note": "" } ] },
      { "q": "Two streets meet at $90^{\\circ}$, and a path leaves the corner at $30^{\\circ}$ to one street. What angle is the path to the other street?", "a": "$60^{\\circ}$",
        "solution": [ { "math": "$90^{\\circ} - 30^{\\circ}$", "note": "Within the right angle" }, { "math": "$= 60^{\\circ}$", "note": "" } ] },
      { "q": "A capital $L$ has perpendicular strokes. How many right angles does the inside corner show?", "a": "$1$",
        "solution": [ { "math": "$\\text{single corner} = 90^{\\circ}$", "note": "One right angle" }, { "math": "$1$", "note": "" } ] },
      { "q": "Which letters of E, F, T, X are made only with perpendicular straight strokes?", "a": "E, F, T",
        "solution": [ { "math": "$\\text{E, F, T meet at } 90^{\\circ}$", "note": "X crosses at $90^{\\circ}$ too but is two diagonals" }, { "math": "$\\text{E, F, T}$", "note": "Right-angle joins" } ] },
      { "q": "Two perpendicular lines cross. A ray bisects one of the right angles. What angle does the ray make with each line?", "a": "$45^{\\circ}$",
        "solution": [ { "math": "$\\tfrac{1}{2} \\times 90^{\\circ}$", "note": "Bisect the right angle" }, { "math": "$= 45^{\\circ}$", "note": "" } ] },
      { "q": "A ladder leans so it is NOT perpendicular to the ground, making $75^{\\circ}$. How far from perpendicular is it?", "a": "$15^{\\circ}$",
        "solution": [ { "math": "$90^{\\circ} - 75^{\\circ}$", "note": "Difference from a right angle" }, { "math": "$= 15^{\\circ}$", "note": "" } ] },
      { "q": "In a rectangle, how many pairs of perpendicular sides meet at the four corners in total?", "a": "$4$ right angles",
        "solution": [ { "math": "$\\text{each corner} = 90^{\\circ}$", "note": "Adjacent sides are perpendicular" }, { "math": "$4 \\text{ corners}$", "note": "" } ] },
      { "q": "A line makes $90^{\\circ}$ with one of two parallel lines. Is it perpendicular to the other parallel line too?", "a": "yes",
        "solution": [ { "math": "$\\text{parallel lines, same angle}$", "note": "Same $90^{\\circ}$ to both" }, { "math": "$\\text{yes}$", "note": "" } ] }
    ]
  }
}
