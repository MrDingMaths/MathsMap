{
  "skillId": "compare-order-integers",
  "atomType": "R",
  "theory": {
    "intro": "On a number line, values increase from left to right. Use that to compare and order integers.",
    "facts": [
      "Further **left** (or lower) → **smaller**; further **right** (or higher) → **larger**.",
      "$<$ means 'less than', $>$ means 'greater than'.",
      "Any negative is less than any positive; $0$ sits between them."
    ],
    "steps": [
      "Picture the integers on a number line.",
      "The one further left is smaller.",
      "Write with $<$ (smaller first) or $>$ (larger first)."
    ]
  },
  "practice": {
    "foundation": [
      {
        "q": "Which is larger: $-4$ or $-1$?", "a": "$-1$",
        "solution": [
          { "math": "$-4 \\quad -1$", "note": "" },
          { "math": "$-1 > -4$", "note": "Right is larger" }
        ]
      },
      {
        "q": "Compare using $<$ or $>$: $4$ and $-2$.", "a": "$4 > -2$",
        "solution": [
          { "math": "$4 \\quad -2$", "note": "" },
          { "math": "$4 > -2$", "note": "Positive > negative" }
        ]
      },
      {
        "q": "Compare using $<$ or $>$: $-9$ and $-13$.", "a": "$-9 > -13$",
        "solution": [
          { "math": "$-9 \\quad -13$", "note": "" },
          { "math": "$-9 > -13$", "note": "Write inequality" }
        ]
      },
      {
        "q": "Which is larger: $2$ or $-8$?", "a": "$2$",
