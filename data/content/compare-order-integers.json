          { "math": "$2 \\quad -8$", "note": "" },
          { "math": "$2 > -8$", "note": "Right is larger" }
        ]
      },
      {
        "q": "Compare using $<$ or $>$: $-6$ and $-3$.", "a": "$-6 < -3$",
        "solution": [
