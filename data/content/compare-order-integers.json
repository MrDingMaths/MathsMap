          { "math": "$-6 < -3$", "note": "Write inequality" }
        ]
      },
      {
        "q": "Compare using $<$ or $>$: $0$ and $-100$.", "a": "$0 > -100$",
        "solution": [
          { "math": "$0 \\quad -100$", "note": "" },
          { "math": "$0 > -100$", "note": "Write inequality" }
