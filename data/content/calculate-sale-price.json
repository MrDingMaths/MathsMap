{
  "skillId": "calculate-sale-price",
  "atomType": "R",
  "theory": {
    "intro": "A discount is a percentage taken off the price. The sale price is what remains after the discount.",
    "facts": [
      "Sale price $=$ original price $-$ discount.",
      "$10\\%$ off $\\to$ pay $90\\%$;$\\ 25\\%$ off $\\to$ pay $75\\%$;$\\ 50\\%$ off $\\to$ pay $50\\%$.",
      "Use the benchmark shortcuts: $10\\% = \\div 10$, $25\\% = \\div 4$, $50\\% = \\div 2$."
    ],
    "steps": [
      "Find the discount: that percentage of the original price.",
      "Subtract the discount from the original price.",
      "Or find the percentage paid directly (e.g. $75\\%$ for $25\\%$ off)."
    ]
  },
  "practice": {
    "foundation": [
      { "q": "A $\\$50$ item has $10\\%$ off. How much is the discount?", "a": "$\\$5$",
        "solution": [ { "math": "$10\\% \\text{ of } 50 = 50 \\div 10$", "note": "Discount" }, { "math": "$= 5$", "note": "" } ] },
      { "q": "A $\\$50$ item has $10\\%$ off. What is the sale price?", "a": "$\\$45$",
        "solution": [ { "math": "$10\\% \\text{ of } 50 = 5$", "note": "Discount" }, { "math": "$50 - 5 = 45$", "note": "Sale price" } ] },
      { "q": "A $\\$80$ item has $50\\%$ off. What is the sale price?", "a": "$\\$40$",
        "solution": [ { "math": "$50\\% = \\tfrac{1}{2}$", "note": "Halve it" }, { "math": "$80 \\div 2 = 40$", "note": "Sale price" } ] },
      { "q": "A $\\$40$ item has $25\\%$ off. How much is the discount?", "a": "$\\$10$",
        "solution": [ { "math": "$25\\% \\text{ of } 40 = 40 \\div 4$", "note": "Discount" }, { "math": "$= 10$", "note": "" } ] },
      { "q": "A $\\$40$ item has $25\\%$ off. What is the sale price?", "a": "$\\$30$",
        "solution": [ { "math": "$25\\% \\text{ of } 40 = 10$", "note": "Discount" }, { "math": "$40 - 10 = 30$", "note": "Sale price" } ] },
      { "q": "A $\\$200$ item has $50\\%$ off. What is the sale price?", "a": "$\\$100$",
        "solution": [ { "math": "$50\\% = \\tfrac{1}{2}$", "note": "Halve it" }, { "math": "$200 \\div 2 = 100$", "note": "Sale price" } ] },
      { "q": "A $\\$30$ item has $10\\%$ off. What is the sale price?", "a": "$\\$27$",
        "solution": [ { "math": "$10\\% \\text{ of } 30 = 3$", "note": "Discount" }, { "math": "$30 - 3 = 27$", "note": "Sale price" } ] },
      { "q": "A $\\$24$ item has $50\\%$ off. What is the sale price?", "a": "$\\$12$",
        "solution": [ { "math": "$24 \\div 2$", "note": "Halve it" }, { "math": "$= 12$", "note": "Sale price" } ] },
      { "q": "A $\\$100$ item has $25\\%$ off. What is the sale price?", "a": "$\\$75$",
        "solution": [ { "math": "$25\\% \\text{ of } 100 = 25$", "note": "Discount" }, { "math": "$100 - 25 = 75$", "note": "Sale price" } ] },
      { "q": "A $\\$60$ item has $10\\%$ off. What is the sale price?", "a": "$\\$54$",
        "solution": [ { "math": "$10\\% \\text{ of } 60 = 6$", "note": "Discount" }, { "math": "$60 - 6 = 54$", "note": "Sale price" } ] }
    ],
    "development": [
      { "q": "A $\\$120$ jacket has $25\\%$ off. What is the sale price?", "a": "$\\$90$",
        "solution": [ { "math": "$25\\% \\text{ of } 120 = 30$", "note": "Discount" }, { "math": "$120 - 30 = 90$", "note": "Sale price" } ] },
      { "q": "A $\\$70$ item has $10\\%$ off. Find the sale price by paying $90\\%$.", "a": "$\\$63$",
        "solution": [ { "math": "$10\\% \\text{ of } 70 = 7$", "note": "$90\\% = 100\\% - 10\\%$" }, { "math": "$70 - 7 = 63$", "note": "Pay 90%" } ] },
      { "q": "A $\\$48$ item has $50\\%$ off. What is the sale price?", "a": "$\\$24$",
        "solution": [ { "math": "$48 \\div 2$", "note": "Halve it" }, { "math": "$= 24$", "note": "Sale price" } ] },
      { "q": "A $\\$240$ item has $25\\%$ off. What is the sale price?", "a": "$\\$180$",
        "solution": [ { "math": "$25\\% \\text{ of } 240 = 60$", "note": "Discount" }, { "math": "$240 - 60 = 180$", "note": "Sale price" } ] },
      { "q": "A $\\$45$ item has $10\\%$ off. What is the sale price?", "a": "$\\$40.50$",
        "solution": [ { "math": "$10\\% \\text{ of } 45 = 4.50$", "note": "Discount" }, { "math": "$45 - 4.50 = 40.50$", "note": "Sale price" } ] },
      { "q": "A $\\$36$ item has $25\\%$ off. What is the sale price?", "a": "$\\$27$",
        "solution": [ { "math": "$36 \\div 4 = 9$", "note": "Discount" }, { "math": "$36 - 9 = 27$", "note": "Sale price" } ] },
      { "q": "A $\\$15$ item has $50\\%$ off. What is the sale price?", "a": "$\\$7.50$",
        "solution": [ { "math": "$15 \\div 2$", "note": "Halve it" }, { "math": "$= 7.50$", "note": "Sale price" } ] },
      { "q": "A $\\$300$ item has $10\\%$ off. What is the sale price?", "a": "$\\$270$",
        "solution": [ { "math": "$10\\% \\text{ of } 300 = 30$", "note": "Discount" }, { "math": "$300 - 30 = 270$", "note": "Sale price" } ] },
      { "q": "A $\\$88$ item has $25\\%$ off. What is the sale price?", "a": "$\\$66$",
        "solution": [ { "math": "$88 \\div 4 = 22$", "note": "Discount" }, { "math": "$88 - 22 = 66$", "note": "Sale price" } ] },
      { "q": "After $50\\%$ off, an item costs $\\$35$. What was the original price?", "a": "$\\$70$",
        "solution": [ { "math": "$50\\% \\text{ paid} = 35$", "note": "Half the original" }, { "math": "$2 \\times 35 = 70$", "note": "Original price" } ] }
    ],
    "mastery": [
      { "q": "A $\\$160$ coat is $25\\%$ off, then a member saves a further $10\\%$ off the sale price. What is the final price?", "a": "$\\$108$",
        "solution": [ { "math": "$160 - 40 = 120$", "note": "25% off" }, { "math": "$120 - 12 = 108$", "note": "10% off the sale price" } ] },
      { "q": "Shop A sells a $\\$200$ item at $25\\%$ off; Shop B at $\\$160$ flat. Which is cheaper?", "a": "Shop A ($\\$150$)",
        "solution": [ { "math": "$200 - 50 = 150$", "note": "Shop A sale price" }, { "math": "$150 < 160$", "note": "Shop A is cheaper" } ] },
      { "q": "A $\\$90$ item has $10\\%$ off and then $\\$5$ off at the register. What is the final price?", "a": "$\\$76$",
        "solution": [ { "math": "$90 - 9 = 81$", "note": "10% off" }, { "math": "$81 - 5 = 76$", "note": "Then $5 off" } ] },
      { "q": "After $25\\%$ off, a phone costs $\\$450$. What was the original price?", "a": "$\\$600$",
        "solution": [ { "math": "$75\\% \\text{ paid} = 450$", "note": "$100\\% - 25\\%$" }, { "math": "$450 \\div 3 \\times 4 = 600$", "note": "Scale up to 100%" } ] },
      { "q": "A $\\$50$ item is $50\\%$ off on Friday and a further $50\\%$ off the new price on Saturday. What is Saturday's price?", "a": "$\\$12.50$",
        "solution": [ { "math": "$50 \\div 2 = 25$", "note": "Friday price" }, { "math": "$25 \\div 2 = 12.50$", "note": "Saturday price" } ] },
      { "q": "A $\\$320$ TV is $10\\%$ off. A second identical TV is bought at the same sale price. What is the total cost?", "a": "$\\$576$",
        "solution": [ { "math": "$320 - 32 = 288$", "note": "Sale price each" }, { "math": "$2 \\times 288 = 576$", "note": "Two TVs" } ] },
      { "q": "Which discount gives a lower price on a $\\$80$ item: $25\\%$ off, or $\\$15$ off?", "a": "$25\\%$ off ($\\$60$)",
        "solution": [ { "math": "$80 - 20 = 60$", "note": "25% off" }, { "math": "$80 - 15 = 65$", "note": "$60 < 65$" } ] },
      { "q": "A $\\$240$ bike is reduced by $50\\%$, but $\\$10$ postage is added. What is the total?", "a": "$\\$130$",
        "solution": [ { "math": "$240 \\div 2 = 120$", "note": "50% off" }, { "math": "$120 + 10 = 130$", "note": "Add postage" } ] },
      { "q": "A store takes $10\\%$ off everything. A trolley of goods totals $\\$130$. What is paid?", "a": "$\\$117$",
        "solution": [ { "math": "$10\\% \\text{ of } 130 = 13$", "note": "Discount" }, { "math": "$130 - 13 = 117$", "note": "Total paid" } ] },
      { "q": "An item is $\\$60$. With $25\\%$ off it is still $\\$5$ more than a rival's price. What is the rival's price?", "a": "$\\$40$",
        "solution": [ { "math": "$60 - 15 = 45$", "note": "Sale price" }, { "math": "$45 - 5 = 40$", "note": "Rival's price" } ] }
    ]
  }
}
