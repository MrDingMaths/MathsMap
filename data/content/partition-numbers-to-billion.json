{
  "skillId": "partition-numbers-to-billion",
  "atomType": "R",
  "theory": {
    "intro": "Partitioning splits a number into parts. The standard partition uses place value; non-standard partitions regroup those parts in other useful ways.",
    "facts": [
      "**Standard partition**: $5\\,372 = 5\\,000 + 300 + 70 + 2$.",
      "**Non-standard partition** regroups a place, e.g. $5\\,372 = 5\\,000 + 200 + 170 + 2$.",
      "Renaming counts a number in one unit, e.g. $4\\,300\\,000 = 43$ hundred-thousands."
    ],
    "steps": [
      "Read each digit's place value.",
      "For a standard partition, write each digit times its place.",
      "To regroup, take $1$ from a higher place and add its value ($10$ of the next unit) lower down."
    ]
  },
  "practice": {
    "foundation": [
      { "q": "Partition $6\\,248$ by place value.", "a": "$6\\,000 + 200 + 40 + 8$",
        "solution": [ { "math": "$6,\\ 2,\\ 4,\\ 8$", "note": "Thousands, hundreds, tens, ones" }, { "math": "$6\\,000 + 200 + 40 + 8$", "note": "Digit × place" } ] },
      { "q": "Partition $35\\,700$ by place value.", "a": "$30\\,000 + 5\\,000 + 700$",
        "solution": [ { "math": "$3,\\ 5,\\ 7$", "note": "Ten-thousands, thousands, hundreds" }, { "math": "$30\\,000 + 5\\,000 + 700$", "note": "Digit × place" } ] },
      { "q": "Partition $4\\,000\\,000 + 200\\,000 + 30\\,000$ into a single number.", "a": "$4\\,230\\,000$",
        "solution": [ { "math": "$4\\,000\\,000 + 200\\,000 + 30\\,000$", "note": "Line up the places" }, { "math": "$4\\,230\\,000$", "note": "Combine" } ] },
      { "q": "Partition $809$ by place value.", "a": "$800 + 9$",
        "solution": [ { "math": "$8,\\ 0,\\ 9$", "note": "$0$ tens" }, { "math": "$800 + 9$", "note": "Skip the zero place" } ] },
      { "q": "Partition $52\\,060$ by place value.", "a": "$50\\,000 + 2\\,000 + 60$",
        "solution": [ { "math": "$5,\\ 2,\\ 0,\\ 6,\\ 0$", "note": "Note the zero hundreds" }, { "math": "$50\\,000 + 2\\,000 + 60$", "note": "Digit × place" } ] },
      { "q": "Write as one number: $700\\,000 + 40\\,000 + 5$.", "a": "$740\\,005$",
        "solution": [ { "math": "$700\\,000 + 40\\,000 + 5$", "note": "Line up the places" }, { "math": "$740\\,005$", "note": "Zeros hold empty places" } ] },
      { "q": "Partition $1\\,250\\,000$ by place value.", "a": "$1\\,000\\,000 + 200\\,000 + 50\\,000$",
        "solution": [ { "math": "$1,\\ 2,\\ 5$", "note": "Millions, hundred-thousands, ten-thousands" }, { "math": "$1\\,000\\,000 + 200\\,000 + 50\\,000$", "note": "Digit × place" } ] },
      { "q": "Partition $3\\,604$ by place value.", "a": "$3\\,000 + 600 + 4$",
        "solution": [ { "math": "$3,\\ 6,\\ 0,\\ 4$", "note": "$0$ tens" }, { "math": "$3\\,000 + 600 + 4$", "note": "Skip the zero place" } ] },
      { "q": "Write as one number: $90\\,000 + 9\\,000 + 900 + 90 + 9$.", "a": "$99\\,999$",
        "solution": [ { "math": "$90\\,000 + 9\\,000 + 900 + 90 + 9$", "note": "Each place has a 9" }, { "math": "$99\\,999$", "note": "Combine" } ] },
      { "q": "Partition $480\\,000$ by place value.", "a": "$400\\,000 + 80\\,000$",
        "solution": [ { "math": "$4,\\ 8$", "note": "Hundred-thousands, ten-thousands" }, { "math": "$400\\,000 + 80\\,000$", "note": "Digit × place" } ] }
    ],
    "development": [
      { "q": "Complete the non-standard partition: $4\\,500 = 4\\,000 + \\square + 100$.", "a": "$400$",
        "solution": [ { "math": "$4\\,500 - 4\\,000 - 100 = 400$", "note": "Find the missing part" }, { "math": "$4\\,000 + 400 + 100 = 4\\,500$", "note": "Check it totals" } ] },
      { "q": "Rename $4\\,300\\,000$ in hundred-thousands.", "a": "$43$ hundred-thousands",
        "solution": [ { "math": "$4\\,300\\,000 \\div 100\\,000$", "note": "How many hundred-thousands?" }, { "math": "$= 43$", "note": "So $43$ hundred-thousands" } ] },
      { "q": "Complete: $6\\,200 = 5\\,000 + \\square$.", "a": "$1\\,200$",
        "solution": [ { "math": "$6\\,200 - 5\\,000 = 1\\,200$", "note": "Non-standard split" }, { "math": "$5\\,000 + 1\\,200 = 6\\,200$", "note": "Check" } ] },
      { "q": "Rename $52\\,000$ in thousands.", "a": "$52$ thousands",
        "solution": [ { "math": "$52\\,000 \\div 1\\,000$", "note": "How many thousands?" }, { "math": "$= 52$", "note": "So $52$ thousands" } ] },
      { "q": "Regroup $3\\,400$ as $\\square$ hundreds.", "a": "$34$ hundreds",
        "solution": [ { "math": "$3\\,400 \\div 100$", "note": "How many hundreds?" }, { "math": "$= 34$", "note": "So $34$ hundreds" } ] },
      { "q": "Complete the non-standard partition: $7\\,000 = 6\\,000 + \\square$.", "a": "$1\\,000$",
        "solution": [ { "math": "$7\\,000 - 6\\,000 = 1\\,000$", "note": "Regroup one thousand" }, { "math": "$6\\,000 + 1\\,000 = 7\\,000$", "note": "Check" } ] },
      { "q": "Write $2\\,508\\,000$ as a standard partition.", "a": "$2\\,000\\,000 + 500\\,000 + 8\\,000$",
        "solution": [ { "math": "$2,\\ 5,\\ 0,\\ 8$", "note": "Note the zero ten-thousands" }, { "math": "$2\\,000\\,000 + 500\\,000 + 8\\,000$", "note": "Digit × place" } ] },
      { "q": "Rename $1\\,000\\,000$ in thousands.", "a": "$1\\,000$ thousands",
        "solution": [ { "math": "$1\\,000\\,000 \\div 1\\,000$", "note": "How many thousands?" }, { "math": "$= 1\\,000$", "note": "So $1\\,000$ thousands" } ] },
      { "q": "Complete: $6\\,372 = 6\\,000 + 200 + \\square + 2$.", "a": "$170$",
        "solution": [ { "math": "$6\\,372 - 6\\,000 - 200 - 2 = 170$", "note": "Non-standard: $300$ split as $200 + 100$, $70$ kept" }, { "math": "$6\\,000 + 200 + 170 + 2 = 6\\,372$", "note": "Check" } ] },
      { "q": "Rename $250$ ten-thousands as a single number.", "a": "$2\\,500\\,000$",
        "solution": [ { "math": "$250 \\times 10\\,000$", "note": "Each is $10\\,000$" }, { "math": "$= 2\\,500\\,000$", "note": "Combine" } ] }
    ],
    "mastery": [
      { "q": "To subtract, $6\\,000$ is regrouped as $5\\,000 + 900 + 100$. Is this correct?", "a": "yes",
        "solution": [ { "math": "$5\\,000 + 900 + 100$", "note": "Add the parts" }, { "math": "$= 6\\,000$", "note": "Correct regrouping" } ] },
      { "q": "Express $1$ billion in millions.", "a": "$1\\,000$ million",
        "solution": [ { "math": "$1\\,000\\,000\\,000 \\div 1\\,000\\,000$", "note": "How many millions?" }, { "math": "$= 1\\,000$", "note": "So $1\\,000$ million" } ] },
      { "q": "A number is $5$ hundred-thousands, $12$ ten-thousands and $3$ thousands. Write it as one number.", "a": "$623\\,000$",
        "solution": [ { "math": "$500\\,000 + 120\\,000 + 3\\,000$", "note": "$12$ ten-thousands $= 120\\,000$" }, { "math": "$= 623\\,000$", "note": "Combine (regroup the extra)" } ] },
      { "q": "Complete: $3\\,000\\,000 = 2\\,000\\,000 + \\square + 500\\,000$.", "a": "$500\\,000$",
        "solution": [ { "math": "$3\\,000\\,000 - 2\\,000\\,000 - 500\\,000$", "note": "Find the missing part" }, { "math": "$= 500\\,000$", "note": "Check it totals" } ] },
      { "q": "Rename $45$ hundreds as thousands and hundreds.", "a": "$4$ thousands and $5$ hundreds ($4\\,500$)",
        "solution": [ { "math": "$45 \\text{ hundreds} = 4\\,500$", "note": "$45 \\times 100$" }, { "math": "$= 4\\,000 + 500$", "note": "Regroup into thousands" } ] },
      { "q": "A shop has $24$ boxes of $1\\,000$ pencils and $7$ loose pencils. How many pencils, and how is this partitioned?", "a": "$24\\,007 = 24\\,000 + 7$",
        "solution": [ { "math": "$24 \\times 1\\,000 = 24\\,000$", "note": "The boxes" }, { "math": "$24\\,000 + 7 = 24\\,007$", "note": "Add the loose pencils" } ] },
      { "q": "Write $807\\,060$ as a standard partition.", "a": "$800\\,000 + 7\\,000 + 60$",
        "solution": [ { "math": "$8,\\ 0,\\ 7,\\ 0,\\ 6,\\ 0$", "note": "Two zero places" }, { "math": "$800\\,000 + 7\\,000 + 60$", "note": "Skip the zeros" } ] },
      { "q": "How many ten-thousands are in $3\\,400\\,000$?", "a": "$340$",
        "solution": [ { "math": "$3\\,400\\,000 \\div 10\\,000$", "note": "How many ten-thousands?" }, { "math": "$= 340$", "note": "So $340$ ten-thousands" } ] },
      { "q": "Complete the non-standard partition: $52\\,000 = 40\\,000 + \\square$.", "a": "$12\\,000$",
        "solution": [ { "math": "$52\\,000 - 40\\,000 = 12\\,000$", "note": "Regroup" }, { "math": "$40\\,000 + 12\\,000 = 52\\,000$", "note": "Check" } ] },
      { "q": "A number is $9$ millions, $9$ hundred-thousands and $11$ ten-thousands. Write it as one number.", "a": "$10\\,010\\,000$",
        "solution": [ { "math": "$9\\,000\\,000 + 900\\,000 + 110\\,000$", "note": "$11$ ten-thousands $= 110\\,000$" }, { "math": "$= 10\\,010\\,000$", "note": "Regroup the carry" } ] }
    ]
  }
}
