{
  "skillId": "measure-angles-protractor",
  "atomType": "R",
  "theory": {
    "intro": "A protractor measures angles in degrees ($^{\\circ}$). Lining it up correctly is the key to a correct reading.",
    "facts": [
      "Place the protractor's **centre** on the vertex and the $0^{\\circ}$ line along one arm.",
      "Read where the **other arm** crosses the scale, using the scale that starts at $0^{\\circ}$.",
      "A full protractor turn is $360^{\\circ}$; record the size with a degree sign, e.g. $52^{\\circ}$."
    ],
    "steps": [
      "Line the centre on the vertex and $0^{\\circ}$ along one arm.",
      "Follow the second arm out to the scale.",
      "Read the number on the scale that began at $0^{\\circ}$, and write it with $^{\\circ}$."
    ]
  },
  "practice": {
    "foundation": [
      { "q": "The second arm crosses the scale at the $40$ mark, reading from $0^{\\circ}$. What is the angle?", "a": "$40^{\\circ}$",
        "tikz": "\\begin{tikzpicture}[scale=1]\n\\coordinate (O) at (0,0);\n\\draw[thick] (O)--(2.4,0);\n\\draw[thick] (O)--(40:2.4);\n\\draw (1,0) arc (0:40:1);\n\\node at (20:1.35) {$x$};\n\\end{tikzpicture}",
        "solution": [ { "math": "$\\text{read scale from } 0^{\\circ}$", "note": "Arm meets the 40 mark" }, { "math": "$= 40^{\\circ}$", "note": "" } ] },
      { "q": "The second arm crosses at the $70$ mark. What is the angle?", "a": "$70^{\\circ}$",
        "tikz": "\\begin{tikzpicture}[scale=1]\n\\coordinate (O) at (0,0);\n\\draw[thick] (O)--(2.4,0);\n\\draw[thick] (O)--(70:2.4);\n\\draw (1,0) arc (0:70:1);\n\\node at (35:1.35) {$x$};\n\\end{tikzpicture}",
        "solution": [ { "math": "$\\text{read scale from } 0^{\\circ}$", "note": "Arm meets the 70 mark" }, { "math": "$= 70^{\\circ}$", "note": "" } ] },
      { "q": "The second arm crosses at the $90$ mark. What is the angle?", "a": "$90^{\\circ}$",
        "tikz": "\\begin{tikzpicture}[scale=1]\n\\coordinate (O) at (0,0);\n\\draw[thick] (O)--(2.4,0);\n\\draw[thick] (O)--(90:2.4);\n\\draw (0,0.4)--(0.4,0.4)--(0.4,0);\n\\end{tikzpicture}",
        "solution": [ { "math": "$\\text{read scale from } 0^{\\circ}$", "note": "Right angle mark" }, { "math": "$= 90^{\\circ}$", "note": "" } ] },
      { "q": "The second arm crosses at the $120$ mark. What is the angle?", "a": "$120^{\\circ}$",
        "tikz": "\\begin{tikzpicture}[scale=1]\n\\coordinate (O) at (0,0);\n\\draw[thick] (O)--(2.4,0);\n\\draw[thick] (O)--(120:2.4);\n\\draw (1,0) arc (0:120:1);\n\\node at (60:1.35) {$x$};\n\\end{tikzpicture}",
        "solution": [ { "math": "$\\text{read scale from } 0^{\\circ}$", "note": "Arm meets the 120 mark" }, { "math": "$= 120^{\\circ}$", "note": "" } ] },
      { "q": "The second arm crosses at the $25$ mark. What is the angle?", "a": "$25^{\\circ}$",
        "tikz": "\\begin{tikzpicture}[scale=1]\n\\coordinate (O) at (0,0);\n\\draw[thick] (O)--(2.4,0);\n\\draw[thick] (O)--(25:2.4);\n\\draw (1,0) arc (0:25:1);\n\\node at (12:1.4) {$x$};\n\\end{tikzpicture}",
        "solution": [ { "math": "$\\text{read scale from } 0^{\\circ}$", "note": "Arm meets the 25 mark" }, { "math": "$= 25^{\\circ}$", "note": "" } ] },
      { "q": "The second arm crosses at the $150$ mark. What is the angle?", "a": "$150^{\\circ}$",
        "tikz": "\\begin{tikzpicture}[scale=1]\n\\coordinate (O) at (0,0);\n\\draw[thick] (O)--(2.4,0);\n\\draw[thick] (O)--(150:2.4);\n\\draw (1,0) arc (0:150:1);\n\\node at (75:1.35) {$x$};\n\\end{tikzpicture}",
        "solution": [ { "math": "$\\text{read scale from } 0^{\\circ}$", "note": "Arm meets the 150 mark" }, { "math": "$= 150^{\\circ}$", "note": "" } ] },
      { "q": "The second arm crosses at the $55$ mark. What is the angle?", "a": "$55^{\\circ}$",
        "tikz": "\\begin{tikzpicture}[scale=1]\n\\coordinate (O) at (0,0);\n\\draw[thick] (O)--(2.4,0);\n\\draw[thick] (O)--(55:2.4);\n\\draw (1,0) arc (0:55:1);\n\\node at (27:1.35) {$x$};\n\\end{tikzpicture}",
        "solution": [ { "math": "$\\text{read scale from } 0^{\\circ}$", "note": "Arm meets the 55 mark" }, { "math": "$= 55^{\\circ}$", "note": "" } ] },
      { "q": "The second arm crosses at the $135$ mark. What is the angle?", "a": "$135^{\\circ}$",
        "tikz": "\\begin{tikzpicture}[scale=1]\n\\coordinate (O) at (0,0);\n\\draw[thick] (O)--(2.4,0);\n\\draw[thick] (O)--(135:2.4);\n\\draw (1,0) arc (0:135:1);\n\\node at (67:1.35) {$x$};\n\\end{tikzpicture}",
        "solution": [ { "math": "$\\text{read scale from } 0^{\\circ}$", "note": "Arm meets the 135 mark" }, { "math": "$= 135^{\\circ}$", "note": "" } ] },
      { "q": "The second arm crosses at the $10$ mark. What is the angle?", "a": "$10^{\\circ}$",
        "tikz": "\\begin{tikzpicture}[scale=1]\n\\coordinate (O) at (0,0);\n\\draw[thick] (O)--(2.4,0);\n\\draw[thick] (O)--(10:2.4);\n\\draw (1,0) arc (0:10:1);\n\\node at (5:1.5) {$x$};\n\\end{tikzpicture}",
        "solution": [ { "math": "$\\text{read scale from } 0^{\\circ}$", "note": "Arm meets the 10 mark" }, { "math": "$= 10^{\\circ}$", "note": "" } ] },
      { "q": "Record an angle of forty-five degrees using the degree symbol.", "a": "$45^{\\circ}$",
        "solution": [ { "math": "$\\text{forty-five degrees}$", "note": "Use the degree sign" }, { "math": "$= 45^{\\circ}$", "note": "" } ] }
    ],
    "development": [
      { "q": "The $0^{\\circ}$ line is on the lower arm and the upper arm reads $80$ on the scale. State the angle.", "a": "$80^{\\circ}$",
        "tikz": "\\begin{tikzpicture}[scale=1]\n\\coordinate (O) at (0,0);\n\\draw[thick] (O)--(2.4,0);\n\\draw[thick] (O)--(80:2.4);\n\\draw (1,0) arc (0:80:1);\n\\node at (40:1.35) {$x$};\n\\end{tikzpicture}",
        "solution": [ { "math": "$\\text{scale from } 0^{\\circ} = 80$", "note": "Read where the arm crosses" }, { "math": "$= 80^{\\circ}$", "note": "" } ] },
      { "q": "An angle reads at the $20$ mark and a second at the $65$ mark. How much larger is the second?", "a": "$45^{\\circ}$",
        "solution": [ { "math": "$65^{\\circ} - 20^{\\circ}$", "note": "Difference of readings" }, { "math": "$= 45^{\\circ}$", "note": "" } ] },
      { "q": "An arm crosses at the $160$ mark. Is the angle acute or obtuse, and what is its size?", "a": "obtuse, $160^{\\circ}$",
        "tikz": "\\begin{tikzpicture}[scale=1]\n\\coordinate (O) at (0,0);\n\\draw[thick] (O)--(2.4,0);\n\\draw[thick] (O)--(160:2.4);\n\\draw (1,0) arc (0:160:1);\n\\node at (80:1.35) {$x$};\n\\end{tikzpicture}",
        "solution": [ { "math": "$160^{\\circ} > 90^{\\circ}$", "note": "Bigger than a right angle" }, { "math": "$\\text{obtuse}, 160^{\\circ}$", "note": "" } ] },
      { "q": "A protractor reading is between the $50$ and $60$ marks, exactly halfway. What is the angle?", "a": "$55^{\\circ}$",
        "solution": [ { "math": "$\\dfrac{50 + 60}{2}$", "note": "Halfway between marks" }, { "math": "$= 55^{\\circ}$", "note": "" } ] },
      { "q": "An arm crosses at the $30$ mark. What is the size of the angle, and what type is it?", "a": "$30^{\\circ}$, acute",
        "tikz": "\\begin{tikzpicture}[scale=1]\n\\coordinate (O) at (0,0);\n\\draw[thick] (O)--(2.4,0);\n\\draw[thick] (O)--(30:2.4);\n\\draw (1,0) arc (0:30:1);\n\\node at (15:1.4) {$x$};\n\\end{tikzpicture}",
        "solution": [ { "math": "$30^{\\circ} < 90^{\\circ}$", "note": "Smaller than a right angle" }, { "math": "$30^{\\circ}, \\text{ acute}$", "note": "" } ] },
      { "q": "A student lines up $0^{\\circ}$ on one arm and the other reads $105$. State the angle.", "a": "$105^{\\circ}$",
        "tikz": "\\begin{tikzpicture}[scale=1]\n\\coordinate (O) at (0,0);\n\\draw[thick] (O)--(2.4,0);\n\\draw[thick] (O)--(105:2.4);\n\\draw (1,0) arc (0:105:1);\n\\node at (52:1.35) {$x$};\n\\end{tikzpicture}",
        "solution": [ { "math": "$\\text{scale from } 0^{\\circ} = 105$", "note": "Read the crossing" }, { "math": "$= 105^{\\circ}$", "note": "" } ] },
      { "q": "Two arms of a turning gate read $15^{\\circ}$ then $75^{\\circ}$. Through how many degrees did the gate turn?", "a": "$60^{\\circ}$",
        "solution": [ { "math": "$75^{\\circ} - 15^{\\circ}$", "note": "Change in reading" }, { "math": "$= 60^{\\circ}$", "note": "" } ] },
      { "q": "An arm crosses at the $90$ mark. Without measuring, what should you check on the diagram?", "a": "the right-angle (square) mark",
        "solution": [ { "math": "$90^{\\circ} = \\text{right angle}$", "note": "Look for the square" }, { "math": "$\\text{a right angle}$", "note": "" } ] },
      { "q": "An arm reads $140$ on the scale. State the angle and its type.", "a": "$140^{\\circ}$, obtuse",
        "solution": [ { "math": "$90^{\\circ} < 140^{\\circ} < 180^{\\circ}$", "note": "Between right and straight" }, { "math": "$140^{\\circ}, \\text{ obtuse}$", "note": "" } ] },
      { "q": "An arm crosses at the $5$ mark. What is the angle, and is it acute?", "a": "$5^{\\circ}$, yes",
        "solution": [ { "math": "$5^{\\circ} < 90^{\\circ}$", "note": "Very small" }, { "math": "$5^{\\circ}, \\text{ acute}$", "note": "" } ] }
    ],
    "mastery": [
      { "q": "A reflex angle is needed. You measure the inner angle as $130^{\\circ}$. What is the reflex angle?", "a": "$230^{\\circ}$",
        "solution": [ { "math": "$360^{\\circ} - 130^{\\circ}$", "note": "Rest of the full turn" }, { "math": "$= 230^{\\circ}$", "note": "" } ] },
      { "q": "A protractor only goes to $180^{\\circ}$. To measure a reflex angle of $300^{\\circ}$, you measure the inner part. What does it read?", "a": "$60^{\\circ}$",
        "solution": [ { "math": "$360^{\\circ} - 300^{\\circ}$", "note": "Inner angle" }, { "math": "$= 60^{\\circ}$", "note": "" } ] },
      { "q": "An arm sits between the $70$ and $80$ marks, two-fifths of the way from $70$. What is the angle?", "a": "$74^{\\circ}$",
        "solution": [ { "math": "$70 + \\tfrac{2}{5} \\times 10$", "note": "Two-fifths of the gap" }, { "math": "$= 74^{\\circ}$", "note": "" } ] },
      { "q": "Reading on the wrong scale, a student writes $130^{\\circ}$ for an acute angle. What is the correct reading?", "a": "$50^{\\circ}$",
        "solution": [ { "math": "$180^{\\circ} - 130^{\\circ}$", "note": "Switch to the 0-start scale" }, { "math": "$= 50^{\\circ}$", "note": "Acute, as expected" } ] },
      { "q": "Three angles meet at a point, measured as $120^{\\circ}$, $90^{\\circ}$ and the last unread. What is the last angle?", "a": "$150^{\\circ}$",
        "solution": [ { "math": "$360^{\\circ} - 120^{\\circ} - 90^{\\circ}$", "note": "Angles at a point" }, { "math": "$= 150^{\\circ}$", "note": "" } ] },
      { "q": "A pie chart sector measures $72^{\\circ}$ with a protractor. What fraction of the whole circle is this?", "a": "$\\tfrac{1}{5}$",
        "solution": [ { "math": "$\\dfrac{72^{\\circ}}{360^{\\circ}}$", "note": "Out of a full turn" }, { "math": "$= \\tfrac{1}{5}$", "note": "" } ] },
      { "q": "You measure an angle as $48^{\\circ}$ but the true value is $50^{\\circ}$. What is your measurement error?", "a": "$2^{\\circ}$",
        "solution": [ { "math": "$50^{\\circ} - 48^{\\circ}$", "note": "Difference" }, { "math": "$= 2^{\\circ}$", "note": "" } ] },
      { "q": "An angle and its reflex add to $360^{\\circ}$. If the reflex is $215^{\\circ}$, what is the angle?", "a": "$145^{\\circ}$",
        "solution": [ { "math": "$360^{\\circ} - 215^{\\circ}$", "note": "Full turn minus reflex" }, { "math": "$= 145^{\\circ}$", "note": "" } ] },
      { "q": "A clock's minute hand sweeps from the $12$ to the $4$. What angle does it turn, measured in degrees?", "a": "$120^{\\circ}$",
        "solution": [ { "math": "$\\dfrac{4}{12} \\times 360^{\\circ}$", "note": "Four of twelve marks" }, { "math": "$= 120^{\\circ}$", "note": "" } ] },
      { "q": "Two measurements of the same angle give $63^{\\circ}$ and $65^{\\circ}$. Record the average as the best estimate.", "a": "$64^{\\circ}$",
        "solution": [ { "math": "$\\dfrac{63^{\\circ} + 65^{\\circ}}{2}$", "note": "Average the readings" }, { "math": "$= 64^{\\circ}$", "note": "" } ] }
    ]
  }
}
