      { "q": "A student writes $5\\,640 \\div 8 = 75$. Is that reasonable?", "a": "No — about $700$ expected",
        "solution": [ { "math": "$5\\,600 \\div 8 = 700$", "note": "Estimate" }, { "math": "$75 \\ll 700$", "note": "Far too small" } ] },
      { "q": "Is $419 \\times 21 = 8\\,799$ reasonable?", "a": "Yes",
        "solution": [ { "math": "$400 \\times 20 = 8\\,000$", "note": "Estimate" }, { "math": "$8\\,799 \\approx 8\\,000$", "note": "Reasonable" } ] },
      { "q": "Is $3\\,640 \\div 9 \\approx 404$ reasonable?", "a": "Yes",
