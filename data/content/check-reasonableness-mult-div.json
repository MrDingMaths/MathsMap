    ],
    "mastery": [
      { "q": "A receipt lists $24$ items at $\\$19$ each totalling $\\$45.60$. Is the total reasonable?", "a": "No — about $\\$480$ expected",
        "solution": [ { "math": "$24 \\times 20 = 480$", "note": "Estimate" }, { "math": "$\\$45.60 \\ll \\$480$", "note": "Decimal error" } ] },
      { "q": "$5\\,952$ km is driven over $8$ days. A log says $74$ km/day. Reasonable?", "a": "No — about $750$ km/day expected",
        "solution": [ { "math": "$6\\,000 \\div 8 = 750$", "note": "Estimate" }, { "math": "$74 \\ll 750$", "note": "Far too small" } ] },
      { "q": "A worker earns $\\$31$/h for $38$ h, reported as $\\$1\\,178$. Reasonable?", "a": "Yes",
        "solution": [ { "math": "$30 \\times 40 = 1\\,200$", "note": "Estimate" }, { "math": "$1\\,178 \\approx 1\\,200$", "note": "Reasonable" } ] },
      { "q": "$3\\,128$ tickets are split among $4$ sellers, recorded as $782$ each. Reasonable?", "a": "Yes",
        "solution": [ { "math": "$3\\,200 \\div 4 = 800$", "note": "Estimate" }, { "math": "$782 \\approx 800$", "note": "Reasonable" } ] },
      { "q": "A class of $29$ paid $\\$48$ each; the teacher banked $\\$13\\,920$. Reasonable?", "a": "No — about $\\$1\\,500$ expected",
        "solution": [ { "math": "$30 \\times 50 = 1\\,500$", "note": "Estimate" }, { "math": "$13\\,920 \\gg 1\\,500$", "note": "Off by a factor of $10$" } ] },
      { "q": "A truck of $4\\,176$ bricks unloads onto $6$ sites, logged as $696$ each. Reasonable?", "a": "Yes",
        "solution": [ { "math": "$4\\,200 \\div 6 = 700$", "note": "Estimate" }, { "math": "$696 \\approx 700$", "note": "Reasonable" } ] },
      { "q": "A shop sells $412$ coffees at $\\$5$, recording takings of $\\$206$. Reasonable?", "a": "No — about $\\$2\\,000$ expected",
        "solution": [ { "math": "$400 \\times 5 = 2\\,000$", "note": "Estimate" }, { "math": "$\\$206 \\ll \\$2\\,000$", "note": "Far too small" } ] },
      { "q": "$9\\,135 \\div 9$ is given as $1\\,015$. Use estimation to judge it.", "a": "Yes",
        "solution": [ { "math": "$9\\,000 \\div 9 = 1\\,000$", "note": "Estimate" }, { "math": "$1\\,015 \\approx 1\\,000$", "note": "Reasonable" } ] },
      { "q": "A farmer plants $58$ rows of $39$ trees, claimed as $22\\,620$ trees. Reasonable?", "a": "No — about $2\\,400$ expected",
        "solution": [ { "math": "$60 \\times 40 = 2\\,400$", "note": "Estimate" }, { "math": "$22\\,620 \\gg 2\\,400$", "note": "Off by a factor of $10$" } ] },
      { "q": "A $\\$2\\,388$ prize is shared by $4$ winners, recorded as $\\$597$ each. Reasonable?", "a": "Yes",
        "solution": [ { "math": "$2\\,400 \\div 4 = 600$", "note": "Estimate" }, { "math": "$597 \\approx 600$", "note": "Reasonable" } ] }
    ]
  }
}
