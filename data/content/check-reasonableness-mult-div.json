{
  "skillId": "check-reasonableness-mult-div",
  "atomType": "R",
  "theory": {
    "intro": "Estimation gives a quick way to judge whether a calculated answer is sensible. Round the numbers, work out a rough answer, and compare.",
    "facts": [
      "Round each number to a tidy value, then multiply or divide.",
      "If the exact answer is far from the estimate, recheck the working.",
      "A misplaced digit usually makes an answer about $10$ times too big or small."
    ],
    "steps": [
      "Round the numbers in the calculation.",
      "Find the estimate.",
      "Compare the given answer with the estimate and judge if it is reasonable."
    ]
  },
  "practice": {
    "foundation": [
      { "q": "Is $38 \\times 21 = 798$ reasonable? Estimate to check.", "a": "Yes",
        "solution": [ { "math": "$40 \\times 20 = 800$", "note": "Estimate" }, { "math": "$798 \\approx 800$", "note": "Reasonable" } ] },
      { "q": "Is $52 \\times 19 = 98$ reasonable? Estimate to check.", "a": "No — too small",
        "solution": [ { "math": "$50 \\times 20 = 1\\,000$", "note": "Estimate" }, { "math": "$98 \\ll 1\\,000$", "note": "Not reasonable" } ] },
      { "q": "Estimate to check $612 \\div 3 = 204$.", "a": "Reasonable",
        "solution": [ { "math": "$600 \\div 3 = 200$", "note": "Estimate" }, { "math": "$204 \\approx 200$", "note": "Reasonable" } ] },
      { "q": "Is $29 \\times 31 = 899$ reasonable?", "a": "Yes",
        "solution": [ { "math": "$30 \\times 30 = 900$", "note": "Estimate" }, { "math": "$899 \\approx 900$", "note": "Reasonable" } ] },
      { "q": "Is $483 \\div 7 = 9$ reasonable?", "a": "No — too small",
        "solution": [ { "math": "$490 \\div 7 = 70$", "note": "Estimate" }, { "math": "$9 \\ll 70$", "note": "Not reasonable" } ] },
      { "q": "Is $48 \\times 52 = 2\\,496$ reasonable?", "a": "Yes",
        "solution": [ { "math": "$50 \\times 50 = 2\\,500$", "note": "Estimate" }, { "math": "$2\\,496 \\approx 2\\,500$", "note": "Reasonable" } ] },
      { "q": "Estimate to check $396 \\div 4 = 99$.", "a": "Reasonable",
        "solution": [ { "math": "$400 \\div 4 = 100$", "note": "Estimate" }, { "math": "$99 \\approx 100$", "note": "Reasonable" } ] },
      { "q": "Is $61 \\times 18 = 1\\,098$ reasonable?", "a": "Yes",
        "solution": [ { "math": "$60 \\times 20 = 1\\,200$", "note": "Estimate" }, { "math": "$1\\,098 \\approx 1\\,200$", "note": "Reasonable" } ] },
      { "q": "Is $720 \\div 9 = 8$ reasonable?", "a": "No — too small",
        "solution": [ { "math": "$720 \\div 9 = 80$", "note": "Estimate" }, { "math": "$8 \\ll 80$", "note": "Not reasonable" } ] },
      { "q": "Is $42 \\times 28 = 1\\,176$ reasonable?", "a": "Yes",
        "solution": [ { "math": "$40 \\times 30 = 1\\,200$", "note": "Estimate" }, { "math": "$1\\,176 \\approx 1\\,200$", "note": "Reasonable" } ] }
    ],
    "development": [
      { "q": "A student gets $187 \\times 6 = 112$. Use estimation to show this is wrong.", "a": "Wrong — should be about $1\\,200$",
        "solution": [ { "math": "$200 \\times 6 = 1\\,200$", "note": "Estimate" }, { "math": "$112 \\ll 1\\,200$", "note": "Far too small" } ] },
      { "q": "Is $324 \\times 19 = 6\\,156$ reasonable?", "a": "Yes",
        "solution": [ { "math": "$300 \\times 20 = 6\\,000$", "note": "Estimate" }, { "math": "$6\\,156 \\approx 6\\,000$", "note": "Reasonable" } ] },
      { "q": "Is $4\\,872 \\div 6 = 812$ reasonable?", "a": "Yes",
