      { "q": "Estimate $48 + 31$ by rounding each to the nearest ten.", "a": "$\\approx 80$",
        "solution": [ { "math": "$48 \\to 50,\\ 31 \\to 30$", "note": "Round to tens" }, { "math": "$50 + 30 = 80$", "note": "$\\approx 80$" } ] },
      { "q": "Estimate $62 - 19$ by rounding each to the nearest ten.", "a": "$\\approx 40$",
        "solution": [ { "math": "$62 \\to 60,\\ 19 \\to 20$", "note": "Round to tens" }, { "math": "$60 - 20 = 40$", "note": "$\\approx 40$" } ] },
      { "q": "Estimate $412 + 285$ by rounding each to the nearest hundred.", "a": "$\\approx 700$",
