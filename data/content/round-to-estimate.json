      { "q": "A budget is $\\$5\\,000$. Expenses are $\\$2\\,180$, $\\$1\\,470$ and $\\$890$. Estimate (to the nearest thousand) whether the budget is enough.", "a": "$\\approx \\$4\\,000$ — yes, enough",
        "solution": [ { "math": "$2\\,000 + 1\\,000 + 1\\,000 = 4\\,000$", "note": "Round each to thousands" }, { "math": "$4\\,000 < 5\\,000$", "note": "Budget is enough" } ] },
      { "q": "Estimate $9\\,820 + 9\\,950 + 9\\,780$ to the nearest thousand.", "a": "$\\approx 30\\,000$",
        "solution": [ { "math": "$10\\,000 + 10\\,000 + 10\\,000$", "note": "Each rounds up" }, { "math": "$= 30\\,000$", "note": "$\\approx 30\\,000$" } ] },
      { "q": "A car costs $\\$28\\,450$ and a trade-in is worth $\\$11\\,800$. Estimate the amount to pay (nearest thousand).", "a": "$\\approx \\$16\\,000$",
        "solution": [ { "math": "$28\\,450 \\to 28\\,000,\\ 11\\,800 \\to 12\\,000$", "note": "Round to thousands" }, { "math": "$28\\,000 - 12\\,000 = 16\\,000$", "note": "$\\approx \\$16\\,000$" } ] },
      { "q": "Why might rounding $19.95 + 19.95$ to $20 + 20 = 40$ slightly overestimate the true total?", "a": "Both numbers were rounded up",
        "solution": [ { "math": "$19.95 \\to 20$ (up)", "note": "Each gained $0.05$" }, { "math": "$\\text{true} = 39.90 < 40$", "note": "Estimate is a little high" } ] },
      { "q": "Estimate $\\$4\\,950 + \\$2\\,030 + \\$1\\,080$ to the nearest thousand, then state if it is over $\\$8\\,000$.", "a": "$\\approx \\$8\\,000$; about equal",
        "solution": [ { "math": "$5\\,000 + 2\\,000 + 1\\,000 = 8\\,000$", "note": "Round each" }, { "math": "$\\approx 8\\,000$", "note": "Close to the limit" } ] },
      { "q": "A tank had $6\\,180$ L and $2\\,940$ L was drawn off. Estimate what remains to the nearest thousand.", "a": "$\\approx 3\\,000$ L",
        "solution": [ { "math": "$6\\,180 \\to 6\\,000,\\ 2\\,940 \\to 3\\,000$", "note": "Round to thousands" }, { "math": "$6\\,000 - 3\\,000 = 3\\,000$", "note": "$\\approx 3\\,000$ L" } ] },
      { "q": "Choose a sensible rounding place to estimate $382 + 6\\,415$ quickly, then estimate.", "a": "Nearest hundred (or thousand); $\\approx 6\\,800$",
