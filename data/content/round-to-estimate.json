{
  "skillId": "round-to-estimate",
  "atomType": "R",
  "theory": {
    "intro": "An estimate is a quick approximate answer. Round each number to a convenient place, then calculate with the rounded numbers.",
    "facts": [
      "Round each number to the **same sensible place** (often the leading digit) before calculating.",
      "Look at the next digit: $5$ or more rounds **up**, $4$ or less rounds **down**.",
      "An estimate is **not** the exact answer — it is close and easy to compute mentally.",
      "Use the symbol $\\approx$ ('approximately equal to') for estimates."
    ],
    "steps": [
      "Round each number to a convenient place value.",
      "Do the calculation with the rounded numbers.",
      "State the estimate using $\\approx$."
    ]
  },
  "practice": {
