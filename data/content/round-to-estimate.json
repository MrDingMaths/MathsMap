    "mastery": [
      { "q": "A trip is $1\\,840$ km one way. Estimate the round trip by rounding to the nearest thousand.", "a": "$\\approx 4\\,000$ km",
        "solution": [ { "math": "$1\\,840 \\to 2\\,000$", "note": "Round to thousands" }, { "math": "$2\\,000 + 2\\,000 = 4\\,000$", "note": "$\\approx 4\\,000$ km" } ] },
      { "q": "A cart holds items costing $\\$12.80$, $\\$7.95$ and $\\$4.20$. Estimate the total to the nearest dollar.", "a": "$\\approx \\$25$",
