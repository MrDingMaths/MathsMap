{
  "skillId": "decimal-place-value-x10",
  "atomType": "R",
  "theory": {
    "intro": "Multiplying or dividing a decimal by $10$ or $100$ moves every digit to a new place-value column.",
    "facts": [
      "$\\times 10$ makes each digit $10$ times bigger → digits shift **one place left**.",
      "$\\div 10$ (or $\\tfrac{1}{10}$ of) makes each digit $10$ times smaller → digits shift **one place right**.",
      "$\\times 100$ or $\\div 100$ shifts digits **two places**."
    ],
    "steps": [
      "Decide the direction: bigger (×) shifts left, smaller (÷) shifts right.",
      "Decide how many places: $10 \\to 1$ place, $100 \\to 2$ places.",
      "Insert zeros where a place would otherwise be empty."
    ]
  },
  "practice": {
    "foundation": [
      { "q": "Find $10 \\times 0.4$.", "a": "$4$",
        "solution": [ { "math": "$0.4 \\times 10$", "note": "Shift one place left" }, { "math": "$= 4$", "note": "" } ] },
      { "q": "Find $\\tfrac{1}{10}$ of $0.6$.", "a": "$0.06$",
        "solution": [ { "math": "$0.6 \\div 10$", "note": "Shift one place right" }, { "math": "$= 0.06$", "note": "" } ] },
      { "q": "Find $100 \\times 0.07$.", "a": "$7$",
        "solution": [ { "math": "$0.07 \\times 100$", "note": "Shift two places left" }, { "math": "$= 7$", "note": "" } ] },
      { "q": "Find $0.5 \\div 10$.", "a": "$0.05$",
        "solution": [ { "math": "$0.5 \\div 10$", "note": "Shift one place right" }, { "math": "$= 0.05$", "note": "" } ] },
      { "q": "Find $10 \\times 0.25$.", "a": "$2.5$",
        "solution": [ { "math": "$0.25 \\times 10$", "note": "Shift one place left" }, { "math": "$= 2.5$", "note": "" } ] },
      { "q": "Find $\\tfrac{1}{100}$ of $3$.", "a": "$0.03$",
        "solution": [ { "math": "$3 \\div 100$", "note": "Shift two places right" }, { "math": "$= 0.03$", "note": "" } ] },
      { "q": "Find $100 \\times 0.6$.", "a": "$60$",
        "solution": [ { "math": "$0.6 \\times 100$", "note": "Shift two places left" }, { "math": "$= 60$", "note": "Zero fills the ones place" } ] },
      { "q": "Find $0.8 \\div 100$.", "a": "$0.008$",
        "solution": [ { "math": "$0.8 \\div 100$", "note": "Shift two places right" }, { "math": "$= 0.008$", "note": "" } ] },
      { "q": "Find $10 \\times 1.2$.", "a": "$12$",
        "solution": [ { "math": "$1.2 \\times 10$", "note": "Shift one place left" }, { "math": "$= 12$", "note": "" } ] },
      { "q": "Find $\\tfrac{1}{10}$ of $9$.", "a": "$0.9$",
        "solution": [ { "math": "$9 \\div 10$", "note": "Shift one place right" }, { "math": "$= 0.9$", "note": "" } ] }
    ],
    "development": [
      { "q": "Find $100 \\times 0.345$.", "a": "$34.5$",
        "solution": [ { "math": "$0.345 \\times 100$", "note": "Shift two places left" }, { "math": "$= 34.5$", "note": "" } ] },
      { "q": "Find $\\tfrac{1}{100}$ of $4.5$.", "a": "$0.045$",
        "solution": [ { "math": "$4.5 \\div 100$", "note": "Shift two places right" }, { "math": "$= 0.045$", "note": "" } ] },
      { "q": "$0.7 \\times \\square = 7$. Find $\\square$.", "a": "$10$",
        "solution": [ { "math": "$0.7 \\to 7$", "note": "One place left = ×10" }, { "math": "$\\square = 10$", "note": "" } ] },
      { "q": "Find $10 \\times 0.09$.", "a": "$0.9$",
        "solution": [ { "math": "$0.09 \\times 10$", "note": "Shift one place left" }, { "math": "$= 0.9$", "note": "" } ] },
      { "q": "$5.2 \\div \\square = 0.052$. Find $\\square$.", "a": "$100$",
        "solution": [ { "math": "$5.2 \\to 0.052$", "note": "Two places right = ÷100" }, { "math": "$\\square = 100$", "note": "" } ] },
      { "q": "Find $100 \\times 2.08$.", "a": "$208$",
        "solution": [ { "math": "$2.08 \\times 100$", "note": "Shift two places left" }, { "math": "$= 208$", "note": "" } ] },
      { "q": "Find $\\tfrac{1}{10}$ of $0.05$.", "a": "$0.005$",
        "solution": [ { "math": "$0.05 \\div 10$", "note": "Shift one place right" }, { "math": "$= 0.005$", "note": "" } ] },
      { "q": "Which is larger: $10 \\times 0.36$ or $100 \\times 0.03$?", "a": "$10 \\times 0.36 = 3.6$",
        "solution": [ { "math": "$0.36 \\times 10 = 3.6$", "note": "First value" }, { "math": "$0.03 \\times 100 = 3$", "note": "$3.6 > 3$" } ] },
      { "q": "Find $0.04 \\times 100$.", "a": "$4$",
        "solution": [ { "math": "$0.04 \\times 100$", "note": "Shift two places left" }, { "math": "$= 4$", "note": "" } ] },
      { "q": "$\\square \\div 10 = 0.7$. Find $\\square$.", "a": "$7$",
        "solution": [ { "math": "$\\square \\to 0.7$", "note": "÷10 shifted right, so reverse it" }, { "math": "$\\square = 7$", "note": "" } ] }
    ],
    "mastery": [
      { "q": "$1$ pen costs $\\$0.85$. How much do $100$ pens cost?", "a": "$\\$85$",
        "solution": [ { "math": "$0.85 \\times 100$", "note": "Shift two places left" }, { "math": "$= 85$", "note": "" } ] },
      { "q": "A bag of $10$ identical screws has mass $0.4$ kg. What is the mass of one screw?", "a": "$0.04$ kg",
        "solution": [ { "math": "$0.4 \\div 10$", "note": "Shift one place right" }, { "math": "$= 0.04$", "note": "" } ] },
      { "q": "Start with $0.6$. Multiply by $10$, then divide by $100$. What is the result?", "a": "$0.06$",
        "solution": [ { "math": "$0.6 \\times 10 = 6$", "note": "First step" }, { "math": "$6 \\div 100 = 0.06$", "note": "Second step" } ] },
      { "q": "A number became $4.5$ after being multiplied by $100$. What was the original number?", "a": "$0.045$",
        "solution": [ { "math": "$4.5 \\div 100$", "note": "Undo ×100 with ÷100" }, { "math": "$= 0.045$", "note": "" } ] },
      { "q": "Which gives the larger answer: $\\tfrac{1}{10}$ of $50$, or $100 \\times 0.06$?", "a": "$100 \\times 0.06 = 6$",
        "solution": [ { "math": "$50 \\div 10 = 5$", "note": "First value" }, { "math": "$0.06 \\times 100 = 6$", "note": "$6 > 5$, so this is larger" } ] },
      { "q": "$1$ litre of juice costs $\\$2.40$. What does $\\tfrac{1}{10}$ of a litre cost?", "a": "$\\$0.24$",
        "solution": [ { "math": "$2.40 \\div 10$", "note": "Shift one place right" }, { "math": "$= 0.24$", "note": "" } ] },
      { "q": "Complete: $0.09 \\times \\square = 9$.", "a": "$100$",
        "solution": [ { "math": "$0.09 \\to 9$", "note": "Two places left" }, { "math": "$\\square = 100$", "note": "" } ] },
      { "q": "A stack of $100$ sheets of paper is $1.2$ cm thick. How thick is one sheet?", "a": "$0.012$ cm",
        "solution": [ { "math": "$1.2 \\div 100$", "note": "Shift two places right" }, { "math": "$= 0.012$", "note": "" } ] },
      { "q": "Start with $0.05$. What single operation turns it into $5$?", "a": "$\\times 100$",
        "solution": [ { "math": "$0.05 \\to 5$", "note": "Two places left" }, { "math": "$\\times 100$", "note": "" } ] },
      { "q": "A recipe uses $0.35$ kg of flour per cake. How much flour is needed for $10$ cakes?", "a": "$3.5$ kg",
        "solution": [ { "math": "$0.35 \\times 10$", "note": "Shift one place left" }, { "math": "$= 3.5$", "note": "" } ] }
    ]
  }
}
