{
  "skillId": "multiply-decimals-by-single-digit",
  "atomType": "R",
  "theory": {
    "intro": "To multiply a decimal by a single-digit number, multiply as if the decimal were a whole number, then put the decimal point back so the answer has the same number of decimal places.",
    "facts": [
      "$3.5 \\times 2$ has **one** decimal place, just like $3.5$.",
      "It often helps to split: $3.5 \\times 2 = 3 \\times 2 + 0.5 \\times 2$.",
      "Estimate first: $3.5 \\times 2 \\approx 4 \\times 2 = 8$, so the answer is near $7$ — sensible."
    ],
    "steps": [
      "Ignore the point and multiply the digits as whole numbers.",
      "Count the decimal places in the original decimal.",
      "Place the point in the answer so it has the same number of decimal places."
    ]
  },
  "practice": {
    "foundation": [
      { "q": "Find $3.5 \\times 2$.", "a": "$7$",
        "solution": [ { "math": "$3 \\times 2 + 0.5 \\times 2$", "note": "Split" }, { "math": "$= 6 + 1 = 7$", "note": "" } ] },
      { "q": "Find $1.2 \\times 4$.", "a": "$4.8$",
        "solution": [ { "math": "$12 \\times 4 = 48$", "note": "Ignore the point" }, { "math": "$= 4.8$", "note": "One decimal place" } ] },
      { "q": "Find $2.5 \\times 3$.", "a": "$7.5$",
        "solution": [ { "math": "$25 \\times 3 = 75$", "note": "Ignore the point" }, { "math": "$= 7.5$", "note": "One decimal place" } ] },
      { "q": "Find $0.6 \\times 5$.", "a": "$3$",
        "solution": [ { "math": "$6 \\times 5 = 30$", "note": "Ignore the point" }, { "math": "$= 3.0 = 3$", "note": "One decimal place" } ] },
      { "q": "Find $4.1 \\times 2$.", "a": "$8.2$",
        "solution": [ { "math": "$41 \\times 2 = 82$", "note": "Ignore the point" }, { "math": "$= 8.2$", "note": "One decimal place" } ] },
      { "q": "Find $1.5 \\times 6$.", "a": "$9$",
        "solution": [ { "math": "$15 \\times 6 = 90$", "note": "Ignore the point" }, { "math": "$= 9.0 = 9$", "note": "One decimal place" } ] },
      { "q": "Find $0.3 \\times 4$.", "a": "$1.2$",
        "solution": [ { "math": "$3 \\times 4 = 12$", "note": "Ignore the point" }, { "math": "$= 1.2$", "note": "One decimal place" } ] },
      { "q": "Find $2.2 \\times 3$.", "a": "$6.6$",
        "solution": [ { "math": "$22 \\times 3 = 66$", "note": "Ignore the point" }, { "math": "$= 6.6$", "note": "One decimal place" } ] },
      { "q": "Find $3.4 \\times 2$.", "a": "$6.8$",
        "solution": [ { "math": "$34 \\times 2 = 68$", "note": "Ignore the point" }, { "math": "$= 6.8$", "note": "One decimal place" } ] },
      { "q": "Find $0.7 \\times 3$.", "a": "$2.1$",
        "solution": [ { "math": "$7 \\times 3 = 21$", "note": "Ignore the point" }, { "math": "$= 2.1$", "note": "One decimal place" } ] }
    ],
    "development": [
      { "q": "Find $4.6 \\times 3$.", "a": "$13.8$",
        "solution": [ { "math": "$46 \\times 3 = 138$", "note": "Ignore the point" }, { "math": "$= 13.8$", "note": "One decimal place" } ] },
      { "q": "Find $7.5 \\times 4$.", "a": "$30$",
        "solution": [ { "math": "$75 \\times 4 = 300$", "note": "Ignore the point" }, { "math": "$= 30.0 = 30$", "note": "One decimal place" } ] },
      { "q": "Find $2.25 \\times 4$.", "a": "$9$",
        "solution": [ { "math": "$225 \\times 4 = 900$", "note": "Ignore the point" }, { "math": "$= 9.00 = 9$", "note": "Two decimal places" } ] },
      { "q": "Find $1.35 \\times 6$.", "a": "$8.1$",
        "solution": [ { "math": "$135 \\times 6 = 810$", "note": "Ignore the point" }, { "math": "$= 8.10 = 8.1$", "note": "Two decimal places" } ] },
      { "q": "Find $0.45 \\times 5$.", "a": "$2.25$",
        "solution": [ { "math": "$45 \\times 5 = 225$", "note": "Ignore the point" }, { "math": "$= 2.25$", "note": "Two decimal places" } ] },
      { "q": "Find $6.8 \\times 5$.", "a": "$34$",
        "solution": [ { "math": "$68 \\times 5 = 340$", "note": "Ignore the point" }, { "math": "$= 34.0 = 34$", "note": "One decimal place" } ] },
      { "q": "Find $9.4 \\times 7$.", "a": "$65.8$",
        "solution": [ { "math": "$94 \\times 7 = 658$", "note": "Ignore the point" }, { "math": "$= 65.8$", "note": "One decimal place" } ] },
      { "q": "Find $3.75 \\times 8$.", "a": "$30$",
        "solution": [ { "math": "$375 \\times 8 = 3\\,000$", "note": "Ignore the point" }, { "math": "$= 30.00 = 30$", "note": "Two decimal places" } ] },
      { "q": "Find $5.6 \\times 9$.", "a": "$50.4$",
        "solution": [ { "math": "$56 \\times 9 = 504$", "note": "Ignore the point" }, { "math": "$= 50.4$", "note": "One decimal place" } ] },
      { "q": "Find $0.25 \\times 6$.", "a": "$1.5$",
        "solution": [ { "math": "$25 \\times 6 = 150$", "note": "Ignore the point" }, { "math": "$= 1.50 = 1.5$", "note": "Two decimal places" } ] }
    ],
    "mastery": [
      { "q": "A drink costs $\\$3.50$. How much for $4$ drinks?", "a": "$\\$14$",
        "solution": [ { "math": "$3.5 \\times 4 = 14.0$", "note": "Multiply" }, { "math": "$= \\$14$", "note": "" } ] },
      { "q": "A ribbon is $1.25$ m long. How long are $6$ ribbons end to end?", "a": "$7.5$ m",
        "solution": [ { "math": "$1.25 \\times 6 = 7.50$", "note": "Multiply" }, { "math": "$= 7.5 \\text{ m}$", "note": "" } ] },
      { "q": "A bag of sugar holds $0.75$ kg. What is the mass of $8$ bags?", "a": "$6$ kg",
        "solution": [ { "math": "$0.75 \\times 8 = 6.00$", "note": "Multiply" }, { "math": "$= 6 \\text{ kg}$", "note": "" } ] },
      { "q": "Estimate then find $6.9 \\times 7$.", "a": "estimate $49$; exact $48.3$",
        "solution": [ { "math": "$7 \\times 7 = 49$", "note": "Estimate" }, { "math": "$69 \\times 7 = 483 \\Rightarrow 48.3$", "note": "Exact" } ] },
      { "q": "A phone call costs $\\$0.45$ per minute. Cost of a $9$-minute call?", "a": "$\\$4.05$",
        "solution": [ { "math": "$0.45 \\times 9 = 4.05$", "note": "Multiply" }, { "math": "$= \\$4.05$", "note": "" } ] },
      { "q": "Each lap of a track is $2.4$ km. How far is $5$ laps?", "a": "$12$ km",
        "solution": [ { "math": "$2.4 \\times 5 = 12.0$", "note": "Multiply" }, { "math": "$= 12 \\text{ km}$", "note": "" } ] },
      { "q": "A recipe needs $0.35$ kg of butter. How much for $4$ batches?", "a": "$1.4$ kg",
        "solution": [ { "math": "$0.35 \\times 4 = 1.40$", "note": "Multiply" }, { "math": "$= 1.4 \\text{ kg}$", "note": "" } ] },
      { "q": "Petrol costs $\\$1.85$ per litre. Cost of $6$ litres?", "a": "$\\$11.10$",
        "solution": [ { "math": "$1.85 \\times 6 = 11.10$", "note": "Multiply" }, { "math": "$= \\$11.10$", "note": "" } ] },
      { "q": "A board is $0.8$ m wide. Three boards side by side span how far?", "a": "$2.4$ m",
        "solution": [ { "math": "$0.8 \\times 3 = 2.4$", "note": "Multiply" }, { "math": "$= 2.4 \\text{ m}$", "note": "" } ] },
      { "q": "A worker earns $\\$24.50$ per hour. Pay for an $8$-hour day?", "a": "$\\$196$",
        "solution": [ { "math": "$24.5 \\times 8 = 196.0$", "note": "Multiply" }, { "math": "$= \\$196$", "note": "" } ] }
    ]
  }
}
