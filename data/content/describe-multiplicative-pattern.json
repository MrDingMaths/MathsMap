{
  "skillId": "describe-multiplicative-pattern",
  "atomType": "R",
  "theory": {
    "intro": "A pattern of multiples can be described by what you multiply the step number by, not just by what you add each time.",
    "facts": [
      "A **multiplicative** description says 'multiply the step by $n$'; an **additive** one says 'add $n$ each time'.",
      "If step $1$ gives $n$, step $2$ gives $2n$, step $3$ gives $3n$, the count is $n \\times \\text{step}$.",
      "Describing multiplicatively lets you jump straight to any step without counting up."
    ],
    "steps": [
      "Find the count at step $1$ — this is the multiplier $n$.",
      "Check that each later count equals $n \\times \\text{step}$.",
      "Describe the pattern as 'the count is $n$ times the step number'."
    ]
  },
  "practice": {
    "foundation": [
      { "q": "Step $1$ has $2$ dots, step $2$ has $4$, step $3$ has $6$. Describe the pattern multiplicatively.", "a": "dots $= 2 \\times$ step",
        "tikz": "\\begin{tikzpicture}[scale=0.5]\n\\foreach \\x in {0,1} \\fill (\\x,0) circle (5pt);\n\\node at (0.5,-1) {Step 1};\n\\foreach \\x in {3,4,5,6} \\fill (\\x,0) circle (5pt);\n\\node at (4.5,-1) {Step 2};\n\\end{tikzpicture}",
        "solution": [ { "math": "$2, 4, 6$", "note": "Multiples of $2$" }, { "math": "$\\text{dots} = 2 \\times \\text{step}$", "note": "Multiply by $2$" } ] },
      { "q": "Step $1$ has $3$ squares, step $2$ has $6$, step $3$ has $9$. Describe multiplicatively.", "a": "squares $= 3 \\times$ step",
        "tikz": "\\begin{tikzpicture}[scale=0.4]\n\\foreach \\x in {0,1,2} \\draw (\\x,0) rectangle (\\x+0.9,0.9);\n\\node at (1.4,-0.8) {Step 1};\n\\foreach \\x in {5,6,7,8,9,10} \\draw (\\x,0) rectangle (\\x+0.9,0.9);\n\\node at (7.9,-0.8) {Step 2};\n\\end{tikzpicture}",
        "solution": [ { "math": "$3, 6, 9$", "note": "Multiples of $3$" }, { "math": "$\\text{squares} = 3 \\times \\text{step}$", "note": "Multiply by $3$" } ] },
      { "q": "The counts are $5, 10, 15$. Describe the pattern multiplicatively.", "a": "count $= 5 \\times$ step",
        "solution": [ { "math": "$5, 10, 15$", "note": "Multiples of $5$" }, { "math": "$\\text{count} = 5 \\times \\text{step}$", "note": "Multiply by $5$" } ] },
      { "q": "The counts are $4, 8, 12$. Describe the pattern multiplicatively.", "a": "count $= 4 \\times$ step",
        "tikz": "\\begin{tikzpicture}[scale=0.4]\n\\foreach \\x in {0,1,2,3} \\draw (\\x,0) rectangle (\\x+0.9,0.9);\n\\node at (1.9,-0.8) {Step 1};\n\\end{tikzpicture}",
        "solution": [ { "math": "$4, 8, 12$", "note": "Multiples of $4$" }, { "math": "$\\text{count} = 4 \\times \\text{step}$", "note": "Multiply by $4$" } ] },
      { "q": "The counts are $10, 20, 30$. Describe multiplicatively.", "a": "count $= 10 \\times$ step",
        "solution": [ { "math": "$10, 20, 30$", "note": "Multiples of $10$" }, { "math": "$\\text{count} = 10 \\times \\text{step}$", "note": "Multiply by $10$" } ] },
      { "q": "The counts are $6, 12, 18$. Describe multiplicatively.", "a": "count $= 6 \\times$ step",
        "solution": [ { "math": "$6, 12, 18$", "note": "Multiples of $6$" }, { "math": "$\\text{count} = 6 \\times \\text{step}$", "note": "Multiply by $6$" } ] },
      { "q": "The counts are $7, 14, 21$. Describe multiplicatively.", "a": "count $= 7 \\times$ step",
        "solution": [ { "math": "$7, 14, 21$", "note": "Multiples of $7$" }, { "math": "$\\text{count} = 7 \\times \\text{step}$", "note": "Multiply by $7$" } ] },
      { "q": "The counts are $8, 16, 24$. Describe multiplicatively.", "a": "count $= 8 \\times$ step",
        "solution": [ { "math": "$8, 16, 24$", "note": "Multiples of $8$" }, { "math": "$\\text{count} = 8 \\times \\text{step}$", "note": "Multiply by $8$" } ] },
      { "q": "The counts are $9, 18, 27$. Describe multiplicatively.", "a": "count $= 9 \\times$ step",
        "solution": [ { "math": "$9, 18, 27$", "note": "Multiples of $9$" }, { "math": "$\\text{count} = 9 \\times \\text{step}$", "note": "Multiply by $9$" } ] },
      { "q": "The counts are $12, 24, 36$. Describe multiplicatively.", "a": "count $= 12 \\times$ step",
        "solution": [ { "math": "$12, 24, 36$", "note": "Multiples of $12$" }, { "math": "$\\text{count} = 12 \\times \\text{step}$", "note": "Multiply by $12$" } ] }
    ],
    "development": [
      { "q": "A student says the pattern $3, 6, 9, 12$ is 'add $3$'. Give a better, multiplicative description.", "a": "count $= 3 \\times$ step",
        "solution": [ { "math": "$3, 6, 9, 12$", "note": "Multiples of $3$" }, { "math": "$\\text{count} = 3 \\times \\text{step}$", "note": "Multiply, not add" } ] },
      { "q": "Describe $5, 10, 15, 20$ multiplicatively, then find step $10$.", "a": "$5 \\times$ step; $50$",
        "solution": [ { "math": "$\\text{count} = 5 \\times \\text{step}$", "note": "Multiply by $5$" }, { "math": "$5 \\times 10 = 50$", "note": "Step $10$" } ] },
      { "q": "Why is 'multiply the step by $4$' more useful than 'add $4$' for the pattern $4, 8, 12, \\dots$?", "a": "lets you jump to any step directly",
        "solution": [ { "math": "$\\text{count} = 4 \\times \\text{step}$", "note": "Direct formula" }, { "math": "$4 \\times 20 = 80$", "note": "No need to add up" } ] },
      { "q": "Describe the pattern in $\\begin{array}{c|cccc} \\text{Step} & 1 & 2 & 3 & 4 \\\\ \\hline \\text{Count} & 6 & 12 & 18 & 24 \\end{array}$ multiplicatively.", "a": "count $= 6 \\times$ step",
        "solution": [ { "math": "$6 \\div 1 = 6$", "note": "Multiplier" }, { "math": "$\\text{count} = 6 \\times \\text{step}$", "note": "Multiply by $6$" } ] },
      { "q": "Describe $11, 22, 33, 44$ multiplicatively, then find step $6$.", "a": "$11 \\times$ step; $66$",
        "solution": [ { "math": "$\\text{count} = 11 \\times \\text{step}$", "note": "Multiply by $11$" }, { "math": "$11 \\times 6 = 66$", "note": "Step $6$" } ] },
      { "q": "A tree grows $2$ m each year, starting at $2$ m. Describe the height multiplicatively.", "a": "height $= 2 \\times$ years",
        "solution": [ { "math": "$2, 4, 6, \\dots$", "note": "Multiples of $2$" }, { "math": "$\\text{height} = 2 \\times \\text{years}$", "note": "Multiply by $2$" } ] },
      { "q": "Describe the pattern in $\\begin{array}{c|cccc} \\text{Step} & 1 & 2 & 3 & 4 \\\\ \\hline \\text{Count} & 9 & 18 & 27 & 36 \\end{array}$ multiplicatively.", "a": "count $= 9 \\times$ step",
        "solution": [ { "math": "$9 \\div 1 = 9$", "note": "Multiplier" }, { "math": "$\\text{count} = 9 \\times \\text{step}$", "note": "Multiply by $9$" } ] },
      { "q": "Describe $15, 30, 45, 60$ multiplicatively.", "a": "count $= 15 \\times$ step",
        "solution": [ { "math": "$15, 30, 45, 60$", "note": "Multiples of $15$" }, { "math": "$\\text{count} = 15 \\times \\text{step}$", "note": "Multiply by $15$" } ] },
      { "q": "A printer outputs $20$ pages per minute. Describe the pages multiplicatively.", "a": "pages $= 20 \\times$ minutes",
        "solution": [ { "math": "$20, 40, 60, \\dots$", "note": "Multiples of $20$" }, { "math": "$\\text{pages} = 20 \\times \\text{minutes}$", "note": "Multiply by $20$" } ] },
      { "q": "Describe $25, 50, 75, 100$ multiplicatively, then find step $8$.", "a": "$25 \\times$ step; $200$",
        "solution": [ { "math": "$\\text{count} = 25 \\times \\text{step}$", "note": "Multiply by $25$" }, { "math": "$25 \\times 8 = 200$", "note": "Step $8$" } ] }
    ],
    "mastery": [
      { "q": "Two students describe $6, 12, 18, 24$: Ana says 'add $6$', Ben says 'multiply step by $6$'. Whose description finds step $50$ faster, and what is it?", "a": "Ben; $300$",
        "solution": [ { "math": "$\\text{count} = 6 \\times \\text{step}$", "note": "Ben's rule is direct" }, { "math": "$6 \\times 50 = 300$", "note": "Step $50$" } ] },
      { "q": "A pattern is described as 'count is $8$ times the step'. What are the counts for steps $1$ to $4$?", "a": "$8, 16, 24, 32$",
        "solution": [ { "math": "$8 \\times 1, 8 \\times 2, \\dots$", "note": "Apply the rule" }, { "math": "$8, 16, 24, 32$", "note": "Multiples of $8$" } ] },
      { "q": "Explain why $3, 6, 9, 12$ is multiplicative but $2, 5, 8, 11$ is not.", "a": "first is multiples of $3$; second is not",
        "solution": [ { "math": "$3, 6, 9, 12 = 3 \\times \\text{step}$", "note": "True multiples" }, { "math": "$2, 5, 8, 11$: add $3$ from $2$", "note": "Not multiples of one number" } ] },
      { "q": "A pattern gives $7$ at step $1$. Describe it multiplicatively and find step $9$.", "a": "$7 \\times$ step; $63$",
        "solution": [ { "math": "$\\text{count} = 7 \\times \\text{step}$", "note": "Step $1$ is $7$" }, { "math": "$7 \\times 9 = 63$", "note": "Step $9$" } ] },
      { "q": "Tiles follow 'multiply step by $5$'. Which step gives $60$ tiles?", "a": "step $12$",
        "solution": [ { "math": "$5 \\times \\square = 60$", "note": "Work backwards" }, { "math": "$\\square = 12$", "note": "Step $12$" } ] },
      { "q": "A water tank fills $\\text{litres} = 12 \\times \\text{minutes}$. Describe in words and find the litres after $7$ minutes.", "a": "$12$ L per minute; $84$ L",
        "solution": [ { "math": "$12$ litres each minute", "note": "Multiplicative" }, { "math": "$12 \\times 7 = 84$", "note": "$84$ L" } ] },
      { "q": "A pattern has counts $10, 20, 30, 40$. Write the rule, then explain how to find step $100$ instantly.", "a": "$10 \\times$ step; $1\\,000$",
        "solution": [ { "math": "$\\text{count} = 10 \\times \\text{step}$", "note": "Rule" }, { "math": "$10 \\times 100 = 1\\,000$", "note": "Multiply directly" } ] },
      { "q": "Describe the savings pattern $\\$15, \\$30, \\$45, \\dots$ multiplicatively, then find week $20$.", "a": "$15 \\times$ week; $\\$300$",
        "solution": [ { "math": "$\\text{savings} = 15 \\times \\text{week}$", "note": "Multiply by $15$" }, { "math": "$15 \\times 20 = 300$", "note": "$\\$300$" } ] },
      { "q": "A pattern is 'multiply step by $6$'. How many counts more does step $5$ have than step $2$?", "a": "$18$",
        "solution": [ { "math": "$6 \\times 5 - 6 \\times 2$", "note": "Difference" }, { "math": "$= 30 - 12 = 18$", "note": "$18$ more" } ] },
      { "q": "A pattern doubles each step: $3, 6, 12, 24$. Is this multiplicative by a fixed step number? Explain.", "a": "No — it is repeated doubling, not $n \\times$ step",
        "solution": [ { "math": "$3, 6, 12, 24$", "note": "Each is $\\times 2$ of the last" }, { "math": "$\\neq n \\times \\text{step}$", "note": "Not a multiple of the step number" } ] }
    ]
  }
