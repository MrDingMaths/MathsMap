{
  "skillId": "find-factors-of-number",
  "atomType": "R",
  "theory": {
    "intro": "A **factor** of a number divides into it exactly with no remainder. Factors come in pairs that multiply to give the number.",
    "facts": [
      "$1$ and the number itself are always factors.",
      "Factors come in **pairs**: for $12$, $1\\times 12$, $2\\times 6$, $3\\times 4$.",
      "List factors in order, smallest to largest."
    ],
    "steps": [
      "Start at $1$ and test each whole number in turn.",
      "If it divides exactly, record it and its partner.",
      "Stop when the pairs meet in the middle; list all factors in order."
    ]
  },
  "practice": {
    "foundation": [
      { "q": "List all the factors of $6$.", "a": "$1, 2, 3, 6$",
        "solution": [ { "math": "$1 \\times 6,\\ 2 \\times 3$", "note": "Factor pairs" }, { "math": "$1, 2, 3, 6$", "note": "" } ] },
      { "q": "List all the factors of $8$.", "a": "$1, 2, 4, 8$",
        "solution": [ { "math": "$1 \\times 8,\\ 2 \\times 4$", "note": "Factor pairs" }, { "math": "$1, 2, 4, 8$", "note": "" } ] },
      { "q": "List all the factors of $10$.", "a": "$1, 2, 5, 10$",
        "solution": [ { "math": "$1 \\times 10,\\ 2 \\times 5$", "note": "Factor pairs" }, { "math": "$1, 2, 5, 10$", "note": "" } ] },
      { "q": "List all the factors of $9$.", "a": "$1, 3, 9$",
        "solution": [ { "math": "$1 \\times 9,\\ 3 \\times 3$", "note": "Factor pairs" }, { "math": "$1, 3, 9$", "note": "" } ] },
      { "q": "List all the factors of $12$.", "a": "$1, 2, 3, 4, 6, 12$",
        "solution": [ { "math": "$1\\times12,\\ 2\\times6,\\ 3\\times4$", "note": "Factor pairs" }, { "math": "$1, 2, 3, 4, 6, 12$", "note": "" } ] },
      { "q": "Is $4$ a factor of $20$?", "a": "yes",
        "solution": [ { "math": "$20 \\div 4 = 5$", "note": "No remainder" }, { "math": "$\\text{yes}$", "note": "" } ] },
      { "q": "Is $3$ a factor of $14$?", "a": "no",
        "solution": [ { "math": "$14 \\div 3 = 4 \\text{ r } 2$", "note": "Leaves a remainder" }, { "math": "$\\text{no}$", "note": "" } ] },
      { "q": "List all the factors of $15$.", "a": "$1, 3, 5, 15$",
        "solution": [ { "math": "$1\\times15,\\ 3\\times5$", "note": "Factor pairs" }, { "math": "$1, 3, 5, 15$", "note": "" } ] },
      { "q": "Write $14$ as a product of two factors.", "a": "$2 \\times 7$",
        "solution": [ { "math": "$14 = 2 \\times 7$", "note": "A factor pair" }, { "math": "$2 \\times 7$", "note": "" } ] },
      { "q": "List all the factors of $7$.", "a": "$1, 7$",
        "solution": [ { "math": "$1 \\times 7$", "note": "Only one pair" }, { "math": "$1, 7$", "note": "" } ] }
    ],
    "development": [
      { "q": "List all the factors of $24$.", "a": "$1, 2, 3, 4, 6, 8, 12, 24$",
        "solution": [ { "math": "$1\\times24,\\ 2\\times12,\\ 3\\times8,\\ 4\\times6$", "note": "Factor pairs" }, { "math": "$1, 2, 3, 4, 6, 8, 12, 24$", "note": "" } ] },
      { "q": "List all the factors of $36$.", "a": "$1, 2, 3, 4, 6, 9, 12, 18, 36$",
        "solution": [ { "math": "$1\\times36,\\ 2\\times18,\\ 3\\times12,\\ 4\\times9,\\ 6\\times6$", "note": "Factor pairs" }, { "math": "$1, 2, 3, 4, 6, 9, 12, 18, 36$", "note": "" } ] },
      { "q": "List all the factors of $30$.", "a": "$1, 2, 3, 5, 6, 10, 15, 30$",
        "solution": [ { "math": "$1\\times30,\\ 2\\times15,\\ 3\\times10,\\ 5\\times6$", "note": "Factor pairs" }, { "math": "$1, 2, 3, 5, 6, 10, 15, 30$", "note": "" } ] },
      { "q": "List all the factors of $18$.", "a": "$1, 2, 3, 6, 9, 18$",
        "solution": [ { "math": "$1\\times18,\\ 2\\times9,\\ 3\\times6$", "note": "Factor pairs" }, { "math": "$1, 2, 3, 6, 9, 18$", "note": "" } ] },
      { "q": "List all the factors of $40$.", "a": "$1, 2, 4, 5, 8, 10, 20, 40$",
        "solution": [ { "math": "$1\\times40,\\ 2\\times20,\\ 4\\times10,\\ 5\\times8$", "note": "Factor pairs" }, { "math": "$1, 2, 4, 5, 8, 10, 20, 40$", "note": "" } ] },
      { "q": "How many factors does $16$ have?", "a": "$5$",
        "solution": [ { "math": "$1, 2, 4, 8, 16$", "note": "$1\\times16, 2\\times8, 4\\times4$" }, { "math": "$5 \\text{ factors}$", "note": "" } ] },
      { "q": "List the factors of $25$.", "a": "$1, 5, 25$",
        "solution": [ { "math": "$1\\times25,\\ 5\\times5$", "note": "Factor pairs" }, { "math": "$1, 5, 25$", "note": "" } ] },
      { "q": "Write $48$ as a product of two factors in two different ways.", "a": "e.g. $6 \\times 8$ and $4 \\times 12$",
        "solution": [ { "math": "$48 = 6 \\times 8$", "note": "One pair" }, { "math": "$48 = 4 \\times 12$", "note": "Another pair" } ] },
      { "q": "Which numbers from $1$ to $10$ are factors of $60$?", "a": "$1, 2, 3, 4, 5, 6, 10$",
        "solution": [ { "math": "$60 \\div 1,2,3,4,5,6,10$", "note": "Divide exactly" }, { "math": "$1,2,3,4,5,6,10$", "note": "$7,8,9$ do not divide" } ] },
      { "q": "List all the factors of $21$.", "a": "$1, 3, 7, 21$",
        "solution": [ { "math": "$1\\times21,\\ 3\\times7$", "note": "Factor pairs" }, { "math": "$1, 3, 7, 21$", "note": "" } ] }
    ],
    "mastery": [
      { "q": "List the common factors of $12$ and $18$.", "a": "$1, 2, 3, 6$",
        "solution": [ { "math": "$12: 1,2,3,4,6,12$", "note": "Factors of 12" }, { "math": "$18: 1,2,3,6,9,18 \\Rightarrow 1,2,3,6$", "note": "Shared factors" } ] },
      { "q": "What is the largest factor of $45$ apart from $45$ itself?", "a": "$15$",
        "solution": [ { "math": "$45 = 3 \\times 15$", "note": "Largest pair below itself" }, { "math": "$15$", "note": "" } ] },
      { "q": "A number has exactly the factors $1, 2, 4, 7, 14, 28$. What is the number?", "a": "$28$",
        "solution": [ { "math": "$\\text{largest factor}$", "note": "The number itself" }, { "math": "$28$", "note": "" } ] },
      { "q": "List the common factors of $24$ and $36$.", "a": "$1, 2, 3, 4, 6, 12$",
        "solution": [ { "math": "$24: 1,2,3,4,6,8,12,24$", "note": "" }, { "math": "$36 \\text{ shares } 1,2,3,4,6,12$", "note": "Common factors" } ] },
      { "q": "Sweets are shared equally with no leftovers among $5$ or $6$ children. What is the smallest number of sweets (more than $0$)?", "a": "$30$",
        "solution": [ { "math": "$5 \\text{ and } 6 \\text{ both divide}$", "note": "Common multiple" }, { "math": "$5 \\times 6 = 30$", "note": "" } ] },
      { "q": "Which number between $20$ and $30$ has exactly $3$ factors?", "a": "$25$",
        "solution": [ { "math": "$25: 1, 5, 25$", "note": "A square of a prime" }, { "math": "$3 \\text{ factors}$", "note": "" } ] },
      { "q": "List the factors of $100$.", "a": "$1, 2, 4, 5, 10, 20, 25, 50, 100$",
        "solution": [ { "math": "$1\\times100, 2\\times50, 4\\times25, 5\\times20, 10\\times10$", "note": "Factor pairs" }, { "math": "$1,2,4,5,10,20,25,50,100$", "note": "" } ] },
      { "q": "A rectangle has area $20$ and whole-number sides. List all possible pairs of side lengths.", "a": "$1\\times20,\\ 2\\times10,\\ 4\\times5$",
        "solution": [ { "math": "$\\text{factor pairs of } 20$", "note": "Sides multiply to area" }, { "math": "$1\\times20,\\ 2\\times10,\\ 4\\times5$", "note": "" } ] },
      { "q": "Find the highest common factor of $16$ and $24$.", "a": "$8$",
        "solution": [ { "math": "$16: 1,2,4,8,16$", "note": "" }, { "math": "$24 \\text{ shares } 8 \\text{ as highest}$", "note": "HCF" } ] },
      { "q": "How many factors does $49$ have, and why?", "a": "$3$ — it is $7^2$",
        "solution": [ { "math": "$49 = 7 \\times 7$", "note": "Square of a prime" }, { "math": "$1, 7, 49$", "note": "Only 3 factors" } ] }
    ]
  }
}
