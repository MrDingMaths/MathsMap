{
  "skillId": "division-as-fraction",
  "atomType": "R",
  "theory": {
    "intro": "A division can be written as a fraction: the dividend becomes the numerator and the divisor becomes the denominator.",
    "facts": [
      "$a \\div b = \\dfrac{a}{b}$ — the first number goes on **top**.",
      "A fraction bar means 'divide the top by the bottom'.",
      "If the division is exact, the fraction simplifies to a whole number."
    ],
    "steps": [
      "Write the dividend as the numerator.",
      "Write the divisor as the denominator.",
      "Simplify or evaluate if possible."
    ]
  },
  "practice": {
