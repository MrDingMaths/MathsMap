{
  "skillId": "probabilities-sum-to-one",
  "atomType": "R",
  "theory": {
    "intro": "If you add up the probabilities of **every** possible outcome of an experiment, the total is always $1$. This is because one of the outcomes is certain to happen.",
    "facts": [
      "$P(\\text{all outcomes together}) = 1$.",
      "$P(\\text{event}) + P(\\text{not the event}) = 1$, so $P(\\text{not}) = 1 - P(\\text{event})$.",
      "A probability of $1$ is **certain**; a probability of $0$ is **impossible**."
    ],
    "steps": [
      "Add the probabilities of all the listed outcomes.",
      "If one is missing, subtract the known total from $1$ to find it.",
      "For a complement, use $P(\\text{not}) = 1 - P(\\text{event})$."
    ]
  },
  "practice": {
    "foundation": [
      { "q": "A spinner has $P(\\text{red}) = \\tfrac{1}{4}$, $P(\\text{blue}) = \\tfrac{1}{4}$, $P(\\text{green}) = \\tfrac{2}{4}$. What do these add to?", "a": "$1$",
        "solution": [ { "math": "$\\tfrac{1}{4} + \\tfrac{1}{4} + \\tfrac{2}{4}$", "note": "Add the numerators" }, { "math": "$= \\tfrac{4}{4} = 1$", "note": "Always 1" } ] },
      { "q": "For a coin, $P(\\text{heads}) = \\tfrac{1}{2}$. What is $P(\\text{tails})$?", "a": "$\\tfrac{1}{2}$",
        "solution": [ { "math": "$1 - \\tfrac{1}{2}$", "note": "Subtract from 1" }, { "math": "$= \\tfrac{1}{2}$", "note": "" } ] },
      { "q": "A bag gives $P(\\text{red}) = \\tfrac{2}{5}$. What is $P(\\text{not red})$?", "a": "$\\tfrac{3}{5}$",
        "solution": [ { "math": "$1 - \\tfrac{2}{5}$", "note": "Complement" }, { "math": "$= \\tfrac{3}{5}$", "note": "" } ] },
      { "q": "A spinner has only red and blue. If $P(\\text{red}) = \\tfrac{1}{3}$, find $P(\\text{blue})$.", "a": "$\\tfrac{2}{3}$",
        "solution": [ { "math": "$1 - \\tfrac{1}{3}$", "note": "Only two outcomes" }, { "math": "$= \\tfrac{2}{3}$", "note": "" } ] },
      { "q": "Do these add to $1$? $\\tfrac{3}{8}$, $\\tfrac{2}{8}$, $\\tfrac{3}{8}$.", "a": "yes",
        "solution": [ { "math": "$\\tfrac{3}{8} + \\tfrac{2}{8} + \\tfrac{3}{8}$", "note": "Add numerators" }, { "math": "$= \\tfrac{8}{8} = 1$", "note": "Yes" } ] },
      { "q": "A die has $P(\\text{even}) = \\tfrac{1}{2}$. What is $P(\\text{odd})$?", "a": "$\\tfrac{1}{2}$",
        "solution": [ { "math": "$1 - \\tfrac{1}{2}$", "note": "Even or odd" }, { "math": "$= \\tfrac{1}{2}$", "note": "" } ] },
      { "q": "A spinner has $P(\\text{win}) = \\tfrac{1}{5}$. What is $P(\\text{lose})$?", "a": "$\\tfrac{4}{5}$",
        "solution": [ { "math": "$1 - \\tfrac{1}{5}$", "note": "Win or lose" }, { "math": "$= \\tfrac{4}{5}$", "note": "" } ] },
      { "q": "Three outcomes have probabilities $\\tfrac{1}{6}$, $\\tfrac{2}{6}$ and a third. What must the third be?", "a": "$\\tfrac{3}{6}$",
        "solution": [ { "math": "$1 - \\tfrac{1}{6} - \\tfrac{2}{6}$", "note": "Subtract from 1" }, { "math": "$= \\tfrac{3}{6}$", "note": "" } ] },
      { "q": "A bag gives $P(\\text{blue}) = \\tfrac{4}{7}$. What is $P(\\text{not blue})$?", "a": "$\\tfrac{3}{7}$",
        "solution": [ { "math": "$1 - \\tfrac{4}{7}$", "note": "Complement" }, { "math": "$= \\tfrac{3}{7}$", "note": "" } ] },
      { "q": "Do these add to $1$? $\\tfrac{1}{4}$, $\\tfrac{1}{4}$, $\\tfrac{1}{4}$.", "a": "no (they make $\\tfrac{3}{4}$)",
        "solution": [ { "math": "$\\tfrac{1}{4}+\\tfrac{1}{4}+\\tfrac{1}{4}$", "note": "Add numerators" }, { "math": "$= \\tfrac{3}{4} \\neq 1$", "note": "No" } ] }
    ],
    "development": [
      { "q": "A spinner has red, blue, green and yellow with $P = \\tfrac{2}{10}, \\tfrac{3}{10}, \\tfrac{1}{10}, ?$. Find the missing probability.", "a": "$\\tfrac{4}{10}$",
        "solution": [ { "math": "$1 - \\tfrac{2}{10} - \\tfrac{3}{10} - \\tfrac{1}{10}$", "note": "Subtract knowns" }, { "math": "$= \\tfrac{4}{10}$", "note": "" } ] },
      { "q": "A die is loaded so $P(6) = \\tfrac{1}{2}$ and the other five faces are equally likely. Find $P(1)$.", "a": "$\\tfrac{1}{10}$",
        "solution": [ { "math": "$1 - \\tfrac{1}{2} = \\tfrac{1}{2}$", "note": "Left for faces 1-5" }, { "math": "$\\tfrac{1}{2} \\div 5 = \\tfrac{1}{10}$", "note": "Share equally" } ] },
      { "q": "A weather model says $P(\\text{sunny}) = \\tfrac{1}{2}$, $P(\\text{cloudy}) = \\tfrac{1}{3}$. Find $P(\\text{rainy})$ if these are the only options.", "a": "$\\tfrac{1}{6}$",
        "solution": [ { "math": "$1 - \\tfrac{1}{2} - \\tfrac{1}{3}$", "note": "Common denominator 6" }, { "math": "$\\tfrac{6}{6}-\\tfrac{3}{6}-\\tfrac{2}{6} = \\tfrac{1}{6}$", "note": "" } ] },
      { "q": "A spinner shows $P(A) = 0.4$, $P(B) = 0.35$. Find $P(C)$ if these are the only sectors.", "a": "$0.25$",
        "solution": [ { "math": "$1 - 0.4 - 0.35$", "note": "Subtract from 1" }, { "math": "$= 0.25$", "note": "" } ] },
      { "q": "A bag has red, blue and green only. $P(\\text{red}) = \\tfrac{1}{4}$, $P(\\text{green}) = \\tfrac{1}{4}$. Find $P(\\text{blue})$.", "a": "$\\tfrac{1}{2}$",
        "solution": [ { "math": "$1 - \\tfrac{1}{4} - \\tfrac{1}{4}$", "note": "Subtract knowns" }, { "math": "$= \\tfrac{2}{4} = \\tfrac{1}{2}$", "note": "Simplify" } ] },
      { "q": "Could a spinner have $P(\\text{red}) = \\tfrac{2}{3}$ and $P(\\text{blue}) = \\tfrac{2}{3}$? Explain.", "a": "no — the total exceeds $1$",
        "solution": [ { "math": "$\\tfrac{2}{3} + \\tfrac{2}{3} = \\tfrac{4}{3}$", "note": "More than 1" }, { "math": "$\\tfrac{4}{3} > 1$", "note": "Impossible" } ] },
      { "q": "A spinner has $P(1) = \\tfrac{1}{8}$, $P(2) = \\tfrac{3}{8}$, $P(3) = \\tfrac{1}{8}$. Find $P(4)$ if these are the only numbers.", "a": "$\\tfrac{3}{8}$",
        "solution": [ { "math": "$1 - \\tfrac{1}{8} - \\tfrac{3}{8} - \\tfrac{1}{8}$", "note": "Subtract knowns" }, { "math": "$= \\tfrac{3}{8}$", "note": "" } ] },
      { "q": "A game has $P(\\text{lose}) = 0.7$. Find $P(\\text{win})$.", "a": "$0.3$",
        "solution": [ { "math": "$1 - 0.7$", "note": "Win or lose" }, { "math": "$= 0.3$", "note": "" } ] },
      { "q": "A four-colour spinner has equal red and blue, with $P(\\text{green}) = \\tfrac{1}{5}$ and $P(\\text{yellow}) = \\tfrac{1}{5}$. Find $P(\\text{red})$.", "a": "$\\tfrac{3}{10}$",
        "solution": [ { "math": "$1 - \\tfrac{1}{5} - \\tfrac{1}{5} = \\tfrac{3}{5}$", "note": "Left for red+blue" }, { "math": "$\\tfrac{3}{5} \\div 2 = \\tfrac{3}{10}$", "note": "Split equally" } ] },
      { "q": "A spinner shows $P(A) = \\tfrac{1}{2}$, $P(B) = \\tfrac{1}{4}$, $P(C) = \\tfrac{1}{8}$. Find $P(D)$ if these are all the outcomes.", "a": "$\\tfrac{1}{8}$",
        "solution": [ { "math": "$1 - \\tfrac{4}{8} - \\tfrac{2}{8} - \\tfrac{1}{8}$", "note": "Common denominator 8" }, { "math": "$= \\tfrac{1}{8}$", "note": "" } ] }
    ],
    "mastery": [
      { "q": "A loaded die has $P(1)=P(2)=P(3)=\\tfrac{1}{12}$ and $P(4)=P(5)=\\tfrac{1}{6}$. Find $P(6)$.", "a": "$\\tfrac{5}{12}$",
        "solution": [ { "math": "$3(\\tfrac{1}{12}) + 2(\\tfrac{2}{12})$", "note": "$=\\tfrac{3}{12}+\\tfrac{4}{12}=\\tfrac{7}{12}$" }, { "math": "$1 - \\tfrac{7}{12} = \\tfrac{5}{12}$", "note": "" } ] },
      { "q": "A bag has red, blue and green. $P(\\text{red}) = 2 \\times P(\\text{blue})$ and $P(\\text{green}) = \\tfrac{1}{2}$. Find $P(\\text{blue})$.", "a": "$\\tfrac{1}{6}$",
        "solution": [ { "math": "$P(\\text{red})+P(\\text{blue}) = \\tfrac{1}{2}$", "note": "$2b + b = \\tfrac{1}{2}$" }, { "math": "$3b = \\tfrac{1}{2} \\Rightarrow b = \\tfrac{1}{6}$", "note": "" } ] },
      { "q": "A spinner has $P(\\text{even}) = \\tfrac{3}{5}$. A student says $P(\\text{odd}) = \\tfrac{3}{5}$ too. Correct them.", "a": "$P(\\text{odd}) = \\tfrac{2}{5}$",
        "solution": [ { "math": "$1 - \\tfrac{3}{5}$", "note": "Complement" }, { "math": "$= \\tfrac{2}{5}$", "note": "Not $\\tfrac{3}{5}$" } ] },
      { "q": "A game gives $P(\\text{win}) = 0.15$ and $P(\\text{draw}) = 0.25$. Find $P(\\text{lose})$.", "a": "$0.6$",
        "solution": [ { "math": "$1 - 0.15 - 0.25$", "note": "Subtract from 1" }, { "math": "$= 0.6$", "note": "" } ] },
      { "q": "A spinner has sectors A, B, C, D with $P(A) = P(B)$ and $P(C) = P(D) = \\tfrac{1}{6}$. Find $P(A)$.", "a": "$\\tfrac{1}{3}$",
        "solution": [ { "math": "$1 - \\tfrac{1}{6} - \\tfrac{1}{6} = \\tfrac{2}{3}$", "note": "Left for A+B" }, { "math": "$\\tfrac{2}{3} \\div 2 = \\tfrac{1}{3}$", "note": "" } ] },
      { "q": "Probabilities are listed as $0.2, 0.3, 0.4, 0.2$. Explain why this cannot be a complete set.", "a": "they total $1.1 > 1$",
        "solution": [ { "math": "$0.2+0.3+0.4+0.2$", "note": "Add them" }, { "math": "$= 1.1 > 1$", "note": "Impossible" } ] },
      { "q": "A bag of red, blue, green has $P(\\text{not red}) = \\tfrac{5}{8}$ and $P(\\text{blue}) = \\tfrac{1}{4}$. Find $P(\\text{green})$.", "a": "$\\tfrac{3}{8}$",
        "solution": [ { "math": "$P(\\text{not red}) = P(\\text{blue})+P(\\text{green})$", "note": "$\\tfrac{5}{8}=\\tfrac{2}{8}+P(\\text{green})$" }, { "math": "$P(\\text{green}) = \\tfrac{3}{8}$", "note": "" } ] },
      { "q": "A spinner has $P(\\text{red}) = \\tfrac{1}{4}$ and the rest is shared equally among blue, green and yellow. Find $P(\\text{blue})$.", "a": "$\\tfrac{1}{4}$",
        "solution": [ { "math": "$1 - \\tfrac{1}{4} = \\tfrac{3}{4}$", "note": "Left for 3 colours" }, { "math": "$\\tfrac{3}{4} \\div 3 = \\tfrac{1}{4}$", "note": "" } ] },
      { "q": "A weather model gives $P(\\text{rain}) = \\tfrac{2}{7}$. Over a week of $7$ days, on how many days does it expect no rain?", "a": "$5$",
        "solution": [ { "math": "$P(\\text{no rain}) = 1-\\tfrac{2}{7} = \\tfrac{5}{7}$", "note": "Complement" }, { "math": "$\\tfrac{5}{7} \\times 7 = 5$", "note": "Days" } ] },
      { "q": "Four outcomes have probabilities $\\tfrac{1}{2}, \\tfrac{1}{4}, x, x$. Find $x$.", "a": "$\\tfrac{1}{8}$",
        "solution": [ { "math": "$\\tfrac{1}{2}+\\tfrac{1}{4}+2x = 1$", "note": "$\\tfrac{3}{4} + 2x = 1$" }, { "math": "$2x = \\tfrac{1}{4} \\Rightarrow x = \\tfrac{1}{8}$", "note": "" } ] }
    ]
  }
}
