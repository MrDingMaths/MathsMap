{
  "skillId": "non-unit-fraction-of-quantity",
  "atomType": "R",
  "theory": {
    "intro": "A non-unit fraction such as $\\tfrac{2}{5}$ has a numerator greater than $1$. Find it by first finding the unit fraction, then taking that many copies.",
    "facts": [
      "$\\tfrac{a}{b}$ of a quantity means **divide by $b$, then multiply by $a$**.",
      "First find $\\tfrac{1}{b}$ (one part), then take $a$ of those parts.",
      "A tape diagram split into $b$ equal segments shows $a$ shaded segments as $\\tfrac{a}{b}$."
    ],
    "steps": [
      "Divide the quantity by the denominator to get one part.",
      "Multiply that one part by the numerator.",
      "The result is the non-unit fraction of the quantity."
    ]
  },
  "practice": {
    "foundation": [
      { "q": "Find $\\tfrac{2}{5}$ of $30$.", "a": "$12$",
        "tikz": "\\begin{tikzpicture}[x=0.4cm,y=0.7cm]\n\\draw (0,0) rectangle (30,1);\n\\foreach \\i in {6,12,18,24} \\draw (\\i,0) -- (\\i,1);\n\\fill[gray!40] (0,0) rectangle (12,1);\n\\node[below=4pt] at (15,0) {$30$};\n\\end{tikzpicture}",
        "solution": [ { "math": "$30 \\div 5 = 6$", "note": "One fifth" }, { "math": "$2 \\times 6 = 12$", "note": "Two fifths" } ] },
      { "q": "Find $\\tfrac{3}{4}$ of $20$.", "a": "$15$",
        "tikz": "\\begin{tikzpicture}[x=0.6cm,y=0.7cm]\n\\draw (0,0) rectangle (20,1);\n\\foreach \\i in {5,10,15} \\draw (\\i,0) -- (\\i,1);\n\\fill[gray!40] (0,0) rectangle (15,1);\n\\node[below=4pt] at (10,0) {$20$};\n\\end{tikzpicture}",
        "solution": [ { "math": "$20 \\div 4 = 5$", "note": "One quarter" }, { "math": "$3 \\times 5 = 15$", "note": "Three quarters" } ] },
      { "q": "Find $\\tfrac{2}{3}$ of $18$.", "a": "$12$",
        "tikz": "\\begin{tikzpicture}[x=0.6cm,y=0.7cm]\n\\draw (0,0) rectangle (18,1);\n\\foreach \\i in {6,12} \\draw (\\i,0) -- (\\i,1);\n\\fill[gray!40] (0,0) rectangle (12,1);\n\\node[below=4pt] at (9,0) {$18$};\n\\end{tikzpicture}",
        "solution": [ { "math": "$18 \\div 3 = 6$", "note": "One third" }, { "math": "$2 \\times 6 = 12$", "note": "Two thirds" } ] },
      { "q": "Find $\\tfrac{3}{5}$ of $25$.", "a": "$15$",
        "solution": [ { "math": "$25 \\div 5 = 5$", "note": "One fifth" }, { "math": "$3 \\times 5 = 15$", "note": "Three fifths" } ] },
      { "q": "Find $\\tfrac{3}{4}$ of $16$.", "a": "$12$",
        "solution": [ { "math": "$16 \\div 4 = 4$", "note": "One quarter" }, { "math": "$3 \\times 4 = 12$", "note": "Three quarters" } ] },
      { "q": "Find $\\tfrac{2}{5}$ of $20$.", "a": "$8$",
        "solution": [ { "math": "$20 \\div 5 = 4$", "note": "One fifth" }, { "math": "$2 \\times 4 = 8$", "note": "Two fifths" } ] },
      { "q": "Find $\\tfrac{7}{10}$ of $40$.", "a": "$28$",
        "solution": [ { "math": "$40 \\div 10 = 4$", "note": "One tenth" }, { "math": "$7 \\times 4 = 28$", "note": "Seven tenths" } ] },
      { "q": "Find $\\tfrac{2}{3}$ of $12$.", "a": "$8$",
        "solution": [ { "math": "$12 \\div 3 = 4$", "note": "One third" }, { "math": "$2 \\times 4 = 8$", "note": "Two thirds" } ] },
      { "q": "Find $\\tfrac{3}{10}$ of $50$.", "a": "$15$",
        "tikz": "\\begin{tikzpicture}[x=0.3cm,y=0.7cm]\n\\draw (0,0) rectangle (50,1);\n\\foreach \\i in {5,10,...,45} \\draw (\\i,0) -- (\\i,1);\n\\fill[gray!40] (0,0) rectangle (15,1);\n\\node[below=4pt] at (25,0) {$50$};\n\\end{tikzpicture}",
        "solution": [ { "math": "$50 \\div 10 = 5$", "note": "One tenth" }, { "math": "$3 \\times 5 = 15$", "note": "Three tenths" } ] },
      { "q": "Find $\\tfrac{4}{5}$ of $15$.", "a": "$12$",
        "solution": [ { "math": "$15 \\div 5 = 3$", "note": "One fifth" }, { "math": "$4 \\times 3 = 12$", "note": "Four fifths" } ] }
    ],
    "development": [
      { "q": "Find $\\tfrac{2}{3}$ of $45$.", "a": "$30$",
        "solution": [ { "math": "$45 \\div 3 = 15$", "note": "One third" }, { "math": "$2 \\times 15 = 30$", "note": "Two thirds" } ] },
      { "q": "Find $\\tfrac{3}{4}$ of $48$.", "a": "$36$",
        "solution": [ { "math": "$48 \\div 4 = 12$", "note": "One quarter" }, { "math": "$3 \\times 12 = 36$", "note": "Three quarters" } ] },
      { "q": "A class of $28$ students has $\\tfrac{3}{4}$ wearing hats. How many wear hats?", "a": "$21$",
        "solution": [ { "math": "$28 \\div 4 = 7$", "note": "One quarter" }, { "math": "$3 \\times 7 = 21$", "note": "Three quarters" } ] },
      { "q": "Find $\\tfrac{4}{5}$ of $\\$45$.", "a": "$\\$36$",
        "solution": [ { "math": "$45 \\div 5 = 9$", "note": "One fifth" }, { "math": "$4 \\times 9 = 36$", "note": "Four fifths" } ] },
      { "q": "A ribbon $60$ cm long is cut so $\\tfrac{2}{5}$ is kept. How long is the kept piece?", "a": "$24$ cm",
        "tikz": "\\begin{tikzpicture}[x=0.25cm,y=0.7cm]\n\\draw (0,0) rectangle (60,1);\n\\foreach \\i in {12,24,36,48} \\draw (\\i,0) -- (\\i,1);\n\\fill[gray!40] (0,0) rectangle (24,1);\n\\node[below=4pt] at (30,0) {$60$};\n\\end{tikzpicture}",
        "solution": [ { "math": "$60 \\div 5 = 12$", "note": "One fifth" }, { "math": "$2 \\times 12 = 24 \\text{ cm}$", "note": "Two fifths" } ] },
      { "q": "Find $\\tfrac{7}{10}$ of $90$.", "a": "$63$",
        "solution": [ { "math": "$90 \\div 10 = 9$", "note": "One tenth" }, { "math": "$7 \\times 9 = 63$", "note": "Seven tenths" } ] },
      { "q": "Find $\\tfrac{5}{6}$ of $36$.", "a": "$30$",
        "solution": [ { "math": "$36 \\div 6 = 6$", "note": "One sixth" }, { "math": "$5 \\times 6 = 30$", "note": "Five sixths" } ] },
      { "q": "Of $1$ hour, find $\\tfrac{3}{4}$ in minutes.", "a": "$45$ min",
        "solution": [ { "math": "$60 \\div 4 = 15$", "note": "One quarter" }, { "math": "$3 \\times 15 = 45 \\text{ min}$", "note": "Three quarters" } ] },
      { "q": "Find $\\tfrac{2}{3}$ of $1$ kg, in grams.", "a": "$\\approx 667$ g",
        "solution": [ { "math": "$1\\,000 \\div 3 \\approx 333.3$", "note": "One third" }, { "math": "$2 \\times 333.3 \\approx 667 \\text{ g}$", "note": "Two thirds" } ] },
      { "q": "Find $\\tfrac{3}{5}$ of $55$.", "a": "$33$",
        "solution": [ { "math": "$55 \\div 5 = 11$", "note": "One fifth" }, { "math": "$3 \\times 11 = 33$", "note": "Three fifths" } ] }
    ],
    "mastery": [
      { "q": "A farmer has $120$ sheep. He sells $\\tfrac{3}{4}$ of them. How many are left?", "a": "$30$",
        "solution": [ { "math": "$\\tfrac{3}{4} \\text{ of } 120 = 90$", "note": "Sold" }, { "math": "$120 - 90 = 30$", "note": "Left" } ] },
      { "q": "$\\tfrac{2}{5}$ of a number is $14$. What is the number?", "a": "$35$",
        "solution": [ { "math": "$14 \\div 2 = 7$", "note": "One fifth" }, { "math": "$7 \\times 5 = 35$", "note": "The whole" } ] },
      { "q": "A book has $200$ pages. Mia reads $\\tfrac{3}{5}$. How many pages are left?", "a": "$80$",
        "solution": [ { "math": "$\\tfrac{3}{5} \\text{ of } 200 = 120$", "note": "Read" }, { "math": "$200 - 120 = 80$", "note": "Left" } ] },
      { "q": "A jug holds $2$ L. After pouring out $\\tfrac{3}{4}$, how many millilitres remain?", "a": "$500$ mL",
        "solution": [ { "math": "$\\tfrac{3}{4} \\text{ of } 2\\,000 = 1\\,500$", "note": "Poured out" }, { "math": "$2\\,000 - 1\\,500 = 500 \\text{ mL}$", "note": "Remaining" } ] },
      { "q": "A team scored $\\tfrac{2}{3}$ of its $54$ shots. How many shots missed?", "a": "$18$",
        "solution": [ { "math": "$\\tfrac{2}{3} \\text{ of } 54 = 36$", "note": "Scored" }, { "math": "$54 - 36 = 18$", "note": "Missed" } ] },
      { "q": "Find $\\tfrac{5}{8}$ of $64$.", "a": "$40$",
        "solution": [ { "math": "$64 \\div 8 = 8$", "note": "One eighth" }, { "math": "$5 \\times 8 = 40$", "note": "Five eighths" } ] },
      { "q": "$\\tfrac{3}{4}$ of a class of children walk to school. If $18$ walk, how many are in the class?", "a": "$24$",
        "solution": [ { "math": "$18 \\div 3 = 6$", "note": "One quarter" }, { "math": "$6 \\times 4 = 24$", "note": "The whole class" } ] },
      { "q": "A phone battery is at $\\tfrac{7}{10}$ of its full $4\\,000$ mAh. How many mAh is that?", "a": "$2\\,800$ mAh",
        "solution": [ { "math": "$4\\,000 \\div 10 = 400$", "note": "One tenth" }, { "math": "$7 \\times 400 = 2\\,800$", "note": "Seven tenths" } ] },
      { "q": "Of $\\$150$, Jo gives $\\tfrac{2}{5}$ to charity and keeps the rest. How much does she keep?", "a": "$\\$90$",
        "solution": [ { "math": "$\\tfrac{2}{5} \\text{ of } 150 = 60$", "note": "Given" }, { "math": "$150 - 60 = \\$90$", "note": "Kept" } ] },
      { "q": "A garden of $90$ m$^2$ has $\\tfrac{2}{3}$ as lawn and the rest as paving. What area is paving?", "a": "$30$ m$^2$",
        "solution": [ { "math": "$\\tfrac{2}{3} \\text{ of } 90 = 60$", "note": "Lawn" }, { "math": "$90 - 60 = 30 \\text{ m}^2$", "note": "Paving" } ] }
    ]
  }
}
