{
  "skillId": "inverse-operations-number-sentences",
  "atomType": "R",
  "theory": {
    "intro": "Every operation has an inverse that undoes it. Use inverses to rearrange a number sentence and find an unknown.",
    "facts": [
      "Addition and subtraction are **inverses**; multiplication and division are **inverses**.",
      "To undo $\\times$, divide; to undo $\\div$, multiply.",
      "Whatever you do to one side of $=$, do to the other to keep it balanced."
    ],
    "steps": [
      "Decide which operation is applied to the unknown.",
      "Apply the inverse operation to both sides.",
      "Simplify to find the unknown and check by substituting."
    ]
  },
  "practice": {
    "foundation": [
      { "q": "Solve for $x$: $x + 7 = 15$.", "a": "$x = 8$",
        "solution": [ { "math": "$x = 15 - 7$", "note": "Subtract to undo $+7$" }, { "math": "$= 8$", "note": "Check $8 + 7 = 15$" } ] },
      { "q": "Solve for $x$: $x - 4 = 9$.", "a": "$x = 13$",
        "solution": [ { "math": "$x = 9 + 4$", "note": "Add to undo $-4$" }, { "math": "$= 13$", "note": "Check $13 - 4 = 9$" } ] },
      { "q": "Solve for $x$: $5x = 35$.", "a": "$x = 7$",
        "solution": [ { "math": "$x = 35 \\div 5$", "note": "Divide to undo $\\times 5$" }, { "math": "$= 7$", "note": "Check $5 \\times 7 = 35$" } ] },
      { "q": "Solve for $x$: $\\tfrac{x}{3} = 6$.", "a": "$x = 18$",
        "solution": [ { "math": "$x = 6 \\times 3$", "note": "Multiply to undo $\\div 3$" }, { "math": "$= 18$", "note": "Check $18 \\div 3 = 6$" } ] },
      { "q": "Solve for $x$: $x + 12 = 20$.", "a": "$x = 8$",
        "solution": [ { "math": "$x = 20 - 12$", "note": "Subtract" }, { "math": "$= 8$", "note": "Check $8 + 12 = 20$" } ] },
      { "q": "Solve for $x$: $8x = 48$.", "a": "$x = 6$",
        "solution": [ { "math": "$x = 48 \\div 8$", "note": "Divide" }, { "math": "$= 6$", "note": "Check $8 \\times 6 = 48$" } ] },
      { "q": "Solve for $x$: $x - 10 = 5$.", "a": "$x = 15$",
        "solution": [ { "math": "$x = 5 + 10$", "note": "Add" }, { "math": "$= 15$", "note": "Check $15 - 10 = 5$" } ] },
      { "q": "Solve for $x$: $\\tfrac{x}{4} = 7$.", "a": "$x = 28$",
        "solution": [ { "math": "$x = 7 \\times 4$", "note": "Multiply" }, { "math": "$= 28$", "note": "Check $28 \\div 4 = 7$" } ] },
      { "q": "Solve for $x$: $6x = 54$.", "a": "$x = 9$",
        "solution": [ { "math": "$x = 54 \\div 6$", "note": "Divide" }, { "math": "$= 9$", "note": "Check $6 \\times 9 = 54$" } ] },
      { "q": "Solve for $x$: $x + 9 = 9$.", "a": "$x = 0$",
        "solution": [ { "math": "$x = 9 - 9$", "note": "Subtract" }, { "math": "$= 0$", "note": "Check $0 + 9 = 9$" } ] }
    ],
    "development": [
      { "q": "Solve for $x$: $2x + 5 = 17$.", "a": "$x = 6$",
        "solution": [ { "math": "$2x = 12$", "note": "Subtract $5$" }, { "math": "$x = 12 \\div 2 = 6$", "note": "Then divide" } ] },
      { "q": "Solve for $x$: $3x - 4 = 20$.", "a": "$x = 8$",
        "solution": [ { "math": "$3x = 24$", "note": "Add $4$" }, { "math": "$x = 24 \\div 3 = 8$", "note": "Then divide" } ] },
      { "q": "Solve for $x$: $\\tfrac{x}{5} + 2 = 9$.", "a": "$x = 35$",
        "solution": [ { "math": "$\\tfrac{x}{5} = 7$", "note": "Subtract $2$" }, { "math": "$x = 7 \\times 5 = 35$", "note": "Then multiply" } ] },
      { "q": "Solve for $x$: $4x + 11 = 43$.", "a": "$x = 8$",
        "solution": [ { "math": "$4x = 32$", "note": "Subtract $11$" }, { "math": "$x = 32 \\div 4 = 8$", "note": "Then divide" } ] },
      { "q": "Solve for $x$: $\\tfrac{x}{2} - 3 = 4$.", "a": "$x = 14$",
        "solution": [ { "math": "$\\tfrac{x}{2} = 7$", "note": "Add $3$" }, { "math": "$x = 7 \\times 2 = 14$", "note": "Then multiply" } ] },
      { "q": "Solve for $x$: $7x = 91$.", "a": "$x = 13$",
        "solution": [ { "math": "$x = 91 \\div 7$", "note": "Divide" }, { "math": "$= 13$", "note": "Check $7 \\times 13 = 91$" } ] },
      { "q": "Solve for $x$: $50 - x = 18$.", "a": "$x = 32$",
        "solution": [ { "math": "$x = 50 - 18$", "note": "Rearrange" }, { "math": "$= 32$", "note": "Check $50 - 32 = 18$" } ] },
      { "q": "Solve for $x$: $6x - 9 = 33$.", "a": "$x = 7$",
        "solution": [ { "math": "$6x = 42$", "note": "Add $9$" }, { "math": "$x = 42 \\div 6 = 7$", "note": "Then divide" } ] },
      { "q": "Solve for $x$: $\\tfrac{x}{6} + 5 = 12$.", "a": "$x = 42$",
        "solution": [ { "math": "$\\tfrac{x}{6} = 7$", "note": "Subtract $5$" }, { "math": "$x = 7 \\times 6 = 42$", "note": "Then multiply" } ] },
      { "q": "Solve for $x$: $9x + 8 = 80$.", "a": "$x = 8$",
        "solution": [ { "math": "$9x = 72$", "note": "Subtract $8$" }, { "math": "$x = 72 \\div 9 = 8$", "note": "Then divide" } ] }
    ],
    "mastery": [
      { "q": "I think of a number, multiply by $4$ and add $3$ to get $31$. What is the number?", "a": "$7$",
        "solution": [ { "math": "$4x = 28$", "note": "Subtract $3$" }, { "math": "$x = 28 \\div 4 = 7$", "note": "Then divide" } ] },
      { "q": "A number is halved and then $6$ is subtracted, giving $9$. Find the number.", "a": "$30$",
        "solution": [ { "math": "$\\tfrac{x}{2} = 15$", "note": "Add $6$" }, { "math": "$x = 15 \\times 2 = 30$", "note": "Then multiply" } ] },
      { "q": "Solve for $x$: $\\tfrac{x+4}{3} = 6$.", "a": "$x = 14$",
        "solution": [ { "math": "$x + 4 = 18$", "note": "Multiply by $3$" }, { "math": "$x = 18 - 4 = 14$", "note": "Then subtract" } ] },
      { "q": "After buying $5$ pens at $\\$x$ each, the cost was $\\$40$. Use a sentence to find $x$.", "a": "$\\$8$",
        "solution": [ { "math": "$5x = 40$", "note": "Set up sentence" }, { "math": "$x = 40 \\div 5 = 8$", "note": "Divide" } ] },
      { "q": "Solve for $x$: $100 = 8x + 4$.", "a": "$x = 12$",
        "solution": [ { "math": "$8x = 96$", "note": "Subtract $4$" }, { "math": "$x = 96 \\div 8 = 12$", "note": "Then divide" } ] },
      { "q": "A taxi charges a $\\$5$ flagfall plus $\\$3$ per km. A trip cost $\\$26$. How many km?", "a": "$7$ km",
        "solution": [ { "math": "$3x = 21$", "note": "Subtract $\\$5$ flagfall" }, { "math": "$x = 21 \\div 3 = 7$", "note": "Then divide" } ] },
      { "q": "Solve for $x$: $\\tfrac{x}{4} - 7 = 0$.", "a": "$x = 28$",
        "solution": [ { "math": "$\\tfrac{x}{4} = 7$", "note": "Add $7$" }, { "math": "$x = 7 \\times 4 = 28$", "note": "Then multiply" } ] },
      { "q": "Three equal boxes plus a $2$ kg parcel weigh $20$ kg. Find one box's mass.", "a": "$6$ kg",
        "solution": [ { "math": "$3x = 18$", "note": "Subtract $2$" }, { "math": "$x = 18 \\div 3 = 6$", "note": "Then divide" } ] },
      { "q": "Solve for $x$: $\\tfrac{2x}{5} = 8$.", "a": "$x = 20$",
        "solution": [ { "math": "$2x = 40$", "note": "Multiply by $5$" }, { "math": "$x = 40 \\div 2 = 20$", "note": "Then divide" } ] },
      { "q": "A number is multiplied by $6$, then $5$ is subtracted; the result equals $5 \\times 5$. Find the number.", "a": "$x = 5$",
        "solution": [ { "math": "$6x - 5 = 25$", "note": "$5 \\times 5 = 25$" }, { "math": "$6x = 30,\\ x = 5$", "note": "Apply inverses" } ] }
    ]
  }
}
