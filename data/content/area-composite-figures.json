{
  "skillId": "area-composite-figures",
  "atomType": "R",
  "theory": {
    "intro": "A composite figure is made from simpler shapes. Split an L-shaped figure into rectangles, find each area, then add (or subtract a missing corner from a large rectangle).",
    "facts": [
      "Area of a rectangle $=$ length $\\times$ width.",
      "**Split** the figure into rectangles and **add** the parts, or take a large rectangle and **subtract** the missing piece.",
      "Find any missing side length using the other lengths (opposite sides of the whole add up)."
    ],
    "steps": [
      "Cut the L-shape into two (or more) rectangles.",
      "Work out any missing side lengths from the given ones.",
      "Find each rectangle's area and add them together."
    ]
  },
  "practice": {
    "foundation": [
      { "q": "Find the area of this L-shape (all right angles).", "a": "$20\\text{ cm}^{2}$",
        "tikz": "\\begin{tikzpicture}[x=0.7cm,y=0.7cm]\n\\draw[thick] (0,0)--(6,0)--(6,2)--(2,2)--(2,4)--(0,4)--cycle;\n\\node[below] at (3,0) {$6$};\n\\node[right] at (6,1) {$2$};\n\\node[left] at (0,2) {$4$};\n\\node[above] at (1,4) {$2$};\n\\end{tikzpicture}",
        "solution": [ { "math": "$6 \\times 2 = 12$", "note": "Bottom rectangle" }, { "math": "$2 \\times (4-2)=4,\\ 12+4+4=20\\text{ cm}^{2}$", "note": "Left top rectangle $2\\times2$" } ] },
      { "q": "Find the area of this L-shape.", "a": "$14\\text{ m}^{2}$",
        "tikz": "\\begin{tikzpicture}[x=0.7cm,y=0.7cm]\n\\draw[thick] (0,0)--(5,0)--(5,2)--(2,2)--(2,4)--(0,4)--cycle;\n\\node[below] at (2.5,0) {$5$};\n\\node[right] at (5,1) {$2$};\n\\node[left] at (0,2) {$4$};\n\\node[above] at (1,4) {$2$};\n\\end{tikzpicture}",
        "solution": [ { "math": "$5 \\times 2 = 10$", "note": "Bottom rectangle" }, { "math": "$2 \\times (4-2)=4,\\ 10+4=14\\text{ m}^{2}$", "note": "Left top rectangle $2\\times2$" } ] },
      { "q": "Find the area of an L-shape made of a $4$ cm by $3$ cm rectangle joined to a $2$ cm by $5$ cm rectangle.", "a": "$22\\text{ cm}^{2}$",
        "solution": [ { "math": "$4 \\times 3 = 12$", "note": "First rectangle" }, { "math": "$2 \\times 5 = 10,\\ 12+10 = 22\\text{ cm}^{2}$", "note": "Add" } ] },
      { "q": "Find the area of this L-shape.", "a": "$22\\text{ cm}^{2}$",
        "tikz": "\\begin{tikzpicture}[x=0.7cm,y=0.7cm]\n\\draw[thick] (0,0)--(6,0)--(6,3)--(2,3)--(2,5)--(0,5)--cycle;\n\\node[below] at (3,0) {$6$};\n\\node[right] at (6,1.5) {$3$};\n\\node[left] at (0,2.5) {$5$};\n\\node[above] at (1,5) {$2$};\n\\end{tikzpicture}",
        "solution": [ { "math": "$6 \\times 3 = 18$", "note": "Bottom rectangle" }, { "math": "$2 \\times (5-3)=4,\\ 18+4 = 22\\text{ cm}^{2}$", "note": "Left top rectangle $2\\times2$" } ] },
      { "q": "A large $8$ m by $5$ m rectangle has a $3$ m by $2$ m corner removed. Find the remaining area.", "a": "$34\\text{ m}^{2}$",
        "solution": [ { "math": "$8 \\times 5 = 40$", "note": "Whole rectangle" }, { "math": "$40 - (3 \\times 2) = 34\\text{ m}^{2}$", "note": "Subtract corner" } ] },
      { "q": "Find the area of this L-shape.", "a": "$25\\text{ m}^{2}$",
        "tikz": "\\begin{tikzpicture}[x=0.6cm,y=0.6cm]\n\\draw[thick] (0,0)--(8,0)--(8,2)--(3,2)--(3,5)--(0,5)--cycle;\n\\node[below] at (4,0) {$8$};\n\\node[right] at (8,1) {$2$};\n\\node[left] at (0,2.5) {$5$};\n\\node[above] at (1.5,5) {$3$};\n\\end{tikzpicture}",
        "solution": [ { "math": "$8 \\times 2 = 16$", "note": "Bottom rectangle" }, { "math": "$3 \\times (5-2)=9,\\ 16+9 = 25\\text{ m}^{2}$", "note": "Left top rectangle $3\\times3$" } ] },
      { "q": "Find the area of an L-shape made from a $6$ m by $4$ m rectangle and a $2$ m by $3$ m rectangle.", "a": "$30\\text{ m}^{2}$",
        "solution": [ { "math": "$6 \\times 4 = 24$", "note": "First rectangle" }, { "math": "$2 \\times 3 = 6,\\ 24+6 = 30\\text{ m}^{2}$", "note": "Add" } ] },
      { "q": "Find the area of this L-shape.", "a": "$12\\text{ cm}^{2}$",
        "tikz": "\\begin{tikzpicture}[x=0.7cm,y=0.7cm]\n\\draw[thick] (0,0)--(4,0)--(4,2)--(2,2)--(2,4)--(0,4)--cycle;\n\\node[below] at (2,0) {$4$};\n\\node[right] at (4,1) {$2$};\n\\node[left] at (0,2) {$4$};\n\\node[above] at (1,4) {$2$};\n\\end{tikzpicture}",
        "solution": [ { "math": "$4 \\times 2 = 8$", "note": "Bottom rectangle" }, { "math": "$2 \\times (4-2)=4,\\ 8+4 = 12\\text{ cm}^{2}$", "note": "Left top rectangle $2\\times2$" } ] },
      { "q": "A $10$ cm by $6$ cm rectangle has a $4$ cm by $3$ cm corner cut out. Find the remaining area.", "a": "$48\\text{ cm}^{2}$",
        "solution": [ { "math": "$10 \\times 6 = 60$", "note": "Whole rectangle" }, { "math": "$60 - (4 \\times 3) = 48\\text{ cm}^{2}$", "note": "Subtract corner" } ] },
      { "q": "Find the area of an L-shape made of a $5$ cm by $5$ cm square and a $3$ cm by $2$ cm rectangle.", "a": "$31\\text{ cm}^{2}$",
        "solution": [ { "math": "$5 \\times 5 = 25$", "note": "Square" }, { "math": "$3 \\times 2 = 6,\\ 25+6 = 31\\text{ cm}^{2}$", "note": "Add" } ] }
    ],
    "development": [
      { "q": "Find the area of this L-shape.", "a": "$47\\text{ cm}^{2}$",
        "tikz": "\\begin{tikzpicture}[x=0.55cm,y=0.55cm]\n\\draw[thick] (0,0)--(8,0)--(8,4)--(5,4)--(5,7)--(0,7)--cycle;\n\\node[below] at (4,0) {$8$};\n\\node[right] at (8,2) {$4$};\n\\node[left] at (0,3.5) {$7$};\n\\node[above] at (2.5,7) {$5$};\n\\end{tikzpicture}",
        "solution": [ { "math": "$8 \\times 4 = 32$", "note": "Bottom rectangle" }, { "math": "$5 \\times (7-4)=15,\\ 32+15 = 47\\text{ cm}^{2}$", "note": "Left top rectangle $5\\times3$" } ] },
      { "q": "Find the area of this L-shape.", "a": "$84\\text{ m}^{2}$",
        "tikz": "\\begin{tikzpicture}[x=0.5cm,y=0.5cm]\n\\draw[thick] (0,0)--(12,0)--(12,5)--(6,5)--(6,9)--(0,9)--cycle;\n\\node[below] at (6,0) {$12$};\n\\node[right] at (12,2.5) {$5$};\n\\node[left] at (0,4.5) {$9$};\n\\node[above] at (3,9) {$6$};\n\\end{tikzpicture}",
        "solution": [ { "math": "$12 \\times 5 = 60$", "note": "Bottom rectangle" }, { "math": "$6 \\times (9-5)=24,\\ 60+24 = 84\\text{ m}^{2}$", "note": "Left top rectangle $6\\times4$" } ] },
      { "q": "A rectangular room $9$ m by $6$ m has a $3$ m by $2$ m alcove removed. Find the floor area.", "a": "$48\\text{ m}^{2}$",
        "solution": [ { "math": "$9 \\times 6 = 54$", "note": "Whole room" }, { "math": "$54 - (3 \\times 2) = 48\\text{ m}^{2}$", "note": "Subtract alcove" } ] },
      { "q": "Find the area of an L-shape: split into a $7$ cm by $4$ cm rectangle and a $3$ cm by $5$ cm rectangle.", "a": "$43\\text{ cm}^{2}$",
        "solution": [ { "math": "$7 \\times 4 = 28$", "note": "First rectangle" }, { "math": "$3 \\times 5 = 15,\\ 28+15 = 43\\text{ cm}^{2}$", "note": "Add" } ] },
      { "q": "Find the area of this L-shape.", "a": "$58\\text{ cm}^{2}$",
        "tikz": "\\begin{tikzpicture}[x=0.55cm,y=0.55cm]\n\\draw[thick] (0,0)--(10,0)--(10,4)--(6,4)--(6,7)--(0,7)--cycle;\n\\node[below] at (5,0) {$10$};\n\\node[right] at (10,2) {$4$};\n\\node[left] at (0,3.5) {$7$};\n\\node[above] at (3,7) {$6$};\n\\end{tikzpicture}",
        "solution": [ { "math": "$10 \\times 4 = 40$", "note": "Bottom rectangle" }, { "math": "$6 \\times 3 = 18,\\ 40+18 = 58\\text{ cm}^{2}$", "note": "Top: 6×(7−4)=18" } ] },
      { "q": "A $15$ m by $10$ m rectangular yard has a $6$ m by $4$ m shed removed. Find the open area.", "a": "$126\\text{ m}^{2}$",
        "solution": [ { "math": "$15 \\times 10 = 150$", "note": "Whole yard" }, { "math": "$150 - (6 \\times 4) = 126\\text{ m}^{2}$", "note": "Subtract shed" } ] },
      { "q": "Find the area of an L-shape made from a $12$ cm by $5$ cm rectangle and a $4$ cm by $7$ cm rectangle.", "a": "$88\\text{ cm}^{2}$",
        "solution": [ { "math": "$12 \\times 5 = 60$", "note": "First rectangle" }, { "math": "$4 \\times 7 = 28,\\ 60+28 = 88\\text{ cm}^{2}$", "note": "Add" } ] },
      { "q": "Find the area of this L-shape.", "a": "$79\\text{ m}^{2}$",
        "tikz": "\\begin{tikzpicture}[x=0.5cm,y=0.5cm]\n\\draw[thick] (0,0)--(11,0)--(11,4)--(7,4)--(7,9)--(0,9)--cycle;\n\\node[below] at (5.5,0) {$11$};\n\\node[right] at (11,2) {$4$};\n\\node[left] at (0,4.5) {$9$};\n\\node[above] at (3.5,9) {$7$};\n\\end{tikzpicture}",
        "solution": [ { "math": "$11 \\times 4 = 44$", "note": "Bottom rectangle" }, { "math": "$7 \\times (9-4)=35,\\ 44+35 = 79\\text{ m}^{2}$", "note": "Left top rectangle $7\\times5$" } ] },
      { "q": "An L-shaped path is a $20$ m by $2$ m strip joined to a $2$ m by $8$ m strip. Find its area.", "a": "$56\\text{ m}^{2}$",
        "solution": [ { "math": "$20 \\times 2 = 40$", "note": "First strip" }, { "math": "$2 \\times 8 = 16,\\ 40+16 = 56\\text{ m}^{2}$", "note": "Add" } ] },
      { "q": "A large rectangle $14$ cm by $9$ cm has a $5$ cm by $4$ cm rectangle cut from one corner. Find the remaining area.", "a": "$106\\text{ cm}^{2}$",
        "solution": [ { "math": "$14 \\times 9 = 126$", "note": "Whole rectangle" }, { "math": "$126 - (5 \\times 4) = 106\\text{ cm}^{2}$", "note": "Subtract corner" } ] }
    ],
    "mastery": [
      { "q": "An L-shaped lounge floor is to be carpeted. It is a $6$ m by $4$ m rectangle joined to a $3$ m by $2$ m rectangle. Carpet costs \\$$45$ per m$^{2}$. Find the cost.", "a": "\\$$1\\,350$",
        "solution": [ { "math": "$6 \\times 4 + 3 \\times 2 = 30\\text{ m}^{2}$", "note": "Total area" }, { "math": "$30 \\times 45 = \\$1\\,350$", "note": "Cost" } ] },
      { "q": "An L-shape has total area $50\\text{ cm}^{2}$. One rectangle within it is $6$ cm by $5$ cm. Find the area of the other rectangle.", "a": "$20\\text{ cm}^{2}$",
        "solution": [ { "math": "$6 \\times 5 = 30\\text{ cm}^{2}$", "note": "Known part" }, { "math": "$50 - 30 = 20\\text{ cm}^{2}$", "note": "Other part" } ] },
      { "q": "A $12$ m by $8$ m room has a $4$ m by $3$ m kitchen bench and a $2$ m by $2$ m pillar removed. Find the floor area.", "a": "$80\\text{ m}^{2}$",
        "solution": [ { "math": "$12 \\times 8 = 96\\text{ m}^{2}$", "note": "Whole room" }, { "math": "$96 - 12 - 4 = 80\\text{ m}^{2}$", "note": "Subtract bench and pillar" } ] },
      { "q": "An L-shape splits into a $10$ cm by $4$ cm rectangle and a square. Its total area is $65\\text{ cm}^{2}$. Find the side of the square.", "a": "$5$ cm",
        "solution": [ { "math": "$10 \\times 4 = 40$", "note": "Rectangle" }, { "math": "$65 - 40 = 25 = 5^{2}$", "note": "Square side $5$ cm" } ] },
      { "q": "A cross (plus) shape is made of five $3$ cm by $3$ cm squares. Find its area.", "a": "$45\\text{ cm}^{2}$",
        "solution": [ { "math": "$3 \\times 3 = 9\\text{ cm}^{2}$", "note": "One square" }, { "math": "$5 \\times 9 = 45\\text{ cm}^{2}$", "note": "Five squares" } ] },
      { "q": "An L-shaped garden bed has area $72\\text{ m}^{2}$. It splits into a $9$ m by $6$ m rectangle and another rectangle of width $3$ m. Find the other rectangle's length.", "a": "$6$ m",
        "solution": [ { "math": "$9 \\times 6 = 54\\text{ m}^{2}$", "note": "First rectangle" }, { "math": "$72 - 54 = 18,\\ 18 \\div 3 = 6\\text{ m}$", "note": "Other length" } ] },
      { "q": "An L-shape is a $20$ cm by $12$ cm rectangle with a $20$ cm by $7$ cm rectangle removed from the top right ($8$ cm wide stays). Find the area.", "a": "$184\\text{ cm}^{2}$",
        "solution": [ { "math": "$20 \\times 12 = 240$", "note": "Whole rectangle" }, { "math": "$240 - (8 \\times 7) = 184\\text{ cm}^{2}$", "note": "Subtract removed part $8\\times7$" } ] },
      { "q": "An L-shaped tile pattern covers $90\\text{ cm}^{2}$. Tiles are $5$ cm by $3$ cm. How many tiles are needed?", "a": "$6$ tiles",
        "solution": [ { "math": "$5 \\times 3 = 15\\text{ cm}^{2}$", "note": "One tile" }, { "math": "$90 \\div 15 = 6$", "note": "" } ] },
      { "q": "An L-shaped deck has area $48\\text{ m}^{2}$, split as a square of side $4$ m and a rectangle of length $8$ m. Find the rectangle's width.", "a": "$4$ m",
        "solution": [ { "math": "$4 \\times 4 = 16\\text{ m}^{2}$", "note": "Square" }, { "math": "$48 - 16 = 32,\\ 32 \\div 8 = 4\\text{ m}$", "note": "Width" } ] },
      { "q": "A $16$ m by $10$ m hall has an L-shaped stage taking up a $6$ m by $4$ m rectangle and a $3$ m by $2$ m rectangle. Find the floor area left for seating.", "a": "$130\\text{ m}^{2}$",
        "solution": [ { "math": "$16 \\times 10 = 160\\text{ m}^{2}$", "note": "Whole hall" }, { "math": "$160 - (24 + 6) = 130\\text{ m}^{2}$", "note": "Subtract stage" } ] }
    ]
  }
}
