{
  "skillId": "add-subtract-strategies",
  "atomType": "R",
  "theory": {
    "intro": "Mental strategies make addition and subtraction faster by reshaping the numbers into friendlier ones.",
    "facts": [
      "**Levelling**: shift one number to a round number and adjust the other to keep the sum the same.",
      "**Constant difference**: add the same amount to both numbers in a subtraction — the difference does not change.",
      "**Addition for subtraction**: find a difference by counting up from the smaller number.",
      "**Bridging**: jump to the next multiple of $10$ or $100$, then add the rest."
    ],
    "steps": [
      "Choose the strategy that makes a round number.",
      "Adjust both numbers consistently, or jump to the bridge.",
      "Combine the easy parts to get the answer."
    ]
  },
  "practice": {
    "foundation": [
      { "q": "Use bridging: $38 + 7$.", "a": "$45$",
        "solution": [ { "math": "$38 + 2 = 40$", "note": "Bridge to 40" }, { "math": "$40 + 5 = 45$", "note": "Add the rest" } ] },
      { "q": "Use levelling: $29 + 16$.", "a": "$45$",
        "solution": [ { "math": "$30 + 15$", "note": "Add 1 to 29, take 1 off 16" }, { "math": "$= 45$", "note": "Same total" } ] },
      { "q": "Use constant difference: $73 - 38$.", "a": "$35$",
        "solution": [ { "math": "$75 - 40$", "note": "Add 2 to both" }, { "math": "$= 35$", "note": "Difference unchanged" } ] },
      { "q": "Use addition for subtraction: $52 - 47$.", "a": "$5$",
        "solution": [ { "math": "$47 + 3 = 50$", "note": "Count up" }, { "math": "$50 + 2 = 52 \\Rightarrow 5$", "note": "$3 + 2 = 5$" } ] },
      { "q": "Use bridging: $56 + 8$.", "a": "$64$",
        "solution": [ { "math": "$56 + 4 = 60$", "note": "Bridge to 60" }, { "math": "$60 + 4 = 64$", "note": "Add the rest" } ] },
      { "q": "Use levelling: $48 + 27$.", "a": "$75$",
        "solution": [ { "math": "$50 + 25$", "note": "Add 2 to 48, take 2 off 27" }, { "math": "$= 75$", "note": "Same total" } ] },
      { "q": "Use constant difference: $64 - 29$.", "a": "$35$",
        "solution": [ { "math": "$65 - 30$", "note": "Add 1 to both" }, { "math": "$= 35$", "note": "Difference unchanged" } ] },
      { "q": "Use addition for subtraction: $61 - 58$.", "a": "$3$",
        "solution": [ { "math": "$58 + 2 = 60$", "note": "Count up" }, { "math": "$60 + 1 = 61 \\Rightarrow 3$", "note": "$2 + 1 = 3$" } ] },
      { "q": "Use bridging: $47 + 6$.", "a": "$53$",
        "solution": [ { "math": "$47 + 3 = 50$", "note": "Bridge to 50" }, { "math": "$50 + 3 = 53$", "note": "Add the rest" } ] },
      { "q": "Use levelling: $19 + 34$.", "a": "$53$",
        "solution": [ { "math": "$20 + 33$", "note": "Add 1 to 19, take 1 off 34" }, { "math": "$= 53$", "note": "Same total" } ] }
    ],
    "development": [
      { "q": "Use levelling: $198 + 47$.", "a": "$245$",
        "solution": [ { "math": "$200 + 45$", "note": "Add 2 to 198, take 2 off 47" }, { "math": "$= 245$", "note": "Same total" } ] },
      { "q": "Use constant difference: $403 - 198$.", "a": "$205$",
        "solution": [ { "math": "$405 - 200$", "note": "Add 2 to both" }, { "math": "$= 205$", "note": "Difference unchanged" } ] },
      { "q": "Use bridging: $367 + 9$.", "a": "$376$",
        "solution": [ { "math": "$367 + 3 = 370$", "note": "Bridge to 370" }, { "math": "$370 + 6 = 376$", "note": "Add the rest" } ] },
      { "q": "Use addition for subtraction: $204 - 196$.", "a": "$8$",
        "solution": [ { "math": "$196 + 4 = 200$", "note": "Count up" }, { "math": "$200 + 4 = 204 \\Rightarrow 8$", "note": "$4 + 4 = 8$" } ] },
      { "q": "Use levelling: $249 + 126$.", "a": "$375$",
        "solution": [ { "math": "$250 + 125$", "note": "Add 1 to 249, take 1 off 126" }, { "math": "$= 375$", "note": "Same total" } ] },
      { "q": "Use constant difference: $612 - 397$.", "a": "$215$",
        "solution": [ { "math": "$615 - 400$", "note": "Add 3 to both" }, { "math": "$= 215$", "note": "Difference unchanged" } ] },
      { "q": "Use bridging: $785 + 30$.", "a": "$815$",
        "solution": [ { "math": "$785 + 15 = 800$", "note": "Bridge to 800" }, { "math": "$800 + 15 = 815$", "note": "Add the rest" } ] },
      { "q": "Use addition for subtraction: $500 - 463$.", "a": "$37$",
        "solution": [ { "math": "$463 + 7 = 470$", "note": "Bridge up" }, { "math": "$470 + 30 = 500 \\Rightarrow 37$", "note": "$7 + 30 = 37$" } ] },
      { "q": "Use levelling: $297 + 458$.", "a": "$755$",
        "solution": [ { "math": "$300 + 455$", "note": "Add 3 to 297, take 3 off 458" }, { "math": "$= 755$", "note": "Same total" } ] },
      { "q": "Use constant difference: $1\\,002 - 897$.", "a": "$105$",
        "solution": [ { "math": "$1\\,005 - 900$", "note": "Add 3 to both" }, { "math": "$= 105$", "note": "Difference unchanged" } ] }
    ],
    "mastery": [
      { "q": "Which strategy is most efficient for $1\\,000 - 648$, and what is the answer?", "a": "Addition for subtraction; $352$",
        "solution": [ { "math": "$648 + 2 = 650$", "note": "Count up by bridging" }, { "math": "$650 + 350 = 1\\,000 \\Rightarrow 352$", "note": "$2 + 350 = 352$" } ] },
      { "q": "Sam buys items for $\\$4.95$ and $\\$3.95$. Use levelling to find the total.", "a": "$\\$8.90$",
        "solution": [ { "math": "$5.00 + 3.90$", "note": "Add $0.05$ to first, take $0.05$ off second" }, { "math": "$= 8.90$", "note": "$\\$8.90$" } ] },
      { "q": "Use constant difference to find $3\\,005 - 1\\,996$.", "a": "$1\\,009$",
        "solution": [ { "math": "$3\\,009 - 2\\,000$", "note": "Add 4 to both" }, { "math": "$= 1\\,009$", "note": "Difference unchanged" } ] },
      { "q": "A bill is $\\$50$ and the cost is $\\$31.40$. Use addition for subtraction to find the change.", "a": "$\\$18.60$",
        "solution": [ { "math": "$31.40 + 0.60 = 32$", "note": "Bridge up" }, { "math": "$32 + 18 = 50 \\Rightarrow 18.60$", "note": "$0.60 + 18 = 18.60$" } ] },
      { "q": "Explain why $73 - 38$ and $75 - 40$ give the same answer.", "a": "Adding $2$ to both keeps the difference $35$",
        "solution": [ { "math": "$73 - 38 = 35$", "note": "Original" }, { "math": "$75 - 40 = 35$", "note": "Both shifted by 2" } ] },
      { "q": "Use levelling to add $1\\,996 + 2\\,547$.", "a": "$4\\,543$",
        "solution": [ { "math": "$2\\,000 + 2\\,543$", "note": "Add 4 to first, take 4 off second" }, { "math": "$= 4\\,543$", "note": "Same total" } ] },
      { "q": "A jump from $268$ to $500$: use bridging to find the total jump.", "a": "$232$",
        "solution": [ { "math": "$268 + 32 = 300$", "note": "Bridge to 300" }, { "math": "$300 + 200 = 500 \\Rightarrow 232$", "note": "$32 + 200 = 232$" } ] },
      { "q": "Mia has $\\$200$ and pays $\\$148$ then $\\$29$. Use constant difference to find what is left after the first payment, then subtract the second.", "a": "$\\$23$",
        "solution": [ { "math": "$200 - 148 = 202 - 150 = 52$", "note": "Add 2 to both" }, { "math": "$52 - 29 = 53 - 30 = 23$", "note": "$\\$23$" } ] },
      { "q": "Use the most efficient mental strategy for $805 - 799$ and name it.", "a": "Addition for subtraction (count up); $6$",
        "solution": [ { "math": "$799 + 1 = 800$", "note": "Count up" }, { "math": "$800 + 5 = 805 \\Rightarrow 6$", "note": "$1 + 5 = 6$" } ] },
      { "q": "Use levelling, then check by another method: $59 + 38$.", "a": "$97$",
        "solution": [ { "math": "$60 + 37 = 97$", "note": "Levelling" }, { "math": "$59 + 1 = 60,\\ 60 + 37 = 97$", "note": "Bridging agrees" } ] }
    ]
  }
}
