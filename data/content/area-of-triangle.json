{
  "skillId": "area-of-triangle",
  "atomType": "R",
  "theory": {
    "intro": "A triangle is exactly half of a parallelogram (or rectangle) with the same base and height, so its area is half of base times height.",
    "facts": [
      "**Area $=$ $\\tfrac{1}{2} \\times$ base $\\times$ height**.",
      "The height is the **perpendicular** distance from the base to the opposite vertex, not a slanted side.",
      "Area is measured in square units: cm$^{2}$, m$^{2}$."
    ],
    "steps": [
      "Identify the base and the perpendicular height (the dashed line at a right angle).",
      "Multiply base $\\times$ height, then halve the result.",
      "Write the answer with squared units."
    ]
  },
  "practice": {
    "foundation": [
      { "q": "Find the area of this triangle.", "a": "$12\\text{ cm}^{2}$",
        "tikz": "\\begin{tikzpicture}[x=1cm,y=1cm]\n\\draw[thick] (0,0)--(4,0)--(1.5,2)--cycle;\n\\draw[dashed] (1.5,2)--(1.5,0);\n\\draw (1.5,0) rectangle (1.75,0.25);\n\\node[below] at (2,0) {$6$ cm};\n\\node[left] at (1.5,1) {$4$ cm};\n\\end{tikzpicture}",
        "solution": [ { "math": "$\\tfrac{1}{2} \\times 6 \\times 4$", "note": "half × base × height" }, { "math": "$= 12\\text{ cm}^{2}$", "note": "" } ] },
      { "q": "Find the area of this triangle.", "a": "$20\\text{ m}^{2}$",
        "tikz": "\\begin{tikzpicture}[x=1cm,y=1cm]\n\\draw[thick] (0,0)--(4,0)--(2.5,2.5)--cycle;\n\\draw[dashed] (2.5,2.5)--(2.5,0);\n\\draw (2.5,0) rectangle (2.75,0.25);\n\\node[below] at (2,0) {$8$ m};\n\\node[right] at (2.5,1.25) {$5$ m};\n\\end{tikzpicture}",
        "solution": [ { "math": "$\\tfrac{1}{2} \\times 8 \\times 5$", "note": "half × base × height" }, { "math": "$= 20\\text{ m}^{2}$", "note": "" } ] },
      { "q": "Find the area of a triangle with base $10$ cm and height $6$ cm.", "a": "$30\\text{ cm}^{2}$",
        "solution": [ { "math": "$\\tfrac{1}{2} \\times 10 \\times 6$", "note": "half × base × height" }, { "math": "$= 30\\text{ cm}^{2}$", "note": "" } ] },
      { "q": "Find the area of this right-angled triangle.", "a": "$6\\text{ cm}^{2}$",
        "tikz": "\\begin{tikzpicture}[x=1cm,y=1cm]\n\\draw[thick] (0,0)--(4,0)--(0,3)--cycle;\n\\draw (0,0) rectangle (0.3,0.3);\n\\node[below] at (2,0) {$4$ cm};\n\\node[left] at (0,1.5) {$3$ cm};\n\\end{tikzpicture}",
        "solution": [ { "math": "$\\tfrac{1}{2} \\times 4 \\times 3$", "note": "legs are base and height" }, { "math": "$= 6\\text{ cm}^{2}$", "note": "" } ] },
      { "q": "Find the area of a triangle with base $8$ cm and height $5$ cm.", "a": "$20\\text{ cm}^{2}$",
        "solution": [ { "math": "$\\tfrac{1}{2} \\times 8 \\times 5$", "note": "half × base × height" }, { "math": "$= 20\\text{ cm}^{2}$", "note": "" } ] },
      { "q": "Find the area of this triangle.", "a": "$18\\text{ m}^{2}$",
        "tikz": "\\begin{tikzpicture}[x=1cm,y=1cm]\n\\draw[thick] (0,0)--(4.5,0)--(2,2)--cycle;\n\\draw[dashed] (2,2)--(2,0);\n\\draw (2,0) rectangle (2.25,0.25);\n\\node[below] at (2.25,0) {$9$ m};\n\\node[right] at (2,1) {$4$ m};\n\\end{tikzpicture}",
        "solution": [ { "math": "$\\tfrac{1}{2} \\times 9 \\times 4$", "note": "half × base × height" }, { "math": "$= 18\\text{ m}^{2}$", "note": "" } ] },
      { "q": "Find the area of a triangle with base $12$ m and height $4$ m.", "a": "$24\\text{ m}^{2}$",
        "solution": [ { "math": "$\\tfrac{1}{2} \\times 12 \\times 4$", "note": "half × base × height" }, { "math": "$= 24\\text{ m}^{2}$", "note": "" } ] },
      { "q": "Find the area of this triangle.", "a": "$21\\text{ cm}^{2}$",
        "tikz": "\\begin{tikzpicture}[x=1cm,y=1cm]\n\\draw[thick] (0,0)--(6,0)--(2,2.1)--cycle;\n\\draw[dashed] (2,2.1)--(2,0);\n\\draw (2,0) rectangle (2.25,0.25);\n\\node[below] at (3,0) {$6$ cm};\n\\node[right] at (2,1.05) {$7$ cm};\n\\end{tikzpicture}",
        "solution": [ { "math": "$\\tfrac{1}{2} \\times 6 \\times 7$", "note": "half × base × height" }, { "math": "$= 21\\text{ cm}^{2}$", "note": "" } ] },
      { "q": "Find the area of a right-angled triangle with legs $6$ cm and $10$ cm.", "a": "$30\\text{ cm}^{2}$",
        "solution": [ { "math": "$\\tfrac{1}{2} \\times 6 \\times 10$", "note": "legs are base and height" }, { "math": "$= 30\\text{ cm}^{2}$", "note": "" } ] },
      { "q": "Find the area of this triangle.", "a": "$14\\text{ cm}^{2}$",
        "tikz": "\\begin{tikzpicture}[x=1cm,y=1cm]\n\\draw[thick] (0,0)--(4,0)--(2,1.4)--cycle;\n\\draw[dashed] (2,1.4)--(2,0);\n\\draw (2,0) rectangle (2.25,0.25);\n\\node[below] at (2,-0.05) {$7$ cm};\n\\node[right] at (2,0.7) {$4$ cm};\n\\end{tikzpicture}",
        "solution": [ { "math": "$\\tfrac{1}{2} \\times 7 \\times 4$", "note": "half × base × height" }, { "math": "$= 14\\text{ cm}^{2}$", "note": "" } ] }
    ],
    "development": [
      { "q": "Find the area of this triangle.", "a": "$84\\text{ cm}^{2}$",
        "tikz": "\\begin{tikzpicture}[x=1cm,y=1cm]\n\\draw[thick] (0,0)--(4.5,0)--(2,2.4)--cycle;\n\\draw[dashed] (2,2.4)--(2,0);\n\\draw (2,0) rectangle (2.25,0.25);\n\\node[below] at (2.25,0) {$14$ cm};\n\\node[right] at (2,1.2) {$12$ cm};\n\\end{tikzpicture}",
        "solution": [ { "math": "$\\tfrac{1}{2} \\times 14 \\times 12$", "note": "half × base × height" }, { "math": "$= 84\\text{ cm}^{2}$", "note": "" } ] },
      { "q": "A triangle has base $25$ m and perpendicular height $16$ m. Find its area.", "a": "$200\\text{ m}^{2}$",
        "solution": [ { "math": "$\\tfrac{1}{2} \\times 25 \\times 16$", "note": "half × base × height" }, { "math": "$= 200\\text{ m}^{2}$", "note": "" } ] },
      { "q": "Find the area of this triangle. The slant side $13$ cm is a distractor.", "a": "$30\\text{ cm}^{2}$",
        "tikz": "\\begin{tikzpicture}[x=1cm,y=1cm]\n\\draw[thick] (0,0)--(5,0)--(0,2.4)--cycle;\n\\draw (0,0) rectangle (0.3,0.3);\n\\node[below] at (2.5,0) {$12$ cm};\n\\node[left] at (0,1.2) {$5$ cm};\n\\node[above right] at (2.5,1.2) {$13$ cm};\n\\end{tikzpicture}",
        "solution": [ { "math": "$\\tfrac{1}{2} \\times 12 \\times 5$", "note": "Use perpendicular sides, not 13 cm" }, { "math": "$= 30\\text{ cm}^{2}$", "note": "" } ] },
      { "q": "A triangle has base $15$ cm and height $8$ cm. Find its area.", "a": "$60\\text{ cm}^{2}$",
        "solution": [ { "math": "$\\tfrac{1}{2} \\times 15 \\times 8$", "note": "half × base × height" }, { "math": "$= 60\\text{ cm}^{2}$", "note": "" } ] },
      { "q": "Find the area of this triangle.", "a": "$11.25\\text{ m}^{2}$",
        "tikz": "\\begin{tikzpicture}[x=1cm,y=1cm]\n\\draw[thick] (0,0)--(4.5,0)--(2,1.8)--cycle;\n\\draw[dashed] (2,1.8)--(2,0);\n\\draw (2,0) rectangle (2.25,0.25);\n\\node[below] at (2.25,0) {$4.5$ m};\n\\node[right] at (2,0.9) {$5$ m};\n\\end{tikzpicture}",
        "solution": [ { "math": "$\\tfrac{1}{2} \\times 4.5 \\times 5$", "note": "half × base × height" }, { "math": "$= 11.25\\text{ m}^{2}$", "note": "" } ] },
      { "q": "A triangular sail has base $3$ m and height $400$ cm. Find its area in m$^{2}$.", "a": "$6\\text{ m}^{2}$",
        "solution": [ { "math": "$400\\text{ cm} = 4\\text{ m}$", "note": "Match units" }, { "math": "$\\tfrac{1}{2} \\times 3 \\times 4 = 6\\text{ m}^{2}$", "note": "" } ] },
      { "q": "A triangle has base $20$ cm and height $9$ cm. Find its area.", "a": "$90\\text{ cm}^{2}$",
        "solution": [ { "math": "$\\tfrac{1}{2} \\times 20 \\times 9$", "note": "half × base × height" }, { "math": "$= 90\\text{ cm}^{2}$", "note": "" } ] },
      { "q": "A triangle has area $48\\text{ cm}^{2}$ and base $16$ cm. Find its height.", "a": "$6$ cm",
        "solution": [ { "math": "$\\tfrac{1}{2} \\times 16 \\times h = 48$", "note": "$8h = 48$" }, { "math": "$h = 6\\text{ cm}$", "note": "" } ] },
      { "q": "A triangle has area $36\\text{ m}^{2}$ and height $9$ m. Find its base.", "a": "$8$ m",
        "solution": [ { "math": "$\\tfrac{1}{2} \\times b \\times 9 = 36$", "note": "$4.5b = 36$" }, { "math": "$b = 8\\text{ m}$", "note": "" } ] },
      { "q": "Find the area of this triangle.", "a": "$54\\text{ cm}^{2}$",
        "tikz": "\\begin{tikzpicture}[x=1cm,y=1cm]\n\\draw[thick] (0,0)--(6,0)--(1.5,3)--cycle;\n\\draw[dashed] (1.5,3)--(1.5,0);\n\\draw (1.5,0) rectangle (1.75,0.25);\n\\node[below] at (3,0) {$12$ cm};\n\\node[left] at (1.5,1.5) {$9$ cm};\n\\end{tikzpicture}",
        "solution": [ { "math": "$\\tfrac{1}{2} \\times 12 \\times 9$", "note": "half × base × height" }, { "math": "$= 54\\text{ cm}^{2}$", "note": "" } ] }
    ],
    "mastery": [
      { "q": "A triangle has area $60\\text{ cm}^{2}$ and base $15$ cm. Find its height.", "a": "$8$ cm",
        "solution": [ { "math": "$\\tfrac{1}{2} \\times 15 \\times h = 60$", "note": "$7.5h = 60$" }, { "math": "$h = 8\\text{ cm}$", "note": "" } ] },
      { "q": "A rectangle $10$ cm by $6$ cm is cut along a diagonal. Find the area of one triangle.", "a": "$30\\text{ cm}^{2}$",
        "solution": [ { "math": "$10 \\times 6 = 60\\text{ cm}^{2}$", "note": "Rectangle area" }, { "math": "$60 \\div 2 = 30\\text{ cm}^{2}$", "note": "Half" } ] },
      { "q": "A triangular garden has base $12$ m and height $9$ m. Turf costs \\$$15$ per m$^{2}$. Find the total cost.", "a": "\\$$810$",
        "solution": [ { "math": "$\\tfrac{1}{2} \\times 12 \\times 9 = 54\\text{ m}^{2}$", "note": "Area" }, { "math": "$54 \\times 15 = \\$810$", "note": "Cost" } ] },
      { "q": "Two triangles have the same area $24\\text{ cm}^{2}$. One has base $8$ cm. Give a base and height for another.", "a": "e.g. base $6$ cm, height $8$ cm",
        "solution": [ { "math": "$\\tfrac{1}{2}bh = 24 \\Rightarrow bh = 48$", "note": "Same area" }, { "math": "$6 \\times 8 = 48$", "note": "One option" } ] },
      { "q": "A triangular flag has base $40$ cm and height $30$ cm. How many flags can be cut from $1.2\\text{ m}^{2}$ of fabric (no waste)?", "a": "$20$ flags",
        "solution": [ { "math": "$\\tfrac{1}{2} \\times 40 \\times 30 = 600\\text{ cm}^{2}$", "note": "One flag" }, { "math": "$12\\,000 \\div 600 = 20$", "note": "$1.2\\text{ m}^{2}=12\\,000\\text{ cm}^{2}$" } ] },
      { "q": "If the height of a triangle is doubled and the base kept the same, what happens to the area?", "a": "It doubles",
        "solution": [ { "math": "$\\tfrac{1}{2} b (2h) = 2 \\times \\tfrac{1}{2}bh$", "note": "Area scales with height" }, { "math": "$\\Rightarrow \\text{doubles}$", "note": "" } ] },
      { "q": "A composite shape is a $10$ cm by $4$ cm rectangle with a triangle (base $10$ cm, height $3$ cm) on top. Find the total area.", "a": "$55\\text{ cm}^{2}$",
        "solution": [ { "math": "$10 \\times 4 = 40\\text{ cm}^{2}$", "note": "Rectangle" }, { "math": "$\\tfrac{1}{2}\\times 10 \\times 3 = 15$, total $55\\text{ cm}^{2}$", "note": "Add triangle" } ] },
      { "q": "A triangular field has base $50$ m and height $36$ m. Find its area in m$^{2}$, then in hectares.", "a": "$900\\text{ m}^{2} = 0.09$ ha",
        "solution": [ { "math": "$\\tfrac{1}{2} \\times 50 \\times 36 = 900\\text{ m}^{2}$", "note": "Area" }, { "math": "$900 \\div 10\\,000 = 0.09\\text{ ha}$", "note": "" } ] },
      { "q": "A triangle has area $30\\text{ cm}^{2}$ and height $12$ cm. A second triangle has the same area but height $5$ cm. Find each base.", "a": "$5$ cm and $12$ cm",
        "solution": [ { "math": "$\\tfrac{1}{2}\\times b \\times 12 = 30 \\Rightarrow b = 5$", "note": "First base" }, { "math": "$\\tfrac{1}{2}\\times b \\times 5 = 30 \\Rightarrow b = 12$", "note": "Second base" } ] },
      { "q": "A triangle has base $(x)$ cm, height $10$ cm and area $45\\text{ cm}^{2}$. Find $x$.", "a": "$9$ cm",
        "solution": [ { "math": "$\\tfrac{1}{2} \\times x \\times 10 = 45$", "note": "$5x = 45$" }, { "math": "$x = 9\\text{ cm}$", "note": "" } ] }
    ]
  }
}
