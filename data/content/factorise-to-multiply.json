{
  "skillId": "factorise-to-multiply",
  "atomType": "R",
  "theory": {
    "intro": "Breaking a number into factors lets you re-group a multiplication into easier steps. This uses the **associative property**.",
    "facts": [
      "You can multiply factors in **any order or grouping**: $a \\times b \\times c = (a \\times b) \\times c$.",
      "e.g. $12 \\times 25 = 3 \\times 4 \\times 25 = 3 \\times 100 = 300$.",
      "Look for factors that pair to make $10$, $100$ or another round number."
    ],
    "steps": [
      "Factorise one number to expose a helpful factor.",
      "Re-group so an easy product (like $\\times 100$) is formed.",
      "Multiply the remaining factors."
    ]
  },
  "practice": {
    "foundation": [
      { "q": "Use factorising to find $12 \\times 25$.", "a": "$300$",
        "solution": [ { "math": "$3 \\times 4 \\times 25$", "note": "$12 = 3 \\times 4$" }, { "math": "$= 3 \\times 100 = 300$", "note": "$4 \\times 25 = 100$" } ] },
      { "q": "Use factorising to find $16 \\times 5$.", "a": "$80$",
        "solution": [ { "math": "$8 \\times 2 \\times 5$", "note": "$16 = 8 \\times 2$" }, { "math": "$= 8 \\times 10 = 80$", "note": "$2 \\times 5 = 10$" } ] },
      { "q": "Use factorising to find $24 \\times 5$.", "a": "$120$",
        "solution": [ { "math": "$12 \\times 2 \\times 5$", "note": "$24 = 12 \\times 2$" }, { "math": "$= 12 \\times 10 = 120$", "note": "$2 \\times 5 = 10$" } ] },
      { "q": "Use factorising to find $14 \\times 5$.", "a": "$70$",
        "solution": [ { "math": "$7 \\times 2 \\times 5$", "note": "$14 = 7 \\times 2$" }, { "math": "$= 7 \\times 10 = 70$", "note": "$2 \\times 5 = 10$" } ] },
      { "q": "Use factorising to find $8 \\times 25$.", "a": "$200$",
        "solution": [ { "math": "$2 \\times 4 \\times 25$", "note": "$8 = 2 \\times 4$" }, { "math": "$= 2 \\times 100 = 200$", "note": "$4 \\times 25 = 100$" } ] },
      { "q": "Use factorising to find $18 \\times 5$.", "a": "$90$",
        "solution": [ { "math": "$9 \\times 2 \\times 5$", "note": "$18 = 9 \\times 2$" }, { "math": "$= 9 \\times 10 = 90$", "note": "$2 \\times 5 = 10$" } ] },
      { "q": "Use factorising to find $16 \\times 25$.", "a": "$400$",
        "solution": [ { "math": "$4 \\times 4 \\times 25$", "note": "$16 = 4 \\times 4$" }, { "math": "$= 4 \\times 100 = 400$", "note": "$4 \\times 25 = 100$" } ] },
      { "q": "Use factorising to find $6 \\times 15$.", "a": "$90$",
        "solution": [ { "math": "$6 \\times 3 \\times 5$", "note": "$15 = 3 \\times 5$" }, { "math": "$= 18 \\times 5 = 90$", "note": "$6 \\times 3 = 18$" } ] },
      { "q": "Use factorising to find $22 \\times 5$.", "a": "$110$",
        "solution": [ { "math": "$11 \\times 2 \\times 5$", "note": "$22 = 11 \\times 2$" }, { "math": "$= 11 \\times 10 = 110$", "note": "$2 \\times 5 = 10$" } ] },
      { "q": "Use factorising to find $4 \\times 35$.", "a": "$140$",
        "solution": [ { "math": "$4 \\times 7 \\times 5$", "note": "$35 = 7 \\times 5$" }, { "math": "$= 28 \\times 5 = 140$", "note": "$4 \\times 7 = 28$" } ] }
    ],
    "development": [
      { "q": "Use factorising to find $32 \\times 25$.", "a": "$800$",
        "solution": [ { "math": "$8 \\times 4 \\times 25$", "note": "$32 = 8 \\times 4$" }, { "math": "$= 8 \\times 100 = 800$", "note": "$4 \\times 25 = 100$" } ] },
      { "q": "Use factorising to find $48 \\times 25$.", "a": "$1\\,200$",
        "solution": [ { "math": "$12 \\times 4 \\times 25$", "note": "$48 = 12 \\times 4$" }, { "math": "$= 12 \\times 100 = 1\\,200$", "note": "$4 \\times 25 = 100$" } ] },
      { "q": "Use factorising to find $25 \\times 36$.", "a": "$900$",
        "solution": [ { "math": "$25 \\times 4 \\times 9$", "note": "$36 = 4 \\times 9$" }, { "math": "$= 100 \\times 9 = 900$", "note": "$25 \\times 4 = 100$" } ] },
      { "q": "Use factorising to find $35 \\times 4$.", "a": "$140$",
        "solution": [ { "math": "$5 \\times 7 \\times 4$", "note": "$35 = 5 \\times 7$" }, { "math": "$= 7 \\times 20 = 140$", "note": "$5 \\times 4 = 20$" } ] },
      { "q": "Use factorising to find $45 \\times 8$.", "a": "$360$",
        "solution": [ { "math": "$45 \\times 2 \\times 4$", "note": "$8 = 2 \\times 4$" }, { "math": "$= 90 \\times 4 = 360$", "note": "$45 \\times 2 = 90$" } ] },
      { "q": "Use factorising to find $15 \\times 12$.", "a": "$180$",
        "solution": [ { "math": "$15 \\times 2 \\times 6$", "note": "$12 = 2 \\times 6$" }, { "math": "$= 30 \\times 6 = 180$", "note": "$15 \\times 2 = 30$" } ] },
      { "q": "Use factorising to find $125 \\times 8$.", "a": "$1\\,000$",
        "solution": [ { "math": "$125 \\times 2 \\times 4$", "note": "$8 = 2 \\times 4$" }, { "math": "$= 250 \\times 4 = 1\\,000$", "note": "$125 \\times 2 = 250$" } ] },
      { "q": "Use factorising to find $50 \\times 18$.", "a": "$900$",
        "solution": [ { "math": "$50 \\times 2 \\times 9$", "note": "$18 = 2 \\times 9$" }, { "math": "$= 100 \\times 9 = 900$", "note": "$50 \\times 2 = 100$" } ] },
      { "q": "Use factorising to find $24 \\times 15$.", "a": "$360$",
        "solution": [ { "math": "$24 \\times 3 \\times 5$", "note": "$15 = 3 \\times 5$" }, { "math": "$= 72 \\times 5 = 360$", "note": "$24 \\times 3 = 72$" } ] },
      { "q": "Use factorising to find $28 \\times 25$.", "a": "$700$",
        "solution": [ { "math": "$7 \\times 4 \\times 25$", "note": "$28 = 7 \\times 4$" }, { "math": "$= 7 \\times 100 = 700$", "note": "$4 \\times 25 = 100$" } ] }
    ],
    "mastery": [
      { "q": "A shop sells $25$ boxes, each holding $16$ pens. Use factorising to find the total.", "a": "$400$",
        "solution": [ { "math": "$25 \\times 4 \\times 4$", "note": "$16 = 4 \\times 4$" }, { "math": "$= 100 \\times 4 = 400$", "note": "$25 \\times 4 = 100$" } ] },
      { "q": "Find $125 \\times 24$ by factorising.", "a": "$3\\,000$",
        "solution": [ { "math": "$125 \\times 8 \\times 3$", "note": "$24 = 8 \\times 3$" }, { "math": "$= 1000 \\times 3 = 3\\,000$", "note": "$125 \\times 8 = 1\\,000$" } ] },
      { "q": "A delivery has $25$ cartons of $12$ cans. Use factorising to find the number of cans.", "a": "$300$",
        "solution": [ { "math": "$25 \\times 4 \\times 3$", "note": "$12 = 4 \\times 3$" }, { "math": "$= 100 \\times 3 = 300$", "note": "$25 \\times 4 = 100$" } ] },
      { "q": "Find $16 \\times 35$ by factorising.", "a": "$560$",
        "solution": [ { "math": "$8 \\times 2 \\times 5 \\times 7$", "note": "$16 = 8 \\times 2,\\ 35 = 5 \\times 7$" }, { "math": "$= 8 \\times 10 \\times 7 = 560$", "note": "$2 \\times 5 = 10$" } ] },
      { "q": "Find $45 \\times 16$ by factorising.", "a": "$720$",
        "solution": [ { "math": "$45 \\times 2 \\times 8$", "note": "$16 = 2 \\times 8$" }, { "math": "$= 90 \\times 8 = 720$", "note": "$45 \\times 2 = 90$" } ] },
      { "q": "Each ticket costs $\\$8$. Use factorising to find the cost of $125$ tickets.", "a": "$\\$1\\,000$",
        "solution": [ { "math": "$125 \\times 2 \\times 4$", "note": "$8 = 2 \\times 4$" }, { "math": "$= 250 \\times 4 = \\$1\\,000$", "note": "$125 \\times 2 = 250$" } ] },
      { "q": "Find $36 \\times 25$ by factorising.", "a": "$900$",
        "solution": [ { "math": "$9 \\times 4 \\times 25$", "note": "$36 = 9 \\times 4$" }, { "math": "$= 9 \\times 100 = 900$", "note": "$4 \\times 25 = 100$" } ] },
      { "q": "A box has $15$ rows of $12$ chocolates. Use factorising to find the total.", "a": "$180$",
        "solution": [ { "math": "$15 \\times 2 \\times 6$", "note": "$12 = 2 \\times 6$" }, { "math": "$= 30 \\times 6 = 180$", "note": "$15 \\times 2 = 30$" } ] },
      { "q": "Find $250 \\times 16$ by factorising.", "a": "$4\\,000$",
        "solution": [ { "math": "$250 \\times 4 \\times 4$", "note": "$16 = 4 \\times 4$" }, { "math": "$= 1000 \\times 4 = 4\\,000$", "note": "$250 \\times 4 = 1\\,000$" } ] },
      { "q": "Find $18 \\times 35$ by factorising.", "a": "$630$",
        "solution": [ { "math": "$18 \\times 7 \\times 5$", "note": "$35 = 7 \\times 5$" }, { "math": "$= 126 \\times 5 = 630$", "note": "$18 \\times 7 = 126$" } ] }
    ]
  }
}
