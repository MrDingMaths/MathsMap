{
  "skillId": "add-multiple-numbers-place-value",
  "atomType": "R",
  "theory": {
    "intro": "When adding or subtracting numbers with different numbers of digits, line them up by place value so each column holds ones, tens, hundreds and so on.",
    "facts": [
      "**Align the place values** (ones under ones, tens under tens) — line up the right-hand ends for whole numbers.",
      "Add a column at a time, **carrying** into the next column when it reaches $10$ or more.",
      "When adding three or more numbers, a column total can be larger than $19$ — carry the full tens part.",
      "Empty places act like a $0$."
    ],
    "steps": [
      "Write the numbers in a column, aligned by place value.",
      "Add (or subtract) the ones, then tens, then hundreds, carrying or borrowing as needed.",
      "Read off the answer."
    ]
  },
  "practice": {
    "foundation": [
      { "q": "Add: $245 + 7 + 38$.", "a": "$290$",
        "solution": [ { "math": "$245 + 7 + 38$", "note": "Line up by place value" }, { "math": "$= 290$", "note": "Ones $5+7+8=20$, carry 2" } ] },
      { "q": "Add: $1\\,200 + 85 + 9$.", "a": "$1\\,294$",
        "solution": [ { "math": "$1\\,200 + 85 + 9$", "note": "Align ends" }, { "math": "$= 1\\,294$", "note": "Add each column" } ] },
      { "q": "Add: $36 + 408 + 5$.", "a": "$449$",
        "solution": [ { "math": "$36 + 408 + 5$", "note": "Ones: $6+8+5=19$" }, { "math": "$= 449$", "note": "Carry 1 to tens" } ] },
      { "q": "Add: $12 + 340 + 6$.", "a": "$358$",
        "solution": [ { "math": "$12 + 340 + 6$", "note": "Align by place value" }, { "math": "$= 358$", "note": "Sum the columns" } ] },
      { "q": "Add: $500 + 64 + 8$.", "a": "$572$",
        "solution": [ { "math": "$500 + 64 + 8$", "note": "Ones: $0+4+8=12$" }, { "math": "$= 572$", "note": "Carry 1" } ] },
      { "q": "Subtract: $403 - 27$.", "a": "$376$",
        "solution": [ { "math": "$403 - 27$", "note": "Align by place value" }, { "math": "$= 376$", "note": "Borrow across the zero" } ] },
      { "q": "Add: $9 + 90 + 900$.", "a": "$999$",
        "solution": [ { "math": "$9 + 90 + 900$", "note": "One digit per place" }, { "math": "$= 999$", "note": "No carrying" } ] },
      { "q": "Add: $215 + 38 + 142$.", "a": "$395$",
        "solution": [ { "math": "$215 + 38 + 142$", "note": "Ones: $5+8+2=15$" }, { "math": "$= 395$", "note": "Carry 1" } ] },
      { "q": "Subtract: $1\\,050 - 84$.", "a": "$966$",
        "solution": [ { "math": "$1\\,050 - 84$", "note": "Align ends" }, { "math": "$= 966$", "note": "Borrow as needed" } ] },
      { "q": "Add: $7 + 56 + 423$.", "a": "$486$",
        "solution": [ { "math": "$7 + 56 + 423$", "note": "Ones: $7+6+3=16$" }, { "math": "$= 486$", "note": "Carry 1" } ] }
    ],
    "development": [
      { "q": "Add: $3\\,420 + 185 + 9$.", "a": "$3\\,614$",
        "solution": [ { "math": "$3\\,420 + 185 + 9$", "note": "Align by place value" }, { "math": "$= 3\\,614$", "note": "Sum the columns" } ] },
      { "q": "Add: $12\\,500 + 760 + 45$.", "a": "$13\\,305$",
        "solution": [ { "math": "$12\\,500 + 760 + 45$", "note": "Line up ends" }, { "math": "$= 13\\,305$", "note": "Carry through" } ] },
      { "q": "Add three numbers: $458 + 1\\,236 + 79$.", "a": "$1\\,773$",
        "solution": [ { "math": "$458 + 1\\,236 + 79$", "note": "Ones: $8+6+9=23$" }, { "math": "$= 1\\,773$", "note": "Carry 2 to tens" } ] },
      { "q": "Subtract: $5\\,006 - 348$.", "a": "$4\\,658$",
        "solution": [ { "math": "$5\\,006 - 348$", "note": "Borrow across zeros" }, { "math": "$= 4\\,658$", "note": "Work right to left" } ] },
      { "q": "Add: $26 + 304 + 1\\,250 + 8$.", "a": "$1\\,588$",
        "solution": [ { "math": "$26 + 304 + 1\\,250 + 8$", "note": "Four numbers, aligned" }, { "math": "$= 1\\,588$", "note": "Add each column" } ] },
      { "q": "Add: $9\\,999 + 1$.", "a": "$10\\,000$",
        "solution": [ { "math": "$9\\,999 + 1$", "note": "Ones: $9+1=10$" }, { "math": "$= 10\\,000$", "note": "Carry cascades" } ] },
      { "q": "Add: $640 + 2\\,375 + 58$.", "a": "$3\\,073$",
        "solution": [ { "math": "$640 + 2\\,375 + 58$", "note": "Ones: $0+5+8=13$" }, { "math": "$= 3\\,073$", "note": "Carry 1" } ] },
      { "q": "Subtract: $20\\,000 - 1\\,475$.", "a": "$18\\,525$",
        "solution": [ { "math": "$20\\,000 - 1\\,475$", "note": "Borrow across the zeros" }, { "math": "$= 18\\,525$", "note": "Work right to left" } ] },
      { "q": "Add four numbers: $35 + 408 + 6\\,200 + 17$.", "a": "$6\\,660$",
        "solution": [ { "math": "$35 + 408 + 6\\,200 + 17$", "note": "Align by place value" }, { "math": "$= 6\\,660$", "note": "Sum the columns" } ] },
      { "q": "Add: $750 + 750 + 750$.", "a": "$2\\,250$",
        "solution": [ { "math": "$750 + 750 + 750$", "note": "Tens: $5+5+5=15$" }, { "math": "$= 2\\,250$", "note": "Carry through" } ] }
    ],
    "mastery": [
      { "q": "Find the total of $4\\,560 + 38 + 1\\,209 + 7$.", "a": "$5\\,814$",
        "solution": [ { "math": "$4\\,560 + 38 + 1\\,209 + 7$", "note": "Align by place value" }, { "math": "$= 5\\,814$", "note": "Carry across columns" } ] },
      { "q": "A till holds notes worth $\\$1\\,200$, coins worth $\\$85$ and $\\$9$ in change. What is the total?", "a": "$\\$1\\,294$",
        "solution": [ { "math": "$1\\,200 + 85 + 9$", "note": "Align by place value" }, { "math": "$= 1\\,294$", "note": "$\\$1\\,294$" } ] },
      { "q": "Add the four distances: $1\\,250 + 980 + 45 + 6$ km.", "a": "$2\\,281$ km",
        "solution": [ { "math": "$1\\,250 + 980 + 45 + 6$", "note": "Ones: $0+0+5+6=11$" }, { "math": "$= 2\\,281$", "note": "$2\\,281$ km" } ] },
      { "q": "Fill the missing digit: $4\\square8 + 27 = 505$.", "a": "$7$ (so $478$)",
        "solution": [ { "math": "$505 - 27 = 478$", "note": "Subtract to undo" }, { "math": "$4\\underline{7}8$", "note": "Missing digit is 7" } ] },
      { "q": "A stadium has $18\\,000$ seats. Three stands seat $6\\,450$, $5\\,280$ and $4\\,975$. How many seats are in the fourth stand?", "a": "$1\\,295$ seats",
        "solution": [ { "math": "$6\\,450 + 5\\,280 + 4\\,975 = 16\\,705$", "note": "Three stands" }, { "math": "$18\\,000 - 16\\,705 = 1\\,295$", "note": "$1\\,295$ seats" } ] },
      { "q": "Add: $99 + 999 + 9\\,999$.", "a": "$11\\,097$",
        "solution": [ { "math": "$99 + 999 + 9\\,999$", "note": "Ones: $9+9+9=27$" }, { "math": "$= 11\\,097$", "note": "Carries cascade" } ] },
      { "q": "Three deliveries weighed $1\\,840$ kg, $76$ kg and $2\\,309$ kg. What is the total, and how much under a $5\\,000$ kg limit?", "a": "$4\\,225$ kg; $775$ kg under",
        "solution": [ { "math": "$1\\,840 + 76 + 2\\,309 = 4\\,225$", "note": "Total" }, { "math": "$5\\,000 - 4\\,225 = 775$", "note": "$775$ kg under" } ] },
      { "q": "Find the missing addend: $258 + \\square + 40 = 1\\,000$.", "a": "$702$",
        "solution": [ { "math": "$258 + 40 = 298$", "note": "Known parts" }, { "math": "$1\\,000 - 298 = 702$", "note": "Missing addend" } ] },
      { "q": "A shop's sales were $\\$3\\,408$, $\\$95$, $\\$1\\,260$ and $\\$7$. What were the total sales?", "a": "$\\$4\\,770$",
        "solution": [ { "math": "$3\\,408 + 95 + 1\\,260 + 7$", "note": "Align by place value" }, { "math": "$= 4\\,770$", "note": "$\\$4\\,770$" } ] },
      { "q": "From $10\\,000$ subtract $4\\,560$, $1\\,209$ and $38$. What remains?", "a": "$4\\,193$",
        "solution": [ { "math": "$4\\,560 + 1\\,209 + 38 = 5\\,807$", "note": "Total to remove" }, { "math": "$10\\,000 - 5\\,807 = 4\\,193$", "note": "$4\\,193$ remains" } ] }
    ]
  }
}
