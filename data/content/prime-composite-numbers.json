{
  "skillId": "prime-composite-numbers",
  "atomType": "R",
  "theory": {
    "intro": "A **prime** number has exactly two factors: $1$ and itself. A **composite** number has more than two factors.",
    "facts": [
      "**Prime**: exactly two factors, e.g. $2, 3, 5, 7, 11$.",
      "**Composite**: more than two factors, e.g. $4, 6, 8, 9$.",
      "$1$ is **neither** prime nor composite; $2$ is the only even prime."
    ],
    "steps": [
      "Count the factors of the number.",
      "Exactly two factors → prime; more than two → composite.",
      "$1$ has only one factor, so it is neither."
    ]
  },
  "practice": {
    "foundation": [
      { "q": "Is $5$ prime or composite?", "a": "prime",
        "solution": [ { "math": "$5: 1, 5$", "note": "Only two factors" }, { "math": "$\\text{prime}$", "note": "" } ] },
      { "q": "Is $6$ prime or composite?", "a": "composite",
        "solution": [ { "math": "$6: 1, 2, 3, 6$", "note": "More than two factors" }, { "math": "$\\text{composite}$", "note": "" } ] },
      { "q": "Is $9$ prime or composite?", "a": "composite",
        "solution": [ { "math": "$9: 1, 3, 9$", "note": "Three factors" }, { "math": "$\\text{composite}$", "note": "" } ] },
      { "q": "Is $7$ prime or composite?", "a": "prime",
        "solution": [ { "math": "$7: 1, 7$", "note": "Only two factors" }, { "math": "$\\text{prime}$", "note": "" } ] },
      { "q": "Is $2$ prime or composite?", "a": "prime",
        "solution": [ { "math": "$2: 1, 2$", "note": "Two factors" }, { "math": "$\\text{prime (the only even prime)}$", "note": "" } ] },
      { "q": "Is $1$ prime, composite or neither?", "a": "neither",
        "solution": [ { "math": "$1: 1$", "note": "Only one factor" }, { "math": "$\\text{neither}$", "note": "" } ] },
      { "q": "Is $11$ prime or composite?", "a": "prime",
        "solution": [ { "math": "$11: 1, 11$", "note": "Two factors" }, { "math": "$\\text{prime}$", "note": "" } ] },
      { "q": "Is $10$ prime or composite?", "a": "composite",
        "solution": [ { "math": "$10: 1, 2, 5, 10$", "note": "Four factors" }, { "math": "$\\text{composite}$", "note": "" } ] },
      { "q": "Is $3$ prime or composite?", "a": "prime",
        "solution": [ { "math": "$3: 1, 3$", "note": "Two factors" }, { "math": "$\\text{prime}$", "note": "" } ] },
      { "q": "Is $8$ prime or composite?", "a": "composite",
        "solution": [ { "math": "$8: 1, 2, 4, 8$", "note": "Four factors" }, { "math": "$\\text{composite}$", "note": "" } ] }
    ],
    "development": [
      { "q": "List the prime numbers between $10$ and $20$.", "a": "$11, 13, 17, 19$",
        "solution": [ { "math": "$\\text{test } 11\\text{–}19$", "note": "Two factors only" }, { "math": "$11, 13, 17, 19$", "note": "" } ] },
      { "q": "Is $15$ prime or composite?", "a": "composite",
        "solution": [ { "math": "$15 = 3 \\times 5$", "note": "Factors besides 1 and 15" }, { "math": "$\\text{composite}$", "note": "" } ] },
      { "q": "Is $13$ prime or composite?", "a": "prime",
        "solution": [ { "math": "$13: 1, 13$", "note": "No other factors" }, { "math": "$\\text{prime}$", "note": "" } ] },
      { "q": "Is $21$ prime or composite?", "a": "composite",
        "solution": [ { "math": "$21 = 3 \\times 7$", "note": "Has factors 3 and 7" }, { "math": "$\\text{composite}$", "note": "" } ] },
      { "q": "Is $17$ prime or composite?", "a": "prime",
        "solution": [ { "math": "$17: 1, 17$", "note": "No other factors" }, { "math": "$\\text{prime}$", "note": "" } ] },
      { "q": "How many primes are there between $1$ and $10$?", "a": "$4$",
        "solution": [ { "math": "$2, 3, 5, 7$", "note": "The primes" }, { "math": "$4 \\text{ primes}$", "note": "" } ] },
      { "q": "Is $27$ prime or composite?", "a": "composite",
        "solution": [ { "math": "$27 = 3 \\times 9$", "note": "Extra factors" }, { "math": "$\\text{composite}$", "note": "" } ] },
      { "q": "Is $23$ prime or composite?", "a": "prime",
        "solution": [ { "math": "$23: 1, 23$", "note": "No other factors" }, { "math": "$\\text{prime}$", "note": "" } ] },
      { "q": "List the composite numbers between $20$ and $26$.", "a": "$21, 22, 24, 25$",
        "solution": [ { "math": "$23 \\text{ is prime}$", "note": "Rest are composite" }, { "math": "$21, 22, 24, 25$", "note": "" } ] },
      { "q": "Explain why every even number greater than $2$ is composite.", "a": "it has $2$ as a factor besides $1$ and itself",
        "solution": [ { "math": "$\\text{even} \\Rightarrow \\div 2$", "note": "Divisible by 2" }, { "math": "$\\text{more than two factors}$", "note": "Composite" } ] }
    ],
    "mastery": [
      { "q": "Is $51$ prime or composite? Justify.", "a": "composite — $51 = 3 \\times 17$",
        "solution": [ { "math": "$5 + 1 = 6 \\Rightarrow \\div 3$", "note": "Digit sum test" }, { "math": "$51 = 3 \\times 17$", "note": "Composite" } ] },
      { "q": "Is $97$ prime or composite?", "a": "prime",
        "solution": [ { "math": "$\\text{no factor up to } 9$", "note": "Not divisible by 2,3,5,7" }, { "math": "$\\text{prime}$", "note": "" } ] },
      { "q": "Find the prime number that is one more than $\\,6 \\times 5$.", "a": "$31$",
        "solution": [ { "math": "$6 \\times 5 + 1 = 31$", "note": "Compute" }, { "math": "$31 \\text{ is prime}$", "note": "" } ] },
      { "q": "Which is the only prime number that is even? Explain.", "a": "$2$ — all other even numbers have $2$ as an extra factor",
        "solution": [ { "math": "$2: 1, 2$", "note": "Two factors" }, { "math": "$\\text{others} \\div 2$", "note": "So composite" } ] },
      { "q": "Express $36$ as a product of prime numbers.", "a": "$2 \\times 2 \\times 3 \\times 3$",
        "solution": [ { "math": "$36 = 4 \\times 9$", "note": "Break down" }, { "math": "$= 2\\times2\\times3\\times3$", "note": "All prime" } ] },
      { "q": "How many prime numbers are there between $30$ and $40$?", "a": "$2$ ($31, 37$)",
        "solution": [ { "math": "$31, 37$", "note": "The primes" }, { "math": "$2 \\text{ primes}$", "note": "" } ] },
      { "q": "A number $n$ has exactly two factors. What can you say about $n$?", "a": "it is prime",
        "solution": [ { "math": "$\\text{two factors} = 1, n$", "note": "Definition" }, { "math": "$n \\text{ is prime}$", "note": "" } ] },
      { "q": "Is $49$ prime or composite? Justify.", "a": "composite — $49 = 7 \\times 7$",
        "solution": [ { "math": "$49 = 7^2$", "note": "Square of a prime" }, { "math": "$\\text{composite}$", "note": "" } ] },
      { "q": "Two primes add to $24$. Give one such pair.", "a": "e.g. $5 + 19$ or $7 + 17$ or $11 + 13$",
        "solution": [ { "math": "$11 + 13 = 24$", "note": "Both prime" }, { "math": "$11, 13$", "note": "" } ] },
      { "q": "Express $60$ as a product of prime numbers.", "a": "$2 \\times 2 \\times 3 \\times 5$",
        "solution": [ { "math": "$60 = 4 \\times 15$", "note": "Break down" }, { "math": "$= 2\\times2\\times3\\times5$", "note": "All prime" } ] }
    ]
  }
}
