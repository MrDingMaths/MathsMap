{
  "skillId": "describe-transformations",
  "atomType": "R",
  "theory": {
    "intro": "A transformation moves a shape to a new position. The three transformations are translation (slide), reflection (flip) and rotation (turn). The shape keeps its size and shape.",
    "facts": [
      "**Translation** slides a shape: right/left and up/down, with no turning or flipping.",
      "**Reflection** flips a shape over a mirror line; the image is back-to-front.",
      "**Rotation** turns a shape about a point by an amount such as a quarter ($90^{\\circ}$) or half ($180^{\\circ}$) turn."
    ],
    "steps": [
      "Compare the image with the original.",
      "If it has slid → translation; flipped → reflection; turned → rotation.",
      "Describe the amount: how far/direction for a slide, the mirror line for a flip, the angle for a turn."
    ]
  },
  "practice": {
    "foundation": [
      { "q": "The shape has slid to a new position without turning or flipping. Name this transformation.", "a": "Translation",
        "tikz": "\\begin{tikzpicture}[x=0.5cm,y=0.5cm]\n\\draw[gray!40] (0,0) grid (8,4);\n\\draw[thick,fill=blue!15] (1,1)--(2,1)--(1.5,2.5)--cycle;\n\\draw[thick,fill=blue!15] (5,1)--(6,1)--(5.5,2.5)--cycle;\n\\end{tikzpicture}",
        "solution": [ { "math": "$\\text{slide, no turn or flip}$", "note": "Identify the move" }, { "math": "$= \\text{translation}$", "note": "" } ] },
      { "q": "The shape has been flipped over a vertical mirror line. Name this transformation.", "a": "Reflection",
        "tikz": "\\begin{tikzpicture}[x=0.5cm,y=0.5cm]\n\\draw[gray!40] (0,0) grid (8,4);\n\\draw[dashed] (4,0)--(4,4);\n\\draw[thick,fill=blue!15] (1,1)--(3,1)--(1,3)--cycle;\n\\draw[thick,fill=blue!15] (7,1)--(5,1)--(7,3)--cycle;\n\\end{tikzpicture}",
        "solution": [ { "math": "$\\text{flipped over the line}$", "note": "Back-to-front" }, { "math": "$= \\text{reflection}$", "note": "" } ] },
      { "q": "The shape has been turned a quarter turn about a point. Name this transformation.", "a": "Rotation",
        "tikz": "\\begin{tikzpicture}[x=0.5cm,y=0.5cm]\n\\draw[gray!40] (0,0) grid (8,5);\n\\draw[thick,fill=blue!15] (1,1)--(3,1)--(1,2)--cycle;\n\\draw[thick,fill=blue!15] (6,1)--(6,3)--(5,1)--cycle;\n\\fill (4,1) circle (2pt);\n\\end{tikzpicture}",
        "solution": [ { "math": "$\\text{turned about a point}$", "note": "Quarter turn" }, { "math": "$= \\text{rotation}$", "note": "" } ] },
      { "q": "A slide is a __________.", "a": "Translation",
        "solution": [ { "math": "$\\text{slide}$", "note": "Everyday word" }, { "math": "$= \\text{translation}$", "note": "" } ] },
      { "q": "A flip is a __________.", "a": "Reflection",
        "solution": [ { "math": "$\\text{flip}$", "note": "Everyday word" }, { "math": "$= \\text{reflection}$", "note": "" } ] },
      { "q": "A turn is a __________.", "a": "Rotation",
        "solution": [ { "math": "$\\text{turn}$", "note": "Everyday word" }, { "math": "$= \\text{rotation}$", "note": "" } ] },
      { "q": "The shape slid $4$ units to the right. Name this transformation.", "a": "Translation",
        "tikz": "\\begin{tikzpicture}[x=0.5cm,y=0.5cm]\n\\draw[gray!40] (0,0) grid (8,3);\n\\draw[thick,fill=blue!15] (1,1) rectangle (2,2);\n\\draw[thick,fill=blue!15] (5,1) rectangle (6,2);\n\\end{tikzpicture}",
        "solution": [ { "math": "$\\text{slide right}$", "note": "No turn or flip" }, { "math": "$= \\text{translation}$", "note": "" } ] },
      { "q": "Does a translation change the size of a shape?", "a": "No",
        "solution": [ { "math": "$\\text{shape and size kept}$", "note": "Only position changes" }, { "math": "$= \\text{no}$", "note": "" } ] },
      { "q": "The shape has been flipped over a horizontal mirror line. Name this transformation.", "a": "Reflection",
        "tikz": "\\begin{tikzpicture}[x=0.5cm,y=0.5cm]\n\\draw[gray!40] (0,0) grid (6,6);\n\\draw[dashed] (0,3)--(6,3);\n\\draw[thick,fill=blue!15] (1,4)--(3,4)--(1,6)--cycle;\n\\draw[thick,fill=blue!15] (1,2)--(3,2)--(1,0)--cycle;\n\\end{tikzpicture}",
        "solution": [ { "math": "$\\text{flipped over horizontal line}$", "note": "Mirror image" }, { "math": "$= \\text{reflection}$", "note": "" } ] },
      { "q": "The shape has been turned half a turn. Name this transformation.", "a": "Rotation",
        "tikz": "\\begin{tikzpicture}[x=0.5cm,y=0.5cm]\n\\draw[gray!40] (0,0) grid (8,4);\n\\draw[thick,fill=blue!15] (1,1)--(3,1)--(1,2)--cycle;\n\\draw[thick,fill=blue!15] (7,3)--(5,3)--(7,2)--cycle;\n\\fill (4,2) circle (2pt);\n\\end{tikzpicture}",
        "solution": [ { "math": "$\\text{turned about a point}$", "note": "Half turn" }, { "math": "$= \\text{rotation}$", "note": "" } ] }
    ],
    "development": [
      { "q": "Describe fully how the shape moved.", "a": "Translation $3$ right and $2$ up",
        "tikz": "\\begin{tikzpicture}[x=0.5cm,y=0.5cm]\n\\draw[gray!40] (0,0) grid (8,5);\n\\draw[thick,fill=blue!15] (1,0) rectangle (2,1);\n\\draw[thick,fill=blue!15] (4,2) rectangle (5,3);\n\\end{tikzpicture}",
        "solution": [ { "math": "$\\text{across } 3,\\ \\text{up } 2$", "note": "Count grid squares" }, { "math": "$= \\text{translation } 3 \\text{ right}, 2 \\text{ up}$", "note": "" } ] },
      { "q": "Describe the mirror line for this reflection.", "a": "Vertical mirror line",
        "tikz": "\\begin{tikzpicture}[x=0.5cm,y=0.5cm]\n\\draw[gray!40] (0,0) grid (8,4);\n\\draw[dashed] (4,0)--(4,4);\n\\draw[thick,fill=blue!15] (1,1)--(3,1)--(2,3)--cycle;\n\\draw[thick,fill=blue!15] (7,1)--(5,1)--(6,3)--cycle;\n\\end{tikzpicture}",
        "solution": [ { "math": "$\\text{image is left-right reversed}$", "note": "Flip line is upright" }, { "math": "$= \\text{vertical mirror line}$", "note": "" } ] },
      { "q": "A shape is rotated a quarter turn ($90^{\\circ}$) clockwise about a point. Describe the transformation.", "a": "Rotation $90^{\\circ}$ clockwise",
        "solution": [ { "math": "$\\text{turn} = 90^{\\circ}$", "note": "Quarter turn" }, { "math": "$= \\text{rotation } 90^{\\circ} \\text{ clockwise}$", "note": "" } ] },
      { "q": "Describe how this shape moved.", "a": "Translation $5$ right",
        "tikz": "\\begin{tikzpicture}[x=0.5cm,y=0.5cm]\n\\draw[gray!40] (0,0) grid (8,3);\n\\draw[thick,fill=blue!15] (1,1)--(2,1)--(1.5,2)--cycle;\n\\draw[thick,fill=blue!15] (6,1)--(7,1)--(6.5,2)--cycle;\n\\end{tikzpicture}",
        "solution": [ { "math": "$\\text{across } 5,\\ \\text{up } 0$", "note": "Count grid squares" }, { "math": "$= \\text{translation } 5 \\text{ right}$", "note": "" } ] },
      { "q": "A triangle is reflected, so its image points the opposite way across a line. What is this transformation, and is the size changed?", "a": "Reflection; size unchanged",
        "solution": [ { "math": "$\\text{flip over a line}$", "note": "Mirror image" }, { "math": "$= \\text{reflection, same size}$", "note": "" } ] },
      { "q": "Describe the turn shown (about the marked point).", "a": "Rotation, half turn ($180^{\\circ}$)",
        "tikz": "\\begin{tikzpicture}[x=0.5cm,y=0.5cm]\n\\draw[gray!40] (0,0) grid (8,4);\n\\draw[thick,fill=blue!15] (1,2)--(3,2)--(1,3)--cycle;\n\\draw[thick,fill=blue!15] (7,2)--(5,2)--(7,1)--cycle;\n\\fill (4,2) circle (2pt);\n\\end{tikzpicture}",
        "solution": [ { "math": "$\\text{shape is upside-down}$", "note": "Turned about the dot" }, { "math": "$= \\text{rotation } 180^{\\circ}$", "note": "" } ] },
      { "q": "A flag slides $2$ left and $3$ down. Write this as a translation.", "a": "Translation $2$ left, $3$ down",
        "solution": [ { "math": "$\\text{left } 2,\\ \\text{down } 3$", "note": "Direction and amount" }, { "math": "$= \\text{translation } 2 \\text{ left}, 3 \\text{ down}$", "note": "" } ] },
      { "q": "Which transformation produces a mirror image: translation, reflection or rotation?", "a": "Reflection",
        "solution": [ { "math": "$\\text{mirror image}$", "note": "Back-to-front" }, { "math": "$= \\text{reflection}$", "note": "" } ] },
      { "q": "Describe how this shape moved.", "a": "Translation $4$ right, $1$ up",
        "tikz": "\\begin{tikzpicture}[x=0.5cm,y=0.5cm]\n\\draw[gray!40] (0,0) grid (8,4);\n\\draw[thick,fill=blue!15] (1,1)--(2,1)--(2,2)--(1,2)--cycle;\n\\draw[thick,fill=blue!15] (5,2)--(6,2)--(6,3)--(5,3)--cycle;\n\\end{tikzpicture}",
        "solution": [ { "math": "$\\text{across } 4,\\ \\text{up } 1$", "note": "Count grid squares" }, { "math": "$= \\text{translation } 4 \\text{ right}, 1 \\text{ up}$", "note": "" } ] },
      { "q": "A square is rotated a quarter turn. Does it look different? Explain.", "a": "No, a square looks the same after a quarter turn (it has rotational symmetry)",
        "solution": [ { "math": "$90^{\\circ} \\text{ turn of a square}$", "note": "Quarter turn" }, { "math": "$= \\text{looks identical}$", "note": "Rotational symmetry" } ] }
    ],
    "mastery": [
      { "q": "A shape at the bottom-left of a grid is moved to the top-right by sliding $6$ right and $4$ up. Then it is flipped over a vertical line. Name the two transformations in order.", "a": "Translation then reflection",
        "solution": [ { "math": "$\\text{slide } 6 \\text{ right}, 4 \\text{ up}$", "note": "First move" }, { "math": "$\\text{flip} = \\text{reflection}$", "note": "Second move" } ] },
      { "q": "A triangle is translated $3$ right, then translated $2$ left. Describe the single transformation that has the same effect.", "a": "Translation $1$ right",
        "solution": [ { "math": "$3 - 2 = 1$", "note": "Combine the slides" }, { "math": "$= \\text{translation } 1 \\text{ right}$", "note": "" } ] },
      { "q": "An L-shaped tile is rotated a half turn, then a half turn again. Describe the result.", "a": "Back to the start (no overall change)",
        "solution": [ { "math": "$180^{\\circ} + 180^{\\circ} = 360^{\\circ}$", "note": "Full turn" }, { "math": "$= \\text{original position}$", "note": "" } ] },
      { "q": "A shape is reflected over a vertical line, then reflected over the same line again. Describe the result.", "a": "Back to the original",
        "solution": [ { "math": "$\\text{flip then flip back}$", "note": "Same mirror line" }, { "math": "$= \\text{original}$", "note": "" } ] },
      { "q": "A pattern repeats by sliding the same motif $2$ units right each time. What transformation builds the pattern?", "a": "Translation (repeated)",
        "solution": [ { "math": "$\\text{repeated slide of } 2$", "note": "Same shape each time" }, { "math": "$= \\text{translation}$", "note": "" } ] },
      { "q": "A footprint pattern alternates left foot, right foot, left foot. What single transformation maps a left footprint to the right one beside it?", "a": "Reflection",
        "solution": [ { "math": "$\\text{mirror image of foot}$", "note": "Left ↔ right" }, { "math": "$= \\text{reflection}$", "note": "" } ] },
      { "q": "A square is rotated by $90^{\\circ}$ four times about its centre. How does it look after all four turns?", "a": "Exactly the same as the start",
        "solution": [ { "math": "$4 \\times 90^{\\circ} = 360^{\\circ}$", "note": "Full turn" }, { "math": "$= \\text{original}$", "note": "" } ] },
      { "q": "Describe the full transformation: a shape ends up the same way round but moved across and up the grid.", "a": "Translation",
        "solution": [ { "math": "$\\text{same orientation, new spot}$", "note": "No flip or turn" }, { "math": "$= \\text{translation}$", "note": "" } ] },
      { "q": "A shape is reflected and the image is identical to the original (sits on top of it). What does this tell you about the shape?", "a": "It has line symmetry along the mirror line",
        "solution": [ { "math": "$\\text{image} = \\text{original}$", "note": "Across the mirror line" }, { "math": "$= \\text{line of symmetry}$", "note": "" } ] },
      { "q": "On a grid, a flag is rotated $90^{\\circ}$ clockwise about a point, then $90^{\\circ}$ clockwise again. Describe the single rotation with the same effect.", "a": "Rotation $180^{\\circ}$ (half turn)",
        "solution": [ { "math": "$90^{\\circ} + 90^{\\circ} = 180^{\\circ}$", "note": "Combine turns" }, { "math": "$= \\text{rotation } 180^{\\circ}$", "note": "" } ] }
    ]
  }
}
