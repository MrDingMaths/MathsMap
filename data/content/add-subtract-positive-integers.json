{
  "skillId": "add-subtract-positive-integers",
  "atomType": "R",
  "theory": {
    "intro": "Use a number line. The first number is your starting point; the second number tells you how far to move.",
    "facts": [
      "To **add** a positive integer: move **right**.",
      "To **subtract** a positive integer: move **left**."
    ],
    "steps": [
      "Start at the first integer on the number line.",
      "Add → move right by the second number.",
      "Subtract → move left by the second number.",
      "Read off where you land (you may pass zero)."
    ]
  },
  "practice": {
