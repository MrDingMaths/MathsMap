{
  "skillId": "classify-angles",
  "atomType": "R",
  "theory": {
    "intro": "Angles are named by their size. Knowing the special turns lets you classify any angle on sight.",
    "facts": [
      "**Acute** $< 90^{\\circ}$; **right** $= 90^{\\circ}$; **obtuse** between $90^{\\circ}$ and $180^{\\circ}$.",
      "**Straight** $= 180^{\\circ}$; **reflex** between $180^{\\circ}$ and $360^{\\circ}$.",
      "A full turn, or **revolution**, $= 360^{\\circ}$."
    ],
    "steps": [
      "Compare the angle with the right angle ($90^{\\circ}$) and the straight angle ($180^{\\circ}$).",
      "Decide which range it falls in.",
      "Name it: acute, right, obtuse, straight, reflex or revolution."
    ]
  },
  "practice": {
    "foundation": [
      { "q": "Classify the marked angle.", "a": "acute",
        "tikz": "\\begin{tikzpicture}[scale=1]\n\\coordinate (O) at (0,0);\n\\coordinate (A) at (2,0);\n\\coordinate (B) at (1.3,1.5);\n\\draw[thick] (A)--(O)--(B);\n\\draw (0.6,0) arc (0:49:0.6);\n\\end{tikzpicture}",
        "solution": [ { "math": "$\\text{angle} < 90^{\\circ}$", "note": "Smaller than a right angle" }, { "math": "$\\text{acute}$", "note": "" } ] },
      { "q": "Classify the marked angle.", "a": "right",
        "tikz": "\\begin{tikzpicture}[scale=1]\n\\coordinate (O) at (0,0);\n\\coordinate (A) at (2,0);\n\\coordinate (B) at (0,2);\n\\draw[thick] (A)--(O)--(B);\n\\draw (0,0.4) -- (0.4,0.4) -- (0.4,0);\n\\end{tikzpicture}",
        "solution": [ { "math": "$\\text{angle} = 90^{\\circ}$", "note": "Square mark shown" }, { "math": "$\\text{right angle}$", "note": "" } ] },
      { "q": "Classify the marked angle.", "a": "obtuse",
        "tikz": "\\begin{tikzpicture}[scale=1]\n\\coordinate (O) at (0,0);\n\\coordinate (A) at (2,0);\n\\coordinate (B) at (-1.3,1.5);\n\\draw[thick] (A)--(O)--(B);\n\\draw (0.6,0) arc (0:131:0.6);\n\\end{tikzpicture}",
        "solution": [ { "math": "$90^{\\circ} < \\text{angle} < 180^{\\circ}$", "note": "Bigger than a right angle" }, { "math": "$\\text{obtuse}$", "note": "" } ] },
      { "q": "Classify the marked angle.", "a": "straight",
        "tikz": "\\begin{tikzpicture}[scale=1]\n\\coordinate (O) at (0,0);\n\\coordinate (A) at (2,0);\n\\coordinate (B) at (-2,0);\n\\draw[thick] (A)--(O)--(B);\n\\draw (0.6,0) arc (0:180:0.6);\n\\fill (O) circle (1.6pt);\n\\end{tikzpicture}",
        "solution": [ { "math": "$\\text{angle} = 180^{\\circ}$", "note": "Forms a straight line" }, { "math": "$\\text{straight angle}$", "note": "" } ] },
      { "q": "Classify the marked angle.", "a": "acute",
        "tikz": "\\begin{tikzpicture}[scale=1]\n\\coordinate (O) at (0,0);\n\\coordinate (A) at (2,0);\n\\coordinate (B) at (1.7,1);\n\\draw[thick] (A)--(O)--(B);\n\\draw (0.6,0) arc (0:30:0.6);\n\\end{tikzpicture}",
        "solution": [ { "math": "$\\text{angle} < 90^{\\circ}$", "note": "A small opening" }, { "math": "$\\text{acute}$", "note": "" } ] },
      { "q": "Classify the marked angle.", "a": "reflex",
        "tikz": "\\begin{tikzpicture}[scale=1]\n\\coordinate (O) at (0,0);\n\\coordinate (A) at (2,0);\n\\coordinate (B) at (0.7,-1.9);\n\\draw[thick] (A)--(O)--(B);\n\\draw (0.7,0) arc (0:-290:0.7);\n\\end{tikzpicture}",
        "solution": [ { "math": "$180^{\\circ} < \\text{angle} < 360^{\\circ}$", "note": "More than a straight angle" }, { "math": "$\\text{reflex}$", "note": "" } ] },
      { "q": "Classify the marked angle.", "a": "obtuse",
        "tikz": "\\begin{tikzpicture}[scale=1]\n\\coordinate (O) at (0,0);\n\\coordinate (A) at (2,0);\n\\coordinate (B) at (-0.7,1.9);\n\\draw[thick] (A)--(O)--(B);\n\\draw (0.6,0) arc (0:110:0.6);\n\\end{tikzpicture}",
        "solution": [ { "math": "$90^{\\circ} < \\text{angle} < 180^{\\circ}$", "note": "Wide opening" }, { "math": "$\\text{obtuse}$", "note": "" } ] },
      { "q": "Classify the marked angle.", "a": "right",
        "tikz": "\\begin{tikzpicture}[scale=1]\n\\coordinate (O) at (0,0);\n\\coordinate (A) at (2,0);\n\\coordinate (B) at (0,-2);\n\\draw[thick] (A)--(O)--(B);\n\\draw (0,-0.4) -- (0.4,-0.4) -- (0.4,0);\n\\end{tikzpicture}",
        "solution": [ { "math": "$\\text{angle} = 90^{\\circ}$", "note": "Square mark shown" }, { "math": "$\\text{right angle}$", "note": "" } ] },
      { "q": "Classify the marked angle.", "a": "acute",
        "tikz": "\\begin{tikzpicture}[scale=1]\n\\coordinate (O) at (0,0);\n\\coordinate (A) at (2,0);\n\\coordinate (B) at (1.1,1.7);\n\\draw[thick] (A)--(O)--(B);\n\\draw (0.6,0) arc (0:57:0.6);\n\\end{tikzpicture}",
        "solution": [ { "math": "$\\text{angle} < 90^{\\circ}$", "note": "Less than a right angle" }, { "math": "$\\text{acute}$", "note": "" } ] },
      { "q": "An angle is a complete turn, $360^{\\circ}$. What is it called?", "a": "a revolution",
        "solution": [ { "math": "$\\text{full turn} = 360^{\\circ}$", "note": "Back to the start" }, { "math": "$\\text{revolution}$", "note": "" } ] }
    ],
    "development": [
      { "q": "Classify an angle of $47^{\\circ}$.", "a": "acute",
        "solution": [ { "math": "$47^{\\circ} < 90^{\\circ}$", "note": "Below a right angle" }, { "math": "$\\text{acute}$", "note": "" } ] },
      { "q": "Classify an angle of $115^{\\circ}$.", "a": "obtuse",
        "solution": [ { "math": "$90^{\\circ} < 115^{\\circ} < 180^{\\circ}$", "note": "Between right and straight" }, { "math": "$\\text{obtuse}$", "note": "" } ] },
      { "q": "Classify an angle of $250^{\\circ}$.", "a": "reflex",
        "solution": [ { "math": "$180^{\\circ} < 250^{\\circ} < 360^{\\circ}$", "note": "Above a straight angle" }, { "math": "$\\text{reflex}$", "note": "" } ] },
      { "q": "Classify an angle of $90^{\\circ}$.", "a": "right",
        "solution": [ { "math": "$\\text{exactly } 90^{\\circ}$", "note": "A quarter turn" }, { "math": "$\\text{right angle}$", "note": "" } ] },
      { "q": "Classify an angle of $180^{\\circ}$.", "a": "straight",
        "solution": [ { "math": "$\\text{exactly } 180^{\\circ}$", "note": "A half turn" }, { "math": "$\\text{straight angle}$", "note": "" } ] },
      { "q": "Classify the marked angle.", "a": "reflex",
        "tikz": "\\begin{tikzpicture}[scale=1]\n\\coordinate (O) at (0,0);\n\\coordinate (A) at (2,0);\n\\coordinate (B) at (-1.3,-1.5);\n\\draw[thick] (A)--(O)--(B);\n\\draw (0.7,0) arc (0:-229:0.7);\n\\node at (0.2,-1.1) {$x$};\n\\end{tikzpicture}",
        "solution": [ { "math": "$180^{\\circ} < x < 360^{\\circ}$", "note": "Reflex region marked" }, { "math": "$\\text{reflex}$", "note": "" } ] },
      { "q": "Classify an angle of $8^{\\circ}$.", "a": "acute",
        "solution": [ { "math": "$8^{\\circ} < 90^{\\circ}$", "note": "Very small opening" }, { "math": "$\\text{acute}$", "note": "" } ] },
      { "q": "Classify an angle of $179^{\\circ}$.", "a": "obtuse",
        "solution": [ { "math": "$90^{\\circ} < 179^{\\circ} < 180^{\\circ}$", "note": "Just below straight" }, { "math": "$\\text{obtuse}$", "note": "" } ] },
      { "q": "Classify an angle of $360^{\\circ}$.", "a": "a revolution",
        "solution": [ { "math": "$\\text{exactly } 360^{\\circ}$", "note": "A full turn" }, { "math": "$\\text{revolution}$", "note": "" } ] },
      { "q": "Classify an angle of $91^{\\circ}$.", "a": "obtuse",
        "solution": [ { "math": "$91^{\\circ} > 90^{\\circ}$", "note": "Just past a right angle" }, { "math": "$\\text{obtuse}$", "note": "" } ] }
    ],
    "mastery": [
      { "q": "A clock's hands at $3$ o'clock form which type of angle?", "a": "right angle",
        "solution": [ { "math": "$\\tfrac{1}{4} \\text{ turn} = 90^{\\circ}$", "note": "Quarter of the dial" }, { "math": "$\\text{right angle}$", "note": "" } ] },
      { "q": "An angle is obtuse. Give a possible whole-number value for it.", "a": "any value such as $120^{\\circ}$",
        "solution": [ { "math": "$90^{\\circ} < \\text{angle} < 180^{\\circ}$", "note": "Obtuse range" }, { "math": "$\\text{e.g. } 120^{\\circ}$", "note": "Any value in range" } ] },
      { "q": "The interior angle marked is $90^{\\circ}$. Is the matching reflex angle around the vertex acute, obtuse or reflex?", "a": "reflex ($270^{\\circ}$)",
        "solution": [ { "math": "$360^{\\circ} - 90^{\\circ}$", "note": "Rest of the full turn" }, { "math": "$= 270^{\\circ} \\Rightarrow \\text{reflex}$", "note": "" } ] },
      { "q": "An angle turns through three right angles. Name and size it.", "a": "reflex, $270^{\\circ}$",
        "solution": [ { "math": "$3 \\times 90^{\\circ} = 270^{\\circ}$", "note": "Three quarter-turns" }, { "math": "$\\text{reflex}$", "note": "" } ] },
      { "q": "True or false: every right angle is also acute.", "a": "false",
        "solution": [ { "math": "$\\text{acute} < 90^{\\circ}$", "note": "Strictly less" }, { "math": "$90^{\\circ} \\text{ is not} < 90^{\\circ}$", "note": "So it is not acute" } ] },
      { "q": "A skateboarder spins half a turn. What angle is this, and what is it called?", "a": "$180^{\\circ}$, straight angle",
        "solution": [ { "math": "$\\tfrac{1}{2} \\times 360^{\\circ}$", "note": "Half a revolution" }, { "math": "$= 180^{\\circ} \\Rightarrow \\text{straight}$", "note": "" } ] },
      { "q": "Order these by size, smallest first: a right angle, a straight angle, an acute angle.", "a": "acute, right, straight",
        "solution": [ { "math": "$\\text{acute} < 90^{\\circ} < 180^{\\circ}$", "note": "Compare sizes" }, { "math": "$\\text{acute, right, straight}$", "note": "" } ] },
      { "q": "An angle measures $200^{\\circ}$. Is this more or less than a straight angle, and what type is it?", "a": "more; reflex",
        "solution": [ { "math": "$200^{\\circ} > 180^{\\circ}$", "note": "Bigger than straight" }, { "math": "$\\text{reflex}$", "note": "" } ] },
      { "q": "A door opens just past square to the wall, turning about $100^{\\circ}$. What type of angle?", "a": "obtuse",
        "solution": [ { "math": "$90^{\\circ} < 100^{\\circ} < 180^{\\circ}$", "note": "Past a right angle" }, { "math": "$\\text{obtuse}$", "note": "" } ] },
      { "q": "Two right angles together make what type of single angle?", "a": "straight angle",
        "solution": [ { "math": "$90^{\\circ} + 90^{\\circ}$", "note": "Two right angles" }, { "math": "$= 180^{\\circ} \\Rightarrow \\text{straight}$", "note": "" } ] }
    ]
  }
}
