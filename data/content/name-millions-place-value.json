      { "q": "Write in numerals: two million, three hundred thousand.", "a": "$2\\,300\\,000$",
        "solution": [ { "math": "$\\text{2 million} = 2\\,000\\,000$", "note": "Millions group" }, { "math": "$2\\,000\\,000 + 300\\,000 = 2\\,300\\,000$", "note": "Add the thousands" } ] },
