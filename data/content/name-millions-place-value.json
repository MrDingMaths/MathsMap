      { "q": "Write $7\\,000\\,000$ in words.", "a": "seven million",
        "solution": [ { "math": "$7\\,|\\,000\\,|\\,000$", "note": "Group in threes" }, { "math": "$\\text{seven million}$", "note": "Only the millions group" } ] },
      { "q": "Write $5\\,200\\,000$ in words.", "a": "five million, two hundred thousand",
