{
  "skillId": "name-millions-place-value",
  "atomType": "R",
  "theory": {
    "intro": "Large numbers are read in groups of three digits called periods: ones, thousands and millions. Within each period the digits show hundreds, tens and ones.",
    "facts": [
      "From the right, group the digits in **threes**: ones, thousands, millions.",
      "Name the millions group, then thousands, then the final three digits.",
      "The **value** of a digit is the digit multiplied by its place, e.g. the $7$ in $4\\,728\\,000$ is worth $700\\,000$."
    ],
    "steps": [
      "Split the number into periods of three from the right.",
      "Read each group as a number, then add its period name (million / thousand).",
      "A $0$ holds a place — it keeps later digits in the correct column."
    ]
  },
  "practice": {
