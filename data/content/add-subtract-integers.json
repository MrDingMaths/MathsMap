  "theory": {
    "intro": "Turn any touching signs into a single sign, then move along the number line.",
    "facts": [
      "$a + (-b) = a - b$ and $a - (-b) = a + b$",
      "Adding a positive moves **right**; subtracting a positive moves **left**."
    ],
    "steps": [
      "Rewrite any touching signs as a single sign.",
      "Start at the first number on a number line.",
      "Add → move right; subtract → move left.",
      "Read off the result."
    ]
  },
