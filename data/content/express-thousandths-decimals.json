{
  "skillId": "express-thousandths-decimals",
  "atomType": "R",
  "theory": {
    "intro": "After the decimal point, the places are tenths, hundredths and thousandths — each is ten times smaller than the one before.",
    "facts": [
      "$0.1 = \\dfrac{1}{10}$, $\\ 0.01 = \\dfrac{1}{100}$, $\\ 0.001 = \\dfrac{1}{1000}$.",
      "The third place after the point is **thousandths**.",
      "$\\dfrac{7}{1000} = 0.007$ — the digit sits in the thousandths place."
    ],
    "steps": [
      "Count the decimal places: 1 = tenths, 2 = hundredths, 3 = thousandths.",
      "Write a fraction over $10$, $100$ or $1000$ as the matching decimal place.",
      "Use zeros to hold empty places after the point."
    ]
  },
  "practice": {
    "foundation": [
      { "q": "Write $\\dfrac{3}{10}$ as a decimal.", "a": "$0.3$",
        "solution": [ { "math": "$\\dfrac{3}{10} \\to \\text{tenths}$", "note": "One decimal place" }, { "math": "$= 0.3$", "note": "" } ] },
      { "q": "Write $\\dfrac{7}{100}$ as a decimal.", "a": "$0.07$",
        "solution": [ { "math": "$\\dfrac{7}{100} \\to \\text{hundredths}$", "note": "Two decimal places" }, { "math": "$= 0.07$", "note": "Zero holds the tenths" } ] },
      { "q": "Write $\\dfrac{9}{1000}$ as a decimal.", "a": "$0.009$",
        "solution": [ { "math": "$\\dfrac{9}{1000} \\to \\text{thousandths}$", "note": "Three decimal places" }, { "math": "$= 0.009$", "note": "Two zeros hold places" } ] },
      { "q": "What is the place value of the $5$ in $0.453$?", "a": "hundredths",
        "solution": [ { "math": "$0.4\\underline{5}3$", "note": "Second place after point" }, { "math": "$\\text{hundredths}$", "note": "Value $\\tfrac{5}{100}$" } ] },
      { "q": "Write $0.6$ as a fraction.", "a": "$\\dfrac{6}{10}$",
        "solution": [ { "math": "$0.6 \\to \\text{tenths}$", "note": "One decimal place" }, { "math": "$= \\dfrac{6}{10}$", "note": "" } ] },
      { "q": "Write $\\dfrac{23}{100}$ as a decimal.", "a": "$0.23$",
        "solution": [ { "math": "$\\dfrac{23}{100} \\to \\text{hundredths}$", "note": "Two decimal places" }, { "math": "$= 0.23$", "note": "" } ] },
      { "q": "What is the place value of the $2$ in $0.812$?", "a": "thousandths",
        "solution": [ { "math": "$0.81\\underline{2}$", "note": "Third place after point" }, { "math": "$\\text{thousandths}$", "note": "Value $\\tfrac{2}{1000}$" } ] },
      { "q": "Write $\\dfrac{125}{1000}$ as a decimal.", "a": "$0.125$",
        "solution": [ { "math": "$\\dfrac{125}{1000} \\to \\text{thousandths}$", "note": "Three decimal places" }, { "math": "$= 0.125$", "note": "" } ] },
      { "q": "Write $0.04$ as a fraction.", "a": "$\\dfrac{4}{100}$",
        "solution": [ { "math": "$0.04 \\to \\text{hundredths}$", "note": "Two decimal places" }, { "math": "$= \\dfrac{4}{100}$", "note": "" } ] },
      { "q": "Read aloud and write the place value of the $8$ in $0.8$.", "a": "tenths",
        "solution": [ { "math": "$0.\\underline{8}$", "note": "First place after point" }, { "math": "$\\text{tenths}$", "note": "Value $\\tfrac{8}{10}$" } ] }
    ],
    "development": [
      { "q": "Write $\\dfrac{47}{1000}$ as a decimal.", "a": "$0.047$",
        "solution": [ { "math": "$\\dfrac{47}{1000} \\to \\text{thousandths}$", "note": "Three decimal places" }, { "math": "$= 0.047$", "note": "Zero holds the tenths" } ] },
      { "q": "What is the value of the $6$ in $2.364$?", "a": "$\\dfrac{6}{100}$ (six hundredths)",
        "solution": [ { "math": "$2.3\\underline{6}4$", "note": "Second place after point" }, { "math": "$\\dfrac{6}{100} = 0.06$", "note": "Hundredths" } ] },
      { "q": "Write three hundred and seven thousandths as a decimal.", "a": "$0.307$",
        "solution": [ { "math": "$\\dfrac{307}{1000} \\to \\text{thousandths}$", "note": "Three decimal places" }, { "math": "$= 0.307$", "note": "" } ] },
      { "q": "Write $0.515$ as a fraction over $1000$.", "a": "$\\dfrac{515}{1000}$",
        "solution": [ { "math": "$0.515 \\to \\text{thousandths}$", "note": "Three decimal places" }, { "math": "$= \\dfrac{515}{1000}$", "note": "" } ] },
      { "q": "Write five hundredths as a decimal.", "a": "$0.05$",
        "solution": [ { "math": "$\\dfrac{5}{100} \\to \\text{hundredths}$", "note": "Two decimal places" }, { "math": "$= 0.05$", "note": "Zero holds the tenths" } ] },
      { "q": "What is the value of the $4$ in $0.049$? Write it as a fraction.", "a": "$\\dfrac{4}{100}$",
        "solution": [ { "math": "$0.0\\underline{4}9$", "note": "Second place after point" }, { "math": "$\\dfrac{4}{100} = 0.04$", "note": "Hundredths" } ] },
      { "q": "Write $\\dfrac{80}{1000}$ as a decimal.", "a": "$0.08$",
        "solution": [ { "math": "$\\dfrac{80}{1000} = \\dfrac{8}{100}$", "note": "Simplify" }, { "math": "$= 0.08$", "note": "Hundredths" } ] },
      { "q": "Write the decimal with $6$ tenths, $0$ hundredths and $2$ thousandths.", "a": "$0.602$",
        "solution": [ { "math": "$6 \\to \\text{tenths},\\ 2 \\to \\text{thousandths}$", "note": "Place each digit" }, { "math": "$0.602$", "note": "Zero holds the hundredths" } ] },
      { "q": "Write $1.205$ in words.", "a": "one and two hundred and five thousandths",
        "solution": [ { "math": "$1 . 205$", "note": "Whole then decimal" }, { "math": "$\\text{1 and } \\tfrac{205}{1000}$", "note": "Read the decimal part" } ] },
      { "q": "What is the place value of the $3$ in $4.039$?", "a": "hundredths",
        "solution": [ { "math": "$4.0\\underline{3}9$", "note": "Second place after point" }, { "math": "$\\text{hundredths}$", "note": "Value $\\tfrac{3}{100}$" } ] }
    ],
    "mastery": [
      { "q": "A runner's time is $\\dfrac{9}{1000}$ of a second faster than the record. Write this as a decimal.", "a": "$0.009$",
        "solution": [ { "math": "$\\dfrac{9}{1000} \\to \\text{thousandths}$", "note": "Three decimal places" }, { "math": "$= 0.009$", "note": "Two zeros hold places" } ] },
      { "q": "Write the decimal that is $2$ tenths $+ 5$ thousandths.", "a": "$0.205$",
        "solution": [ { "math": "$0.2 + 0.005$", "note": "Add by place" }, { "math": "$= 0.205$", "note": "Zero holds the hundredths" } ] },
      { "q": "In $0.736$, which digit has the smallest value, and what is that value?", "a": "$6$, worth $\\dfrac{6}{1000}$",
        "solution": [ { "math": "$0.73\\underline{6}$", "note": "Thousandths is the smallest place" }, { "math": "$\\dfrac{6}{1000} = 0.006$", "note": "" } ] },
      { "q": "Write nine and forty-two thousandths as a decimal.", "a": "$9.042$",
        "solution": [ { "math": "$\\dfrac{42}{1000} = 0.042$", "note": "Decimal part" }, { "math": "$9 + 0.042 = 9.042$", "note": "Add the whole" } ] },
      { "q": "How many thousandths are in $0.3$?", "a": "$300$",
        "solution": [ { "math": "$0.3 = \\dfrac{300}{1000}$", "note": "Rename to thousandths" }, { "math": "$= 300 \\text{ thousandths}$", "note": "" } ] },
      { "q": "Write $0.4$ and $0.40$ and $0.400$ as fractions. Are they equal?", "a": "yes, all equal $\\dfrac{4}{10}$",
        "solution": [ { "math": "$0.4 = \\tfrac{4}{10},\\ 0.40 = \\tfrac{40}{100},\\ 0.400 = \\tfrac{400}{1000}$", "note": "Different names" }, { "math": "$\\tfrac{40}{100} = \\tfrac{400}{1000} = \\tfrac{4}{10}$", "note": "Trailing zeros don't change value" } ] },
      { "q": "A length is $\\dfrac{6}{100}$ m. Write it as a decimal in metres.", "a": "$0.06$ m",
        "solution": [ { "math": "$\\dfrac{6}{100} \\to \\text{hundredths}$", "note": "Two decimal places" }, { "math": "$= 0.06$", "note": "" } ] },
      { "q": "Write the decimal with $0$ ones, $0$ tenths, $7$ hundredths and $5$ thousandths.", "a": "$0.075$",
        "solution": [ { "math": "$7 \\to \\text{hundredths},\\ 5 \\to \\text{thousandths}$", "note": "Place each digit" }, { "math": "$0.075$", "note": "Zero holds the tenths" } ] },
      { "q": "Which is larger, the value of the $5$ in $0.516$ or the value of the $5$ in $0.165$?", "a": "the $5$ in $0.516$ (tenths)",
        "solution": [ { "math": "$0.\\underline{5}16 \\to \\tfrac{5}{10}$", "note": "Tenths" }, { "math": "$0.16\\underline{5} \\to \\tfrac{5}{1000}$", "note": "Thousandths — much smaller" } ] },
      { "q": "Write 'two and three thousandths' as a decimal.", "a": "$2.003$",
        "solution": [ { "math": "$\\dfrac{3}{1000} = 0.003$", "note": "Decimal part" }, { "math": "$2 + 0.003 = 2.003$", "note": "Add the whole" } ] }
    ]
  }
}
