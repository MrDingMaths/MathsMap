{
  "skillId": "construct-angles-protractor",
  "atomType": "R",
  "theory": {
    "intro": "To draw an angle of a given size, use a protractor to mark the second arm at the correct degree.",
    "facts": [
      "Start with a base arm, then place the protractor centre on its endpoint with $0^{\\circ}$ along the arm.",
      "Mark a dot at the required degree, then rule the second arm through it.",
      "For reflex angles ($> 180^{\\circ}$), draw the inner angle $360^{\\circ} -$ (reflex) and mark the outside."
    ],
    "steps": [
      "Draw a base arm and place the protractor centre on its end.",
      "Find the required degree and mark a point.",
      "Join the vertex to the point with a ruler."
    ]
  },
  "practice": {
    "foundation": [
      { "q": "Which degree mark do you place a dot at to draw a $50^{\\circ}$ angle from the base arm?", "a": "$50^{\\circ}$",
        "tikz": "\\begin{tikzpicture}[scale=1]\n\\coordinate (O) at (0,0);\n\\draw[thick] (O)--(2.4,0);\n\\draw[thick,dashed] (O)--(50:2.4);\n\\draw (0.9,0) arc (0:50:0.9);\n\\node at (25:1.25) {$50^{\\circ}$};\n\\end{tikzpicture}",
        "solution": [ { "math": "$0^{\\circ} \\text{ along base arm}$", "note": "Centre on the vertex" }, { "math": "$\\text{mark at } 50^{\\circ}$", "note": "" } ] },
      { "q": "To construct an $80^{\\circ}$ angle, where do you mark the second arm?", "a": "at the $80^{\\circ}$ mark",
        "tikz": "\\begin{tikzpicture}[scale=1]\n\\coordinate (O) at (0,0);\n\\draw[thick] (O)--(2.4,0);\n\\draw[thick,dashed] (O)--(80:2.4);\n\\draw (0.9,0) arc (0:80:0.9);\n\\node at (40:1.25) {$80^{\\circ}$};\n\\end{tikzpicture}",
        "solution": [ { "math": "$\\text{read scale from } 0^{\\circ}$", "note": "Up the base arm" }, { "math": "$\\text{mark at } 80^{\\circ}$", "note": "" } ] },
      { "q": "A drawn angle should be $90^{\\circ}$. What mark should it carry?", "a": "a right-angle (square) mark",
        "tikz": "\\begin{tikzpicture}[scale=1]\n\\coordinate (O) at (0,0);\n\\draw[thick] (O)--(2.4,0);\n\\draw[thick] (O)--(90:2.4);\n\\draw (0,0.4)--(0.4,0.4)--(0.4,0);\n\\end{tikzpicture}",
        "solution": [ { "math": "$90^{\\circ} = \\text{right angle}$", "note": "Quarter turn" }, { "math": "$\\text{draw a small square}$", "note": "" } ] },
      { "q": "To draw a $120^{\\circ}$ angle, which mark do you use?", "a": "the $120^{\\circ}$ mark",
        "tikz": "\\begin{tikzpicture}[scale=1]\n\\coordinate (O) at (0,0);\n\\draw[thick] (O)--(2.4,0);\n\\draw[thick,dashed] (O)--(120:2.4);\n\\draw (0.9,0) arc (0:120:0.9);\n\\node at (60:1.25) {$120^{\\circ}$};\n\\end{tikzpicture}",
        "solution": [ { "math": "$120^{\\circ} > 90^{\\circ}$", "note": "An obtuse angle" }, { "math": "$\\text{mark at } 120^{\\circ}$", "note": "" } ] },
      { "q": "Construct a $35^{\\circ}$ angle. At which degree do you mark the dot?", "a": "$35^{\\circ}$",
        "tikz": "\\begin{tikzpicture}[scale=1]\n\\coordinate (O) at (0,0);\n\\draw[thick] (O)--(2.4,0);\n\\draw[thick,dashed] (O)--(35:2.4);\n\\draw (0.9,0) arc (0:35:0.9);\n\\node at (17:1.3) {$35^{\\circ}$};\n\\end{tikzpicture}",
        "solution": [ { "math": "$\\text{from } 0^{\\circ}$", "note": "Along the base arm" }, { "math": "$\\text{mark at } 35^{\\circ}$", "note": "" } ] },
      { "q": "Construct a $150^{\\circ}$ angle. At which degree do you mark the dot?", "a": "$150^{\\circ}$",
        "tikz": "\\begin{tikzpicture}[scale=1]\n\\coordinate (O) at (0,0);\n\\draw[thick] (O)--(2.4,0);\n\\draw[thick,dashed] (O)--(150:2.4);\n\\draw (0.9,0) arc (0:150:0.9);\n\\node at (75:1.25) {$150^{\\circ}$};\n\\end{tikzpicture}",
        "solution": [ { "math": "$\\text{read scale from } 0^{\\circ}$", "note": "Obtuse angle" }, { "math": "$\\text{mark at } 150^{\\circ}$", "note": "" } ] },
      { "q": "What size base arm angle is $0^{\\circ}$ on the protractor?", "a": "$0^{\\circ}$ (the arm itself)",
        "solution": [ { "math": "$\\text{base arm} = 0^{\\circ}$", "note": "The starting line" }, { "math": "$0^{\\circ}$", "note": "" } ] },
      { "q": "Construct a $65^{\\circ}$ angle. At which degree do you mark the dot?", "a": "$65^{\\circ}$",
        "tikz": "\\begin{tikzpicture}[scale=1]\n\\coordinate (O) at (0,0);\n\\draw[thick] (O)--(2.4,0);\n\\draw[thick,dashed] (O)--(65:2.4);\n\\draw (0.9,0) arc (0:65:0.9);\n\\node at (32:1.25) {$65^{\\circ}$};\n\\end{tikzpicture}",
        "solution": [ { "math": "$\\text{from } 0^{\\circ}$", "note": "Up the base arm" }, { "math": "$\\text{mark at } 65^{\\circ}$", "note": "" } ] },
      { "q": "Construct a $100^{\\circ}$ angle. What type of angle have you drawn?", "a": "obtuse",
        "tikz": "\\begin{tikzpicture}[scale=1]\n\\coordinate (O) at (0,0);\n\\draw[thick] (O)--(2.4,0);\n\\draw[thick] (O)--(100:2.4);\n\\draw (0.9,0) arc (0:100:0.9);\n\\node at (50:1.25) {$100^{\\circ}$};\n\\end{tikzpicture}",
        "solution": [ { "math": "$90^{\\circ} < 100^{\\circ} < 180^{\\circ}$", "note": "Between right and straight" }, { "math": "$\\text{obtuse}$", "note": "" } ] },
      { "q": "To draw a straight angle, at which degree do you mark the second arm?", "a": "$180^{\\circ}$",
        "solution": [ { "math": "$\\text{straight} = 180^{\\circ}$", "note": "Opposite end of the protractor" }, { "math": "$\\text{mark at } 180^{\\circ}$", "note": "" } ] }
    ],
    "development": [
      { "q": "You drew an angle by marking at $60^{\\circ}$. What is its size and type?", "a": "$60^{\\circ}$, acute",
        "tikz": "\\begin{tikzpicture}[scale=1]\n\\coordinate (O) at (0,0);\n\\draw[thick] (O)--(2.4,0);\n\\draw[thick] (O)--(60:2.4);\n\\draw (0.9,0) arc (0:60:0.9);\n\\node at (30:1.25) {$60^{\\circ}$};\n\\end{tikzpicture}",
        "solution": [ { "math": "$60^{\\circ} < 90^{\\circ}$", "note": "Less than a right angle" }, { "math": "$60^{\\circ}, \\text{ acute}$", "note": "" } ] },
      { "q": "To draw two angles $45^{\\circ}$ and $30^{\\circ}$ side by side from the same arm, where is the outer arm marked?", "a": "$75^{\\circ}$",
        "solution": [ { "math": "$45^{\\circ} + 30^{\\circ}$", "note": "Build the second on the first" }, { "math": "$= 75^{\\circ}$", "note": "Outer mark" } ] },
      { "q": "A student wants a $145^{\\circ}$ angle but marks at $35^{\\circ}$ on the wrong scale. What angle did they actually draw?", "a": "$35^{\\circ}$",
        "solution": [ { "math": "$\\text{wrong scale used}$", "note": "Read from the wrong $0$" }, { "math": "$= 35^{\\circ}$", "note": "Not what was wanted" } ] },
      { "q": "Construct an angle equal to two-thirds of $90^{\\circ}$. At which mark do you draw the arm?", "a": "$60^{\\circ}$",
        "solution": [ { "math": "$\\tfrac{2}{3} \\times 90^{\\circ}$", "note": "Two-thirds of a right angle" }, { "math": "$= 60^{\\circ}$", "note": "" } ] },
      { "q": "You construct a $90^{\\circ}$ angle then a $40^{\\circ}$ angle inside it sharing one arm. What angle remains?", "a": "$50^{\\circ}$",
        "tikz": "\\begin{tikzpicture}[scale=1]\n\\coordinate (O) at (0,0);\n\\draw[thick] (O)--(2.4,0);\n\\draw[thick] (O)--(90:2.4);\n\\draw[thick] (O)--(40:2.4);\n\\draw (0.9,0) arc (0:40:0.9);\n\\node at (20:1.25) {$40^{\\circ}$};\n\\node at (65:1.3) {$x$};\n\\draw (0,0.5)--(0.5,0.5)--(0.5,0);\n\\end{tikzpicture}",
        "solution": [ { "math": "$90^{\\circ} - 40^{\\circ}$", "note": "Inside a right angle" }, { "math": "$= 50^{\\circ}$", "note": "" } ] },
      { "q": "Construct a $170^{\\circ}$ angle. Is it acute, obtuse or reflex?", "a": "obtuse",
        "tikz": "\\begin{tikzpicture}[scale=1]\n\\coordinate (O) at (0,0);\n\\draw[thick] (O)--(2.4,0);\n\\draw[thick] (O)--(170:2.4);\n\\draw (0.9,0) arc (0:170:0.9);\n\\node at (85:1.25) {$170^{\\circ}$};\n\\end{tikzpicture}",
        "solution": [ { "math": "$90^{\\circ} < 170^{\\circ} < 180^{\\circ}$", "note": "Just short of straight" }, { "math": "$\\text{obtuse}$", "note": "" } ] },
      { "q": "An angle of $15^{\\circ}$ is drawn, then doubled by adding another $15^{\\circ}$. What is the new angle's mark?", "a": "$30^{\\circ}$",
        "solution": [ { "math": "$15^{\\circ} + 15^{\\circ}$", "note": "Two equal steps" }, { "math": "$= 30^{\\circ}$", "note": "" } ] },
      { "q": "To draw a $135^{\\circ}$ angle accurately, between which two $10^{\\circ}$ marks does the dot sit?", "a": "between $130^{\\circ}$ and $140^{\\circ}$",
        "solution": [ { "math": "$130^{\\circ} < 135^{\\circ} < 140^{\\circ}$", "note": "Halfway between marks" }, { "math": "$\\text{midway}$", "note": "" } ] },
      { "q": "Construct three $40^{\\circ}$ angles in a row from the same vertex. What is the total angle?", "a": "$120^{\\circ}$",
        "solution": [ { "math": "$3 \\times 40^{\\circ}$", "note": "Three equal angles" }, { "math": "$= 120^{\\circ}$", "note": "" } ] },
      { "q": "You draw an angle marked at $25^{\\circ}$ and want to extend it to a right angle. How much more must you add?", "a": "$65^{\\circ}$",
        "solution": [ { "math": "$90^{\\circ} - 25^{\\circ}$", "note": "Up to a right angle" }, { "math": "$= 65^{\\circ}$", "note": "" } ] }
    ],
    "mastery": [
      { "q": "Construct a reflex angle of $300^{\\circ}$ using a $180^{\\circ}$ protractor. What inner angle do you draw, and on which side is the reflex?", "a": "draw $60^{\\circ}$ inner; reflex is the outside",
        "solution": [ { "math": "$360^{\\circ} - 300^{\\circ}$", "note": "Inner angle to draw" }, { "math": "$= 60^{\\circ}$", "note": "Mark the outside as reflex" } ] },
      { "q": "Construct a reflex angle of $215^{\\circ}$. What inner angle do you set out?", "a": "$145^{\\circ}$",
        "solution": [ { "math": "$360^{\\circ} - 215^{\\circ}$", "note": "Inner angle" }, { "math": "$= 145^{\\circ}$", "note": "" } ] },
      { "q": "An equilateral triangle has all angles equal. At what degree do you mark each angle when constructing one?", "a": "$60^{\\circ}$",
        "solution": [ { "math": "$\\dfrac{180^{\\circ}}{3}$", "note": "Angle sum of a triangle" }, { "math": "$= 60^{\\circ}$", "note": "" } ] },
      { "q": "To divide a full turn into $5$ equal angles at a point, at what intervals do you mark?", "a": "every $72^{\\circ}$",
        "solution": [ { "math": "$\\dfrac{360^{\\circ}}{5}$", "note": "Share the full turn" }, { "math": "$= 72^{\\circ}$", "note": "" } ] },
      { "q": "You construct a $48^{\\circ}$ angle and need its reflex drawn too. What is the reflex angle?", "a": "$312^{\\circ}$",
        "solution": [ { "math": "$360^{\\circ} - 48^{\\circ}$", "note": "Rest of the full turn" }, { "math": "$= 312^{\\circ}$", "note": "" } ] },
      { "q": "Construct two angles on a straight line: one is $115^{\\circ}$. At which degree do you mark the second so they fill the line?", "a": "$65^{\\circ}$",
        "solution": [ { "math": "$180^{\\circ} - 115^{\\circ}$", "note": "Angles on a line" }, { "math": "$= 65^{\\circ}$", "note": "" } ] },
      { "q": "A regular hexagon's interior angle is constructed. What is its size?", "a": "$120^{\\circ}$",
        "solution": [ { "math": "$\\dfrac{(6-2) \\times 180^{\\circ}}{6}$", "note": "Interior angle of a hexagon" }, { "math": "$= 120^{\\circ}$", "note": "" } ] },
      { "q": "You draw a $90^{\\circ}$ angle then split it exactly in half. At what degree is the bisector marked?", "a": "$45^{\\circ}$",
        "solution": [ { "math": "$\\tfrac{1}{2} \\times 90^{\\circ}$", "note": "Bisect the right angle" }, { "math": "$= 45^{\\circ}$", "note": "" } ] },
      { "q": "To construct $250^{\\circ}$ as a reflex angle, what inner angle is drawn, and what type is the inner angle?", "a": "$110^{\\circ}$, obtuse",
        "solution": [ { "math": "$360^{\\circ} - 250^{\\circ}$", "note": "Inner angle" }, { "math": "$= 110^{\\circ}, \\text{ obtuse}$", "note": "" } ] },
      { "q": "A sector for $\\tfrac{3}{8}$ of a pie chart is constructed. What angle do you mark at the centre?", "a": "$135^{\\circ}$",
        "solution": [ { "math": "$\\tfrac{3}{8} \\times 360^{\\circ}$", "note": "Three-eighths of the circle" }, { "math": "$= 135^{\\circ}$", "note": "" } ] }
    ]
  }
}
