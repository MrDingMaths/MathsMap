{
  "skillId": "angles-add-to-360",
  "atomType": "R",
  "theory": {
    "intro": "The rays meeting at a single point divide a full turn into angles that together add to $360^{\\circ}$. These are angles **at a point**.",
    "facts": [
      "Angles **at a point** (around one vertex) add to $360^{\\circ}$.",
      "A full turn is $360^{\\circ}$.",
      "If all but one angle is known, subtract the total of the known angles from $360^{\\circ}$."
    ],
    "steps": [
      "Check the angles all meet at one point and fill a full turn.",
      "Add the known angles.",
      "Subtract from $360^{\\circ}$ to find the unknown."
    ]
  },
  "practice": {
    "foundation": [
      { "q": "Three angles meet at a point. Find $x$.", "a": "$150^{\\circ}$",
        "tikz": "\\begin{tikzpicture}[scale=1]\n\\coordinate (O) at (0,0);\n\\draw[thick] (O)--(0:2.2);\n\\draw[thick] (O)--(120:2.2);\n\\draw[thick] (O)--(210:2.2);\n\\node at (60:1.2) {$120^{\\circ}$};\n\\node at (165:1.2) {$90^{\\circ}$};\n\\node at (285:1.2) {$x$};\n\\fill (O) circle (1.4pt);\n\\end{tikzpicture}",
        "solution": [ { "math": "$120^{\\circ} + 90^{\\circ} + x = 360^{\\circ}$", "note": "Angles at a point" }, { "math": "$x = 150^{\\circ}$", "note": "" } ] },
      { "q": "Two angles at a point are shown. Find $x$.", "a": "$250^{\\circ}$",
        "tikz": "\\begin{tikzpicture}[scale=1]\n\\coordinate (O) at (0,0);\n\\draw[thick] (O)--(0:2.2);\n\\draw[thick] (O)--(110:2.2);\n\\draw (0.7,0) arc (0:110:0.7);\n\\node at (55:1.1) {$110^{\\circ}$};\n\\node at (235:1.1) {$x$};\n\\fill (O) circle (1.4pt);\n\\end{tikzpicture}",
        "solution": [ { "math": "$110^{\\circ} + x = 360^{\\circ}$", "note": "Angles at a point" }, { "math": "$x = 250^{\\circ}$", "note": "" } ] },
      { "q": "Three angles meet at a point. Find $x$.", "a": "$130^{\\circ}$",
        "tikz": "\\begin{tikzpicture}[scale=1]\n\\coordinate (O) at (0,0);\n\\draw[thick] (O)--(0:2.2);\n\\draw[thick] (O)--(130:2.2);\n\\draw[thick] (O)--(230:2.2);\n\\node at (65:1.2) {$130^{\\circ}$};\n\\node at (180:1.2) {$100^{\\circ}$};\n\\node at (295:1.2) {$x$};\n\\fill (O) circle (1.4pt);\n\\end{tikzpicture}",
        "solution": [ { "math": "$130^{\\circ} + 100^{\\circ} + x = 360^{\\circ}$", "note": "Angles at a point" }, { "math": "$x = 130^{\\circ}$", "note": "" } ] },
      { "q": "Find the angle that adds to $300^{\\circ}$ to make $360^{\\circ}$.", "a": "$60^{\\circ}$",
        "solution": [ { "math": "$360^{\\circ} - 300^{\\circ}$", "note": "Full turn" }, { "math": "$= 60^{\\circ}$", "note": "" } ] },
      { "q": "Two angles at a point are shown. Find $x$.", "a": "$215^{\\circ}$",
        "tikz": "\\begin{tikzpicture}[scale=1]\n\\coordinate (O) at (0,0);\n\\draw[thick] (O)--(0:2.2);\n\\draw[thick] (O)--(145:2.2);\n\\draw (0.7,0) arc (0:145:0.7);\n\\node at (72:1.1) {$145^{\\circ}$};\n\\node at (250:1.1) {$x$};\n\\fill (O) circle (1.4pt);\n\\end{tikzpicture}",
        "solution": [ { "math": "$145^{\\circ} + x = 360^{\\circ}$", "note": "Angles at a point" }, { "math": "$x = 215^{\\circ}$", "note": "" } ] },
      { "q": "Four right angles meet at a point. What is their total?", "a": "$360^{\\circ}$",
        "solution": [ { "math": "$4 \\times 90^{\\circ}$", "note": "Four right angles" }, { "math": "$= 360^{\\circ}$", "note": "A full turn" } ] },
      { "q": "Three angles meet at a point. Find $x$.", "a": "$80^{\\circ}$",
        "tikz": "\\begin{tikzpicture}[scale=1]\n\\coordinate (O) at (0,0);\n\\draw[thick] (O)--(0:2.2);\n\\draw[thick] (O)--(160:2.2);\n\\draw[thick] (O)--(280:2.2);\n\\node at (80:1.2) {$160^{\\circ}$};\n\\node at (220:1.2) {$120^{\\circ}$};\n\\node at (320:1.2) {$x$};\n\\fill (O) circle (1.4pt);\n\\end{tikzpicture}",
        "solution": [ { "math": "$160^{\\circ} + 120^{\\circ} + x = 360^{\\circ}$", "note": "Angles at a point" }, { "math": "$x = 80^{\\circ}$", "note": "" } ] },
      { "q": "What is the size of one angle if three equal angles meet at a point?", "a": "$120^{\\circ}$",
        "solution": [ { "math": "$360^{\\circ} \\div 3$", "note": "Three equal parts" }, { "math": "$= 120^{\\circ}$", "note": "" } ] },
      { "q": "Two angles at a point are shown. Find $x$.", "a": "$285^{\\circ}$",
        "tikz": "\\begin{tikzpicture}[scale=1]\n\\coordinate (O) at (0,0);\n\\draw[thick] (O)--(0:2.2);\n\\draw[thick] (O)--(75:2.2);\n\\draw (0.7,0) arc (0:75:0.7);\n\\node at (37:1.1) {$75^{\\circ}$};\n\\node at (220:1.1) {$x$};\n\\fill (O) circle (1.4pt);\n\\end{tikzpicture}",
        "solution": [ { "math": "$75^{\\circ} + x = 360^{\\circ}$", "note": "Angles at a point" }, { "math": "$x = 285^{\\circ}$", "note": "" } ] },
      { "q": "Angles around a point add to what total?", "a": "$360^{\\circ}$",
        "solution": [ { "math": "$\\text{full turn}$", "note": "All the way around" }, { "math": "$= 360^{\\circ}$", "note": "" } ] }
    ],
    "development": [
      { "q": "At a point, four angles are $90^{\\circ}$, $80^{\\circ}$, $100^{\\circ}$ and $x$. Find $x$.", "a": "$90^{\\circ}$",
        "solution": [ { "math": "$90^{\\circ} + 80^{\\circ} + 100^{\\circ} + x = 360^{\\circ}$", "note": "Angles at a point" }, { "math": "$x = 90^{\\circ}$", "note": "" } ] },
      { "q": "At a point, three equal angles are shown. Find each angle.", "a": "$120^{\\circ}$",
        "tikz": "\\begin{tikzpicture}[scale=1]\n\\coordinate (O) at (0,0);\n\\draw[thick] (O)--(90:2.2);\n\\draw[thick] (O)--(210:2.2);\n\\draw[thick] (O)--(330:2.2);\n\\node at (150:1.1) {$x$};\n\\node at (270:1.1) {$x$};\n\\node at (30:1.1) {$x$};\n\\fill (O) circle (1.4pt);\n\\end{tikzpicture}",
        "solution": [ { "math": "$3x = 360^{\\circ}$", "note": "Angles at a point" }, { "math": "$x = 120^{\\circ}$", "note": "" } ] },
      { "q": "At a point, two equal angles and a $200^{\\circ}$ angle are shown. Find each equal angle.", "a": "$80^{\\circ}$",
        "solution": [ { "math": "$2x + 200^{\\circ} = 360^{\\circ}$", "note": "Angles at a point" }, { "math": "$2x = 160^{\\circ},\\ x = 80^{\\circ}$", "note": "" } ] },
      { "q": "At a point, two angles are $x$ and $3x$. Find $x$.", "a": "$90^{\\circ}$",
        "tikz": "\\begin{tikzpicture}[scale=1]\n\\coordinate (O) at (0,0);\n\\draw[thick] (O)--(0:2.2);\n\\draw[thick] (O)--(90:2.2);\n\\draw (0.7,0) arc (0:90:0.7);\n\\node at (45:1.2) {$x$};\n\\node at (225:1.2) {$3x$};\n\\fill (O) circle (1.4pt);\n\\end{tikzpicture}",
        "solution": [ { "math": "$x + 3x = 360^{\\circ}$", "note": "Angles at a point" }, { "math": "$4x = 360^{\\circ},\\ x = 90^{\\circ}$", "note": "" } ] },
      { "q": "At a point, angles are $115^{\\circ}$, $95^{\\circ}$, $60^{\\circ}$ and $x$. Find $x$.", "a": "$90^{\\circ}$",
        "solution": [ { "math": "$115^{\\circ} + 95^{\\circ} + 60^{\\circ} + x = 360^{\\circ}$", "note": "Angles at a point" }, { "math": "$x = 90^{\\circ}$", "note": "" } ] },
      { "q": "At a point, four equal angles are shown. Find each angle.", "a": "$90^{\\circ}$",
        "solution": [ { "math": "$4x = 360^{\\circ}$", "note": "Equal parts of a full turn" }, { "math": "$x = 90^{\\circ}$", "note": "" } ] },
      { "q": "At a point, one angle is $5$ times the other. Find the smaller angle.", "a": "$60^{\\circ}$",
        "solution": [ { "math": "$x + 5x = 360^{\\circ}$", "note": "Angles at a point" }, { "math": "$6x = 360^{\\circ},\\ x = 60^{\\circ}$", "note": "" } ] },
      { "q": "Three angles meet at a point: $145^{\\circ}$, $x$ and $128^{\\circ}$. Find $x$.", "a": "$87^{\\circ}$",
        "tikz": "\\begin{tikzpicture}[scale=1]\n\\coordinate (O) at (0,0);\n\\draw[thick] (O)--(0:2.2);\n\\draw[thick] (O)--(145:2.2);\n\\draw[thick] (O)--(232:2.2);\n\\node at (72:1.2) {$145^{\\circ}$};\n\\node at (188:1.2) {$x$};\n\\node at (300:1.2) {$128^{\\circ}$};\n\\fill (O) circle (1.4pt);\n\\end{tikzpicture}",
        "solution": [ { "math": "$145^{\\circ} + x + 128^{\\circ} = 360^{\\circ}$", "note": "Angles at a point" }, { "math": "$x = 87^{\\circ}$", "note": "" } ] },
      { "q": "At a point, the larger of two angles is $80^{\\circ}$ more than the smaller. Find the smaller.", "a": "$140^{\\circ}$",
        "solution": [ { "math": "$x + (x + 80^{\\circ}) = 360^{\\circ}$", "note": "Angles at a point" }, { "math": "$2x = 280^{\\circ},\\ x = 140^{\\circ}$", "note": "" } ] },
      { "q": "At a point, two adjacent angles are $2x$ and $x + 30^{\\circ}$, together with a right angle. Find $x$.", "a": "$80^{\\circ}$",
        "solution": [ { "math": "$2x + (x + 30^{\\circ}) + 90^{\\circ} = 360^{\\circ}$", "note": "Angles at a point" }, { "math": "$3x = 240^{\\circ},\\ x = 80^{\\circ}$", "note": "" } ] }
    ],
    "mastery": [
      { "q": "At a point, angles are in the ratio $1:2:3$. Find the largest.", "a": "$180^{\\circ}$",
        "solution": [ { "math": "$x + 2x + 3x = 360^{\\circ}$", "note": "Ratio parts" }, { "math": "$6x = 360^{\\circ},\\ 3x = 180^{\\circ}$", "note": "" } ] },
      { "q": "At a point, angles are $x$, $2x$, $3x$ and $4x$. Find the largest.", "a": "$144^{\\circ}$",
        "solution": [ { "math": "$x + 2x + 3x + 4x = 360^{\\circ}$", "note": "Angles at a point" }, { "math": "$10x = 360^{\\circ},\\ 4x = 144^{\\circ}$", "note": "" } ] },
      { "q": "A round pizza is cut from the centre into $5$ equal slices. What angle is at the tip of each slice?", "a": "$72^{\\circ}$",
        "solution": [ { "math": "$360^{\\circ} \\div 5$", "note": "Equal slices about the centre" }, { "math": "$= 72^{\\circ}$", "note": "" } ] },
      { "q": "Three roads leave a roundabout. Two of the angles between them are $130^{\\circ}$ and $140^{\\circ}$. Find the third.", "a": "$90^{\\circ}$",
        "solution": [ { "math": "$130^{\\circ} + 140^{\\circ} + x = 360^{\\circ}$", "note": "Angles at a point" }, { "math": "$x = 90^{\\circ}$", "note": "" } ] },
      { "q": "At a point, three angles are equal and a fourth is $150^{\\circ}$. Find each equal angle.", "a": "$70^{\\circ}$",
        "solution": [ { "math": "$3x + 150^{\\circ} = 360^{\\circ}$", "note": "Angles at a point" }, { "math": "$3x = 210^{\\circ},\\ x = 70^{\\circ}$", "note": "" } ] },
      { "q": "At a point, angles are $90^{\\circ}$, $90^{\\circ}$, $x$ and $x$. Find $x$.", "a": "$90^{\\circ}$",
        "solution": [ { "math": "$90^{\\circ} + 90^{\\circ} + 2x = 360^{\\circ}$", "note": "Angles at a point" }, { "math": "$2x = 180^{\\circ},\\ x = 90^{\\circ}$", "note": "" } ] },
      { "q": "At a point, angles are $x$, $x + 20^{\\circ}$, $x + 40^{\\circ}$ and $x + 60^{\\circ}$. Find $x$.", "a": "$60^{\\circ}$",
        "solution": [ { "math": "$4x + 120^{\\circ} = 360^{\\circ}$", "note": "Angles at a point" }, { "math": "$4x = 240^{\\circ},\\ x = 60^{\\circ}$", "note": "" } ] },
      { "q": "The hands of a clock divide a full turn at the centre. If three angles are $100^{\\circ}$, $130^{\\circ}$ and the rest is one angle, find the fourth angle.", "a": "$130^{\\circ}$",
        "solution": [ { "math": "$100^{\\circ} + 130^{\\circ} + x = 360^{\\circ}$", "note": "Angles at a point" }, { "math": "$x = 130^{\\circ}$", "note": "" } ] },
      { "q": "At a point, two reflex-free angles are in the ratio $4:5$ and a third is $90^{\\circ}$. Find the larger of the ratio angles.", "a": "$150^{\\circ}$",
        "solution": [ { "math": "$4x + 5x + 90^{\\circ} = 360^{\\circ}$", "note": "Angles at a point" }, { "math": "$9x = 270^{\\circ},\\ 5x = 150^{\\circ}$", "note": "" } ] },
      { "q": "At a point, six equal angles are drawn. What is each, and what type of angle is it?", "a": "$60^{\\circ}$, acute",
        "solution": [ { "math": "$6x = 360^{\\circ}$", "note": "Angles at a point" }, { "math": "$x = 60^{\\circ}, \\text{ acute}$", "note": "" } ] }
    ]
  }
}
