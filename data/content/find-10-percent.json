  "theory": {
    "intro": "Ten per cent is one tenth, so finding $10\\%$ of an amount means dividing it by $10$.",
    "facts": [
      "$10\\% = \\dfrac{10}{100} = \\dfrac{1}{10}$.",
      "$10\\%$ of an amount $=$ amount $\\div 10$.",
      "Once you have $10\\%$, you can double it for $20\\%$ or halve it for $5\\%$."
    ],
    "steps": [
      "Divide the amount by $10$ (move the digits one place right).",
      "Keep the units (dollars, kg, …).",
      "Check: $10\\%$ should be much smaller than the whole."
    ]
  },
  "practice": {
    "foundation": [
      { "q": "Find $10\\%$ of $80$.", "a": "$8$",
