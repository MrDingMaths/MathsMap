      { "q": "Petrol is $\\$1.80$/L and rises by $10\\%$. What is the new price per litre?", "a": "$\\$1.98$",
        "solution": [ { "math": "$1.80 \\div 10 = 0.18$", "note": "10% rise" }, { "math": "$1.80 + 0.18 = 1.98$", "note": "" } ] },
      { "q": "A class of $30$ has $10\\%$ absent. How many students are present?", "a": "$27$",
        "solution": [ { "math": "$30 \\div 10 = 3$", "note": "10% absent" }, { "math": "$30 - 3 = 27$", "note": "Present" } ] },
      { "q": "Find $90\\%$ of $\\$200$ by subtracting $10\\%$ from the whole.", "a": "$\\$180$",
        "solution": [ { "math": "$10\\% \\text{ of } 200 = 20$", "note": "Divide by 10" }, { "math": "$200 - 20 = 180$", "note": "$100\\% - 10\\%$" } ] }
    ]
