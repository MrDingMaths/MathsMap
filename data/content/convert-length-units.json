{
  "skillId": "convert-length-units",
  "atomType": "R",
  "theory": {
    "intro": "Metres and kilometres are linked by place value: there are $1000$ metres in one kilometre. Decimals make converting between them quick.",
    "facts": [
      "$1$ km $= 1000$ m.",
      "To change **m to km**, divide by $1000$ (move the point $3$ places left).",
      "To change **km to m**, multiply by $1000$ (move the point $3$ places right)."
    ],
    "steps": [
      "Decide which way you are converting.",
      "Multiply by $1000$ (km $\\to$ m) or divide by $1000$ (m $\\to$ km).",
      "Move the decimal point three places in the matching direction."
    ]
  },
  "practice": {
    "foundation": [
      { "q": "Convert $2$ km to metres.", "a": "$2000$ m",
        "solution": [ { "math": "$2 \\times 1000$", "note": "$1$ km $= 1000$ m" }, { "math": "$= 2000 \\text{ m}$", "note": "" } ] },
      { "q": "Convert $5000$ m to kilometres.", "a": "$5$ km",
        "solution": [ { "math": "$5000 \\div 1000$", "note": "$1000$ m $= 1$ km" }, { "math": "$= 5 \\text{ km}$", "note": "" } ] },
      { "q": "Convert $3.5$ km to metres.", "a": "$3500$ m",
        "solution": [ { "math": "$3.5 \\times 1000$", "note": "Point moves $3$ right" }, { "math": "$= 3500 \\text{ m}$", "note": "" } ] },
      { "q": "Convert $1500$ m to kilometres.", "a": "$1.5$ km",
        "solution": [ { "math": "$1500 \\div 1000$", "note": "Point moves $3$ left" }, { "math": "$= 1.5 \\text{ km}$", "note": "" } ] },
      { "q": "Convert $0.4$ km to metres.", "a": "$400$ m",
        "solution": [ { "math": "$0.4 \\times 1000$", "note": "$1$ km $= 1000$ m" }, { "math": "$= 400 \\text{ m}$", "note": "" } ] },
      { "q": "Convert $250$ m to kilometres.", "a": "$0.25$ km",
        "solution": [ { "math": "$250 \\div 1000$", "note": "Less than a km" }, { "math": "$= 0.25 \\text{ km}$", "note": "" } ] },
      { "q": "Convert $7$ km to metres.", "a": "$7000$ m",
        "solution": [ { "math": "$7 \\times 1000$", "note": "$1$ km $= 1000$ m" }, { "math": "$= 7000 \\text{ m}$", "note": "" } ] },
      { "q": "Convert $800$ m to kilometres.", "a": "$0.8$ km",
        "solution": [ { "math": "$800 \\div 1000$", "note": "$1000$ m $= 1$ km" }, { "math": "$= 0.8 \\text{ km}$", "note": "" } ] },
      { "q": "Convert $1.25$ km to metres.", "a": "$1250$ m",
        "solution": [ { "math": "$1.25 \\times 1000$", "note": "Point moves $3$ right" }, { "math": "$= 1250 \\text{ m}$", "note": "" } ] },
      { "q": "Convert $4250$ m to kilometres.", "a": "$4.25$ km",
        "solution": [ { "math": "$4250 \\div 1000$", "note": "Point moves $3$ left" }, { "math": "$= 4.25 \\text{ km}$", "note": "" } ] }
    ],
    "development": [
      { "q": "Convert $0.075$ km to metres.", "a": "$75$ m",
        "solution": [ { "math": "$0.075 \\times 1000$", "note": "Point moves $3$ right" }, { "math": "$= 75 \\text{ m}$", "note": "" } ] },
      { "q": "Convert $90$ m to kilometres.", "a": "$0.09$ km",
        "solution": [ { "math": "$90 \\div 1000$", "note": "Point moves $3$ left" }, { "math": "$= 0.09 \\text{ km}$", "note": "" } ] },
      { "q": "Convert $12.4$ km to metres.", "a": "$12\\,400$ m",
        "solution": [ { "math": "$12.4 \\times 1000$", "note": "$1$ km $= 1000$ m" }, { "math": "$= 12\\,400 \\text{ m}$", "note": "" } ] },
      { "q": "Convert $6700$ m to kilometres.", "a": "$6.7$ km",
        "solution": [ { "math": "$6700 \\div 1000$", "note": "$1000$ m $= 1$ km" }, { "math": "$= 6.7 \\text{ km}$", "note": "" } ] },
      { "q": "A road is $2.05$ km long. How many metres is that?", "a": "$2050$ m",
        "solution": [ { "math": "$2.05 \\times 1000$", "note": "Point moves $3$ right" }, { "math": "$= 2050 \\text{ m}$", "note": "" } ] },
      { "q": "A trail measures $350$ m. Write its length in kilometres.", "a": "$0.35$ km",
        "solution": [ { "math": "$350 \\div 1000$", "note": "Less than a km" }, { "math": "$= 0.35 \\text{ km}$", "note": "" } ] },
      { "q": "Convert $0.008$ km to metres.", "a": "$8$ m",
        "solution": [ { "math": "$0.008 \\times 1000$", "note": "$1$ km $= 1000$ m" }, { "math": "$= 8 \\text{ m}$", "note": "" } ] },
      { "q": "Convert $10\\,500$ m to kilometres.", "a": "$10.5$ km",
        "solution": [ { "math": "$10\\,500 \\div 1000$", "note": "Point moves $3$ left" }, { "math": "$= 10.5 \\text{ km}$", "note": "" } ] },
      { "q": "A swimmer covers $1.6$ km. How many metres is this?", "a": "$1600$ m",
        "solution": [ { "math": "$1.6 \\times 1000$", "note": "$1$ km $= 1000$ m" }, { "math": "$= 1600 \\text{ m}$", "note": "" } ] },
      { "q": "Convert $45$ m to kilometres.", "a": "$0.045$ km",
        "solution": [ { "math": "$45 \\div 1000$", "note": "Point moves $3$ left" }, { "math": "$= 0.045 \\text{ km}$", "note": "" } ] }
    ],
    "mastery": [
      { "q": "A cyclist rides $3.2$ km then $850$ m further. How many metres in total?", "a": "$4050$ m",
        "solution": [ { "math": "$3.2 \\text{ km} = 3200 \\text{ m}$", "note": "Convert first" }, { "math": "$3200 + 850 = 4050 \\text{ m}$", "note": "" } ] },
      { "q": "A walk of $1.75$ km is split into two equal parts. How long is each part in metres?", "a": "$875$ m",
        "solution": [ { "math": "$1.75 \\text{ km} = 1750 \\text{ m}$", "note": "Convert" }, { "math": "$1750 \\div 2 = 875 \\text{ m}$", "note": "" } ] },
      { "q": "Which is longer: $0.9$ km or $950$ m?", "a": "$950$ m",
        "solution": [ { "math": "$0.9 \\text{ km} = 900 \\text{ m}$", "note": "Same unit" }, { "math": "$950 > 900$", "note": "So $950$ m" } ] },
      { "q": "A fun run is $5$ km. A runner has covered $3650$ m. How many metres remain?", "a": "$1350$ m",
        "solution": [ { "math": "$5 \\text{ km} = 5000 \\text{ m}$", "note": "Convert" }, { "math": "$5000 - 3650 = 1350 \\text{ m}$", "note": "" } ] },
      { "q": "Express the total of $2$ km and $400$ m in kilometres.", "a": "$2.4$ km",
        "solution": [ { "math": "$400 \\text{ m} = 0.4 \\text{ km}$", "note": "Convert" }, { "math": "$2 + 0.4 = 2.4 \\text{ km}$", "note": "" } ] },
      { "q": "A delivery van travels $0.6$ km, $0.6$ km and $0.6$ km. What is the total in metres?", "a": "$1800$ m",
        "solution": [ { "math": "$0.6 \\times 3 = 1.8 \\text{ km}$", "note": "Total km" }, { "math": "$1.8 \\times 1000 = 1800 \\text{ m}$", "note": "" } ] },
      { "q": "Order from shortest to longest: $1.2$ km, $900$ m, $1050$ m.", "a": "$900$ m, $1050$ m, $1.2$ km",
        "solution": [ { "math": "$1.2 \\text{ km} = 1200 \\text{ m}$", "note": "Same unit" }, { "math": "$900 < 1050 < 1200$", "note": "" } ] },
      { "q": "A track lap is $400$ m. How many laps make $3$ km?", "a": "$7.5$ laps",
        "solution": [ { "math": "$3 \\text{ km} = 3000 \\text{ m}$", "note": "Convert" }, { "math": "$3000 \\div 400 = 7.5$", "note": "" } ] },
      { "q": "A map distance is $0.125$ km. Express this in metres.", "a": "$125$ m",
        "solution": [ { "math": "$0.125 \\times 1000$", "note": "$1$ km $= 1000$ m" }, { "math": "$= 125 \\text{ m}$", "note": "" } ] },
      { "q": "A hiker walks $4$ km $250$ m. Write the total distance in kilometres.", "a": "$4.25$ km",
        "solution": [ { "math": "$250 \\text{ m} = 0.25 \\text{ km}$", "note": "Convert" }, { "math": "$4 + 0.25 = 4.25 \\text{ km}$", "note": "" } ] }
    ]
  }
}
