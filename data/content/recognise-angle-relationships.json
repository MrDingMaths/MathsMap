{
  "skillId": "recognise-angle-relationships",
  "atomType": "R",
  "theory": {
    "intro": "Angles in a diagram often add up to a known total. Spotting the relationship lets you find a missing angle.",
    "facts": [
      "Two angles forming a **right angle** add to $90^{\\circ}$.",
      "Angles on a **straight line** add to $180^{\\circ}$.",
      "Angles **at a point** (around a vertex) add to $360^{\\circ}$."
    ],
    "steps": [
      "Decide which relationship the diagram shows ($90^{\\circ}$, $180^{\\circ}$ or $360^{\\circ}$).",
      "Add the known angles.",
      "Subtract from the total to find the unknown."
    ]
  },
  "practice": {
    "foundation": [
      { "q": "The two angles form a right angle. Find $x$.", "a": "$60^{\\circ}$",
        "tikz": "\\begin{tikzpicture}[scale=1]\n\\coordinate (O) at (0,0);\n\\draw[thick] (O)--(2.2,0);\n\\draw[thick] (O)--(0,2.2);\n\\draw[thick] (O)--(30:2.2);\n\\draw (0,0.45)--(0.45,0.45)--(0.45,0);\n\\node at (15:1.4) {$30^{\\circ}$};\n\\node at (60:1.4) {$x$};\n\\end{tikzpicture}",
        "solution": [ { "math": "$x + 30^{\\circ} = 90^{\\circ}$", "note": "Right angle" }, { "math": "$x = 60^{\\circ}$", "note": "" } ] },
      { "q": "The angles lie on a straight line. Find $x$.", "a": "$70^{\\circ}$",
        "tikz": "\\begin{tikzpicture}[scale=1]\n\\coordinate (O) at (0,0);\n\\draw[thick] (-2.4,0)--(2.4,0);\n\\draw[thick] (O)--(110:2.2);\n\\node at (55:1.3) {$110^{\\circ}$};\n\\node at (145:1.3) {$x$};\n\\fill (O) circle (1.4pt);\n\\end{tikzpicture}",
        "solution": [ { "math": "$x + 110^{\\circ} = 180^{\\circ}$", "note": "Straight line" }, { "math": "$x = 70^{\\circ}$", "note": "" } ] },
      { "q": "Three angles meet at a point. Find $x$.", "a": "$160^{\\circ}$",
        "tikz": "\\begin{tikzpicture}[scale=1]\n\\coordinate (O) at (0,0);\n\\draw[thick] (O)--(0:2.2);\n\\draw[thick] (O)--(120:2.2);\n\\draw[thick] (O)--(200:2.2);\n\\node at (60:1.2) {$120^{\\circ}$};\n\\node at (160:1.2) {$80^{\\circ}$};\n\\node at (280:1.2) {$x$};\n\\fill (O) circle (1.4pt);\n\\end{tikzpicture}",
        "solution": [ { "math": "$120^{\\circ} + 80^{\\circ} + x = 360^{\\circ}$", "note": "Angles at a point" }, { "math": "$x = 160^{\\circ}$", "note": "" } ] },
      { "q": "The two angles form a right angle. Find $x$.", "a": "$35^{\\circ}$",
        "tikz": "\\begin{tikzpicture}[scale=1]\n\\coordinate (O) at (0,0);\n\\draw[thick] (O)--(2.2,0);\n\\draw[thick] (O)--(0,2.2);\n\\draw[thick] (O)--(55:2.2);\n\\draw (0,0.45)--(0.45,0.45)--(0.45,0);\n\\node at (27:1.4) {$55^{\\circ}$};\n\\node at (72:1.4) {$x$};\n\\end{tikzpicture}",
        "solution": [ { "math": "$x + 55^{\\circ} = 90^{\\circ}$", "note": "Right angle" }, { "math": "$x = 35^{\\circ}$", "note": "" } ] },
      { "q": "The angles lie on a straight line. Find $x$.", "a": "$45^{\\circ}$",
        "tikz": "\\begin{tikzpicture}[scale=1]\n\\coordinate (O) at (0,0);\n\\draw[thick] (-2.4,0)--(2.4,0);\n\\draw[thick] (O)--(135:2.2);\n\\node at (67:1.3) {$135^{\\circ}$};\n\\node at (157:1.3) {$x$};\n\\fill (O) circle (1.4pt);\n\\end{tikzpicture}",
        "solution": [ { "math": "$x + 135^{\\circ} = 180^{\\circ}$", "note": "Straight line" }, { "math": "$x = 45^{\\circ}$", "note": "" } ] },
      { "q": "Two angles at a point are shown. Find $x$.", "a": "$280^{\\circ}$",
        "tikz": "\\begin{tikzpicture}[scale=1]\n\\coordinate (O) at (0,0);\n\\draw[thick] (O)--(0:2.2);\n\\draw[thick] (O)--(80:2.2);\n\\draw (0.7,0) arc (0:80:0.7);\n\\node at (40:1.1) {$80^{\\circ}$};\n\\node at (220:1.1) {$x$};\n\\fill (O) circle (1.4pt);\n\\end{tikzpicture}",
        "solution": [ { "math": "$x + 80^{\\circ} = 360^{\\circ}$", "note": "Angles at a point" }, { "math": "$x = 280^{\\circ}$", "note": "" } ] },
      { "q": "The two angles form a right angle. Find $x$.", "a": "$25^{\\circ}$",
        "tikz": "\\begin{tikzpicture}[scale=1]\n\\coordinate (O) at (0,0);\n\\draw[thick] (O)--(2.2,0);\n\\draw[thick] (O)--(0,2.2);\n\\draw[thick] (O)--(65:2.2);\n\\draw (0,0.45)--(0.45,0.45)--(0.45,0);\n\\node at (32:1.4) {$65^{\\circ}$};\n\\node at (77:1.5) {$x$};\n\\end{tikzpicture}",
        "solution": [ { "math": "$x + 65^{\\circ} = 90^{\\circ}$", "note": "Right angle" }, { "math": "$x = 25^{\\circ}$", "note": "" } ] },
      { "q": "The angles lie on a straight line. Find $x$.", "a": "$95^{\\circ}$",
        "tikz": "\\begin{tikzpicture}[scale=1]\n\\coordinate (O) at (0,0);\n\\draw[thick] (-2.4,0)--(2.4,0);\n\\draw[thick] (O)--(85:2.2);\n\\node at (42:1.3) {$85^{\\circ}$};\n\\node at (133:1.3) {$x$};\n\\fill (O) circle (1.4pt);\n\\end{tikzpicture}",
        "solution": [ { "math": "$x + 85^{\\circ} = 180^{\\circ}$", "note": "Straight line" }, { "math": "$x = 95^{\\circ}$", "note": "" } ] },
      { "q": "Which relationship is shown: two angles together making a square corner?", "a": "they add to $90^{\\circ}$",
        "solution": [ { "math": "$\\text{square corner} = 90^{\\circ}$", "note": "A right angle" }, { "math": "$\\text{sum} = 90^{\\circ}$", "note": "" } ] },
      { "q": "Angles around a point add to what total?", "a": "$360^{\\circ}$",
        "solution": [ { "math": "$\\text{full turn}$", "note": "All the way around" }, { "math": "$= 360^{\\circ}$", "note": "" } ] }
    ],
    "development": [
      { "q": "On a straight line, two angles are $x$ and $2x$. Find $x$.", "a": "$60^{\\circ}$",
        "tikz": "\\begin{tikzpicture}[scale=1]\n\\coordinate (O) at (0,0);\n\\draw[thick] (-2.4,0)--(2.4,0);\n\\draw[thick] (O)--(60:2.2);\n\\node at (30:1.3) {$2x$};\n\\node at (120:1.3) {$x$};\n\\fill (O) circle (1.4pt);\n\\end{tikzpicture}",
        "solution": [ { "math": "$x + 2x = 180^{\\circ}$", "note": "Straight line" }, { "math": "$3x = 180^{\\circ},\\ x = 60^{\\circ}$", "note": "" } ] },
      { "q": "At a point, three equal angles are shown. Find each angle.", "a": "$120^{\\circ}$",
        "tikz": "\\begin{tikzpicture}[scale=1]\n\\coordinate (O) at (0,0);\n\\draw[thick] (O)--(90:2.2);\n\\draw[thick] (O)--(210:2.2);\n\\draw[thick] (O)--(330:2.2);\n\\node at (150:1.1) {$x$};\n\\node at (270:1.1) {$x$};\n\\node at (30:1.1) {$x$};\n\\fill (O) circle (1.4pt);\n\\end{tikzpicture}",
        "solution": [ { "math": "$3x = 360^{\\circ}$", "note": "Angles at a point" }, { "math": "$x = 120^{\\circ}$", "note": "" } ] },
      { "q": "A right angle is split into $x$ and $52^{\\circ}$. Find $x$.", "a": "$38^{\\circ}$",
        "tikz": "\\begin{tikzpicture}[scale=1]\n\\coordinate (O) at (0,0);\n\\draw[thick] (O)--(2.2,0);\n\\draw[thick] (O)--(0,2.2);\n\\draw[thick] (O)--(52:2.2);\n\\draw (0,0.45)--(0.45,0.45)--(0.45,0);\n\\node at (26:1.4) {$52^{\\circ}$};\n\\node at (71:1.45) {$x$};\n\\end{tikzpicture}",
        "solution": [ { "math": "$x + 52^{\\circ} = 90^{\\circ}$", "note": "Right angle" }, { "math": "$x = 38^{\\circ}$", "note": "" } ] },
      { "q": "On a straight line three angles are $40^{\\circ}$, $x$ and $75^{\\circ}$. Find $x$.", "a": "$65^{\\circ}$",
        "tikz": "\\begin{tikzpicture}[scale=1]\n\\coordinate (O) at (0,0);\n\\draw[thick] (-2.4,0)--(2.4,0);\n\\draw[thick] (O)--(40:2.2);\n\\draw[thick] (O)--(115:2.2);\n\\node at (20:1.3) {$40^{\\circ}$};\n\\node at (77:1.3) {$x$};\n\\node at (150:1.3) {$75^{\\circ}$};\n\\fill (O) circle (1.4pt);\n\\end{tikzpicture}",
        "solution": [ { "math": "$40^{\\circ} + x + 75^{\\circ} = 180^{\\circ}$", "note": "Straight line" }, { "math": "$x = 65^{\\circ}$", "note": "" } ] },
      { "q": "At a point, angles are $90^{\\circ}$, $110^{\\circ}$, $70^{\\circ}$ and $x$. Find $x$.", "a": "$90^{\\circ}$",
        "solution": [ { "math": "$90^{\\circ} + 110^{\\circ} + 70^{\\circ} + x = 360^{\\circ}$", "note": "Angles at a point" }, { "math": "$x = 90^{\\circ}$", "note": "" } ] },
      { "q": "Two angles forming a right angle are equal. Find each.", "a": "$45^{\\circ}$",
        "solution": [ { "math": "$2x = 90^{\\circ}$", "note": "Equal halves of a right angle" }, { "math": "$x = 45^{\\circ}$", "note": "" } ] },
      { "q": "On a straight line, one angle is $4$ times the other. Find the smaller angle.", "a": "$36^{\\circ}$",
        "solution": [ { "math": "$x + 4x = 180^{\\circ}$", "note": "Straight line" }, { "math": "$5x = 180^{\\circ},\\ x = 36^{\\circ}$", "note": "" } ] },
      { "q": "At a point, two equal angles and a $160^{\\circ}$ angle are shown. Find each equal angle.", "a": "$100^{\\circ}$",
        "solution": [ { "math": "$2x + 160^{\\circ} = 360^{\\circ}$", "note": "Angles at a point" }, { "math": "$2x = 200^{\\circ},\\ x = 100^{\\circ}$", "note": "" } ] },
      { "q": "A right angle is split into three equal parts. Find each part.", "a": "$30^{\\circ}$",
        "solution": [ { "math": "$3x = 90^{\\circ}$", "note": "Equal parts of a right angle" }, { "math": "$x = 30^{\\circ}$", "note": "" } ] },
      { "q": "On a straight line two angles are $x + 20^{\\circ}$ and $x$. Find $x$.", "a": "$80^{\\circ}$",
        "solution": [ { "math": "$(x + 20^{\\circ}) + x = 180^{\\circ}$", "note": "Straight line" }, { "math": "$2x = 160^{\\circ},\\ x = 80^{\\circ}$", "note": "" } ] }
    ],
    "mastery": [
      { "q": "At a point, angles are $x$, $x + 30^{\\circ}$, $x + 60^{\\circ}$ and $90^{\\circ}$. Find $x$.", "a": "$60^{\\circ}$",
        "solution": [ { "math": "$3x + 90^{\\circ} + 90^{\\circ} = 360^{\\circ}$", "note": "Angles at a point" }, { "math": "$3x = 180^{\\circ},\\ x = 60^{\\circ}$", "note": "" } ] },
      { "q": "Two angles on a straight line are in the ratio $2:3$. Find the larger angle.", "a": "$108^{\\circ}$",
        "solution": [ { "math": "$2x + 3x = 180^{\\circ}$", "note": "Ratio parts on a line" }, { "math": "$5x = 180^{\\circ},\\ 3x = 108^{\\circ}$", "note": "" } ] },
      { "q": "A right angle is divided so one part is twice the other. Find the larger part.", "a": "$60^{\\circ}$",
        "solution": [ { "math": "$x + 2x = 90^{\\circ}$", "note": "Right angle" }, { "math": "$3x = 90^{\\circ},\\ 2x = 60^{\\circ}$", "note": "" } ] },
      { "q": "Around a point, four equal angles are drawn. What is each, and what type of angle is it?", "a": "$90^{\\circ}$, right angle",
        "solution": [ { "math": "$4x = 360^{\\circ}$", "note": "Angles at a point" }, { "math": "$x = 90^{\\circ}$", "note": "Right angle" } ] },
      { "q": "On a straight line, angles are $3x$, $x$ and $40^{\\circ}$. Find $x$.", "a": "$35^{\\circ}$",
        "solution": [ { "math": "$3x + x + 40^{\\circ} = 180^{\\circ}$", "note": "Straight line" }, { "math": "$4x = 140^{\\circ},\\ x = 35^{\\circ}$", "note": "" } ] },
      { "q": "At a point, three angles are equal and a fourth is $120^{\\circ}$. Find each equal angle.", "a": "$80^{\\circ}$",
        "solution": [ { "math": "$3x + 120^{\\circ} = 360^{\\circ}$", "note": "Angles at a point" }, { "math": "$3x = 240^{\\circ},\\ x = 80^{\\circ}$", "note": "" } ] },
      { "q": "A right angle at a desk corner is split by a pencil into $2x$ and $x + 15^{\\circ}$. Find $x$.", "a": "$25^{\\circ}$",
        "solution": [ { "math": "$2x + x + 15^{\\circ} = 90^{\\circ}$", "note": "Right angle" }, { "math": "$3x = 75^{\\circ},\\ x = 25^{\\circ}$", "note": "" } ] },
      { "q": "On a straight line, three equal angles are shown. What is each, and what type?", "a": "$60^{\\circ}$, acute",
        "solution": [ { "math": "$3x = 180^{\\circ}$", "note": "Straight line" }, { "math": "$x = 60^{\\circ}, \\text{ acute}$", "note": "" } ] },
      { "q": "Around a point, angles are $x$, $2x$, $3x$ and $4x$. Find the largest.", "a": "$144^{\\circ}$",
        "solution": [ { "math": "$x + 2x + 3x + 4x = 360^{\\circ}$", "note": "Angles at a point" }, { "math": "$10x = 360^{\\circ},\\ 4x = 144^{\\circ}$", "note": "" } ] },
      { "q": "A straight angle is split into two; the larger is $50^{\\circ}$ more than the smaller. Find the smaller.", "a": "$65^{\\circ}$",
        "solution": [ { "math": "$x + (x + 50^{\\circ}) = 180^{\\circ}$", "note": "Straight line" }, { "math": "$2x = 130^{\\circ},\\ x = 65^{\\circ}$", "note": "" } ] }
    ]
  }
}
