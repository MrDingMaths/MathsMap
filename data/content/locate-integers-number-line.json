  "theory": {
    "intro": "Integers are the positive whole numbers, the negative whole numbers, and zero. On a number line they sit in order, evenly spaced.",
    "facts": [
      "Negative integers are to the **left** of zero; positive integers to the **right**.",
      "Each interval (gap) on a number line is the **same size** — read the scale first."
    ],
    "steps": [
      "Find zero and read the size of one interval.",
      "Count along in equal intervals.",
      "Left of zero → negative; right of zero → positive."
    ]
