        "tikz": "\\begin{tikzpicture}[x=0.7cm,y=0.7cm]\n\\draw[thick,-{Stealth[length=2mm]}] (-6.8,0) -- (6.8,0);\n\\foreach \\x in {-6,-5,...,6} \\draw (\\x,0.12) -- (\\x,-0.12);\n\\foreach \\x in {-6,-4,-2,0,2,4,6} \\draw (\\x,0.22) -- (\\x,-0.22) node[below=1pt] {$\\x$};\n\\fill (-3,0) circle (2.6pt);\n\\node[above=3pt] at (-3,0) {$A$};\n\\end{tikzpicture}",
        "solution": [
          { "math": "$\\text{scale: 1 per tick}$", "note": "Each small tick = 1" },
          { "math": "$-4 + 1 = -3$", "note": "1 tick right of $-4$" }
