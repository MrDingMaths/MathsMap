{
  "skillId": "compare-lengths-same-unit",
  "atomType": "R",
  "theory": {
    "intro": "To compare lengths fairly, first write them in the **same unit**. Then the numbers can be compared directly.",
    "facts": [
      "You cannot compare $1.2$ m and $90$ cm until both use one unit.",
      "Useful links: $1$ m $= 100$ cm, $1$ cm $= 10$ mm, $1$ km $= 1000$ m.",
      "Convert to the **smaller** unit to avoid decimals, or to a common unit of your choice."
    ],
    "steps": [
      "Choose one common unit for all the lengths.",
      "Convert every length into that unit.",
      "Compare or order the numbers."
    ]
  },
  "practice": {
    "foundation": [
      { "q": "Which is longer: $1.3$ m or $120$ cm?", "a": "$1.3$ m",
        "solution": [ { "math": "$1.3 \\text{ m} = 130 \\text{ cm}$", "note": "Same unit" }, { "math": "$130 > 120$", "note": "So $1.3$ m" } ] },
      { "q": "Which is shorter: $45$ cm or $0.5$ m?", "a": "$45$ cm",
        "solution": [ { "math": "$0.5 \\text{ m} = 50 \\text{ cm}$", "note": "Same unit" }, { "math": "$45 < 50$", "note": "So $45$ cm" } ] },
      { "q": "Which is longer: $8$ cm or $75$ mm?", "a": "$8$ cm",
        "solution": [ { "math": "$8 \\text{ cm} = 80 \\text{ mm}$", "note": "Same unit" }, { "math": "$80 > 75$", "note": "So $8$ cm" } ] },
      { "q": "Compare using $<$ or $>$: $2.1$ m and $190$ cm.", "a": "$2.1$ m $>$ $190$ cm",
        "solution": [ { "math": "$2.1 \\text{ m} = 210 \\text{ cm}$", "note": "Same unit" }, { "math": "$210 > 190$", "note": "" } ] },
      { "q": "Which is longer: $0.7$ m or $70$ cm?", "a": "They are equal",
        "solution": [ { "math": "$0.7 \\text{ m} = 70 \\text{ cm}$", "note": "Same unit" }, { "math": "$70 = 70$", "note": "Equal" } ] },
      { "q": "Which is shorter: $35$ mm or $4$ cm?", "a": "$35$ mm",
        "solution": [ { "math": "$4 \\text{ cm} = 40 \\text{ mm}$", "note": "Same unit" }, { "math": "$35 < 40$", "note": "So $35$ mm" } ] },
      { "q": "Which is longer: $1.5$ km or $1400$ m?", "a": "$1.5$ km",
        "solution": [ { "math": "$1.5 \\text{ km} = 1500 \\text{ m}$", "note": "Same unit" }, { "math": "$1500 > 1400$", "note": "So $1.5$ km" } ] },
      { "q": "Compare using $<$ or $>$: $60$ cm and $0.6$ m.", "a": "$60$ cm $=$ $0.6$ m",
        "solution": [ { "math": "$0.6 \\text{ m} = 60 \\text{ cm}$", "note": "Same unit" }, { "math": "$60 = 60$", "note": "Equal" } ] },
      { "q": "Which is longer: $250$ cm or $2.3$ m?", "a": "$250$ cm",
        "solution": [ { "math": "$2.3 \\text{ m} = 230 \\text{ cm}$", "note": "Same unit" }, { "math": "$250 > 230$", "note": "So $250$ cm" } ] },
      { "q": "Which is shorter: $9$ mm or $1$ cm?", "a": "$9$ mm",
        "solution": [ { "math": "$1 \\text{ cm} = 10 \\text{ mm}$", "note": "Same unit" }, { "math": "$9 < 10$", "note": "So $9$ mm" } ] }
    ],
    "development": [
      { "q": "Order from shortest to longest: $1.2$ m, $90$ cm, $1050$ mm.", "a": "$90$ cm, $1.2$ m, $1050$ mm",
        "solution": [ { "math": "$\\text{in mm: } 1200,\\ 900,\\ 1050$", "note": "Common unit" }, { "math": "$900 < 1050 < 1200$", "note": "" } ] },
      { "q": "Order from longest to shortest: $0.8$ m, $85$ cm, $790$ mm.", "a": "$85$ cm, $0.8$ m, $790$ mm",
        "solution": [ { "math": "$\\text{in mm: } 800,\\ 850,\\ 790$", "note": "Common unit" }, { "math": "$850 > 800 > 790$", "note": "" } ] },
      { "q": "Which is longest: $1.05$ m, $98$ cm, or $1100$ mm?", "a": "$1100$ mm",
        "solution": [ { "math": "$\\text{in mm: } 1050,\\ 980,\\ 1100$", "note": "Common unit" }, { "math": "$1100 \\text{ is largest}$", "note": "" } ] },
      { "q": "Compare using $<$ or $>$: $0.45$ km and $480$ m.", "a": "$0.45$ km $<$ $480$ m",
        "solution": [ { "math": "$0.45 \\text{ km} = 450 \\text{ m}$", "note": "Same unit" }, { "math": "$450 < 480$", "note": "" } ] },
      { "q": "Three ribbons: $1.4$ m, $135$ cm, $1450$ mm. Which is shortest?", "a": "$135$ cm",
        "solution": [ { "math": "$\\text{in mm: } 1400,\\ 1350,\\ 1450$", "note": "Common unit" }, { "math": "$1350 \\text{ is smallest}$", "note": "" } ] },
      { "q": "Which is greater: $3$ cm $5$ mm or $32$ mm?", "a": "$3$ cm $5$ mm",
        "solution": [ { "math": "$3 \\text{ cm } 5 \\text{ mm} = 35 \\text{ mm}$", "note": "Same unit" }, { "math": "$35 > 32$", "note": "" } ] },
      { "q": "Order from shortest to longest: $2.5$ km, $2600$ m, $2.45$ km.", "a": "$2.45$ km, $2.5$ km, $2600$ m",
        "solution": [ { "math": "$\\text{in m: } 2500,\\ 2600,\\ 2450$", "note": "Common unit" }, { "math": "$2450 < 2500 < 2600$", "note": "" } ] },
      { "q": "Which is longer: $1$ m $8$ cm or $115$ cm?", "a": "$115$ cm",
        "solution": [ { "math": "$1 \\text{ m } 8 \\text{ cm} = 108 \\text{ cm}$", "note": "Same unit" }, { "math": "$115 > 108$", "note": "" } ] },
      { "q": "Compare using $<$ or $>$: $750$ mm and $0.8$ m.", "a": "$750$ mm $<$ $0.8$ m",
        "solution": [ { "math": "$0.8 \\text{ m} = 800 \\text{ mm}$", "note": "Same unit" }, { "math": "$750 < 800$", "note": "" } ] },
      { "q": "Which is closest to $1$ m: $96$ cm, $1.1$ m, or $1020$ mm?", "a": "$96$ cm (4 cm away)",
        "solution": [ { "math": "$\\text{in cm: } 96,\\ 110,\\ 102$", "note": "Gaps from 100: 4, 10, 2" }, { "math": "$1020 \\text{ mm} = 102 \\text{ cm} \\to 2 \\text{ cm}$", "note": "Closest is $1020$ mm" } ] }
    ],
    "mastery": [
      { "q": "A high jumper clears $1.55$ m. The record is $158$ cm. By how many cm did they miss it?", "a": "$3$ cm",
        "solution": [ { "math": "$1.55 \\text{ m} = 155 \\text{ cm}$", "note": "Same unit" }, { "math": "$158 - 155 = 3 \\text{ cm}$", "note": "" } ] },
      { "q": "Three planks measure $1.2$ m, $125$ cm and $1180$ mm. List them shortest to longest.", "a": "$1180$ mm, $1.2$ m, $125$ cm",
        "solution": [ { "math": "$\\text{in mm: } 1200,\\ 1250,\\ 1180$", "note": "Common unit" }, { "math": "$1180 < 1200 < 1250$", "note": "" } ] },
      { "q": "Two routes are $0.85$ km and $870$ m. Which is shorter and by how many metres?", "a": "$0.85$ km, by $20$ m",
        "solution": [ { "math": "$0.85 \\text{ km} = 850 \\text{ m}$", "note": "Same unit" }, { "math": "$870 - 850 = 20 \\text{ m}$", "note": "" } ] },
      { "q": "A shelf is $90$ cm wide. A book is $0.32$ m thick. How many such books fit side by side?", "a": "$2$ books",
        "solution": [ { "math": "$0.32 \\text{ m} = 32 \\text{ cm}$", "note": "Same unit" }, { "math": "$90 \\div 32 \\approx 2.8 \\to 2$", "note": "Whole books" } ] },
      { "q": "Which is taller: a $1.8$ m adult or a stack of $19$ blocks each $9$ cm tall?", "a": "The stack ($171$ cm vs $180$ cm) — the adult",
        "solution": [ { "math": "$19 \\times 9 = 171 \\text{ cm}$", "note": "Stack height" }, { "math": "$180 > 171$", "note": "Adult is taller" } ] },
      { "q": "A rope is $2.5$ m. Pieces of $80$ cm are cut off. How many full pieces, and what is left?", "a": "$3$ pieces, $10$ cm left",
        "solution": [ { "math": "$2.5 \\text{ m} = 250 \\text{ cm}$", "note": "Same unit" }, { "math": "$250 \\div 80 = 3 \\text{ r } 10$", "note": "$3$ pieces, $10$ cm" } ] },
      { "q": "Order from longest to shortest: $1.05$ m, $1$ m $50$ mm, $1080$ mm.", "a": "$1080$ mm, then $1.05$ m $=$ $1$ m $50$ mm",
        "solution": [ { "math": "$\\text{in mm: } 1050,\\ 1050,\\ 1080$", "note": "Common unit" }, { "math": "$1080 > 1050 = 1050$", "note": "First two equal" } ] },
      { "q": "A worm is $48$ mm and a pencil is $0.15$ m. How much longer is the pencil in mm?", "a": "$102$ mm",
        "solution": [ { "math": "$0.15 \\text{ m} = 150 \\text{ mm}$", "note": "Same unit" }, { "math": "$150 - 48 = 102 \\text{ mm}$", "note": "" } ] },
      { "q": "Which is the greatest distance: $1.5$ km, $1450$ m, or $1$ km $480$ m?", "a": "$1.5$ km",
        "solution": [ { "math": "$\\text{in m: } 1500,\\ 1450,\\ 1480$", "note": "Common unit" }, { "math": "$1500 \\text{ is largest}$", "note": "" } ] },
      { "q": "A fence needs $12$ m. Panels come in $0.8$ m widths. Will $14$ panels be enough?", "a": "No — $11.2$ m only",
        "solution": [ { "math": "$14 \\times 0.8 = 11.2 \\text{ m}$", "note": "Total length" }, { "math": "$11.2 < 12$", "note": "Not enough" } ] }
    ]
  }
}
