{
  "skillId": "area-units-hectare-km2",
  "atomType": "R",
  "theory": {
    "intro": "Large areas of land are measured in hectares (ha) and square kilometres (km$^2$) rather than square metres.",
    "facts": [
      "$1\\text{ ha} = 10\\,000\\text{ m}^2$ (a square $100$ m by $100$ m).",
      "$1\\text{ km}^2 = 1\\,000\\,000\\text{ m}^2 = 100\\text{ ha}$.",
      "Use **ha** for paddocks, parks and sports grounds; use **km$^2$** for suburbs, forests and countries."
    ],
    "steps": [
      "Decide whether the area is land-sized (ha) or region-sized (km$^2$).",
      "To convert m$^2$ to ha, divide by $10\\,000$.",
      "To convert ha to km$^2$, divide by $100$ (or m$^2$ to km$^2$ divide by $1\\,000\\,000$)."
    ]
  },
  "practice": {
    "foundation": [
      { "q": "How many square metres are in $1$ hectare?", "a": "$10\\,000\\text{ m}^2$",
        "solution": [ { "math": "$1\\text{ ha} = 100 \\times 100\\text{ m}^2$", "note": "A 100 m square" }, { "math": "$= 10\\,000\\text{ m}^2$", "note": "" } ] },
      { "q": "How many square metres are in $1$ square kilometre?", "a": "$1\\,000\\,000\\text{ m}^2$",
        "solution": [ { "math": "$1\\text{ km}^2 = 1000 \\times 1000\\text{ m}^2$", "note": "A 1000 m square" }, { "math": "$= 1\\,000\\,000\\text{ m}^2$", "note": "" } ] },
      { "q": "Convert $30\\,000\\text{ m}^2$ to hectares.", "a": "$3$ ha",
        "solution": [ { "math": "$30\\,000 \\div 10\\,000$", "note": "÷ 10 000" }, { "math": "$= 3\\text{ ha}$", "note": "" } ] },
      { "q": "Convert $5$ ha to square metres.", "a": "$50\\,000\\text{ m}^2$",
        "solution": [ { "math": "$5 \\times 10\\,000$", "note": "× 10 000" }, { "math": "$= 50\\,000\\text{ m}^2$", "note": "" } ] },
      { "q": "Which unit suits the area of a school's sports oval: ha or km$^2$?", "a": "ha",
        "solution": [ { "math": "$\\text{land-sized}$", "note": "Not a whole region" }, { "math": "$= \\text{ha}$", "note": "" } ] },
      { "q": "Which unit suits the area of a national park: ha or km$^2$?", "a": "km$^2$",
        "solution": [ { "math": "$\\text{region-sized}$", "note": "Very large" }, { "math": "$= \\text{km}^2$", "note": "" } ] },
      { "q": "How many hectares are in $1$ square kilometre?", "a": "$100$ ha",
        "solution": [ { "math": "$1\\,000\\,000 \\div 10\\,000$", "note": "m² in km² ÷ m² in ha" }, { "math": "$= 100\\text{ ha}$", "note": "" } ] },
      { "q": "A paddock measures $100$ m by $100$ m. What is its area in hectares?", "a": "$1$ ha",
        "solution": [ { "math": "$100 \\times 100 = 10\\,000\\text{ m}^2$", "note": "" }, { "math": "$= 1\\text{ ha}$", "note": "" } ] },
      { "q": "Convert $2$ ha to square metres.", "a": "$20\\,000\\text{ m}^2$",
        "solution": [ { "math": "$2 \\times 10\\,000$", "note": "× 10 000" }, { "math": "$= 20\\,000\\text{ m}^2$", "note": "" } ] },
      { "q": "Convert $70\\,000\\text{ m}^2$ to hectares.", "a": "$7$ ha",
        "solution": [ { "math": "$70\\,000 \\div 10\\,000$", "note": "÷ 10 000" }, { "math": "$= 7\\text{ ha}$", "note": "" } ] }
    ],
    "development": [
      { "q": "A farm covers $4$ km$^2$. How many hectares is this?", "a": "$400$ ha",
        "solution": [ { "math": "$4 \\times 100$", "note": "1 km² = 100 ha" }, { "math": "$= 400\\text{ ha}$", "note": "" } ] },
      { "q": "Convert $250$ ha to square kilometres.", "a": "$2.5$ km$^2$",
        "solution": [ { "math": "$250 \\div 100$", "note": "100 ha = 1 km²" }, { "math": "$= 2.5\\text{ km}^2$", "note": "" } ] },
      { "q": "A rectangular field is $200$ m by $150$ m. Find its area in hectares.", "a": "$3$ ha",
        "solution": [ { "math": "$200 \\times 150 = 30\\,000\\text{ m}^2$", "note": "Area in m²" }, { "math": "$30\\,000 \\div 10\\,000 = 3\\text{ ha}$", "note": "" } ] },
      { "q": "Convert $2\\,500\\,000\\text{ m}^2$ to square kilometres.", "a": "$2.5$ km$^2$",
        "solution": [ { "math": "$2\\,500\\,000 \\div 1\\,000\\,000$", "note": "÷ 1 000 000" }, { "math": "$= 2.5\\text{ km}^2$", "note": "" } ] },
      { "q": "This square of land is $100$ m on each side. State its area in m$^2$ and ha.", "a": "$10\\,000\\text{ m}^2 = 1$ ha",
        "tikz": "\\begin{tikzpicture}[x=1cm,y=1cm]\n\\draw[thick] (0,0) rectangle (2.4,2.4);\n\\draw (0,0) rectangle (0.22,0.22);\n\\node[below] at (1.2,0) {$100$ m};\n\\node[left] at (0,1.2) {$100$ m};\n\\end{tikzpicture}",
        "solution": [ { "math": "$100 \\times 100 = 10\\,000\\text{ m}^2$", "note": "" }, { "math": "$= 1\\text{ ha}$", "note": "" } ] },
      { "q": "Convert $0.5$ km$^2$ to hectares.", "a": "$50$ ha",
        "solution": [ { "math": "$0.5 \\times 100$", "note": "1 km² = 100 ha" }, { "math": "$= 50\\text{ ha}$", "note": "" } ] },
      { "q": "A reserve is $12$ ha. Convert this to square metres.", "a": "$120\\,000\\text{ m}^2$",
        "solution": [ { "math": "$12 \\times 10\\,000$", "note": "× 10 000" }, { "math": "$= 120\\,000\\text{ m}^2$", "note": "" } ] },
      { "q": "Which is larger: $1$ km$^2$ or $90$ ha?", "a": "$1$ km$^2$",
        "solution": [ { "math": "$1\\text{ km}^2 = 100\\text{ ha}$", "note": "" }, { "math": "$100 > 90$", "note": "So km² is larger" } ] },
      { "q": "Convert $850\\,000\\text{ m}^2$ to hectares.", "a": "$85$ ha",
        "solution": [ { "math": "$850\\,000 \\div 10\\,000$", "note": "÷ 10 000" }, { "math": "$= 85\\text{ ha}$", "note": "" } ] },
      { "q": "A car park is $80$ m by $50$ m. Is this more or less than $1$ ha?", "a": "Less than $1$ ha",
        "solution": [ { "math": "$80 \\times 50 = 4\\,000\\text{ m}^2$", "note": "Area" }, { "math": "$4\\,000 < 10\\,000$", "note": "Less than 1 ha" } ] }
    ],
    "mastery": [
      { "q": "A property is $1.8$ km$^2$. Express this in hectares and in square metres.", "a": "$180$ ha $= 1\\,800\\,000\\text{ m}^2$",
        "solution": [ { "math": "$1.8 \\times 100 = 180\\text{ ha}$", "note": "km² to ha" }, { "math": "$1.8 \\times 1\\,000\\,000 = 1\\,800\\,000\\text{ m}^2$", "note": "" } ] },
      { "q": "Three paddocks of $4$ ha, $6$ ha and $10$ ha are joined. Express the total in km$^2$.", "a": "$0.2$ km$^2$",
        "solution": [ { "math": "$4 + 6 + 10 = 20\\text{ ha}$", "note": "Total ha" }, { "math": "$20 \\div 100 = 0.2\\text{ km}^2$", "note": "" } ] },
      { "q": "A national park is $250$ km$^2$. A new section of $30$ km$^2$ is added. How many hectares is the park now?", "a": "$28\\,000$ ha",
        "solution": [ { "math": "$250 + 30 = 280\\text{ km}^2$", "note": "Total" }, { "math": "$280 \\times 100 = 28\\,000\\text{ ha}$", "note": "" } ] },
      { "q": "A square solar farm has area $1$ km$^2$. How long is each side in metres?", "a": "$1000$ m",
        "solution": [ { "math": "$\\text{side}^2 = 1\\,000\\,000\\text{ m}^2$", "note": "" }, { "math": "$\\text{side} = 1000\\text{ m}$", "note": "$\\sqrt{1\\,000\\,000}$" } ] },
      { "q": "Which unit (m$^2$, ha or km$^2$) best fits each: a classroom floor, a wheat farm, a city's land area?", "a": "Classroom m$^2$; farm ha; city km$^2$",
        "solution": [ { "math": "$\\text{small} \\to \\text{m}^2$", "note": "Classroom" }, { "math": "$\\text{farm} \\to \\text{ha},\\ \\text{city} \\to \\text{km}^2$", "note": "" } ] },
      { "q": "A field of $35\\,000\\text{ m}^2$ is divided into $7$ equal plots. Find each plot's area in hectares.", "a": "$0.5$ ha",
        "solution": [ { "math": "$35\\,000 \\div 7 = 5\\,000\\text{ m}^2$", "note": "One plot" }, { "math": "$5\\,000 \\div 10\\,000 = 0.5\\text{ ha}$", "note": "" } ] },
      { "q": "A farmer owns $3.2$ km$^2$ and sells $80$ ha. How much land remains, in hectares?", "a": "$240$ ha",
        "solution": [ { "math": "$3.2 \\times 100 = 320\\text{ ha}$", "note": "Total" }, { "math": "$320 - 80 = 240\\text{ ha}$", "note": "" } ] },
      { "q": "A rectangular reserve is $2$ km long and $500$ m wide. Find its area in km$^2$.", "a": "$1$ km$^2$",
        "solution": [ { "math": "$500\\text{ m} = 0.5\\text{ km}$", "note": "Convert width" }, { "math": "$2 \\times 0.5 = 1\\text{ km}^2$", "note": "" } ] },
      { "q": "Order from smallest to largest: $5\\,000\\text{ m}^2$, $0.6$ ha, $0.0009$ km$^2$.", "a": "$0.0009$ km$^2$, $5\\,000\\text{ m}^2$, $0.6$ ha",
        "solution": [ { "math": "$0.6\\text{ ha} = 6\\,000\\text{ m}^2$", "note": "Convert all to m²" }, { "math": "$0.0009\\text{ km}^2 = 900\\text{ m}^2$", "note": "So $900 < 5\\,000 < 6\\,000$" } ] },
      { "q": "A wind farm covers $4.5$ km$^2$. Each turbine needs $0.5$ ha of clear land. How many turbines fit (assuming all land is used)?", "a": "$900$ turbines",
        "solution": [ { "math": "$4.5\\text{ km}^2 = 450\\text{ ha}$", "note": "× 100" }, { "math": "$450 \\div 0.5 = 900$", "note": "" } ] }
    ]
  }
}
