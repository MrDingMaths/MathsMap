{
  "skillId": "add-subtract-related-denominators",
  "atomType": "R",
  "theory": {
    "intro": "When one denominator divides into the other (like $4$ and $8$, or $3$ and $6$), rename the fractions so they share the **same** denominator, then add or subtract the numerators.",
    "facts": [
      "Related denominators: one is a multiple of the other, e.g. $\\tfrac{1}{4} = \\tfrac{2}{8}$ because $4 \\times 2 = 8$.",
      "Rename the fraction with the **smaller** denominator to match the larger one.",
      "Once denominators match, **add or subtract the numerators** and keep the denominator the same."
    ],
    "steps": [
      "Find the larger denominator — it becomes the common denominator.",
      "Rename the other fraction as an equivalent fraction over that denominator.",
      "Add or subtract the numerators; simplify if you can."
    ]
  },
  "practice": {
    "foundation": [
      { "q": "Use the bar to add: $\\tfrac{1}{4} + \\tfrac{1}{8}$.", "a": "$\\tfrac{3}{8}$",
        "tikz": "\\begin{tikzpicture}[x=0.7cm,y=0.7cm]\n\\draw (0,0) rectangle (8,1);\n\\foreach \\i in {1,...,7} \\draw (\\i,0) -- (\\i,1);\n\\fill[gray!40] (0,0) rectangle (2,1);\n\\fill[gray!70] (2,0) rectangle (3,1);\n\\node[below=4pt] at (4,0) {eighths};\n\\end{tikzpicture}",
        "solution": [ { "math": "$\\tfrac{1}{4} = \\tfrac{2}{8}$", "note": "Rename" }, { "math": "$\\tfrac{2}{8} + \\tfrac{1}{8} = \\tfrac{3}{8}$", "note": "Add numerators" } ] },
      { "q": "Use the bar to subtract: $\\tfrac{1}{2} - \\tfrac{1}{4}$.", "a": "$\\tfrac{1}{4}$",
        "tikz": "\\begin{tikzpicture}[x=1.4cm,y=0.7cm]\n\\draw (0,0) rectangle (4,1);\n\\foreach \\i in {1,2,3} \\draw (\\i,0) -- (\\i,1);\n\\fill[gray!40] (0,0) rectangle (2,1);\n\\node[below=4pt] at (2,0) {quarters};\n\\end{tikzpicture}",
        "solution": [ { "math": "$\\tfrac{1}{2} = \\tfrac{2}{4}$", "note": "Rename" }, { "math": "$\\tfrac{2}{4} - \\tfrac{1}{4} = \\tfrac{1}{4}$", "note": "Subtract" } ] },
      { "q": "Use the bar to add: $\\tfrac{1}{3} + \\tfrac{1}{6}$.", "a": "$\\tfrac{1}{2}$",
