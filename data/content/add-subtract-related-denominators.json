        "solution": [ { "math": "$\\tfrac{1}{3} = \\tfrac{2}{6}$", "note": "Rename" }, { "math": "$\\tfrac{2}{6} + \\tfrac{1}{6} = \\tfrac{3}{6} = \\tfrac{1}{2}$", "note": "Add, simplify" } ] },
