      { "q": "Name this quadrilateral.", "a": "Parallelogram",
        "tikz": "\\begin{tikzpicture}[x=1cm,y=1cm]\n\\draw[thick] (0,0)--(3,0)--(3.8,1.4)--(0.8,1.4)--cycle;\n\\draw[-{Stealth[length=2mm]}] (1.4,0)--(1.6,0);\n\\draw[-{Stealth[length=2mm]}] (2.2,1.4)--(2.4,1.4);\n\\node[below] at (1.5,0) {$6$ cm};\n\\node[right] at (3.4,0.7) {$3$ cm};\n\\end{tikzpicture}",
        "solution": [ { "math": "$\\text{2 pairs parallel, sides unequal}$", "note": "" }, { "math": "$= \\text{parallelogram}$", "note": "" } ] },
      { "q": "A rhombus has all sides $7$ cm. Find its perimeter.", "a": "$28$ cm",
        "solution": [ { "math": "$4 \\times 7$", "note": "4 equal sides" }, { "math": "$= 28 \\text{ cm}$", "note": "" } ] },
      { "q": "Name this quadrilateral.", "a": "Square",
        "tikz": "\\begin{tikzpicture}[x=1cm,y=1cm]\n\\draw[thick] (0,0) rectangle (2.4,2.4);\n\\draw (0,0) rectangle (0.25,0.25);\n\\foreach \\p in {(1.2,0),(1.2,2.4)} \\draw \\p ++(0,0.08)--++(0,-0.16);\n\\foreach \\p in {(0,1.2),(2.4,1.2)} \\draw \\p ++(0.08,0)--++(-0.16,0);\n\\node[below] at (1.2,0) {$5$ cm};\n\\end{tikzpicture}",
        "solution": [ { "math": "$\\text{4 equal sides, right angles}$", "note": "" }, { "math": "$= \\text{square}$", "note": "" } ] },
      { "q": "A rectangle is $9$ cm long and $4$ cm wide. Find its perimeter.", "a": "$26$ cm",
        "solution": [ { "math": "$2(9 + 4)$", "note": "Opposite sides equal" }, { "math": "$= 26 \\text{ cm}$", "note": "" } ] },
      { "q": "True or false: every rectangle is a square.", "a": "False",
        "solution": [ { "math": "$\\text{rectangle: opposite sides equal}$", "note": "Not all 4 equal" }, { "math": "$\\Rightarrow \\text{not always a square}$", "note": "" } ] },
      { "q": "A parallelogram has sides $5$ cm and $8$ cm. Find its perimeter.", "a": "$26$ cm",
        "solution": [ { "math": "$2(5 + 8)$", "note": "Opposite sides equal" }, { "math": "$= 26 \\text{ cm}$", "note": "" } ] }
    ],
    "mastery": [
      { "q": "A quadrilateral is a parallelogram with all sides equal but no right angles. Give its most specific name.", "a": "Rhombus",
        "solution": [ { "math": "$\\text{4 equal sides, slanted}$", "note": "" }, { "math": "$= \\text{rhombus}$", "note": "Most specific" } ] },
      { "q": "A square has perimeter $36$ cm. Find one side.", "a": "$9$ cm",
        "solution": [ { "math": "$36 \\div 4$", "note": "4 equal sides" }, { "math": "$= 9 \\text{ cm}$", "note": "" } ] },
      { "q": "I am a quadrilateral with opposite sides parallel, $4$ right angles, and all sides equal. Name me.", "a": "Square",
        "solution": [ { "math": "$\\text{right angles + equal sides}$", "note": "" }, { "math": "$= \\text{square}$", "note": "" } ] },
      { "q": "A rhombus has perimeter $52$ cm. Find one side.", "a": "$13$ cm",
        "solution": [ { "math": "$52 \\div 4$", "note": "4 equal sides" }, { "math": "$= 13 \\text{ cm}$", "note": "" } ] },
      { "q": "Explain why a square fits the definition of a rhombus.", "a": "A square has $4$ equal sides, which is the defining property of a rhombus",
        "solution": [ { "math": "$\\text{rhombus: 4 equal sides}$", "note": "" }, { "math": "$\\text{square has this too}$", "note": "So square is a rhombus" } ] },
      { "q": "A parallelogram has one side $7$ cm and perimeter $30$ cm. Find the other side.", "a": "$8$ cm",
        "solution": [ { "math": "$30 \\div 2 = 15$", "note": "Half the perimeter = sum of two adjacent sides" }, { "math": "$15 - 7 = 8 \\text{ cm}$", "note": "" } ] },
      { "q": "Sort these by most specific name: A has $4$ equal sides + right angles; B has opposite sides equal + right angles only; C has $4$ equal sides, no right angles.", "a": "A square, B rectangle, C rhombus",
        "solution": [ { "math": "$A: \\text{square}$", "note": "Equal sides + right angles" }, { "math": "$B: \\text{rectangle},\\ C: \\text{rhombus}$", "note": "" } ] },
      { "q": "Name this quadrilateral and give its perimeter.", "a": "Rhombus; $24$ cm",
        "tikz": "\\begin{tikzpicture}[x=1cm,y=1cm]\n\\draw[thick] (0,0)--(1.5,0.9)--(0,1.8)--(-1.5,0.9)--cycle;\n\\foreach \\p in {(0.75,0.45),(-0.75,0.45),(0.75,1.35),(-0.75,1.35)} \\draw \\p ++(0.06,0.05)--++(-0.12,-0.1);\n\\node[right] at (0.85,0.45) {$6$ cm};\n\\end{tikzpicture}",
        "solution": [ { "math": "$\\text{4 equal sides} = \\text{rhombus}$", "note": "" }, { "math": "$4 \\times 6 = 24 \\text{ cm}$", "note": "Perimeter" } ] },
      { "q": "A rectangle and a square have the same perimeter of $40$ cm. The rectangle is $14$ cm long. Find the square's side and the rectangle's width.", "a": "Square side $10$ cm; rectangle width $6$ cm",
        "solution": [ { "math": "$\\text{square: } 40 \\div 4 = 10$", "note": "" }, { "math": "$\\text{rect: } 20 - 14 = 6 \\text{ cm}$", "note": "Half perimeter minus length" } ] },
      { "q": "Is the statement 'all parallelograms are rectangles' true or false? Explain.", "a": "False — parallelograms need not have right angles",
        "solution": [ { "math": "$\\text{rectangle needs 4 right angles}$", "note": "" }, { "math": "$\\text{parallelogram may be slanted}$", "note": "So false" } ] }
    ]
  }
}
