{
  "skillId": "classify-quadrilaterals",
  "atomType": "R",
  "theory": {
    "intro": "A quadrilateral is a four-sided shape. It is named by its sides and angles: equal sides (tick marks), right angles (small square) and parallel sides (arrows).",
    "facts": [
      "**Square**: $4$ equal sides and $4$ right angles.",
      "**Rectangle**: opposite sides equal and $4$ right angles.",
      "**Rhombus**: $4$ equal sides, opposite sides parallel (no right angles needed).",
      "**Parallelogram**: opposite sides parallel and equal."
    ],
    "steps": [
      "Check for right angles (small square marks).",
      "Check which sides are equal (tick marks) and which are parallel (arrows).",
      "Match the properties to the most specific name."
    ]
  },
  "practice": {
    "foundation": [
      { "q": "Name this quadrilateral.", "a": "Square",
        "tikz": "\\begin{tikzpicture}[x=1cm,y=1cm]\n\\draw[thick] (0,0) rectangle (2.2,2.2);\n\\draw (0,0) rectangle (0.25,0.25);\n\\foreach \\p in {(1.1,0),(1.1,2.2)} \\draw \\p ++(0,0.08)--++(0,-0.16);\n\\foreach \\p in {(0,1.1),(2.2,1.1)} \\draw \\p ++(0.08,0)--++(-0.16,0);\n\\end{tikzpicture}",
        "solution": [ { "math": "$\\text{4 equal sides, 4 right angles}$", "note": "" }, { "math": "$= \\text{square}$", "note": "" } ] },
      { "q": "Name this quadrilateral.", "a": "Rectangle",
        "tikz": "\\begin{tikzpicture}[x=1cm,y=1cm]\n\\draw[thick] (0,0) rectangle (3.2,1.8);\n\\draw (0,0) rectangle (0.25,0.25);\n\\draw (2.95,0) rectangle (3.2,0.25);\n\\end{tikzpicture}",
        "solution": [ { "math": "$\\text{opposite sides equal, 4 right angles}$", "note": "" }, { "math": "$= \\text{rectangle}$", "note": "" } ] },
      { "q": "Name this quadrilateral.", "a": "Parallelogram",
        "tikz": "\\begin{tikzpicture}[x=1cm,y=1cm]\n\\draw[thick] (0,0)--(2.4,0)--(3.2,1.5)--(0.8,1.5)--cycle;\n\\draw[-{Stealth[length=2mm]}] (1.1,0)--(1.3,0);\n\\draw[-{Stealth[length=2mm]}] (1.9,1.5)--(2.1,1.5);\n\\end{tikzpicture}",
        "solution": [ { "math": "$\\text{opposite sides parallel, no right angles}$", "note": "" }, { "math": "$= \\text{parallelogram}$", "note": "" } ] },
      { "q": "Name this quadrilateral.", "a": "Rhombus",
        "tikz": "\\begin{tikzpicture}[x=1cm,y=1cm]\n\\draw[thick] (0,0)--(1.5,0.9)--(0,1.8)--(-1.5,0.9)--cycle;\n\\foreach \\p in {(0.75,0.45),(-0.75,0.45),(0.75,1.35),(-0.75,1.35)} \\draw \\p ++(0.06,0.05)--++(-0.12,-0.1);\n\\end{tikzpicture}",
        "solution": [ { "math": "$\\text{4 equal sides, no right angles}$", "note": "" }, { "math": "$= \\text{rhombus}$", "note": "" } ] },
      { "q": "A quadrilateral has $4$ equal sides and $4$ right angles. Name it.", "a": "Square",
        "solution": [ { "math": "$\\text{4 equal sides + right angles}$", "note": "" }, { "math": "$= \\text{square}$", "note": "" } ] },
      { "q": "A quadrilateral has opposite sides equal and $4$ right angles, but not all sides equal. Name it.", "a": "Rectangle",
        "solution": [ { "math": "$\\text{right angles, not all sides equal}$", "note": "" }, { "math": "$= \\text{rectangle}$", "note": "" } ] },
      { "q": "Name this quadrilateral.", "a": "Square",
        "tikz": "\\begin{tikzpicture}[x=1cm,y=1cm]\n\\draw[thick] (0,0) rectangle (2,2);\n\\draw (0,0) rectangle (0.25,0.25);\n\\foreach \\p in {(1,0),(1,2)} \\draw \\p ++(0,0.08)--++(0,-0.16);\n\\foreach \\p in {(0,1),(2,1)} \\draw \\p ++(0.08,0)--++(-0.16,0);\n\\end{tikzpicture}",
        "solution": [ { "math": "$\\text{4 equal sides, 4 right angles}$", "note": "" }, { "math": "$= \\text{square}$", "note": "" } ] },
