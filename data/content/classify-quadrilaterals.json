        "solution": [ { "math": "$\\text{opposite sides parallel}$", "note": "" }, { "math": "$= \\text{parallelogram}$", "note": "" } ] },
      { "q": "A quadrilateral has $4$ equal sides but its angles are not right angles. Name it.", "a": "Rhombus",
