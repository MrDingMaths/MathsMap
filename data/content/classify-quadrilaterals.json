      { "q": "Name this quadrilateral.", "a": "Rhombus",
        "tikz": "\\begin{tikzpicture}[x=1cm,y=1cm]\n\\draw[thick] (0,0)--(2,0)--(2.7,1.4)--(0.7,1.4)--cycle;\n\\foreach \\p in {(1,0),(1.7,1.4)} \\draw \\p ++(0,0.07)--++(0,-0.14);\n\\draw (0.35,0.7) ++(0.07,0.04)--++(-0.14,-0.08);\n\\draw (2.35,0.7) ++(0.07,0.04)--++(-0.14,-0.08);\n\\node[below] at (1,0) {$4$ cm};\n\\node[right] at (2.35,0.7) {$4$ cm};\n\\end{tikzpicture}",
        "solution": [ { "math": "$\\text{4 equal sides, slanted}$", "note": "No right angles" }, { "math": "$= \\text{rhombus}$", "note": "" } ] },
      { "q": "Which is the most specific name for a shape with $4$ equal sides and $4$ right angles: rectangle, rhombus or square?", "a": "Square",
        "solution": [ { "math": "$\\text{equal sides + right angles}$", "note": "Both properties" }, { "math": "$= \\text{square}$", "note": "Most specific" } ] },
      { "q": "True or false: every square is also a rectangle.", "a": "True",
