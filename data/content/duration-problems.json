{
  "skillId": "duration-problems",
  "atomType": "R",
  "theory": {
    "intro": "Duration problems ask you to find a start time, finish time, or how long something lasts. Work in both $12$-hour (am/pm) and $24$-hour notation.",
    "facts": [
      "To convert pm times to $24$-hour, add $12$ to the hour: $3{:}30$ pm $= 15{:}30$. Midnight is $00{:}00$, noon is $12{:}00$.",
      "**Finish $=$ start $+$ duration**, and **duration $=$ finish $-$ start**.",
      "When minutes pass $60$, carry $1$ hour; when hours pass $24$, the time crosses midnight into the next day."
    ],
    "steps": [
      "Decide whether you need the start, finish, or duration.",
      "Add or subtract hours first, then minutes, carrying at $60$ minutes.",
      "Write the answer in the notation asked for."
    ]
  },
  "practice": {
    "foundation": [
      { "q": "A film starts at $2{:}00$ pm and lasts $2$ h. When does it finish?", "a": "$4{:}00$ pm",
        "solution": [ { "math": "$2{:}00 + 2 \\text{ h}$", "note": "Add hours" }, { "math": "$= 4{:}00 \\text{ pm}$", "note": "" } ] },
      { "q": "Write $3{:}30$ pm in $24$-hour time.", "a": "$15{:}30$",
        "solution": [ { "math": "$3 + 12 = 15$", "note": "pm $\\Rightarrow$ add $12$" }, { "math": "$= 15{:}30$", "note": "" } ] },
      { "q": "A class lasts $45$ min and starts at $9{:}00$ am. When does it end?", "a": "$9{:}45$ am",
        "solution": [ { "math": "$9{:}00 + 45 \\text{ min}$", "note": "Add minutes" }, { "math": "$= 9{:}45 \\text{ am}$", "note": "" } ] },
      { "q": "Write $08{:}15$ in $12$-hour time.", "a": "$8{:}15$ am",
        "solution": [ { "math": "$08{:}15 < 12{:}00$", "note": "Morning" }, { "math": "$= 8{:}15 \\text{ am}$", "note": "" } ] },
      { "q": "A train departs $10{:}00$ and the trip is $3$ h. When does it arrive?", "a": "$13{:}00$",
        "solution": [ { "math": "$10{:}00 + 3 \\text{ h}$", "note": "Add hours" }, { "math": "$= 13{:}00$", "note": "" } ] },
      { "q": "Write $7{:}45$ pm in $24$-hour time.", "a": "$19{:}45$",
        "solution": [ { "math": "$7 + 12 = 19$", "note": "pm $\\Rightarrow$ add $12$" }, { "math": "$= 19{:}45$", "note": "" } ] },
      { "q": "A movie of $1$ h $30$ min starts at $6{:}00$ pm. When does it finish?", "a": "$7{:}30$ pm",
        "solution": [ { "math": "$6{:}00 + 1{:}30$", "note": "Add duration" }, { "math": "$= 7{:}30 \\text{ pm}$", "note": "" } ] },
      { "q": "Write $12{:}00$ (noon) in $12$-hour time.", "a": "$12{:}00$ pm",
        "solution": [ { "math": "$12{:}00 = \\text{noon}$", "note": "Midday" }, { "math": "$= 12{:}00 \\text{ pm}$", "note": "" } ] },
      { "q": "A flight leaves $14{:}00$ and lasts $2$ h. When does it land?", "a": "$16{:}00$",
        "solution": [ { "math": "$14{:}00 + 2 \\text{ h}$", "note": "Add hours" }, { "math": "$= 16{:}00$", "note": "" } ] },
      { "q": "A bus ride starts $9{:}20$ am and lasts $40$ min. When does it end?", "a": "$10{:}00$ am",
        "solution": [ { "math": "$9{:}20 + 40 \\text{ min}$", "note": "$20 + 40 = 60$" }, { "math": "$= 10{:}00 \\text{ am}$", "note": "Carry $1$ h" } ] }
    ],
    "development": [
      { "q": "A train leaves $11{:}50$ and the trip is $1$ h $25$ min. When does it arrive (24-hour)?", "a": "$13{:}15$",
        "solution": [ { "math": "$11{:}50 + 1 \\text{ h} = 12{:}50$", "note": "Add hour" }, { "math": "$12{:}50 + 25 \\text{ min} = 13{:}15$", "note": "Carry at $60$" } ] },
      { "q": "A movie of $2$ h $20$ min starts $7{:}55$ pm. When does it finish?", "a": "$10{:}15$ pm",
        "solution": [ { "math": "$7{:}55 + 2 \\text{ h} = 9{:}55$", "note": "Add hours" }, { "math": "$9{:}55 + 20 \\text{ min} = 10{:}15 \\text{ pm}$", "note": "Carry $1$ h" } ] },
      { "q": "A flight lands $16{:}10$ after a $3$ h $40$ min trip. When did it depart?", "a": "$12{:}30$",
        "solution": [ { "math": "$16{:}10 - 3 \\text{ h} = 13{:}10$", "note": "Subtract hours" }, { "math": "$13{:}10 - 40 \\text{ min} = 12{:}30$", "note": "Borrow $1$ h" } ] },
      { "q": "A lesson ends $10{:}05$ am after $50$ min. When did it start?", "a": "$9{:}15$ am",
        "solution": [ { "math": "$10{:}05 - 50 \\text{ min}$", "note": "Borrow $1$ h" }, { "math": "$= 9{:}15 \\text{ am}$", "note": "" } ] },
      { "q": "A train departs $13{:}48$ and the trip is $2$ h $27$ min. When does it arrive?", "a": "$16{:}15$",
        "solution": [ { "math": "$13{:}48 + 2 \\text{ h} = 15{:}48$", "note": "Add hours" }, { "math": "$15{:}48 + 27 \\text{ min} = 16{:}15$", "note": "Carry at $60$" } ] },
      { "q": "Write $11{:}30$ pm in $24$-hour time, then add $1$ h $15$ min.", "a": "$23{:}30 \\to 00{:}45$",
        "solution": [ { "math": "$11{:}30 \\text{ pm} = 23{:}30$", "note": "Add $12$" }, { "math": "$23{:}30 + 1{:}15 = 00{:}45$", "note": "Past midnight" } ] },
      { "q": "A school day starts $8{:}50$ am and is $6$ h $25$ min long. When does it end?", "a": "$3{:}15$ pm",
        "solution": [ { "math": "$8{:}50 + 6 \\text{ h} = 2{:}50 \\text{ pm}$", "note": "Past noon" }, { "math": "$2{:}50 + 25 \\text{ min} = 3{:}15 \\text{ pm}$", "note": "Carry $1$ h" } ] },
      { "q": "A concert ends $22{:}05$ after $2$ h $35$ min. When did it begin?", "a": "$19{:}30$",
        "solution": [ { "math": "$22{:}05 - 2 \\text{ h} = 20{:}05$", "note": "Subtract hours" }, { "math": "$20{:}05 - 35 \\text{ min} = 19{:}30$", "note": "Borrow $1$ h" } ] },
      { "q": "A ferry leaves $9{:}35$ am and arrives $11{:}20$ am. How long is the crossing?", "a": "$1$ h $45$ min",
        "solution": [ { "math": "$9{:}35 \\to 11{:}35 = 2 \\text{ h}$", "note": "Too far by $15$ min" }, { "math": "$11{:}35 - 11{:}20 = 15 \\Rightarrow 1 \\text{ h } 45 \\text{ min}$", "note": "" } ] },
      { "q": "Write $00{:}40$ in $12$-hour time.", "a": "$12{:}40$ am",
        "solution": [ { "math": "$00{:}40$ is after midnight", "note": "Early morning" }, { "math": "$= 12{:}40 \\text{ am}$", "note": "" } ] }
    ],
    "mastery": [
      { "q": "A flight departs $21{:}50$ and lasts $5$ h $35$ min. When does it land (24-hour)?", "a": "$03{:}25$ next day",
        "solution": [ { "math": "$21{:}50 + 5 \\text{ h} = 26{:}50 = 02{:}50$", "note": "Crosses midnight" }, { "math": "$02{:}50 + 35 \\text{ min} = 03{:}25$", "note": "Next day" } ] },
      { "q": "A train arrives $1{:}10$ pm after a $4$ h $50$ min trip. When did it leave (12-hour)?", "a": "$8{:}20$ am",
        "solution": [ { "math": "$1{:}10 \\text{ pm} = 13{:}10$", "note": "$24$-hour" }, { "math": "$13{:}10 - 4{:}50 = 08{:}20 = 8{:}20 \\text{ am}$", "note": "" } ] },
      { "q": "A movie starts $10{:}40$ pm, runs $2$ h $30$ min, then $15$ min of credits. When do the credits end?", "a": "$1{:}25$ am",
        "solution": [ { "math": "$22{:}40 + 2{:}30 = 25{:}10 = 01{:}10$", "note": "Past midnight" }, { "math": "$01{:}10 + 15 \\text{ min} = 01{:}25 = 1{:}25 \\text{ am}$", "note": "" } ] },
      { "q": "A worker starts $7{:}45$ am, works $8$ h $15$ min, with a $45$-min break. When do they leave?", "a": "$4{:}45$ pm",
        "solution": [ { "math": "$7{:}45 + 8{:}15 = 16{:}00$", "note": "Work time" }, { "math": "$16{:}00 + 45 \\text{ min} = 16{:}45 = 4{:}45 \\text{ pm}$", "note": "Add break" } ] },
      { "q": "A bus leaves $14{:}25$, the next is $50$ min later, and that one takes $1$ h $40$ min. When does the second bus arrive?", "a": "$16{:}55$",
        "solution": [ { "math": "$14{:}25 + 50 \\text{ min} = 15{:}15$", "note": "Second departs" }, { "math": "$15{:}15 + 1{:}40 = 16{:}55$", "note": "Arrives" } ] },
      { "q": "An overnight flight leaves $23{:}30$ and lands $06{:}05$. How long is it?", "a": "$6$ h $35$ min",
        "solution": [ { "math": "$23{:}30 \\to 24{:}00 = 30 \\text{ min}$", "note": "To midnight" }, { "math": "$00{:}00 \\to 06{:}05 = 6 \\text{ h } 5 \\text{ min} \\Rightarrow 6 \\text{ h } 35 \\text{ min}$", "note": "" } ] },
      { "q": "A train leaves Brisbane $11{:}48$ am and arrives $4{:}33$ pm. How long is the trip?", "a": "$4$ h $45$ min",
        "solution": [ { "math": "$11{:}48 \\to 4{:}48 \\text{ pm} = 5 \\text{ h}$", "note": "Too far by $15$ min" }, { "math": "$4{:}48 - 4{:}33 = 15 \\Rightarrow 4 \\text{ h } 45 \\text{ min}$", "note": "" } ] },
      { "q": "A show ends $00{:}15$ after running $3$ h $25$ min. When did it start (12-hour)?", "a": "$8{:}50$ pm",
        "solution": [ { "math": "$00{:}15 = 24{:}15$", "note": "Treat as past midnight" }, { "math": "$24{:}15 - 3{:}25 = 20{:}50 = 8{:}50 \\text{ pm}$", "note": "" } ] },
      { "q": "Three legs of a journey take $1$ h $20$ min, $2$ h $50$ min and $45$ min. What is the total duration?", "a": "$4$ h $55$ min",
        "solution": [ { "math": "$1{:}20 + 2{:}50 = 4 \\text{ h } 10 \\text{ min}$", "note": "First two" }, { "math": "$4{:}10 + 45 \\text{ min} = 4 \\text{ h } 55 \\text{ min}$", "note": "Add third" } ] },
      { "q": "A flight is timetabled $13{:}15$ to $18{:}40$ but lands $25$ min late. What is the actual flight time?", "a": "$5$ h $50$ min",
        "solution": [ { "math": "$13{:}15 \\to 18{:}40 = 5 \\text{ h } 25 \\text{ min}$", "note": "Scheduled" }, { "math": "$5{:}25 + 25 \\text{ min} = 5 \\text{ h } 50 \\text{ min}$", "note": "Add delay" } ] }
    ]
  }
}
