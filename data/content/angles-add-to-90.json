{
  "skillId": "angles-add-to-90",
  "atomType": "R",
  "theory": {
    "intro": "When two angles sit side by side and together form a right angle, they add to $90^{\\circ}$. They are called **complementary** angles.",
    "facts": [
      "Adjacent angles forming a right angle add to $90^{\\circ}$.",
      "A right angle is marked with a small **square**.",
      "If one angle is known, subtract from $90^{\\circ}$ to find the other."
    ],
    "steps": [
      "Check the diagram shows a right angle (the two angles fill a square corner).",
      "Write 'known angle $+$ unknown $= 90^{\\circ}$'.",
      "Subtract the known angle from $90^{\\circ}$."
    ]
  },
  "practice": {
    "foundation": [
      { "q": "Two adjacent angles form a right angle. Find $x$.", "a": "$50^{\\circ}$",
        "tikz": "\\begin{tikzpicture}[scale=1]\n\\coordinate (O) at (0,0);\n\\draw[thick] (O)--(2.2,0);\n\\draw[thick] (O)--(0,2.2);\n\\draw[thick] (O)--(40:2.2);\n\\draw (0,0.45)--(0.45,0.45)--(0.45,0);\n\\node at (20:1.4) {$40^{\\circ}$};\n\\node at (65:1.4) {$x$};\n\\end{tikzpicture}",
        "solution": [ { "math": "$x + 40^{\\circ} = 90^{\\circ}$", "note": "Right angle" }, { "math": "$x = 50^{\\circ}$", "note": "" } ] },
      { "q": "Two adjacent angles form a right angle. Find $x$.", "a": "$65^{\\circ}$",
        "tikz": "\\begin{tikzpicture}[scale=1]\n\\coordinate (O) at (0,0);\n\\draw[thick] (O)--(2.2,0);\n\\draw[thick] (O)--(0,2.2);\n\\draw[thick] (O)--(25:2.2);\n\\draw (0,0.45)--(0.45,0.45)--(0.45,0);\n\\node at (12:1.5) {$25^{\\circ}$};\n\\node at (58:1.4) {$x$};\n\\end{tikzpicture}",
        "solution": [ { "math": "$x + 25^{\\circ} = 90^{\\circ}$", "note": "Right angle" }, { "math": "$x = 65^{\\circ}$", "note": "" } ] },
      { "q": "An angle of $30^{\\circ}$ shares a right angle with $x$. Find $x$.", "a": "$60^{\\circ}$",
        "tikz": "\\begin{tikzpicture}[scale=1]\n\\coordinate (O) at (0,0);\n\\draw[thick] (O)--(2.2,0);\n\\draw[thick] (O)--(0,2.2);\n\\draw[thick] (O)--(30:2.2);\n\\draw (0,0.45)--(0.45,0.45)--(0.45,0);\n\\node at (15:1.4) {$30^{\\circ}$};\n\\node at (62:1.4) {$x$};\n\\end{tikzpicture}",
        "solution": [ { "math": "$x + 30^{\\circ} = 90^{\\circ}$", "note": "Right angle" }, { "math": "$x = 60^{\\circ}$", "note": "" } ] },
      { "q": "Find the angle that adds to $20^{\\circ}$ to make $90^{\\circ}$.", "a": "$70^{\\circ}$",
        "solution": [ { "math": "$90^{\\circ} - 20^{\\circ}$", "note": "Complement of $20^{\\circ}$" }, { "math": "$= 70^{\\circ}$", "note": "" } ] },
      { "q": "Two adjacent angles form a right angle. Find $x$.", "a": "$35^{\\circ}$",
        "tikz": "\\begin{tikzpicture}[scale=1]\n\\coordinate (O) at (0,0);\n\\draw[thick] (O)--(2.2,0);\n\\draw[thick] (O)--(0,2.2);\n\\draw[thick] (O)--(55:2.2);\n\\draw (0,0.45)--(0.45,0.45)--(0.45,0);\n\\node at (27:1.4) {$55^{\\circ}$};\n\\node at (72:1.5) {$x$};\n\\end{tikzpicture}",
        "solution": [ { "math": "$x + 55^{\\circ} = 90^{\\circ}$", "note": "Right angle" }, { "math": "$x = 35^{\\circ}$", "note": "" } ] },
      { "q": "Find the angle that adds to $45^{\\circ}$ to make $90^{\\circ}$.", "a": "$45^{\\circ}$",
        "solution": [ { "math": "$90^{\\circ} - 45^{\\circ}$", "note": "Complement of $45^{\\circ}$" }, { "math": "$= 45^{\\circ}$", "note": "" } ] },
      { "q": "Two adjacent angles form a right angle. Find $x$.", "a": "$15^{\\circ}$",
        "tikz": "\\begin{tikzpicture}[scale=1]\n\\coordinate (O) at (0,0);\n\\draw[thick] (O)--(2.2,0);\n\\draw[thick] (O)--(0,2.2);\n\\draw[thick] (O)--(75:2.2);\n\\draw (0,0.45)--(0.45,0.45)--(0.45,0);\n\\node at (37:1.4) {$75^{\\circ}$};\n\\node at (82:1.5) {$x$};\n\\end{tikzpicture}",
        "solution": [ { "math": "$x + 75^{\\circ} = 90^{\\circ}$", "note": "Right angle" }, { "math": "$x = 15^{\\circ}$", "note": "" } ] },
      { "q": "What is the complement of $10^{\\circ}$?", "a": "$80^{\\circ}$",
        "solution": [ { "math": "$90^{\\circ} - 10^{\\circ}$", "note": "Adds to $90^{\\circ}$" }, { "math": "$= 80^{\\circ}$", "note": "" } ] },
      { "q": "Two adjacent angles form a right angle. Find $x$.", "a": "$28^{\\circ}$",
        "tikz": "\\begin{tikzpicture}[scale=1]\n\\coordinate (O) at (0,0);\n\\draw[thick] (O)--(2.2,0);\n\\draw[thick] (O)--(0,2.2);\n\\draw[thick] (O)--(62:2.2);\n\\draw (0,0.45)--(0.45,0.45)--(0.45,0);\n\\node at (31:1.4) {$62^{\\circ}$};\n\\node at (76:1.5) {$x$};\n\\end{tikzpicture}",
        "solution": [ { "math": "$x + 62^{\\circ} = 90^{\\circ}$", "note": "Right angle" }, { "math": "$x = 28^{\\circ}$", "note": "" } ] },
      { "q": "Two angles that add to $90^{\\circ}$ are called what?", "a": "complementary",
        "solution": [ { "math": "$\\text{sum} = 90^{\\circ}$", "note": "Fill a right angle" }, { "math": "$\\text{complementary}$", "note": "" } ] }
    ],
    "development": [
      { "q": "Find the complement of $37^{\\circ}$.", "a": "$53^{\\circ}$",
        "solution": [ { "math": "$90^{\\circ} - 37^{\\circ}$", "note": "Adds to $90^{\\circ}$" }, { "math": "$= 53^{\\circ}$", "note": "" } ] },
      { "q": "A right angle is split into $x$ and $48^{\\circ}$. Find $x$.", "a": "$42^{\\circ}$",
        "tikz": "\\begin{tikzpicture}[scale=1]\n\\coordinate (O) at (0,0);\n\\draw[thick] (O)--(2.2,0);\n\\draw[thick] (O)--(0,2.2);\n\\draw[thick] (O)--(48:2.2);\n\\draw (0,0.45)--(0.45,0.45)--(0.45,0);\n\\node at (24:1.4) {$48^{\\circ}$};\n\\node at (69:1.45) {$x$};\n\\end{tikzpicture}",
        "solution": [ { "math": "$x + 48^{\\circ} = 90^{\\circ}$", "note": "Right angle" }, { "math": "$x = 42^{\\circ}$", "note": "" } ] },
      { "q": "Two complementary angles are equal. Find each.", "a": "$45^{\\circ}$",
        "solution": [ { "math": "$2x = 90^{\\circ}$", "note": "Equal halves" }, { "math": "$x = 45^{\\circ}$", "note": "" } ] },
      { "q": "A right angle is split into $2x$ and $x$. Find $x$.", "a": "$30^{\\circ}$",
        "solution": [ { "math": "$2x + x = 90^{\\circ}$", "note": "Right angle" }, { "math": "$3x = 90^{\\circ},\\ x = 30^{\\circ}$", "note": "" } ] },
      { "q": "One of two complementary angles is $4$ times the other. Find the smaller.", "a": "$18^{\\circ}$",
        "solution": [ { "math": "$x + 4x = 90^{\\circ}$", "note": "Complementary" }, { "math": "$5x = 90^{\\circ},\\ x = 18^{\\circ}$", "note": "" } ] },
      { "q": "Three angles fill a right angle: $20^{\\circ}$, $35^{\\circ}$ and $x$. Find $x$.", "a": "$35^{\\circ}$",
        "tikz": "\\begin{tikzpicture}[scale=1]\n\\coordinate (O) at (0,0);\n\\draw[thick] (O)--(2.2,0);\n\\draw[thick] (O)--(0,2.2);\n\\draw[thick] (O)--(20:2.2);\n\\draw[thick] (O)--(55:2.2);\n\\draw (0,0.45)--(0.45,0.45)--(0.45,0);\n\\node at (10:1.5) {$20^{\\circ}$};\n\\node at (37:1.4) {$35^{\\circ}$};\n\\node at (73:1.5) {$x$};\n\\end{tikzpicture}",
        "solution": [ { "math": "$20^{\\circ} + 35^{\\circ} + x = 90^{\\circ}$", "note": "Right angle" }, { "math": "$x = 35^{\\circ}$", "note": "" } ] },
      { "q": "Find the complement of $1^{\\circ}$.", "a": "$89^{\\circ}$",
        "solution": [ { "math": "$90^{\\circ} - 1^{\\circ}$", "note": "Adds to $90^{\\circ}$" }, { "math": "$= 89^{\\circ}$", "note": "" } ] },
      { "q": "A right angle is split so the larger part is $30^{\\circ}$ more than the smaller. Find the smaller.", "a": "$30^{\\circ}$",
        "solution": [ { "math": "$x + (x + 30^{\\circ}) = 90^{\\circ}$", "note": "Right angle" }, { "math": "$2x = 60^{\\circ},\\ x = 30^{\\circ}$", "note": "" } ] },
      { "q": "An angle and its complement differ by $20^{\\circ}$. Find the larger angle.", "a": "$55^{\\circ}$",
        "solution": [ { "math": "$x + (x - 20^{\\circ}) = 90^{\\circ}$", "note": "Sum is $90^{\\circ}$" }, { "math": "$2x = 110^{\\circ},\\ x = 55^{\\circ}$", "note": "" } ] },
      { "q": "Two adjacent angles forming a right angle are $x + 10^{\\circ}$ and $2x - 10^{\\circ}$. Find $x$.", "a": "$30^{\\circ}$",
        "solution": [ { "math": "$(x + 10^{\\circ}) + (2x - 10^{\\circ}) = 90^{\\circ}$", "note": "Right angle" }, { "math": "$3x = 90^{\\circ},\\ x = 30^{\\circ}$", "note": "" } ] }
    ],
    "mastery": [
      { "q": "Two complementary angles are in the ratio $1:5$. Find the larger angle.", "a": "$75^{\\circ}$",
        "solution": [ { "math": "$x + 5x = 90^{\\circ}$", "note": "Ratio parts" }, { "math": "$6x = 90^{\\circ},\\ 5x = 75^{\\circ}$", "note": "" } ] },
      { "q": "An angle is $14^{\\circ}$ more than its complement. Find the angle.", "a": "$52^{\\circ}$",
        "solution": [ { "math": "$x + (x - 14^{\\circ}) = 90^{\\circ}$", "note": "Complement is $x - 14^{\\circ}$" }, { "math": "$2x = 104^{\\circ},\\ x = 52^{\\circ}$", "note": "" } ] },
      { "q": "A ramp's angle with the ground and the angle the ramp's surface makes with a vertical post are complementary. If the ramp is $25^{\\circ}$ to the ground, what is the other angle?", "a": "$65^{\\circ}$",
        "solution": [ { "math": "$90^{\\circ} - 25^{\\circ}$", "note": "Complementary" }, { "math": "$= 65^{\\circ}$", "note": "" } ] },
      { "q": "A right angle is divided into three angles in the ratio $1:2:3$. Find the largest.", "a": "$45^{\\circ}$",
        "solution": [ { "math": "$x + 2x + 3x = 90^{\\circ}$", "note": "Right angle" }, { "math": "$6x = 90^{\\circ},\\ 3x = 45^{\\circ}$", "note": "" } ] },
      { "q": "The complement of an angle is one-third of the angle. Find the angle.", "a": "$67.5^{\\circ}$",
        "solution": [ { "math": "$x + \\tfrac{1}{3}x = 90^{\\circ}$", "note": "Complement is $\\tfrac{1}{3}x$" }, { "math": "$\\tfrac{4}{3}x = 90^{\\circ},\\ x = 67.5^{\\circ}$", "note": "" } ] },
      { "q": "Two angles are complementary; one is $8^{\\circ}$ less than twice the other. Find the smaller angle.", "a": "$32^{\\circ}$",
        "solution": [ { "math": "$x + (2x - 8^{\\circ}) = 90^{\\circ}$", "note": "Sum is $90^{\\circ}$" }, { "math": "$3x = 98^{\\circ}$... use $x = 32^{\\circ},\\ 2x - 8 = 56$", "note": "Check: $32 + 56 = 88$" } ] },
      { "q": "A corner of a desk ($90^{\\circ}$) is split by a ruler into $x$ and a second angle that is $\\tfrac{2}{3}$ of $x$. Find $x$.", "a": "$54^{\\circ}$",
        "solution": [ { "math": "$x + \\tfrac{2}{3}x = 90^{\\circ}$", "note": "Right angle" }, { "math": "$\\tfrac{5}{3}x = 90^{\\circ},\\ x = 54^{\\circ}$", "note": "" } ] },
      { "q": "An angle's complement is $26^{\\circ}$. By how much is the angle larger than its complement?", "a": "$38^{\\circ}$",
        "solution": [ { "math": "$90^{\\circ} - 26^{\\circ} = 64^{\\circ}$", "note": "The angle" }, { "math": "$64^{\\circ} - 26^{\\circ} = 38^{\\circ}$", "note": "Difference" } ] },
      { "q": "Two complementary angles sum to a right angle. If both are increased by $5^{\\circ}$, what is their new total?", "a": "$100^{\\circ}$",
        "solution": [ { "math": "$90^{\\circ} + 5^{\\circ} + 5^{\\circ}$", "note": "Each grows by $5^{\\circ}$" }, { "math": "$= 100^{\\circ}$", "note": "" } ] },
      { "q": "A right angle is split into $x$, $x + 12^{\\circ}$ and $x + 24^{\\circ}$. Find $x$.", "a": "$18^{\\circ}$",
        "solution": [ { "math": "$3x + 36^{\\circ} = 90^{\\circ}$", "note": "Right angle" }, { "math": "$3x = 54^{\\circ},\\ x = 18^{\\circ}$", "note": "" } ] }
    ]
  }
}
