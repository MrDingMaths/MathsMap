{
  "skillId": "unit-fraction-of-quantity",
  "atomType": "R",
  "theory": {
    "intro": "A unit fraction has a numerator of $1$. Finding a unit fraction of a quantity means sharing the quantity into that many equal parts.",
    "facts": [
      "$\\tfrac{1}{n}$ of a quantity is the quantity **divided by $n$**.",
      "$\\tfrac{1}{2}$ means split into $2$ equal parts, $\\tfrac{1}{4}$ into $4$, and so on.",
      "A bar split into $n$ equal segments shows each segment as $\\tfrac{1}{n}$ of the whole."
    ],
    "steps": [
      "Read the denominator to see how many equal parts to make.",
      "Divide the quantity by that number.",
      "The result is one of the equal parts."
    ]
  },
  "practice": {
    "foundation": [
      { "q": "Find $\\tfrac{1}{2}$ of $10$.", "a": "$5$",
        "tikz": "\\begin{tikzpicture}[x=0.7cm,y=0.7cm]\n\\draw (0,0) rectangle (10,1);\n\\foreach \\i in {1,...,9} \\draw (\\i,0) -- (\\i,1);\n\\fill[gray!40] (0,0) rectangle (5,1);\n\\node[below=4pt] at (5,0) {$10$};\n\\end{tikzpicture}",
        "solution": [ { "math": "$\\tfrac{1}{2} \\text{ of } 10 = 10 \\div 2$", "note": "Split into 2 parts" }, { "math": "$= 5$", "note": "" } ] },
      { "q": "Find $\\tfrac{1}{4}$ of $12$.", "a": "$3$",
        "tikz": "\\begin{tikzpicture}[x=0.7cm,y=0.7cm]\n\\draw (0,0) rectangle (12,1);\n\\foreach \\i in {3,6,9} \\draw (\\i,0) -- (\\i,1);\n\\fill[gray!40] (0,0) rectangle (3,1);\n\\node[below=4pt] at (6,0) {$12$};\n\\end{tikzpicture}",
        "solution": [ { "math": "$\\tfrac{1}{4} \\text{ of } 12 = 12 \\div 4$", "note": "Split into 4 parts" }, { "math": "$= 3$", "note": "" } ] },
      { "q": "Find $\\tfrac{1}{5}$ of $20$.", "a": "$4$",
        "tikz": "\\begin{tikzpicture}[x=0.6cm,y=0.7cm]\n\\draw (0,0) rectangle (20,1);\n\\foreach \\i in {4,8,12,16} \\draw (\\i,0) -- (\\i,1);\n\\fill[gray!40] (0,0) rectangle (4,1);\n\\node[below=4pt] at (10,0) {$20$};\n\\end{tikzpicture}",
        "solution": [ { "math": "$\\tfrac{1}{5} \\text{ of } 20 = 20 \\div 5$", "note": "Split into 5 parts" }, { "math": "$= 4$", "note": "" } ] },
      { "q": "Find $\\tfrac{1}{10}$ of $30$.", "a": "$3$",
        "tikz": "\\begin{tikzpicture}[x=0.5cm,y=0.7cm]\n\\draw (0,0) rectangle (30,1);\n\\foreach \\i in {3,6,...,27} \\draw (\\i,0) -- (\\i,1);\n\\fill[gray!40] (0,0) rectangle (3,1);\n\\node[below=4pt] at (15,0) {$30$};\n\\end{tikzpicture}",
        "solution": [ { "math": "$\\tfrac{1}{10} \\text{ of } 30 = 30 \\div 10$", "note": "Split into 10 parts" }, { "math": "$= 3$", "note": "" } ] },
      { "q": "Find $\\tfrac{1}{2}$ of $16$.", "a": "$8$",
        "solution": [ { "math": "$16 \\div 2$", "note": "Half" }, { "math": "$= 8$", "note": "" } ] },
      { "q": "Find $\\tfrac{1}{4}$ of $20$.", "a": "$5$",
        "solution": [ { "math": "$20 \\div 4$", "note": "Quarter" }, { "math": "$= 5$", "note": "" } ] },
      { "q": "Find $\\tfrac{1}{5}$ of $15$.", "a": "$3$",
        "solution": [ { "math": "$15 \\div 5$", "note": "One fifth" }, { "math": "$= 3$", "note": "" } ] },
      { "q": "Find $\\tfrac{1}{10}$ of $50$.", "a": "$5$",
        "solution": [ { "math": "$50 \\div 10$", "note": "One tenth" }, { "math": "$= 5$", "note": "" } ] },
      { "q": "Find $\\tfrac{1}{2}$ of $8$.", "a": "$4$",
        "tikz": "\\begin{tikzpicture}[x=0.7cm,y=0.7cm]\n\\draw (0,0) rectangle (8,1);\n\\foreach \\i in {1,...,7} \\draw (\\i,0) -- (\\i,1);\n\\fill[gray!40] (0,0) rectangle (4,1);\n\\node[below=4pt] at (4,0) {$8$};\n\\end{tikzpicture}",
        "solution": [ { "math": "$8 \\div 2$", "note": "Half" }, { "math": "$= 4$", "note": "" } ] },
      { "q": "Find $\\tfrac{1}{4}$ of $8$.", "a": "$2$",
        "solution": [ { "math": "$8 \\div 4$", "note": "Quarter" }, { "math": "$= 2$", "note": "" } ] }
    ],
    "development": [
      { "q": "Find $\\tfrac{1}{5}$ of $35$.", "a": "$7$",
        "solution": [ { "math": "$35 \\div 5$", "note": "Split into 5 parts" }, { "math": "$= 7$", "note": "" } ] },
      { "q": "Find $\\tfrac{1}{4}$ of $32$.", "a": "$8$",
        "solution": [ { "math": "$32 \\div 4$", "note": "Quarter" }, { "math": "$= 8$", "note": "" } ] },
      { "q": "A ribbon is $24$ cm long. How long is $\\tfrac{1}{2}$ of it?", "a": "$12$ cm",
        "solution": [ { "math": "$24 \\div 2$", "note": "Half the length" }, { "math": "$= 12 \\text{ cm}$", "note": "" } ] },
      { "q": "There are $40$ marbles. How many is $\\tfrac{1}{10}$ of them?", "a": "$4$",
        "solution": [ { "math": "$40 \\div 10$", "note": "One tenth" }, { "math": "$= 4$", "note": "" } ] },
      { "q": "Find $\\tfrac{1}{2}$ of $1$ litre, in millilitres.", "a": "$500$ mL",
        "solution": [ { "math": "$1\\,000 \\div 2$", "note": "$1$ L $= 1\\,000$ mL" }, { "math": "$= 500 \\text{ mL}$", "note": "" } ] },
      { "q": "A bag of $45$ lollies is shared equally among $5$ children. How many does each get?", "a": "$9$",
        "tikz": "\\begin{tikzpicture}[x=0.4cm,y=0.7cm]\n\\draw (0,0) rectangle (45,1);\n\\foreach \\i in {9,18,27,36} \\draw (\\i,0) -- (\\i,1);\n\\fill[gray!40] (0,0) rectangle (9,1);\n\\node[below=4pt] at (22.5,0) {$45$};\n\\end{tikzpicture}",
        "solution": [ { "math": "$\\tfrac{1}{5} \\text{ of } 45 = 45 \\div 5$", "note": "One of 5 equal parts" }, { "math": "$= 9$", "note": "" } ] },
      { "q": "Find $\\tfrac{1}{4}$ of $1$ hour, in minutes.", "a": "$15$ min",
        "solution": [ { "math": "$60 \\div 4$", "note": "$1$ hour $= 60$ min" }, { "math": "$= 15 \\text{ min}$", "note": "" } ] },
      { "q": "Find $\\tfrac{1}{10}$ of $\\$70$.", "a": "$\\$7$",
        "solution": [ { "math": "$70 \\div 10$", "note": "One tenth" }, { "math": "$= \\$7$", "note": "" } ] },
      { "q": "Find $\\tfrac{1}{2}$ of $\\tfrac{1}{2}$ of $20$.", "a": "$5$",
        "solution": [ { "math": "$\\tfrac{1}{2} \\text{ of } 20 = 10$", "note": "First half" }, { "math": "$\\tfrac{1}{2} \\text{ of } 10 = 5$", "note": "Half again" } ] },
      { "q": "Find $\\tfrac{1}{5}$ of $60$.", "a": "$12$",
        "solution": [ { "math": "$60 \\div 5$", "note": "Split into 5 parts" }, { "math": "$= 12$", "note": "" } ] }
    ],
    "mastery": [
      { "q": "A class of $30$ students has $\\tfrac{1}{5}$ away sick. How many are away?", "a": "$6$",
        "solution": [ { "math": "$30 \\div 5$", "note": "One fifth away" }, { "math": "$= 6$", "note": "" } ] },
      { "q": "Sam spends $\\tfrac{1}{4}$ of his $\\$48$ savings. How much does he spend?", "a": "$\\$12$",
        "solution": [ { "math": "$48 \\div 4$", "note": "A quarter" }, { "math": "$= \\$12$", "note": "" } ] },
      { "q": "A tank holds $200$ L. It is $\\tfrac{1}{10}$ full. How many litres are in it?", "a": "$20$ L",
        "solution": [ { "math": "$200 \\div 10$", "note": "One tenth" }, { "math": "$= 20 \\text{ L}$", "note": "" } ] },
      { "q": "Half of a number is $9$. What was $\\tfrac{1}{4}$ of the same number?", "a": "$4.5$",
        "solution": [ { "math": "$\\text{Number} = 9 \\times 2 = 18$", "note": "Reverse the half" }, { "math": "$18 \\div 4 = 4.5$", "note": "A quarter of it" } ] },
      { "q": "A recipe needs $\\tfrac{1}{2}$ of $750$ g of flour. How much flour is that?", "a": "$375$ g",
        "solution": [ { "math": "$750 \\div 2$", "note": "Half" }, { "math": "$= 375 \\text{ g}$", "note": "" } ] },
      { "q": "A film is $90$ minutes. After $\\tfrac{1}{5}$ of it, how many minutes have passed?", "a": "$18$ min",
        "solution": [ { "math": "$90 \\div 5$", "note": "One fifth" }, { "math": "$= 18 \\text{ min}$", "note": "" } ] },
      { "q": "A walk is $4$ km. Each rest is taken after every $\\tfrac{1}{4}$ of the walk. How far apart are the rests?", "a": "$1$ km",
        "solution": [ { "math": "$4 \\div 4$", "note": "A quarter of the distance" }, { "math": "$= 1 \\text{ km}$", "note": "" } ] },
      { "q": "A jug holds $1.5$ L. How many millilitres is $\\tfrac{1}{2}$ of it?", "a": "$750$ mL",
        "solution": [ { "math": "$1\\,500 \\div 2$", "note": "$1.5$ L $= 1\\,500$ mL" }, { "math": "$= 750 \\text{ mL}$", "note": "" } ] },
      { "q": "One tenth of a crowd of $4\\,500$ left early. How many left?", "a": "$450$",
        "solution": [ { "math": "$4\\,500 \\div 10$", "note": "One tenth" }, { "math": "$= 450$", "note": "" } ] },
      { "q": "A jar of $36$ sweets is shared so each of $4$ friends gets $\\tfrac{1}{4}$. How many sweets are left over for the jar?", "a": "$0$ — each gets $9$",
        "solution": [ { "math": "$36 \\div 4 = 9$", "note": "Each friend's quarter" }, { "math": "$4 \\times 9 = 36$", "note": "All shared, none left" } ] }
    ]
  }
}
