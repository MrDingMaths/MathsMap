      { "q": "Find the product of $7$ and $7$.", "a": "$49$",
        "solution": [ { "math": "$7 \\times 7$", "note": "" }, { "math": "$= 49$", "note": "" } ] },
      { "q": "Find the product of $0$ and $11$.", "a": "$0$",
        "solution": [ { "math": "$0 \\times 11$", "note": "Any number times $0$" }, { "math": "$= 0$", "note": "" } ] },
      { "q": "Find the product of $1$ and $25$.", "a": "$25$",
        "solution": [ { "math": "$1 \\times 25$", "note": "Multiplying by $1$" }, { "math": "$= 25$", "note": "" } ] },
      { "q": "Find the product of $10$ and $6$.", "a": "$60$",
        "solution": [ { "math": "$10 \\times 6$", "note": "" }, { "math": "$= 60$", "note": "" } ] },
      { "q": "Find the product of $8$ and $9$.", "a": "$72$",
        "solution": [ { "math": "$8 \\times 9$", "note": "" }, { "math": "$= 72$", "note": "" } ] },
      { "q": "Find the product of $12$ and $12$.", "a": "$144$",
        "solution": [ { "math": "$12 \\times 12$", "note": "" }, { "math": "$= 144$", "note": "" } ] }
    ],
    "development": [
      { "q": "Find the product of $2$, $3$ and $5$.", "a": "$30$",
        "solution": [ { "math": "$2 \\times 3 = 6$", "note": "First pair" }, { "math": "$6 \\times 5 = 30$", "note": "Then by $5$" } ] },
      { "q": "Find the product of $4$, $5$ and $2$.", "a": "$40$",
