      { "q": "The product of two numbers is $100$ and one factor is $25$. Find the other factor.", "a": "$4$",
        "solution": [ { "math": "$25 \\times \\square = 100$", "note": "Missing factor" }, { "math": "$100 \\div 25 = 4$", "note": "" } ] },
      { "q": "Find the product of $9$, $0$ and $123$.", "a": "$0$",
