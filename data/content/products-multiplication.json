{
  "skillId": "products-multiplication",
  "atomType": "R",
  "theory": {
    "intro": "The **product** is the answer when you multiply numbers together. The numbers being multiplied are called factors.",
    "facts": [
      "$5 \\times 3 = 15$, so the **product** of $5$ and $3$ is $15$.",
      "Order does not matter: $4 \\times 6 = 6 \\times 4$ (commutative).",
      "You can multiply more than two numbers, e.g. $2 \\times 3 \\times 5 = 30$."
    ],
    "steps": [
      "Identify the numbers (factors) to be multiplied.",
      "Multiply them together, two at a time.",
      "State the product (the final answer)."
    ]
  },
  "practice": {
    "foundation": [
      { "q": "Find the product of $6$ and $7$.", "a": "$42$",
        "solution": [ { "math": "$6 \\times 7$", "note": "Product means multiply" }, { "math": "$= 42$", "note": "" } ] },
      { "q": "Find the product of $8$ and $4$.", "a": "$32$",
        "solution": [ { "math": "$8 \\times 4$", "note": "" }, { "math": "$= 32$", "note": "" } ] },
      { "q": "Find the product of $9$ and $5$.", "a": "$45$",
        "solution": [ { "math": "$9 \\times 5$", "note": "" }, { "math": "$= 45$", "note": "" } ] },
      { "q": "Find the product of $3$ and $12$.", "a": "$36$",
