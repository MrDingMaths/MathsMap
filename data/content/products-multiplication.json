      { "q": "A multiplication square shows the product $63$. Its two factors are equal-sided to $7$ and what?", "a": "$9$",
        "solution": [ { "math": "$7 \\times \\square = 63$", "note": "" }, { "math": "$63 \\div 7 = 9$", "note": "" } ] },
      { "q": "Find the product of $6$, $5$ and $5$, then double it.", "a": "$300$",
        "solution": [ { "math": "$6 \\times 5 \\times 5 = 150$", "note": "The product" }, { "math": "$2 \\times 150 = 300$", "note": "Double" } ] },
      { "q": "Two factors have a product of $144$. If one is $12$, what is the other?", "a": "$12$",
        "solution": [ { "math": "$12 \\times \\square = 144$", "note": "" }, { "math": "$144 \\div 12 = 12$", "note": "" } ] },
      { "q": "A theatre has $10$ rows of $9$ seats in each of $3$ sections. Find the product for total seats.", "a": "$270$",
        "solution": [ { "math": "$10 \\times 9 = 90$", "note": "Per section" }, { "math": "$90 \\times 3 = 270$", "note": "" } ] },
      { "q": "Explain why the product of $4 \\times 25$ equals the product of $25 \\times 4$.", "a": "multiplication is commutative; both equal $100$",
        "solution": [ { "math": "$4 \\times 25 = 100$", "note": "" }, { "math": "$25 \\times 4 = 100$", "note": "Order does not change product" } ] }
    ]
  }
