{
  "skillId": "equivalent-fractions",
  "atomType": "R",
  "theory": {
    "intro": "Equivalent fractions name the same amount in different ways, such as $\\tfrac{6}{8} = \\tfrac{3}{4}$. They occupy the same point on a number line and shade the same area.",
    "facts": [
      "Multiply **or** divide the numerator and denominator by the **same** number to make an equivalent fraction.",
      "$\\tfrac{1}{2} = \\tfrac{2}{4} = \\tfrac{3}{6} = \\tfrac{5}{10}$ — all the same amount.",
      "A fraction is in **simplest form** when numerator and denominator share no common factor except $1$."
    ],
    "steps": [
      "To scale up, multiply top and bottom by the same number.",
      "To simplify, divide top and bottom by a common factor.",
      "Check the two fractions shade the same area or hit the same point."
    ]
  },
  "practice": {
    "foundation": [
      { "q": "Both shapes are the same size. Write the two equivalent fractions shown.", "a": "$\\tfrac{1}{2} = \\tfrac{2}{4}$",
        "tikz": "\\begin{tikzpicture}[x=0.7cm,y=0.7cm]\n\\draw (0,0) rectangle (2,1);\n\\draw (1,0) -- (1,1);\n\\fill[gray!40] (0,0) rectangle (1,1);\n\\begin{scope}[xshift=3cm]\n\\draw (0,0) rectangle (2,1);\n\\foreach \\i in {0.5,1,1.5} \\draw (\\i,0) -- (\\i,1);\n\\fill[gray!40] (0,0) rectangle (1,1);\n\\end{scope}\n\\end{tikzpicture}",
        "solution": [ { "math": "$\\tfrac{1}{2}$", "note": "Left shape" }, { "math": "$= \\tfrac{2}{4}$", "note": "Same area, more parts" } ] },
      { "q": "Fill the blank: $\\tfrac{1}{2} = \\tfrac{\\square}{6}$.", "a": "$3$",
        "tikz": "\\begin{tikzpicture}[x=0.7cm,y=0.7cm]\n\\draw (0,0) rectangle (6,1);\n\\foreach \\i in {1,2,3,4,5} \\draw (\\i,0) -- (\\i,1);\n\\fill[gray!40] (0,0) rectangle (3,1);\n\\end{tikzpicture}",
        "solution": [ { "math": "$\\tfrac{1}{2} = \\tfrac{1 \\times 3}{2 \\times 3}$", "note": "Multiply by 3" }, { "math": "$= \\tfrac{3}{6}$", "note": "" } ] },
      { "q": "Fill the blank: $\\tfrac{3}{4} = \\tfrac{6}{\\square}$.", "a": "$8$",
        "solution": [ { "math": "$\\tfrac{3}{4} = \\tfrac{3 \\times 2}{4 \\times 2}$", "note": "Multiply by 2" }, { "math": "$= \\tfrac{6}{8}$", "note": "" } ] },
      { "q": "Simplify $\\tfrac{6}{8}$.", "a": "$\\tfrac{3}{4}$",
        "tikz": "\\begin{tikzpicture}[x=0.6cm,y=0.7cm]\n\\draw (0,0) rectangle (8,1);\n\\foreach \\i in {1,...,7} \\draw (\\i,0) -- (\\i,1);\n\\fill[gray!40] (0,0) rectangle (6,1);\n\\end{tikzpicture}",
        "solution": [ { "math": "$\\tfrac{6}{8} = \\tfrac{6 \\div 2}{8 \\div 2}$", "note": "Divide by 2" }, { "math": "$= \\tfrac{3}{4}$", "note": "" } ] },
      { "q": "Fill the blank: $\\tfrac{1}{3} = \\tfrac{\\square}{9}$.", "a": "$3$",
        "solution": [ { "math": "$\\tfrac{1}{3} = \\tfrac{1 \\times 3}{3 \\times 3}$", "note": "Multiply by 3" }, { "math": "$= \\tfrac{3}{9}$", "note": "" } ] },
      { "q": "Simplify $\\tfrac{4}{10}$.", "a": "$\\tfrac{2}{5}$",
        "solution": [ { "math": "$\\tfrac{4}{10} = \\tfrac{4 \\div 2}{10 \\div 2}$", "note": "Divide by 2" }, { "math": "$= \\tfrac{2}{5}$", "note": "" } ] },
      { "q": "Fill the blank: $\\tfrac{2}{5} = \\tfrac{\\square}{10}$.", "a": "$4$",
        "solution": [ { "math": "$\\tfrac{2}{5} = \\tfrac{2 \\times 2}{5 \\times 2}$", "note": "Multiply by 2" }, { "math": "$= \\tfrac{4}{10}$", "note": "" } ] },
      { "q": "Simplify $\\tfrac{5}{10}$.", "a": "$\\tfrac{1}{2}$",
        "tikz": "\\begin{tikzpicture}[x=0.6cm,y=0.7cm]\n\\draw (0,0) rectangle (10,1);\n\\foreach \\i in {1,...,9} \\draw (\\i,0) -- (\\i,1);\n\\fill[gray!40] (0,0) rectangle (5,1);\n\\end{tikzpicture}",
        "solution": [ { "math": "$\\tfrac{5}{10} = \\tfrac{5 \\div 5}{10 \\div 5}$", "note": "Divide by 5" }, { "math": "$= \\tfrac{1}{2}$", "note": "" } ] },
      { "q": "Fill the blank: $\\tfrac{1}{4} = \\tfrac{2}{\\square}$.", "a": "$8$",
        "solution": [ { "math": "$\\tfrac{1}{4} = \\tfrac{1 \\times 2}{4 \\times 2}$", "note": "Multiply by 2" }, { "math": "$= \\tfrac{2}{8}$", "note": "" } ] },
      { "q": "Simplify $\\tfrac{3}{9}$.", "a": "$\\tfrac{1}{3}$",
        "solution": [ { "math": "$\\tfrac{3}{9} = \\tfrac{3 \\div 3}{9 \\div 3}$", "note": "Divide by 3" }, { "math": "$= \\tfrac{1}{3}$", "note": "" } ] }
    ],
    "development": [
      { "q": "Fill the blank: $\\tfrac{2}{3} = \\tfrac{\\square}{12}$.", "a": "$8$",
        "solution": [ { "math": "$\\tfrac{2}{3} = \\tfrac{2 \\times 4}{3 \\times 4}$", "note": "Multiply by 4" }, { "math": "$= \\tfrac{8}{12}$", "note": "" } ] },
      { "q": "Simplify $\\tfrac{12}{16}$.", "a": "$\\tfrac{3}{4}$",
        "solution": [ { "math": "$\\tfrac{12}{16} = \\tfrac{12 \\div 4}{16 \\div 4}$", "note": "Divide by 4" }, { "math": "$= \\tfrac{3}{4}$", "note": "" } ] },
      { "q": "Write three fractions equivalent to $\\tfrac{1}{2}$.", "a": "e.g. $\\tfrac{2}{4}, \\tfrac{3}{6}, \\tfrac{5}{10}$",
        "solution": [ { "math": "$\\tfrac{1}{2} = \\tfrac{2}{4} = \\tfrac{3}{6}$", "note": "Multiply by 2, 3" }, { "math": "$= \\tfrac{5}{10}$", "note": "Multiply by 5" } ] },
      { "q": "Simplify $\\tfrac{8}{12}$.", "a": "$\\tfrac{2}{3}$",
        "solution": [ { "math": "$\\tfrac{8}{12} = \\tfrac{8 \\div 4}{12 \\div 4}$", "note": "Divide by 4" }, { "math": "$= \\tfrac{2}{3}$", "note": "" } ] },
      { "q": "Fill the blank: $\\tfrac{3}{5} = \\tfrac{\\square}{20}$.", "a": "$12$",
        "solution": [ { "math": "$\\tfrac{3}{5} = \\tfrac{3 \\times 4}{5 \\times 4}$", "note": "Multiply by 4" }, { "math": "$= \\tfrac{12}{20}$", "note": "" } ] },
      { "q": "Is $\\tfrac{4}{6}$ equivalent to $\\tfrac{2}{3}$? Show why.", "a": "Yes",
        "solution": [ { "math": "$\\tfrac{4}{6} = \\tfrac{4 \\div 2}{6 \\div 2}$", "note": "Divide by 2" }, { "math": "$= \\tfrac{2}{3}$", "note": "Equivalent" } ] },
      { "q": "Simplify $\\tfrac{10}{15}$.", "a": "$\\tfrac{2}{3}$",
        "solution": [ { "math": "$\\tfrac{10}{15} = \\tfrac{10 \\div 5}{15 \\div 5}$", "note": "Divide by 5" }, { "math": "$= \\tfrac{2}{3}$", "note": "" } ] },
      { "q": "Fill the blanks: $\\tfrac{1}{4} = \\tfrac{3}{\\square} = \\tfrac{\\square}{20}$.", "a": "$12$ and $5$",
        "solution": [ { "math": "$\\tfrac{1}{4} = \\tfrac{3}{12}$", "note": "Multiply by 3" }, { "math": "$= \\tfrac{5}{20}$", "note": "Multiply by 5" } ] },
      { "q": "Simplify $\\tfrac{9}{12}$.", "a": "$\\tfrac{3}{4}$",
        "solution": [ { "math": "$\\tfrac{9}{12} = \\tfrac{9 \\div 3}{12 \\div 3}$", "note": "Divide by 3" }, { "math": "$= \\tfrac{3}{4}$", "note": "" } ] },
      { "q": "Which is the odd one out: $\\tfrac{2}{4}, \\tfrac{3}{6}, \\tfrac{2}{5}$?", "a": "$\\tfrac{2}{5}$",
        "solution": [ { "math": "$\\tfrac{2}{4} = \\tfrac{3}{6} = \\tfrac{1}{2}$", "note": "Both equal a half" }, { "math": "$\\tfrac{2}{5} \\neq \\tfrac{1}{2}$", "note": "The odd one" } ] }
    ],
    "mastery": [
      { "q": "Simplify $\\tfrac{24}{36}$ fully.", "a": "$\\tfrac{2}{3}$",
        "solution": [ { "math": "$\\tfrac{24}{36} = \\tfrac{24 \\div 12}{36 \\div 12}$", "note": "Divide by 12" }, { "math": "$= \\tfrac{2}{3}$", "note": "Simplest form" } ] },
      { "q": "A pizza is cut into $8$ slices; $6$ are eaten. Write the eaten amount in simplest form.", "a": "$\\tfrac{3}{4}$",
        "solution": [ { "math": "$\\tfrac{6}{8} = \\tfrac{6 \\div 2}{8 \\div 2}$", "note": "Divide by 2" }, { "math": "$= \\tfrac{3}{4}$", "note": "" } ] },
      { "q": "Find the missing number: $\\tfrac{15}{\\square} = \\tfrac{3}{4}$.", "a": "$20$",
        "solution": [ { "math": "$15 \\div 3 = 5$", "note": "Scale factor" }, { "math": "$4 \\times 5 = 20$", "note": "Denominator" } ] },
      { "q": "Are $\\tfrac{6}{9}$ and $\\tfrac{8}{12}$ equivalent? Justify by simplifying both.", "a": "Yes, both $\\tfrac{2}{3}$",
        "solution": [ { "math": "$\\tfrac{6}{9} = \\tfrac{2}{3}$", "note": "Divide by 3" }, { "math": "$\\tfrac{8}{12} = \\tfrac{2}{3}$", "note": "Divide by 4" } ] },
      { "q": "$\\tfrac{20}{25}$ of a field is planted. Write this in simplest form.", "a": "$\\tfrac{4}{5}$",
        "solution": [ { "math": "$\\tfrac{20}{25} = \\tfrac{20 \\div 5}{25 \\div 5}$", "note": "Divide by 5" }, { "math": "$= \\tfrac{4}{5}$", "note": "" } ] },
      { "q": "Find the missing number: $\\tfrac{2}{3} = \\tfrac{\\square}{30}$.", "a": "$20$",
        "solution": [ { "math": "$30 \\div 3 = 10$", "note": "Scale factor" }, { "math": "$2 \\times 10 = 20$", "note": "Numerator" } ] },
      { "q": "Write $\\tfrac{16}{24}$ in simplest form.", "a": "$\\tfrac{2}{3}$",
        "solution": [ { "math": "$\\tfrac{16}{24} = \\tfrac{16 \\div 8}{24 \\div 8}$", "note": "Divide by 8" }, { "math": "$= \\tfrac{2}{3}$", "note": "" } ] },
      { "q": "Two recipes use $\\tfrac{3}{4}$ cup and $\\tfrac{9}{12}$ cup of sugar. Are they the same?", "a": "Yes",
        "solution": [ { "math": "$\\tfrac{9}{12} = \\tfrac{9 \\div 3}{12 \\div 3}$", "note": "Divide by 3" }, { "math": "$= \\tfrac{3}{4}$", "note": "Same amount" } ] },
      { "q": "Complete the chain: $\\tfrac{1}{3} = \\tfrac{4}{\\square} = \\tfrac{\\square}{30}$.", "a": "$12$ and $10$",
        "solution": [ { "math": "$\\tfrac{1}{3} = \\tfrac{4}{12}$", "note": "Multiply by 4" }, { "math": "$= \\tfrac{10}{30}$", "note": "Multiply by 10" } ] },
      { "q": "$\\tfrac{18}{30}$ of votes were 'yes'. Write the simplest equivalent fraction.", "a": "$\\tfrac{3}{5}$",
        "solution": [ { "math": "$\\tfrac{18}{30} = \\tfrac{18 \\div 6}{30 \\div 6}$", "note": "Divide by 6" }, { "math": "$= \\tfrac{3}{5}$", "note": "" } ] }
    ]
  }
}
