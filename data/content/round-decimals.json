{
  "skillId": "round-decimals",
  "atomType": "R",
  "theory": {
    "intro": "Rounding a decimal keeps it to a stated number of decimal places by looking at the next digit.",
    "facts": [
      "Look at the digit **just after** the place you are rounding to.",
      "If it is $5$ or more, round **up**; if it is $4$ or less, round **down**.",
      "Drop all digits after the rounding place."
    ],
    "steps": [
      "Find the place you are rounding to (1 dp = tenths, 2 dp = hundredths).",
      "Look at the next digit to its right.",
      "Round up or keep the digit, then drop the rest."
    ]
  },
  "practice": {
    "foundation": [
      { "q": "Round $3.47$ to $1$ decimal place.", "a": "$3.5$",
        "solution": [ { "math": "$3.4\\underline{7}$", "note": "Next digit is 7" }, { "math": "$7 \\geq 5 \\Rightarrow 3.5$", "note": "Round up" } ] },
      { "q": "Round $5.83$ to the nearest whole number.", "a": "$6$",
        "solution": [ { "math": "$5.\\underline{8}3$", "note": "Next digit is 8" }, { "math": "$8 \\geq 5 \\Rightarrow 6$", "note": "Round up" } ] },
      { "q": "Round $2.31$ to $1$ decimal place.", "a": "$2.3$",
        "solution": [ { "math": "$2.3\\underline{1}$", "note": "Next digit is 1" }, { "math": "$1 < 5 \\Rightarrow 2.3$", "note": "Round down" } ] },
      { "q": "Round $7.6$ to the nearest whole number.", "a": "$8$",
        "solution": [ { "math": "$7.\\underline{6}$", "note": "Next digit is 6" }, { "math": "$6 \\geq 5 \\Rightarrow 8$", "note": "Round up" } ] },
      { "q": "Round $0.84$ to $1$ decimal place.", "a": "$0.8$",
        "solution": [ { "math": "$0.8\\underline{4}$", "note": "Next digit is 4" }, { "math": "$4 < 5 \\Rightarrow 0.8$", "note": "Round down" } ] },
      { "q": "Round $4.5$ to the nearest whole number.", "a": "$5$",
        "solution": [ { "math": "$4.\\underline{5}$", "note": "Next digit is 5" }, { "math": "$5 \\geq 5 \\Rightarrow 5$", "note": "Round up" } ] },
      { "q": "Round $9.28$ to $1$ decimal place.", "a": "$9.3$",
        "solution": [ { "math": "$9.2\\underline{8}$", "note": "Next digit is 8" }, { "math": "$8 \\geq 5 \\Rightarrow 9.3$", "note": "Round up" } ] },
      { "q": "Round $1.42$ to the nearest whole number.", "a": "$1$",
        "solution": [ { "math": "$1.\\underline{4}2$", "note": "Next digit is 4" }, { "math": "$4 < 5 \\Rightarrow 1$", "note": "Round down" } ] },
      { "q": "Round $6.05$ to $1$ decimal place.", "a": "$6.1$",
        "solution": [ { "math": "$6.0\\underline{5}$", "note": "Next digit is 5" }, { "math": "$5 \\geq 5 \\Rightarrow 6.1$", "note": "Round up" } ] },
      { "q": "Round $0.3$ to the nearest whole number.", "a": "$0$",
        "solution": [ { "math": "$0.\\underline{3}$", "note": "Next digit is 3" }, { "math": "$3 < 5 \\Rightarrow 0$", "note": "Round down" } ] }
    ],
    "development": [
      { "q": "Round $4.728$ to $2$ decimal places.", "a": "$4.73$",
        "solution": [ { "math": "$4.72\\underline{8}$", "note": "Next digit is 8" }, { "math": "$8 \\geq 5 \\Rightarrow 4.73$", "note": "Round up" } ] },
      { "q": "Round $0.135$ to $2$ decimal places.", "a": "$0.14$",
        "solution": [ { "math": "$0.13\\underline{5}$", "note": "Next digit is 5" }, { "math": "$5 \\geq 5 \\Rightarrow 0.14$", "note": "Round up" } ] },
      { "q": "Round $3.961$ to $1$ decimal place.", "a": "$4.0$",
        "solution": [ { "math": "$3.9\\underline{6}1$", "note": "Next digit is 6, round up" }, { "math": "$3.9 + 0.1 = 4.0$", "note": "Carry rolls over" } ] },
      { "q": "Round $12.504$ to $2$ decimal places.", "a": "$12.50$",
        "solution": [ { "math": "$12.50\\underline{4}$", "note": "Next digit is 4" }, { "math": "$4 < 5 \\Rightarrow 12.50$", "note": "Round down" } ] },
      { "q": "Round $0.096$ to $2$ decimal places.", "a": "$0.10$",
        "solution": [ { "math": "$0.09\\underline{6}$", "note": "Next digit is 6, round up" }, { "math": "$0.09 + 0.01 = 0.10$", "note": "Carry rolls over" } ] },
      { "q": "Round $8.347$ to $2$ decimal places.", "a": "$8.35$",
        "solution": [ { "math": "$8.34\\underline{7}$", "note": "Next digit is 7" }, { "math": "$7 \\geq 5 \\Rightarrow 8.35$", "note": "Round up" } ] },
      { "q": "Round $5.998$ to $2$ decimal places.", "a": "$6.00$",
        "solution": [ { "math": "$5.99\\underline{8}$", "note": "Next digit is 8, round up" }, { "math": "$5.99 + 0.01 = 6.00$", "note": "Carry cascades" } ] },
      { "q": "Round $2.451$ to $1$ decimal place.", "a": "$2.5$",
        "solution": [ { "math": "$2.4\\underline{5}1$", "note": "Next digit is 5" }, { "math": "$5 \\geq 5 \\Rightarrow 2.5$", "note": "Round up" } ] },
      { "q": "Round $0.804$ to $1$ decimal place.", "a": "$0.8$",
        "solution": [ { "math": "$0.8\\underline{0}4$", "note": "Next digit is 0" }, { "math": "$0 < 5 \\Rightarrow 0.8$", "note": "Round down" } ] },
      { "q": "Round $19.95$ to $1$ decimal place.", "a": "$20.0$",
        "solution": [ { "math": "$19.9\\underline{5}$", "note": "Next digit is 5, round up" }, { "math": "$19.9 + 0.1 = 20.0$", "note": "Carry rolls over" } ] }
    ],
    "mastery": [
      { "q": "A bill is $\\$23.467$. Round it to the nearest cent ($2$ decimal places).", "a": "$\\$23.47$",
        "solution": [ { "math": "$23.46\\underline{7}$", "note": "Next digit is 7" }, { "math": "$7 \\geq 5 \\Rightarrow 23.47$", "note": "Round up" } ] },
      { "q": "A length is measured as $1.096$ m. Round it to $2$ decimal places.", "a": "$1.10$ m",
        "solution": [ { "math": "$1.09\\underline{6}$", "note": "Next digit is 6, round up" }, { "math": "$1.09 + 0.01 = 1.10$", "note": "Carry rolls over" } ] },
      { "q": "Round $3.14159$ to $2$ decimal places.", "a": "$3.14$",
        "solution": [ { "math": "$3.14\\underline{1}59$", "note": "Next digit is 1" }, { "math": "$1 < 5 \\Rightarrow 3.14$", "note": "Round down" } ] },
      { "q": "A number rounds to $4.2$ to $1$ decimal place. What is the smallest it could be?", "a": "$4.15$",
        "solution": [ { "math": "$4.15 \\to 4.2$", "note": "Halfway rounds up" }, { "math": "$\\text{smallest} = 4.15$", "note": "" } ] },
      { "q": "Round $0.05$ to $1$ decimal place.", "a": "$0.1$",
        "solution": [ { "math": "$0.\\underline{0}5 \\to \\text{tenths place is } 0$", "note": "Next digit is 5" }, { "math": "$5 \\geq 5 \\Rightarrow 0.1$", "note": "Round up" } ] },
      { "q": "A runner's time is $10.748$ s. Give it to $1$ decimal place.", "a": "$10.7$ s",
        "solution": [ { "math": "$10.7\\underline{4}8$", "note": "Next digit is 4" }, { "math": "$4 < 5 \\Rightarrow 10.7$", "note": "Round down" } ] },
      { "q": "Round $99.96$ to $1$ decimal place.", "a": "$100.0$",
        "solution": [ { "math": "$99.9\\underline{6}$", "note": "Next digit is 6, round up" }, { "math": "$99.9 + 0.1 = 100.0$", "note": "Carry cascades" } ] },
      { "q": "Petrol costs $172.9$ cents/L, shown to the driver in dollars as $\\$1.729$. Round to the nearest cent.", "a": "$\\$1.73$",
        "solution": [ { "math": "$1.72\\underline{9}$", "note": "Next digit is 9" }, { "math": "$9 \\geq 5 \\Rightarrow 1.73$", "note": "Round up" } ] },
      { "q": "A number rounds to $7.0$ to $1$ decimal place. What is the largest it could be (to $2$ dp)?", "a": "$7.04$",
        "solution": [ { "math": "$7.04 \\to 7.0$", "note": "Still rounds down" }, { "math": "$7.05 \\to 7.1$", "note": "So largest is $7.04$" } ] },
      { "q": "Round $2.345$ to $2$ dp, then round that result to $1$ dp.", "a": "$2.35$, then $2.4$",
        "solution": [ { "math": "$2.34\\underline{5} \\Rightarrow 2.35$", "note": "To 2 dp" }, { "math": "$2.3\\underline{5} \\Rightarrow 2.4$", "note": "To 1 dp" } ] }
    ]
  }
}
