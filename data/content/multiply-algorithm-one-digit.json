{
  "skillId": "multiply-algorithm-one-digit",
  "atomType": "R",
  "theory": {
    "intro": "The formal multiplication algorithm multiplies a number by a one-digit number, working from the right and carrying when a column total is $10$ or more.",
    "facts": [
      "Multiply the **ones** first, then tens, then hundreds.",
      "If a column gives $10$ or more, write the ones digit and **carry** the tens.",
      "Add any carried digit to the next column's product."
    ],
    "steps": [
      "Set out the number with the single digit beneath the ones place.",
      "Multiply each digit by the one-digit number, right to left.",
      "Carry where needed and combine to get the product."
    ]
  },
  "practice": {
    "foundation": [
      { "q": "Calculate $23 \\times 3$.", "a": "$69$",
        "solution": [ { "math": "$3 \\times 3 = 9$", "note": "Ones" }, { "math": "$3 \\times 20 = 60 \\Rightarrow 69$", "note": "Tens" } ] },
      { "q": "Calculate $42 \\times 2$.", "a": "$84$",
        "solution": [ { "math": "$2 \\times 2 = 4$", "note": "Ones" }, { "math": "$2 \\times 40 = 80 \\Rightarrow 84$", "note": "Tens" } ] },
      { "q": "Calculate $14 \\times 4$.", "a": "$56$",
        "solution": [ { "math": "$4 \\times 4 = 16$", "note": "Write 6, carry 1" }, { "math": "$4 \\times 10 + 10 = 50 \\Rightarrow 56$", "note": "Add carry" } ] },
      { "q": "Calculate $31 \\times 3$.", "a": "$93$",
        "solution": [ { "math": "$3 \\times 1 = 3$", "note": "Ones" }, { "math": "$3 \\times 30 = 90 \\Rightarrow 93$", "note": "Tens" } ] },
      { "q": "Calculate $26 \\times 2$.", "a": "$52$",
        "solution": [ { "math": "$2 \\times 6 = 12$", "note": "Write 2, carry 1" }, { "math": "$2 \\times 20 + 10 = 50 \\Rightarrow 52$", "note": "" } ] },
      { "q": "Calculate $33 \\times 3$.", "a": "$99$",
        "solution": [ { "math": "$3 \\times 3 = 9$", "note": "Ones" }, { "math": "$3 \\times 30 = 90 \\Rightarrow 99$", "note": "" } ] },
      { "q": "Calculate $17 \\times 5$.", "a": "$85$",
        "solution": [ { "math": "$5 \\times 7 = 35$", "note": "Write 5, carry 3" }, { "math": "$5 \\times 10 + 30 = 80 \\Rightarrow 85$", "note": "" } ] },
      { "q": "Calculate $44 \\times 2$.", "a": "$88$",
        "solution": [ { "math": "$2 \\times 4 = 8$", "note": "Ones" }, { "math": "$2 \\times 40 = 80 \\Rightarrow 88$", "note": "" } ] },
      { "q": "Calculate $28 \\times 3$.", "a": "$84$",
        "solution": [ { "math": "$3 \\times 8 = 24$", "note": "Write 4, carry 2" }, { "math": "$3 \\times 20 + 20 = 80 \\Rightarrow 84$", "note": "" } ] },
      { "q": "Calculate $19 \\times 4$.", "a": "$76$",
        "solution": [ { "math": "$4 \\times 9 = 36$", "note": "Write 6, carry 3" }, { "math": "$4 \\times 10 + 30 = 70 \\Rightarrow 76$", "note": "" } ] }
    ],
    "development": [
      { "q": "Calculate $124 \\times 3$.", "a": "$372$",
        "solution": [ { "math": "$3 \\times 4 = 12,\\ 3 \\times 2 = 6$", "note": "Ones, tens" }, { "math": "$3 \\times 1 = 3 \\Rightarrow 372$", "note": "Hundreds" } ] },
      { "q": "Calculate $246 \\times 4$.", "a": "$984$",
        "solution": [ { "math": "$4 \\times 6 = 24$", "note": "Write 4, carry 2" }, { "math": "$4 \\times 4 + 2 = 18,\\ 4 \\times 2 + 1 = 9 \\Rightarrow 984$", "note": "" } ] },
      { "q": "Calculate $357 \\times 6$.", "a": "$2142$",
        "solution": [ { "math": "$6 \\times 7 = 42$", "note": "Write 2, carry 4" }, { "math": "$6 \\times 5 + 4 = 34,\\ 6 \\times 3 + 3 = 21 \\Rightarrow 2\\,142$", "note": "" } ] },
      { "q": "Calculate $408 \\times 5$.", "a": "$2040$",
        "solution": [ { "math": "$5 \\times 8 = 40$", "note": "Write 0, carry 4" }, { "math": "$5 \\times 0 + 4 = 4,\\ 5 \\times 4 = 20 \\Rightarrow 2\\,040$", "note": "" } ] },
      { "q": "Calculate $573 \\times 7$.", "a": "$4011$",
        "solution": [ { "math": "$7 \\times 3 = 21$", "note": "Write 1, carry 2" }, { "math": "$7 \\times 7 + 2 = 51,\\ 7 \\times 5 + 5 = 40 \\Rightarrow 4\\,011$", "note": "" } ] },
      { "q": "Calculate $619 \\times 8$.", "a": "$4952$",
        "solution": [ { "math": "$8 \\times 9 = 72$", "note": "Write 2, carry 7" }, { "math": "$8 \\times 1 + 7 = 15,\\ 8 \\times 6 + 1 = 49 \\Rightarrow 4\\,952$", "note": "" } ] },
      { "q": "Calculate $208 \\times 6$.", "a": "$1248$",
        "solution": [ { "math": "$6 \\times 8 = 48$", "note": "Write 8, carry 4" }, { "math": "$6 \\times 0 + 4 = 4,\\ 6 \\times 2 = 12 \\Rightarrow 1\\,248$", "note": "" } ] },
      { "q": "Calculate $735 \\times 4$.", "a": "$2940$",
        "solution": [ { "math": "$4 \\times 5 = 20$", "note": "Write 0, carry 2" }, { "math": "$4 \\times 3 + 2 = 14,\\ 4 \\times 7 + 1 = 29 \\Rightarrow 2\\,940$", "note": "" } ] },
      { "q": "Calculate $864 \\times 9$.", "a": "$7776$",
        "solution": [ { "math": "$9 \\times 4 = 36$", "note": "Write 6, carry 3" }, { "math": "$9 \\times 6 + 3 = 57,\\ 9 \\times 8 + 5 = 77 \\Rightarrow 7\\,776$", "note": "" } ] },
      { "q": "Calculate $1\\,243 \\times 3$.", "a": "$3729$",
        "solution": [ { "math": "$3 \\times 3 = 9,\\ 3 \\times 4 = 12$", "note": "Write 9, then 2 carry 1" }, { "math": "$3\\times2+1=7,\\ 3\\times1=3 \\Rightarrow 3\\,729$", "note": "" } ] }
    ],
    "mastery": [
      { "q": "A school buys $7$ boxes, each holding $384$ crayons. How many crayons in total?", "a": "$2688$",
        "solution": [ { "math": "$384 \\times 7$", "note": "Multiply" }, { "math": "$= 2\\,688$", "note": "" } ] },
      { "q": "Calculate $2\\,476 \\times 8$.", "a": "$19\\,808$",
        "solution": [ { "math": "$8 \\times 6 = 48$", "note": "Write 8, carry 4" }, { "math": "$\\dots \\Rightarrow 19\\,808$", "note": "Continue with carries" } ] },
      { "q": "A bottle holds $475$ mL. How many mL in $6$ bottles?", "a": "$2850$ mL",
        "solution": [ { "math": "$475 \\times 6$", "note": "Multiply" }, { "math": "$= 2\\,850$", "note": "" } ] },
      { "q": "Calculate $909 \\times 9$.", "a": "$8181$",
        "solution": [ { "math": "$9 \\times 9 = 81$", "note": "Write 1, carry 8" }, { "math": "$9 \\times 0 + 8 = 8,\\ 9 \\times 9 = 81 \\Rightarrow 8\\,181$", "note": "" } ] },
      { "q": "A coach seats $53$ people. How many seats on $8$ identical coaches?", "a": "$424$",
        "solution": [ { "math": "$53 \\times 8$", "note": "Multiply" }, { "math": "$= 424$", "note": "" } ] },
      { "q": "Calculate $3\\,608 \\times 5$.", "a": "$18\\,040$",
        "solution": [ { "math": "$5 \\times 8 = 40$", "note": "Write 0, carry 4" }, { "math": "$\\dots \\Rightarrow 18\\,040$", "note": "Continue" } ] },
      { "q": "A factory packs $246$ items per hour for $7$ hours. How many items?", "a": "$1722$",
        "solution": [ { "math": "$246 \\times 7$", "note": "Multiply" }, { "math": "$= 1\\,722$", "note": "" } ] },
      { "q": "Calculate $588 \\times 6$ and check by estimating.", "a": "$3528$ (estimate $\\approx 3600$)",
        "solution": [ { "math": "$588 \\times 6 = 3\\,528$", "note": "Exact" }, { "math": "$600 \\times 6 = 3\\,600$", "note": "Estimate is close" } ] },
      { "q": "Tickets cost $\\$38$. Find the takings from $9$ tickets.", "a": "$\\$342$",
        "solution": [ { "math": "$38 \\times 9$", "note": "Multiply" }, { "math": "$= 342$", "note": "" } ] },
      { "q": "$\\square \\times 4 = 1\\,248$. Use the algorithm to check $\\square = 312$.", "a": "yes, $312 \\times 4 = 1248$",
        "solution": [ { "math": "$312 \\times 4$", "note": "Multiply back" }, { "math": "$= 1\\,248$", "note": "Confirms" } ] }
    ]
  }
}
